@implements IAsyncDisposable
@inject IJSRuntime _js

@if (_visible)
{
    <div class="install-hint" role="dialog" aria-labelledby="install-hint-title">
        <svg class="install-hint__arrow" viewBox="0 0 64 64" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
            <path d="M10 10 Q 40 8 54 22 L 48 18 M 54 22 L 50 30"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round" />
        </svg>
        <div class="install-hint__body">
            <div class="install-hint__title" id="install-hint-title">Install BlazorUI Docs</div>
            <p class="install-hint__desc">@_description</p>
            <div class="install-hint__actions">
                @if (_state.CanPrompt)
                {
                    <button type="button" class="install-hint__btn install-hint__btn--primary" @onclick="PromptAsync">
                        Install app
                    </button>
                }
                <button type="button" class="install-hint__btn install-hint__btn--ghost" @onclick="DismissAsync">
                    Not now
                </button>
            </div>
        </div>
    </div>
}

@code {
    private const string DismissKey = "bui-docs-install-dismissed";

    private IJSObjectReference? _module;
    private DotNetObjectReference<InstallAppHint>? _ref;
    private State _state = new();
    private bool _dismissed;
    private bool _loaded;

    private bool _visible =>
        _loaded
        && !_dismissed
        && !_state.Installed
        && !_state.Standalone;

    private string _description => _state.Platform switch
    {
        "ios" => "Tap the Share icon in Safari, then \"Add to Home Screen\".",
        "firefox" => "Open the browser menu and choose \"Install\" to add this app.",
        "safari" => "Use the File menu → \"Add to Dock\" to install this app.",
        "android" => "Open the browser menu and tap \"Install app\" or \"Add to Home screen\".",
        "chrome" or "edge" => _state.CanPrompt
            ? "Install the docs as an app for offline access and a native-like experience."
            : "Open the browser menu and choose \"Install BlazorUI Docs\" to add this app.",
        _ => "Install the docs as an app for offline access and a native-like experience."
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            _module = await _js.InvokeAsync<IJSObjectReference>("import", "./js/install-prompt.js");
            _dismissed = await _module.InvokeAsync<bool>("getDismissed", DismissKey);
            _ref = DotNetObjectReference.Create(this);
            await _module.InvokeVoidAsync("register", _ref);
            _state = await _module.InvokeAsync<State>("getState");
            _loaded = true;
            StateHasChanged();
        }
        catch (JSDisconnectedException) { }
    }

    [JSInvokable]
    public Task OnStateChanged(State next)
    {
        _state = next;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task PromptAsync()
    {
        if (_module is null) return;
        try { await _module.InvokeAsync<string>("prompt"); }
        catch (JSDisconnectedException) { }
    }

    private async Task DismissAsync()
    {
        _dismissed = true;
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("setDismissed", DismissKey); }
            catch (JSDisconnectedException) { }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("unregister");
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }
        _ref?.Dispose();
    }

    public sealed class State
    {
        public bool CanPrompt { get; set; }
        public bool Installed { get; set; }
        public bool Standalone { get; set; }
        public string Platform { get; set; } = "other";
    }
}
