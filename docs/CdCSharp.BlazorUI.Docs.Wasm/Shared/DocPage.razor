@using CdCSharp.BlazorUI.Docs.Components

@inject NavigationManager Nav

<CascadingValue Value="_ctx" IsFixed="true">
    <div class="doc-page">
        <header class="doc-page__header">
            @if (!string.IsNullOrEmpty(Eyebrow))
            {
                <span class="doc-page__eyebrow">@Eyebrow</span>
            }
            <h1 class="doc-page__title">@Title</h1>
            @if (!string.IsNullOrEmpty(Lede))
            {
                <p class="doc-page__lede">@Lede</p>
            }
        </header>

        @ChildContent
    </div>
</CascadingValue>

@if (ShowPerformanceDashboard())
{
    <CdCSharp.BlazorUI.Components.Diagnostics.BUIPerformanceDashboard />
}

@code {
    [Parameter] public string? Eyebrow { get; set; }
    [Parameter, EditorRequired] public string Title { get; set; } = default!;
    [Parameter] public string? Lede { get; set; }
    [Parameter] public object? PageInstance { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private DocDemoContext? _ctx;

    protected override void OnParametersSet()
        => _ctx = PageInstance is null ? null : new DocDemoContext(PageInstance);

    private bool ShowPerformanceDashboard()
    {
#if DEBUG
    var uri = new Uri(Nav.Uri);
    var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
    return query["perf"] != null || query["performance"] != null;
#else
        return false;
#endif
    }
}
