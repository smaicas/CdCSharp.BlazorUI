@page "/"
@implements IAsyncDisposable
@inject IJSRuntime _js

<PageTitle>CdCSharp.BlazorUI — Modern Blazor components for .NET 10</PageTitle>
<InstallAppHint />

<section class="hero" @ref="_heroRef">
    <div class="hero__puzzle" aria-hidden="true">
        <span class="hero__tile hero__tile--1"></span>
        <span class="hero__tile hero__tile--2"></span>
        <span class="hero__tile hero__tile--3"></span>
        <span class="hero__tile hero__tile--4"></span>
        <span class="hero__tile hero__tile--5"></span>
        <span class="hero__tile hero__tile--6"></span>
        <span class="hero__tile hero__tile--7"></span>
    </div>

    <div class="hero__content">
        <span class="hero__badge">
            <span class="hero__badge-dot"></span>
            v1.0 · .NET 10
        </span>

        <h1 class="hero__title">
            Blazor<span class="hero__title-accent">UI</span>
        </h1>

        <p class="hero__lede">
            A component library for Blazor Server and WebAssembly.
            Themed, typed, done.
        </p>

        <div class="hero__ctas">
            <BUIButton Text="Get started"
                       Size="SizeEnum.Large"
                       OnClick="@(() => _nav.NavigateTo("/getting-started"))" />
            <BUIButton Text="Components"
                       Size="SizeEnum.Large"
                       Border="@BUIBorderPresets.Default"
                       BackgroundColor="transparent"
                       Color="@PaletteColor.Primary"
                       OnClick="@(() => _nav.NavigateTo("/components/button"))" />
        </div>

        <div class="hero__snippet" role="figure" aria-label="Install command">
            <span class="hero__snippet-prompt">$</span>
            <code>dotnet add package CdCSharp.BlazorUI</code>
        </div>
    </div>
</section>

<section class="pillars">
    <div class="pillar">
        <div class="pillar__mark pillar__mark--a"></div>
        <h3 class="pillar__title">Data-attribute styling</h3>
        <p class="pillar__desc">No class toggling. Components expose <code>IHas*</code> interfaces; CSS reads <code>data-bui-*</code> and custom properties.</p>
    </div>
    <div class="pillar">
        <div class="pillar__mark pillar__mark--b"></div>
        <h3 class="pillar__title">Theme-first palettes</h3>
        <p class="pillar__desc">Light and dark out of the box. Override any semantic token with a single CSS variable.</p>
    </div>
    <div class="pillar">
        <div class="pillar__mark pillar__mark--c"></div>
        <h3 class="pillar__title">Pluggable variants</h3>
        <p class="pillar__desc">Every component accepts custom render templates alongside its built-ins. Swap, don't fork.</p>
    </div>
</section>

<section class="install">
    <div class="install__head">
        <h2 class="install__title">Install</h2>
        <p class="install__desc">Three steps. Package, services, stylesheet.</p>
    </div>

    <ol class="install__steps">
        <li class="install__step">
            <span class="install__step-num">1</span>
            <div class="install__step-body">
                <h3 class="install__step-title">Add the package</h3>
                <BUICodeBlock Title="Terminal"
                              Language="SyntaxHighlightLanguage.CSharp"
                              Code="@_packageSnippet" />
            </div>
        </li>
        <li class="install__step">
            <span class="install__step-num">2</span>
            <div class="install__step-body">
                <h3 class="install__step-title">Register the services</h3>
                <BUICodeBlock Title="Program.cs"
                              Language="SyntaxHighlightLanguage.CSharp"
                              Code="@_programSnippet" />
            </div>
        </li>
        <li class="install__step">
            <span class="install__step-num">3</span>
            <div class="install__step-body">
                <h3 class="install__step-title">Link the stylesheet</h3>
                <BUICodeBlock Title="wwwroot/index.html"
                              Language="SyntaxHighlightLanguage.Razor"
                              Code="@_indexSnippet" />
            </div>
        </li>
    </ol>

    <p class="install__more">
        Full walkthrough in the <a href="/getting-started">Getting started</a> guide.
    </p>
</section>

@code {
    [Inject] private NavigationManager _nav { get; set; } = default!;

    private ElementReference _heroRef;
    private IJSObjectReference? _parallaxModule;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _parallaxModule = await _js.InvokeAsync<IJSObjectReference>("import", "./js/hero-parallax.js");
                await _parallaxModule.InvokeVoidAsync("attach", _heroRef);
            }
            catch (JSDisconnectedException) { }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_parallaxModule is not null)
        {
            try
            {
                await _parallaxModule.InvokeVoidAsync("detach");
                await _parallaxModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }
    }

    private const string _packageSnippet = @"dotnet add package CdCSharp.BlazorUI";

    private const string _programSnippet = @"builder.Services.AddBlazorUI();";

    private const string _indexSnippet = @"<link href=""_content/CdCSharp.BlazorUI/css/blazorui.css"" rel=""stylesheet"" />";
}
