@page "/components/number"

<PageTitle>Number — CdCSharp.BlazorUI</PageTitle>

<DocPage Eyebrow="Component"
         Title="InputNumber"
         Lede="Strongly-typed numeric input with min/max, stepper buttons, acceleration, and culture-aware formatting.">

    <section class="doc-section">
        <h2 class="doc-section__title">Basic usage</h2>
        <ComponentDemo Definition="@BasicDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Variants</h2>
        <ComponentDemo Definition="@VariantsDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Sizes</h2>
        <ComponentDemo Definition="@SizesDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Min &amp; max</h2>
        <ComponentDemo Definition="@MinMaxDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Decimals &amp; step</h2>
        <ComponentDemo Definition="@DecimalDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Step buttons placement</h2>
        <ComponentDemo Definition="@PlacementDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Prefix / suffix</h2>
        <ComponentDemo Definition="@PrefixSuffixDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">States</h2>
        <ComponentDemo Definition="@StatesDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Properties</h2>
        <PropertyTable Properties="@BUIInputNumberComponentInfo.Parameters" />
    </section>

</DocPage>

@code {
    private int _basic = 10;
    private int _outlinedValue;
    private int _filledValue;
    private int _standardValue;
    private int _smallValue;
    private int _mediumValue;
    private int _largeValue;
    private int _minMax = 50;
    private decimal _decimal = 0.5m;
    private int _leftPlacement;
    private int _splitPlacement;
    private decimal _price = 9.99m;
    private int _percentage = 25;
    private int _required;
    private int _readonly = 42;
    private int _disabled = 42;
    private int _errorValue = -5;

    private ComponentDemoDefinition BasicDemo => new()
    {
        CodeTitle = "Basic.razor",
        Code =
            """
            <BUIInputNumber TValue="int" @bind-Value="_value" Label="Quantity" />
            """,
        Demo = RenderBasic()
    };

    private RenderFragment RenderBasic() => __builder =>
    {
        <BUIInputNumber TValue="int" @bind-Value="_basic" Label="Quantity" />
    };

    private ComponentDemoDefinition VariantsDemo => new()
    {
        Demo = RenderVariants(),
        Code =
            """
            <BUIInputNumber TValue="int" @bind-Value="_outlinedValue" Label="Outlined" Variant="BUIInputVariant.Outlined" />
            <BUIInputNumber TValue="int" @bind-Value="_filledValue" Label="Filled" Variant="BUIInputVariant.Filled" />
            <BUIInputNumber TValue="int" @bind-Value="_standardValue" Label="Standard" Variant="BUIInputVariant.Standard" />
            """
    };

    private RenderFragment RenderVariants() => __builder =>
    {
        <BUIInputNumber TValue="int" @bind-Value="_outlinedValue" Label="Outlined" Variant="BUIInputVariant.Outlined"/>
        <BUIInputNumber TValue="int" @bind-Value="_filledValue" Label="Filled" Variant="BUIInputVariant.Filled"/>
        <BUIInputNumber TValue="int" @bind-Value="_standardValue" Label="Standard" Variant="BUIInputVariant.Standard"/>
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code =
            """
            <BUIInputNumber TValue="int" @bind-Value="_smallValue" Label="Small" Size="SizeEnum.Small" />
            <BUIInputNumber TValue="int" @bind-Value="_mediumValue" Label="Medium (Default)" Size="SizeEnum.Medium" />
            <BUIInputNumber TValue="int" @bind-Value="_largeValue" Label="Large" Size="SizeEnum.Large" />
            """
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <BUIInputNumber TValue="int" @bind-Value="_smallValue" Label="Small" Size="SizeEnum.Small"/>
        <BUIInputNumber TValue="int" @bind-Value="_mediumValue" Label="Medium (Default)" Size="SizeEnum.Medium"/>
        <BUIInputNumber TValue="int" @bind-Value="_largeValue" Label="Large" Size="SizeEnum.Large"/>
    };

    private ComponentDemoDefinition MinMaxDemo => new()
    {
        CodeTitle = "MinMax.razor",
        Code =
            """
            <BUIInputNumber TValue="int" @bind-Value="_minMax" Min="0" Max="100" Label="Progress" HelperText="Clamped between 0 and 100." />
            """,
        Demo = RenderMinMax()
    };

    private RenderFragment RenderMinMax() => __builder =>
    {
        <BUIInputNumber TValue="int" @bind-Value="_minMax" Min="0" Max="100" Label="Progress" HelperText="Clamped between 0 and 100."/>
    };

    private ComponentDemoDefinition DecimalDemo => new()
    {
        CodeTitle = "Decimal.razor",
        Code =
            """
            <BUIInputNumber TValue="decimal" @bind-Value="_decimal" Step="0.1m" DecimalPlaces="2" Label="Price" />
            """,
        Demo = RenderDecimal()
    };

    private RenderFragment RenderDecimal() => __builder =>
    {
        <BUIInputNumber TValue="decimal" @bind-Value="_decimal" Step="0.1m" DecimalPlaces="2" Label="Price"/>
    };

    private ComponentDemoDefinition PlacementDemo => new()
    {
        Demo = RenderPlacement(),
        Code =
            """
            <BUIInputNumber TValue="int" @bind-Value="_leftPlacement" ButtonPlacement="StepButtonPlacement.Left" Label="Left" />
            <BUIInputNumber TValue="int" @bind-Value="_splitPlacement" ButtonPlacement="StepButtonPlacement.Right" Label="Right (default)" />
            """
    };

    private RenderFragment RenderPlacement() => __builder =>
    {
        <div class="demo-stack">
            <BUIInputNumber TValue="int" @bind-Value="_leftPlacement" ButtonPlacement="StepButtonPlacement.Left" Label="Left"/>
            <BUIInputNumber TValue="int" @bind-Value="_splitPlacement" ButtonPlacement="StepButtonPlacement.Right" Label="Right (default)"/>
        </div>
    };

    private ComponentDemoDefinition PrefixSuffixDemo => new()
    {
        Demo = RenderPrefixSuffix(),
        Code =
            """
            <BUIInputNumber TValue="decimal" @bind-Value="_price" PrefixText="$" Label="Price" Step="0.01m" DecimalPlaces="2" />
            <BUIInputNumber TValue="int" @bind-Value="_percentage" SuffixText="%" Label="Discount" Min="0" Max="100" />
            """
    };

    private RenderFragment RenderPrefixSuffix() => __builder =>
    {
        <div class="demo-stack">
            <BUIInputNumber TValue="decimal" @bind-Value="_price" PrefixText="$" Label="Price" Step="0.01m" DecimalPlaces="2"/>
            <BUIInputNumber TValue="int" @bind-Value="_percentage" SuffixText="%" Label="Discount" Min="0" Max="100"/>
        </div>
    };

    private ComponentDemoDefinition StatesDemo => new()
    {
        Demo = RenderStates(),
        Code =
            """
            <BUIInputNumber TValue="int" Label="Required" Required="true" />
            <BUIInputNumber TValue="int" Label="ReadOnly" ReadOnly="true" />
            <BUIInputNumber TValue="int" Label="Disabled" Disabled="true" />
            <BUIInputNumber TValue="int" Label="Error" Error="true" HelperText="Value out of range" />
            """
    };

    private RenderFragment RenderStates() => __builder =>
    {
        <BUIInputNumber TValue="int" @bind-Value="_required" Label="Required" Required="true"/>
        <BUIInputNumber TValue="int" @bind-Value="_readonly" Label="ReadOnly" ReadOnly="true"/>
        <BUIInputNumber TValue="int" @bind-Value="_disabled" Label="Disabled" Disabled="true"/>
        <BUIInputNumber TValue="int" @bind-Value="_errorValue" Label="Error" Error="true" HelperText="Value out of range"/>
    };
}
