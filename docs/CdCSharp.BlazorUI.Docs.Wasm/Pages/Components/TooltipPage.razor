@page "/components/tooltip"

@inject IStringLocalizer<TooltipPage> Loc

<PageTitle>BlazorUI - BUITooltip</PageTitle>

<DocPage Eyebrow="@Loc["Component"]" Title="@Loc["BUITooltip"]"
         Lede="@Loc["Context popups with 12 placements, five triggers, interactive content, delays, auto-close, and custom markup."]"
         PageType="typeof(TooltipPage)">

    <DocDemo Key="Basic" Title="@Loc["Basic usage"]">
        <BUITooltip Text="@Loc["This is a basic tooltip"]">
            <BUIButton Text="@Loc["Hover me"]" OnClick="@(() => { })" />
        </BUITooltip>
    </DocDemo>

    <DocDemo Key="Placements" Title="@Loc["Placements"]" Description="@Loc["Four sides × three alignments (Start, center, End)."]">
        <div class="demo-grid" style="padding: 2.5rem 0;">
            <BUITooltip Text="@Loc["Top"]" Placement="TooltipPlacement.Top"><BUIButton Text="@Loc["Top"]" Size="SizeEnum.Small" /></BUITooltip>
            <BUITooltip Text="@Loc["Bottom"]" Placement="TooltipPlacement.Bottom"><BUIButton Text="@Loc["Bottom"]" Size="SizeEnum.Small" /></BUITooltip>
            <BUITooltip Text="@Loc["Left"]" Placement="TooltipPlacement.Left"><BUIButton Text="@Loc["Left"]" Size="SizeEnum.Small" /></BUITooltip>
            <BUITooltip Text="@Loc["Right"]" Placement="TooltipPlacement.Right"><BUIButton Text="@Loc["Right"]" Size="SizeEnum.Small" /></BUITooltip>
            <BUITooltip Text="@Loc["TopStart"]" Placement="TooltipPlacement.TopStart"><BUIButton Text="@Loc["TopStart"]" Size="SizeEnum.Small" /></BUITooltip>
            <BUITooltip Text="@Loc["TopEnd"]" Placement="TooltipPlacement.TopEnd"><BUIButton Text="@Loc["TopEnd"]" Size="SizeEnum.Small" /></BUITooltip>
            <BUITooltip Text="@Loc["BottomStart"]" Placement="TooltipPlacement.BottomStart"><BUIButton Text="@Loc["BottomStart"]" Size="SizeEnum.Small" /></BUITooltip>
            <BUITooltip Text="@Loc["BottomEnd"]" Placement="TooltipPlacement.BottomEnd"><BUIButton Text="@Loc["BottomEnd"]" Size="SizeEnum.Small" /></BUITooltip>
        </div>
    </DocDemo>

    <DocDemo Key="Triggers" Title="@Loc["Triggers"]">
        <div class="demo-row">
            <BUITooltip Text="@Loc["Hover (default)"]" Trigger="TooltipTrigger.Hover">
                <BUIButton Text="@Loc["Hover"]" />
            </BUITooltip>
            <BUITooltip Text="@Loc["Focus via keyboard"]" Trigger="TooltipTrigger.Focus">
                <BUIButton Text="@Loc["Focus (Tab)"]" />
            </BUITooltip>
            <BUITooltip Text="@Loc["Click to toggle"]" Trigger="TooltipTrigger.Click">
                <BUIButton Text="@Loc["Click"]" />
            </BUITooltip>
            <BUITooltip Text="@Loc["Hover or focus"]" Trigger="TooltipTrigger.HoverAndFocus">
                <BUIButton Text="@Loc["Hover + Focus"]" />
            </BUITooltip>
        </div>
    </DocDemo>

    <DocDemo Key="RichContent" Title="@Loc["Rich content"]" Description="@Loc["Use TooltipContent and ChildContent slots."]">
        <div class="demo-row">
            <BUITooltip>
                <ChildContent>
                    <BUIButton Text="@Loc["With icon + text"]" />
                </ChildContent>
                <TooltipContent>
                    <div style="text-align: center;">
                        <BUISvgIcon Icon="@BUIIcons.UI.Info" Color="@PaletteColor.Primary" />
                        <p style="margin: 0.5rem 0 0;"><strong>@Loc["Information"]</strong></p>
                        <p style="margin: 0; font-size: 0.85em;">@Loc["Rich tooltip content."]</p>
                    </div>
                </TooltipContent>
            </BUITooltip>
            <BUITooltip Interactive="true">
                <ChildContent>
                    <BUIButton Text="@Loc["Keyboard shortcuts"]" />
                </ChildContent>
                <TooltipContent>
                    <div>
                        <strong>@Loc["Shortcuts"]</strong>
                        <ul style="margin: 0.5rem 0 0; padding-left: 1.2rem;">
                            <li>Ctrl+S — @Loc["Save"]</li>
                            <li>Ctrl+Z — @Loc["Undo"]</li>
                            <li>Ctrl+Y — @Loc["Redo"]</li>
                        </ul>
                    </div>
                </TooltipContent>
            </BUITooltip>
        </div>
    </DocDemo>

    <DocDemo Key="Interactive" Title="@Loc["Interactive + auto-close"]">
        <div class="demo-row">
            <BUITooltip Text="@Loc["Closes in 2s"]" AutoCloseAfterMs="2000">
                <BUIButton Text="@Loc["Auto-close 2s"]" />
            </BUITooltip>
            <BUITooltip Text="@Loc["Hover into tooltip to keep it open"]" Interactive="true" AutoCloseAfterMs="3000">
                <BUIButton Text="@Loc["Interactive + auto-close"]" />
            </BUITooltip>
        </div>
    </DocDemo>

    <DocDemo Key="Delays" Title="@Loc["Delays + offset"]">
        <div class="demo-row">
            <BUITooltip Text="@Loc["Instant show"]" ShowDelay="0">
                <BUIButton Text="@Loc["No show delay"]" />
            </BUITooltip>
            <BUITooltip Text="@Loc["500ms leave delay"]" LeaveDelay="500">
                <BUIButton Text="@Loc["Sticky leave"]" />
            </BUITooltip>
            <BUITooltip Text="@Loc["20px away from trigger"]" Offset="20">
                <BUIButton Text="@Loc["20px offset"]" />
            </BUITooltip>
            <BUITooltip Text="@Loc["No arrow"]" Arrow="false">
                <BUIButton Text="@Loc["No arrow"]" />
            </BUITooltip>
        </div>
    </DocDemo>

    <section class="doc-section">
        <h2 class="doc-section__title">@Loc["Properties"]</h2>
        <PropertyTable Properties="@BUITooltipComponentInfo.Parameters" />
    </section>

</DocPage>
