@page "/components/dropdown"

<PageTitle>Dropdown — CdCSharp.BlazorUI</PageTitle>

<DocPage Eyebrow="Component"
         Title="Dropdown"
         Lede="Single-select list with keyboard navigation, search, and strongly-typed values. Options are declared as children.">

    <section class="doc-section">
        <h2 class="doc-section__title">Basic usage</h2>
        <ComponentDemo Definition="@BasicDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Variants</h2>
        <ComponentDemo Definition="@VariantsDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Sizes</h2>
        <ComponentDemo Definition="@SizesDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Box Placement</h2>
        <p class="doc-section__description">Placement supports <code>Top, Bottom, TopStart, TopEnd, BottomStart, BottomEnd or Auto</code></p>
        <p class="doc-section__description">Auto mode will position the box in the bottom if it has space. Otherwise it will position the box on top.</p>
        <ComponentDemo Definition="@PlacementDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Searchable</h2>
        <p class="doc-section__description">Set <code>Searchable</code> to filter options by typing.</p>
        <ComponentDemo Definition="@SearchableDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Custom template when there are not items.</h2>
        <ComponentDemo Definition="@NoOptionsDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Disabled options</h2>
        <ComponentDemo Definition="@DisabledOptionDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Properties</h2>
        <PropertyTable Properties="@_properties" />
    </section>

</DocPage>

@code {
    private int? _basicSingle;
    private int? _basicMulti;
    private string? _outlinedValue;
    private string? _filledValue;
    private string? _standardValue;
    private string? _smallValue;
    private string? _mediumValue;
    private string? _largeValue;
    private string? _topValue;
    private string? _autoValue;
    private string? _bottomValue;
    private string? _searchable = null;
    private string? _noOptionsValue = null;
    private string? _disabled = "apple";
    private string? _placement = "up";

    private List<string> _optionsStrings = new() { "Option 1", "Option 2", "Option 3", "Option 4", "Option 5" };

    private ComponentDemoDefinition BasicDemo => new()
    {
        CodeTitle = "Basic.razor",
        Code =
            """
            <BUIInputDropdown @bind-Value="_basicSingle" Label="Single" HelperText="Single selection">
                <DropdownOption TOption="int" Value="1">Option 1</DropdownOption>
                <DropdownOption TOption="int" Value="2">Option 2</DropdownOption>
                <DropdownOption TOption="int" Value="3">Option 3</DropdownOption>
                <DropdownOption TOption="int" Value="4">Option 4</DropdownOption>
            </BUIInputDropdown>

            <BUIInputDropdown @bind-Value="_basicMulti" Label="Multi" HelperText="Multiple selection">
                <DropdownOption TOption="int" Value="1">Option 1</DropdownOption>
                <DropdownOption TOption="int" Value="2">Option 2</DropdownOption>
                <DropdownOption TOption="int" Value="3">Option 3</DropdownOption>
                <DropdownOption TOption="int" Value="4">Option 4</DropdownOption>
            </BUIInputDropdown>
            """,
        Demo = RenderBasic()
    };

    private RenderFragment RenderBasic() => __builder =>
    {
        <BUIInputDropdown @bind-Value="_basicSingle" Label="Single" HelperText="Single selection">
            <DropdownOption TOption="int" Value="1">Option 1</DropdownOption>
            <DropdownOption TOption="int" Value="2">Option 2</DropdownOption>
            <DropdownOption TOption="int" Value="3">Option 3</DropdownOption>
            <DropdownOption TOption="int" Value="4">Option 4</DropdownOption>
        </BUIInputDropdown>

        <BUIInputDropdown @bind-Value="_basicMulti" Label="Multi" HelperText="Multiple selection">
            <DropdownOption TOption="int" Value="1">Option 1</DropdownOption>
            <DropdownOption TOption="int" Value="2">Option 2</DropdownOption>
            <DropdownOption TOption="int" Value="3">Option 3</DropdownOption>
            <DropdownOption TOption="int" Value="4">Option 4</DropdownOption>
        </BUIInputDropdown>
    };

    private ComponentDemoDefinition VariantsDemo => new()
    {
        Demo = RenderVariants(),
        Code =
            """
            <BUIInputDropdown @bind-Value="_outlinedValue"
                              Label="Outlined"
                              Variant="BUIInputVariant.Outlined">
                @foreach (var option in _optionsStrings)
                {
                    <DropdownOption Value="@option" Text="@option" />
                }
            </BUIInputDropdown>

            <BUIInputDropdown @bind-Value="_filledValue"
                              Label="Filled"
                              Variant="BUIInputVariant.Filled">
                @foreach (var option in _optionsStrings)
                {
                    <DropdownOption Value="@option" Text="@option" />
                }
            </BUIInputDropdown>

            <BUIInputDropdown @bind-Value="_standardValue"
                              Label="Standard"
                              Variant="BUIInputVariant.Standard">
                @foreach (var option in _optionsStrings)
                {
                    <DropdownOption Value="@option" Text="@option" />
                }
            </BUIInputDropdown>
            """,
    };

    private RenderFragment RenderVariants() => __builder =>
    {

        <BUIInputDropdown @bind-Value="_outlinedValue"
                          Label="Outlined"
                          Variant="BUIInputVariant.Outlined">
            @foreach (string option in _optionsStrings)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>

        <BUIInputDropdown @bind-Value="_filledValue"
                          Label="Filled"
                          Variant="BUIInputVariant.Filled">
            @foreach (var option in _optionsStrings)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>

        <BUIInputDropdown @bind-Value="_standardValue"
                          Label="Standard"
                          Variant="BUIInputVariant.Standard">
            @foreach (var option in _optionsStrings)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code =
        """
        <BUIInputDropdown @bind-Value="_smallValue" Label="Small" Size="SizeEnum.Small">
            @foreach (var option in _optionsStrings)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>
        <BUIInputDropdown @bind-Value="_mediumValue" Label="Medium (Default)" Size="SizeEnum.Medium">
            @foreach (var option in _optionsStrings)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>
        <BUIInputDropdown @bind-Value="_largeValue" Label="Large" Size="SizeEnum.Large">
            @foreach (var option in _optionsStrings)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>
        """
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <BUIInputDropdown @bind-Value="_smallValue" Label="Small" Size="SizeEnum.Small">
            @foreach (var option in _optionsStrings)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>
        <BUIInputDropdown @bind-Value="_mediumValue" Label="Medium (Default)" Size="SizeEnum.Medium">
            @foreach (var option in _optionsStrings)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>
        <BUIInputDropdown @bind-Value="_largeValue" Label="Large" Size="SizeEnum.Large">
            @foreach (var option in _optionsStrings)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>
    };

    private ComponentDemoDefinition PlacementDemo => new()
    {
        Demo = RenderPlacement(),
        Code = 
        """
        <BUIInputDropdown @bind-Value="_bottomValue"
                          Label="Bottom Placement (Default)"
                          Placement="DropdownPlacement.Bottom">
            @foreach (var option in _optionsStrings)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>
        <BUIInputDropdown @bind-Value="_topValue"
                          Label="Top Placement"
                          Placement="DropdownPlacement.Top">
            @foreach (var option in _optionsStrings)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>
        <BUIInputDropdown @bind-Value="_autoValue"
                          Label="Auto Placement"
                          Placement="DropdownPlacement.Auto">
            @foreach (var option in _optionsStrings)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>
        """
    };

    private RenderFragment RenderPlacement() => __builder =>
    {
        <BUIInputDropdown @bind-Value="_bottomValue"
                          Label="Bottom Placement (Default)"
                          Placement="DropdownPlacement.Bottom">
            @foreach (var option in _optionsStrings)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>
        <BUIInputDropdown @bind-Value="_topValue"
                          Label="Top Placement"
                          Placement="DropdownPlacement.Top">
            @foreach (var option in _optionsStrings)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>
        <BUIInputDropdown @bind-Value="_autoValue"
                          Label="Auto Placement"
                          Placement="DropdownPlacement.Auto">
            @foreach (var option in _optionsStrings)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>

    };

    private ComponentDemoDefinition SearchableDemo => new()
    {
        CodeTitle = "Searchable.razor",
        Code =
        """
        <BUIInputDropdown TValue="string" @bind-Value="_searchable" Label="Country" Searchable="true" SearchPlaceholder="Type a country...">
            <DropdownOption TOption="string" Value="@("us")">United States</DropdownOption>
            <DropdownOption TOption="string" Value="@("mx")">Mexico</DropdownOption>
            <DropdownOption TOption="string" Value="@("ca")">Canada</DropdownOption>
            <DropdownOption TOption="string" Value="@("br")">Brazil</DropdownOption>
            <DropdownOption TOption="string" Value="@("ar")">Argentina</DropdownOption>
            <DropdownOption TOption="string" Value="@("es")">Spain</DropdownOption>
            <DropdownOption TOption="string" Value="@("fr")">France</DropdownOption>
            <DropdownOption TOption="string" Value="@("de")">Germany</DropdownOption>
            <DropdownOption TOption="string" Value="@("uk")">United Kingdom</DropdownOption>
            <DropdownOption TOption="string" Value="@("jp")">Japan</DropdownOption>
        </BUIInputDropdown>
        """,
        Demo = RenderSearchable()
    };

    private RenderFragment RenderSearchable() => __builder =>
    {
        <BUIInputDropdown TValue="string" @bind-Value="_searchable" Label="Country" Searchable="true" SearchPlaceholder="Type a country...">
            <DropdownOption TOption="string" Value="@("us")">United States</DropdownOption>
            <DropdownOption TOption="string" Value="@("mx")">Mexico</DropdownOption>
            <DropdownOption TOption="string" Value="@("ca")">Canada</DropdownOption>
            <DropdownOption TOption="string" Value="@("br")">Brazil</DropdownOption>
            <DropdownOption TOption="string" Value="@("ar")">Argentina</DropdownOption>
            <DropdownOption TOption="string" Value="@("es")">Spain</DropdownOption>
            <DropdownOption TOption="string" Value="@("fr")">France</DropdownOption>
            <DropdownOption TOption="string" Value="@("de")">Germany</DropdownOption>
            <DropdownOption TOption="string" Value="@("uk")">United Kingdom</DropdownOption>
            <DropdownOption TOption="string" Value="@("jp")">Japan</DropdownOption>
        </BUIInputDropdown>
    };

    private ComponentDemoDefinition NoOptionsDemo => new()
    {
        Demo = RenderNoOptions(),
        Code = 
        """
        <BUIInputDropdown TValue="string"
                          @bind-Value="_noOptionsValue"
                          Label="Empty Dropdown">
            <NoOptionsTemplate>
                <span>No items available</span>
            </NoOptionsTemplate>
        </BUIInputDropdown>
        """
    };

    private RenderFragment RenderNoOptions() => __builder =>
    {
        <BUIInputDropdown TValue="string"
                          @bind-Value="_noOptionsValue"
                          Label="Empty Dropdown">
            <NoOptionsTemplate>
                <span>No items available</span>
            </NoOptionsTemplate>
        </BUIInputDropdown>
    };

    private ComponentDemoDefinition DisabledOptionDemo => new()
    {
        CodeTitle = "DisabledOption.razor",
        Code = @"<DropdownOption TOption=""string"" Value=""kiwi"" Disabled=""true"">Kiwi (out of stock)</DropdownOption>",
        Demo = RenderDisabledOption()
    };

    private RenderFragment RenderDisabledOption() => __builder =>
    {
        <BUIInputDropdown TValue="string" @bind-Value="_disabled" Label="Fruit">
            <DropdownOption TOption="string" Value="@("apple")">Apple</DropdownOption>
            <DropdownOption TOption="string" Value="@("banana")">Banana</DropdownOption>
            <DropdownOption TOption="string" Value="@("kiwi")" Disabled="true">Kiwi (out of stock)</DropdownOption>
            <DropdownOption TOption="string" Value="@("orange")">Orange</DropdownOption>
        </BUIInputDropdown>
    };

    private readonly PropertyDefinition[] _properties =
    [
        new("Value", "TValue?", "default", "Bound value"),
        new("Label / Placeholder / HelperText", "string?", "null", "Descriptive text"),
        new("Searchable", "bool", "false", "Show search input"),
        new("SearchPlaceholder", "string", "Search...", "Placeholder for search input"),
        new("SearchMode", "SearchMode", "Smart", "Contains / StartsWith / Smart"),
        new("Placement", "DropdownPlacement", "Auto", "Auto / Top / Bottom / BottomStart / BottomEnd / …"),
        new("CloseOnSelect", "bool", "true", "Close after selection"),
        new("MaxVisibleItems", "int", "8", "Items shown before scrolling"),
        new("ItemHeight", "int", "40", "Item height in px (for virtualization)"),
        new("Variant", "BUIInputVariant", "Outlined", "Visual variant"),
        new("Size / Density", "SizeEnum / DensityEnum", "—", "Sizing"),
        new("Disabled / ReadOnly / Required / IsLoading", "bool", "false", "State flags"),
        new("NoOptionsTemplate / NoResultsTemplate", "RenderFragment?", "null", "Empty-state customization")
    ];

}
