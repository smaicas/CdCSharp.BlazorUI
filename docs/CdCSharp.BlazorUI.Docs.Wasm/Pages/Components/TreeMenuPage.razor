@page "/components/treemenu"

<PageTitle>Tree Menu — CdCSharp.BlazorUI</PageTitle>

<DocPage Eyebrow="Component"
         Title="Tree Menu"
         Lede="Hierarchical navigation with icons, nested groups, vertical or horizontal orientation, and hover or click triggers.">

    <section class="doc-section">
        <h2 class="doc-section__title">Basic usage</h2>
        <p class="doc-section__description">Declare <code>BUITreeMenuItem</code>s — nest them via <code>&lt;ChildContent&gt;</code>.</p>
        <ComponentDemo Definition="@BasicDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Horizontal (top bar)</h2>
        <ComponentDemo Definition="@HorizontalDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Hover trigger</h2>
        <p class="doc-section__description">Open submenus on hover instead of click.</p>
        <ComponentDemo Definition="@HoverDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Properties</h2>

        <h3 class="doc-section__subtitle">BUITreeMenu</h3>
        <PropertyTable Properties="@BUITreeMenuComponentInfo.Parameters" />

        <h3 class="doc-section__subtitle">BUITreeMenuItem</h3>
        <PropertyTable Properties="@BUITreeMenuItemComponentInfo.Parameters" />
    </section>

</DocPage>

@code {
    private ComponentDemoDefinition BasicDemo => new()
    {
        CodeTitle = "Basic.razor",
        Code = @"<BUITreeMenu TItem=""object"" Size=""SizeEnum.Medium"">
    <BUITreeMenuItem Text=""Home"" Icon=""@BUIIcons.UI.Home"" Href=""/"" />
    <BUITreeMenuItem Text=""Components"" Icon=""@BUIIcons.UI.Folder"" InitiallyExpanded=""true"">
        <ChildContent>
            <BUITreeMenuItem Text=""Button"" Href=""/components/button"" />
            <BUITreeMenuItem Text=""Card""   Href=""/components/card"" />
        </ChildContent>
    </BUITreeMenuItem>
</BUITreeMenu>",
        Demo = RenderBasic()
    };

    private RenderFragment RenderBasic() => __builder =>
    {
        <div class="demo-panel" style="max-width: 320px;">
            <BUITreeMenu TItem="object" Size="SizeEnum.Medium">
                <BUITreeMenuItem Text="Dashboard" Icon="@BUIIcons.UI.Home" />
                <BUITreeMenuItem Text="Projects" Icon="@BUIIcons.UI.Folder" InitiallyExpanded="true">
                    <ChildContent>
                        <BUITreeMenuItem Text="Active" />
                        <BUITreeMenuItem Text="Archived" />
                        <BUITreeMenuItem Text="Templates">
                            <ChildContent>
                                <BUITreeMenuItem Text="Blank" />
                                <BUITreeMenuItem Text="Starter" />
                            </ChildContent>
                        </BUITreeMenuItem>
                    </ChildContent>
                </BUITreeMenuItem>
                <BUITreeMenuItem Text="Team" Icon="@BUIIcons.UI.Settings" />
            </BUITreeMenu>
        </div>
    };

    private ComponentDemoDefinition HorizontalDemo => new()
    {
        CodeTitle = "Horizontal.razor",
        Code = @"<BUITreeMenu TItem=""object""
             Orientation=""TreeMenuOrientation.Horizontal""
             ExpandMode=""TreeMenuExpandMode.Flyout""
             Trigger=""TreeMenuTrigger.Hover"">…</BUITreeMenu>",
        Demo = RenderHorizontal()
    };

    private RenderFragment RenderHorizontal() => __builder =>
    {
        <BUITreeMenu TItem="object"
                     Orientation="TreeMenuOrientation.Horizontal"
                     ExpandMode="TreeMenuExpandMode.Flyout"
                     Trigger="TreeMenuTrigger.Hover">
            <BUITreeMenuItem Text="File">
                <ChildContent>
                    <BUITreeMenuItem Text="New" />
                    <BUITreeMenuItem Text="Open" />
                    <BUITreeMenuItem Text="Save" />
                </ChildContent>
            </BUITreeMenuItem>
            <BUITreeMenuItem Text="Edit">
                <ChildContent>
                    <BUITreeMenuItem Text="Undo" />
                    <BUITreeMenuItem Text="Redo" />
                </ChildContent>
            </BUITreeMenuItem>
            <BUITreeMenuItem Text="Help" />
        </BUITreeMenu>
    };

    private ComponentDemoDefinition HoverDemo => new()
    {
        CodeTitle = "Hover.razor",
        Code = @"<BUITreeMenu Trigger=""TreeMenuTrigger.Hover"" HoverOpenDelay=""100"" />",
        Demo = RenderHover()
    };

    private RenderFragment RenderHover() => __builder =>
    {
        <div class="demo-panel" style="max-width: 320px;">
            <BUITreeMenu TItem="object" Trigger="TreeMenuTrigger.Hover" HoverOpenDelay="100">
                <BUITreeMenuItem Text="Hover me" Icon="@BUIIcons.UI.Settings">
                    <ChildContent>
                        <BUITreeMenuItem Text="Profile" />
                        <BUITreeMenuItem Text="Appearance" />
                        <BUITreeMenuItem Text="Account" />
                    </ChildContent>
                </BUITreeMenuItem>
            </BUITreeMenu>
        </div>
    };

}
