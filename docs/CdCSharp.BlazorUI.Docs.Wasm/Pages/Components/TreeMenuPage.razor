@page "/components/treemenu"

@inject IStringLocalizer<TreeMenuPage> Loc

<PageTitle>BlazorUI - BUITreeMenu</PageTitle>

<DocPage Eyebrow="@Loc["Component"]" Title="@Loc["BUITreeMenu"]"
         Lede="@Loc["Hierarchical navigation with icons, nested groups, vertical or horizontal orientation, and hover or click triggers."]"
         PageType="typeof(TreeMenuPage)">

    <DocDemo Key="Basic" Title="@Loc["Basic usage"]" Description="@Loc["Declare BUITreeMenuItems — nest them via ChildContent."]">
        <div class="demo-panel" style="max-width: 320px;">
            <BUITreeMenu TItem="object" Size="SizeEnum.Medium">
                <BUITreeMenuItem Text="@Loc["Dashboard"]" Icon="@BUIIcons.UI.Home" />
                <BUITreeMenuItem Text="@Loc["Projects"]" Icon="@BUIIcons.UI.Folder" InitiallyExpanded="true">
                    <ChildContent>
                        <BUITreeMenuItem Text="@Loc["Active"]" />
                        <BUITreeMenuItem Text="@Loc["Archived"]" />
                        <BUITreeMenuItem Text="@Loc["Templates"]">
                            <ChildContent>
                                <BUITreeMenuItem Text="@Loc["Blank"]" />
                                <BUITreeMenuItem Text="@Loc["Starter"]" />
                            </ChildContent>
                        </BUITreeMenuItem>
                    </ChildContent>
                </BUITreeMenuItem>
                <BUITreeMenuItem Text="@Loc["Team"]" Icon="@BUIIcons.UI.Settings" />
            </BUITreeMenu>
        </div>
    </DocDemo>

    <DocDemo Key="Horizontal" Title="@Loc["Horizontal (top bar)"]">
        <BUITreeMenu TItem="object"
                     Orientation="TreeMenuOrientation.Horizontal"
                     ExpandMode="TreeMenuExpandMode.Flyout"
                     Trigger="TreeMenuTrigger.Hover">
            <BUITreeMenuItem Text="@Loc["File"]">
                <ChildContent>
                    <BUITreeMenuItem Text="@Loc["New"]" />
                    <BUITreeMenuItem Text="@Loc["Open"]" />
                    <BUITreeMenuItem Text="@Loc["Save"]" />
                </ChildContent>
            </BUITreeMenuItem>
            <BUITreeMenuItem Text="@Loc["Edit"]">
                <ChildContent>
                    <BUITreeMenuItem Text="@Loc["Undo"]" />
                    <BUITreeMenuItem Text="@Loc["Redo"]" />
                </ChildContent>
            </BUITreeMenuItem>
            <BUITreeMenuItem Text="@Loc["Help"]" />
        </BUITreeMenu>
    </DocDemo>

    <DocDemo Key="Hover" Title="@Loc["Hover trigger"]" Description="@Loc["Open submenus on hover instead of click."]">
        <div class="demo-panel" style="max-width: 320px;">
            <BUITreeMenu TItem="object" Trigger="TreeMenuTrigger.Hover" HoverOpenDelay="100">
                <BUITreeMenuItem Text="@Loc["Hover me"]" Icon="@BUIIcons.UI.Settings">
                    <ChildContent>
                        <BUITreeMenuItem Text="@Loc["Profile"]" />
                        <BUITreeMenuItem Text="@Loc["Appearance"]" />
                        <BUITreeMenuItem Text="@Loc["Account"]" />
                    </ChildContent>
                </BUITreeMenuItem>
            </BUITreeMenu>
        </div>
    </DocDemo>

    <section class="doc-section">
        <h2 class="doc-section__title">@Loc["Properties"]</h2>

        <h3 class="doc-section__subtitle">BUITreeMenu</h3>
        <PropertyTable Properties="@BUITreeMenuComponentInfo.Parameters" />

        <h3 class="doc-section__subtitle">BUITreeMenuItem</h3>
        <PropertyTable Properties="@BUITreeMenuItemComponentInfo.Parameters" />
    </section>

</DocPage>
