@page "/components/draggable"

<PageTitle>Draggable — CdCSharp.BlazorUI</PageTitle>

<DocPage Eyebrow="Component"
         Title="Draggable"
         Lede="Make any element mouse-draggable with fine-grained events. Renders its child content untouched — positioning is up to you.">

    <section class="doc-section">
        <h2 class="doc-section__title">Basic usage</h2>
        <p class="doc-section__description">Wrap anything in <code>&lt;BUIDraggable&gt;</code> and listen to <code>OnDrag</code>. Client coordinates are reported in <code>DragEventArgs</code>.</p>
        <ComponentDemo Definition="@BasicDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Lifecycle events</h2>
        <p class="doc-section__description">Fires <code>OnDragStart</code> on mousedown, <code>OnDrag</code> continuously, and <code>OnDragEnd</code> on release.</p>
        <ComponentDemo Definition="@EventsDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Disabled</h2>
        <ComponentDemo Definition="@DisabledDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Properties</h2>
        <PropertyTable Properties="@BUIDraggableComponentInfo.Parameters" />
    </section>

</DocPage>

@code {
    private double _x = 60;
    private double _y = 20;
    private double _startX, _startY, _originX, _originY;

    private string _lastEvent = "(none)";
    private int _dragTicks;

    private ComponentDemoDefinition BasicDemo => new()
    {
        CodeTitle = "Basic.razor",
        Code = @"<BUIDraggable OnDragStart=""HandleStart""
              OnDrag=""HandleDrag"">
    <div style=""@GetBoxStyle()"">Drag me</div>
</BUIDraggable>",
        Demo = RenderBasic()
    };

    private RenderFragment RenderBasic() => __builder =>
    {
        <div style="position: relative; height: 180px; border: 1px dashed var(--palette-border); border-radius: .5rem; overflow: hidden;">
            <BUIDraggable OnDragStart="HandleBasicStart" OnDrag="HandleBasicDrag">
                <div style="@BasicBoxStyle">
                    Drag me
                </div>
            </BUIDraggable>
        </div>
    };

    private string BasicBoxStyle =>
        $"position: absolute; left: {_x}px; top: {_y}px; user-select: none; " +
        "padding: .75rem 1rem; border-radius: .5rem; cursor: grab; " +
        "background: var(--palette-primary); color: var(--palette-primarycontrast); " +
        "box-shadow: 0 4px 14px rgba(0,0,0,.15);";

    private void HandleBasicStart(DragEventArgs e)
    {
        _startX = e.ClientX;
        _startY = e.ClientY;
        _originX = _x;
        _originY = _y;
    }

    private void HandleBasicDrag(DragEventArgs e)
    {
        _x = _originX + (e.ClientX - _startX);
        _y = _originY + (e.ClientY - _startY);
    }

    private ComponentDemoDefinition EventsDemo => new()
    {
        CodeTitle = "Events.razor",
        Code = @"<BUIDraggable OnDragStart=""@(_ => _lastEvent = ""start"")""
              OnDrag=""@(_ => _dragTicks++)""
              OnDragEnd=""@(_ => _lastEvent = ""end"")"">
    ...
</BUIDraggable>",
        Demo = RenderEvents()
    };

    private RenderFragment RenderEvents() => __builder =>
    {
        <div>
            <BUIDraggable OnDragStart="@(_ => { _lastEvent = "start"; _dragTicks = 0; })"
                          OnDrag="@(_ => _dragTicks++)"
                          OnDragEnd="@(_ => _lastEvent = "end")">
                <BUIButton Text="Drag me and watch the counter" />
            </BUIDraggable>
            <p style="margin-top: 1rem;">
                Last event: <code>@_lastEvent</code> · Tick count: <code>@_dragTicks</code>
            </p>
        </div>
    };

    private ComponentDemoDefinition DisabledDemo => new()
    {
        CodeTitle = "Disabled.razor",
        Code = @"<BUIDraggable Disabled=""true"">
    <BUIButton Text=""Locked"" />
</BUIDraggable>",
        Demo = RenderDisabled()
    };

    private RenderFragment RenderDisabled() => __builder =>
    {
        <BUIDraggable Disabled="true">
            <BUIButton Text="Locked — can't drag" />
        </BUIDraggable>
    };
}
