@page "/components/loading"

@inject IStringLocalizer<LoadingPage> Loc

<PageTitle>BlazorUI - BUILoadingIndicator</PageTitle>

<DocPage Eyebrow="@Loc["Component"]" Title="@Loc["BUILoadingIndicator"]"
         Lede="@Loc["Six animation variants for progress, activity, and waiting states. Size- and color-aware."]"
         PageInstance="this">

    <DocDemo Key="Variants" Title="@Loc["Variants"]" Description="@Loc["Six built-in animations covering every common case."]">
                <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" />
                <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.CircularProgress" />
                <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Ring" />
                <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Dots" />
                <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Bars" />
                <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.LinearIndeterminate" />
    </DocDemo>

    <DocDemo Key="Sizes" Title="@Loc["Sizes"]">
                <BUILoadingIndicator Size="SizeEnum.Small" />
                <BUILoadingIndicator Size="SizeEnum.Medium" />
                <BUILoadingIndicator Size="SizeEnum.Large" />
    </DocDemo>

    <DocDemo Key="Colors" Title="@Loc["Colors"]">
                <BUILoadingIndicator Color="@PaletteColor.Primary" />
                <BUILoadingIndicator Color="@PaletteColor.Secondary" />
                <BUILoadingIndicator Color="@PaletteColor.Error" />
                <BUILoadingIndicator Color="@PaletteColor.Success" />
                <BUILoadingIndicator Color="@PaletteColor.Warning" />
    </DocDemo>

    <section class="doc-section">
        <h2 class="doc-section__title">@Loc["Properties"]</h2>
        <PropertyTable Properties="@BUILoadingIndicatorComponentInfo.Parameters" />
    </section>

</DocPage>
