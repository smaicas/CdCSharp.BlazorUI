@page "/components/toast"

@inject IToastService Toast
@inject IStringLocalizer<ToastPage> Loc

<PageTitle>BlazorUI - BUIToast</PageTitle>

<DocPage Eyebrow="@Loc["Component"]" Title="@Loc["BUIToast"]"
         Lede="@Loc["Transient notifications shown via IToastService. Six positions, configurable duration, animations, custom content."]"
         PageType="typeof(ToastPage)">

    <DocDemo Key="Basic" Title="@Loc["Basic usage"]">
        <BUIButton Text="@Loc["Show toast"]" OnClick="@(() => Toast.Show(b => b.AddContent(0, Loc["Hello from a toast!"])))" />
    </DocDemo>

    <DocDemo Key="Positions" Title="@Loc["Positions"]">
        <div class="demo-grid">
            <BUIButton Text="@Loc["Top Left"]" Size="SizeEnum.Small" OnClick="@(() => ShowAt(ToastPosition.TopLeft))" />
            <BUIButton Text="@Loc["Top Center"]" Size="SizeEnum.Small" OnClick="@(() => ShowAt(ToastPosition.TopCenter))" />
            <BUIButton Text="@Loc["Top Right"]" Size="SizeEnum.Small" OnClick="@(() => ShowAt(ToastPosition.TopRight))" />
            <BUIButton Text="@Loc["Bottom Left"]" Size="SizeEnum.Small" OnClick="@(() => ShowAt(ToastPosition.BottomLeft))" />
            <BUIButton Text="@Loc["Bottom Center"]" Size="SizeEnum.Small" OnClick="@(() => ShowAt(ToastPosition.BottomCenter))" />
            <BUIButton Text="@Loc["Bottom Right"]" Size="SizeEnum.Small" OnClick="@(() => ShowAt(ToastPosition.BottomRight))" />
        </div>
    </DocDemo>

    <DocDemo Key="Durations" Title="@Loc["Durations"]">
        <div class="demo-row">
            <BUIButton Text="@Loc["Quick (2s)"]" OnClick="@(() => Toast.Show(b => b.AddContent(0, Loc["Quick (2s)"]), ToastOptions.Quick))" />
            <BUIButton Text="@Loc["Default (4s)"]" OnClick="@(() => Toast.Show(b => b.AddContent(0, Loc["Default (4s)"]), ToastOptions.Default))" />
            <BUIButton Text="@Loc["Long (8s)"]" OnClick="@(() => Toast.Show(b => b.AddContent(0, Loc["Long (8s)"]), ToastOptions.Long))" />
        </div>
    </DocDemo>

    <DocDemo Key="Persistent" Title="@Loc["Persistent + closable"]">
        <div class="demo-row">
            <BUIButton Text="@Loc["Persistent (no dismiss)"]" OnClick="@(() => Toast.Show(b => b.AddContent(0, Loc["Stays until closed."]), ToastOptions.Persistent))" />
            <BUIButton Text="@Loc["Not closable"]" OnClick="@(() => Toast.Show(b => b.AddContent(0, Loc["No X button — wait it out."]), new ToastOptions { Closable = false }))" />
        </div>
    </DocDemo>

    <DocDemo Key="Animations" Title="@Loc["Animations"]">
        <div class="demo-row">
            <BUIButton Text="@Loc["Slide & Fade"]" OnClick="@(() => Toast.Show(b => b.AddContent(0, Loc["Slide & Fade"]), new ToastOptions { Animation = ToastAnimation.SlideAndFade }))" />
            <BUIButton Text="@Loc["Slide only"]" OnClick="@(() => Toast.Show(b => b.AddContent(0, Loc["Slide only"]), new ToastOptions { Animation = ToastAnimation.SlideOnly }))" />
            <BUIButton Text="@Loc["Fade only"]" OnClick="@(() => Toast.Show(b => b.AddContent(0, Loc["Fade only"]), new ToastOptions { Animation = ToastAnimation.FadeOnly }))" />
            <BUIButton Text="@Loc["None"]" OnClick="@(() => Toast.Show(b => b.AddContent(0, Loc["No animation"]), new ToastOptions { Animation = ToastAnimation.None }))" />
        </div>
    </DocDemo>

    <DocDemo Key="Types" Title="@Loc["Typed helpers"]" Description="@Loc["Add toast-info / toast-success / toast-warning / toast-error CSS rules in your app, then pass CssClass."]">
        <div class="demo-row">
            <BUIButton Text="@Loc["Info"]" BackgroundColor="@PaletteColor.Info" Color="@PaletteColor.InfoContrast"
                       OnClick="@(() => Toast.Show(b => b.AddContent(0, Loc["Info toast"]), new ToastOptions { CssClass = "toast-info" }))" />
            <BUIButton Text="@Loc["Success"]" BackgroundColor="@PaletteColor.Success" Color="@PaletteColor.SuccessContrast"
                       OnClick="@(() => Toast.Show(b => b.AddContent(0, Loc["Success!"]), new ToastOptions { CssClass = "toast-success" }))" />
            <BUIButton Text="@Loc["Warning"]" BackgroundColor="@PaletteColor.Warning" Color="@PaletteColor.WarningContrast"
                       OnClick="@(() => Toast.Show(b => b.AddContent(0, Loc["Watch out."]), new ToastOptions { CssClass = "toast-warning" }))" />
            <BUIButton Text="@Loc["Error"]" BackgroundColor="@PaletteColor.Error" Color="@PaletteColor.ErrorContrast"
                       OnClick="@(() => Toast.Show(b => b.AddContent(0, Loc["Something broke."]), new ToastOptions { CssClass = "toast-error" }))" />
        </div>
    </DocDemo>

    <DocDemo Key="Manage" Title="@Loc["Manage"]">
        <div class="demo-row">
            <BUIButton Text="@Loc["Show 3 toasts"]" OnClick="@ShowThree" />
            <BUIButton Text="@Loc["Close all"]"
                       BackgroundColor="@PaletteColor.Error"
                       Color="@PaletteColor.ErrorContrast"
                       OnClick="@(() => Toast.CloseAll())" />
            <BUIButton Text="@($"{Loc["Clicks"]}: {_clicks}")" OnClick="@ShowClickable" />
        </div>
    </DocDemo>

    <section class="doc-section">
        <h2 class="doc-section__title">@Loc["Properties"]</h2>

        <h3 class="doc-section__subtitle">BUIToast</h3>
        <PropertyTable Properties="@BUIToastComponentInfo.Parameters" />

        <h3 class="doc-section__subtitle">BUIToastHost</h3>
        <PropertyTable Properties="@BUIToastHostComponentInfo.Parameters" />
    </section>

</DocPage>

@code {
    private int _clicks;

    private void ShowAt(ToastPosition position)
    {
        Toast.Show(b => b.AddContent(0, $"Toast at {position}"),
            new ToastOptions { Position = position });
    }

    private void ShowThree()
    {
        for (int i = 1; i <= 3; i++)
        {
            int idx = i;
            Toast.Show(b => b.AddContent(0, $"Toast #{idx}"),
                new ToastOptions { Duration = TimeSpan.FromSeconds(10) });
        }
    }

    private void ShowClickable()
    {
        Toast.Show(b => b.AddContent(0, Loc["Click me to bump counter"].Value),
            new ToastOptions { OnClick = () => _clicks++, Duration = TimeSpan.FromSeconds(6) });
    }
}
