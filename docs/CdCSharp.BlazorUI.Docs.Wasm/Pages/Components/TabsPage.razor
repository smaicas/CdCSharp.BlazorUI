@page "/components/tabs"

@inject IStringLocalizer<TabsPage> Loc

<PageTitle>BlazorUI - BUITabs</PageTitle>

<DocPage Eyebrow="@Loc["Component"]" Title="@Loc["BUITabs"]"
         Lede="@Loc["Tab panels with three visual variants. Declare tabs as children — the active one renders automatically."]"
         PageInstance="this">

    <DocDemo Key="Basic" Title="@Loc["Basic usage"]">
        <BUITabs @bind-ActiveTab="_basic">
            <BUITab Id="overview" Label="@Loc["Overview"]">
                @Loc["Overview content — the first tab is active by default."]
            </BUITab>
            <BUITab Id="details" Label="@Loc["Details"]">
                @Loc["Details content."]
            </BUITab>
            <BUITab Id="reviews" Label="@Loc["Reviews"]">
                @Loc["Reviews content."]
            </BUITab>
        </BUITabs>
    </DocDemo>

    <DocDemo Key="Variants" Title="@Loc["Variants"]" Description="@Loc["Underline (default), Pills, and Enclosed."]">
        <div class="demo-stack">
            <BUITabs Variant="BUITabsVariant.Pills" @bind-ActiveTab="_pills">
                <BUITab Id="account" Label="@Loc["Account"]">
                    @Loc["Account settings."]
                </BUITab>
                <BUITab Id="billing" Label="@Loc["Billing"]">
                    @Loc["Billing details."]
                </BUITab>
                <BUITab Id="team" Label="@Loc["Team"]">
                    @Loc["Team members."]
                </BUITab>
            </BUITabs>
            <BUITabs Variant="BUITabsVariant.Enclosed" @bind-ActiveTab="_enclosed">
                <BUITab Id="profile" Label="@Loc["Profile"]">
                    @Loc["Profile tab."]
                </BUITab>
                <BUITab Id="notifications" Label="@Loc["Notifications"]">
                    @Loc["Notifications tab."]
                </BUITab>
                <BUITab Id="security" Label="@Loc["Security"]">
                    @Loc["Security tab."]
                </BUITab>
            </BUITabs>
        </div>
    </DocDemo>

    <DocDemo Key="FullWidth" Title="@Loc["Full width"]">
        <BUITabs FullWidth="true" @bind-ActiveTab="_full">
            <BUITab Id="inbox" Label="@Loc["Inbox"]">
                @Loc["Inbox."]
            </BUITab>
            <BUITab Id="sent" Label="@Loc["Sent"]">
                @Loc["Sent messages."]
            </BUITab>
            <BUITab Id="archive" Label="@Loc["Archive"]">
                @Loc["Archive."]
            </BUITab>
        </BUITabs>
    </DocDemo>

    <DocDemo Key="Disabled" Title="@Loc["Disabled tab"]">
        <BUITabs @bind-ActiveTab="_disabled">
            <BUITab Id="general" Label="@Loc["General"]">
                @Loc["General settings."]
            </BUITab>
            <BUITab Id="pro" Label="@Loc["Pro features"]" Disabled="true">
                @Loc["Unreachable content."]
            </BUITab>
            <BUITab Id="about" Label="@Loc["About"]">
                @Loc["About page."]
            </BUITab>
        </BUITabs>
    </DocDemo>

    <section class="doc-section">
        <h2 class="doc-section__title">@Loc["Properties"]</h2>

        <h3 class="doc-section__subtitle">BUITabs</h3>
        <PropertyTable Properties="@BUITabsComponentInfo.Parameters" />

        <h3 class="doc-section__subtitle">BUITab</h3>
        <PropertyTable Properties="@BUITabComponentInfo.Parameters" />
    </section>

</DocPage>

@code {
    private string? _basic = "overview";
    private string? _pills = "billing";
    private string? _enclosed = "notifications";
    private string? _full = "inbox";
    private string? _disabled = "general";
}
