@page "/components/svgicon"

@inject IStringLocalizer<SvgIconPage> Loc

<PageTitle>BlazorUI - BUISvgIcon</PageTitle>

<DocPage Eyebrow="@Loc["Component"]" Title="@Loc["BUISvgIcon"]"
         Lede="@Loc["Render SVGs from the bundled Material or UI icon sets (or any path/string). Inherits color and scales with size."]"
         PageInstance="this">

    <DocDemo Key="Basic" Title="@Loc["Basic usage"]">
        <BUISvgIcon Icon="@BUIIcons.UI.Home" />
    </DocDemo>

    <DocDemo Key="Material" Title="@Loc["Material Icons"]" Description="@Loc["Use BUIIcons.MaterialIconsOutlined, .MaterialIconsRound, .MaterialIconsSharp, or .MaterialIconsFilled."]">
            <BUISvgIcon Icon="@BUIIcons.MaterialIconsOutlined.i_favorite" />
            <BUISvgIcon Icon="@BUIIcons.MaterialIconsOutlined.i_star" />
            <BUISvgIcon Icon="@BUIIcons.MaterialIconsOutlined.i_settings" />
            <BUISvgIcon Icon="@BUIIcons.MaterialIconsOutlined.i_search" />
            <BUISvgIcon Icon="@BUIIcons.MaterialIconsOutlined.i_shopping_cart" />
    </DocDemo>

    <DocDemo Key="UI" Title="@Loc["UI Icons"]" Description="@Loc["A curated set for UI chrome: BUIIcons.UI.*."]">
            <BUISvgIcon Icon="@BUIIcons.UI.Home" />
            <BUISvgIcon Icon="@BUIIcons.UI.Search" />
            <BUISvgIcon Icon="@BUIIcons.UI.Settings" />
            <BUISvgIcon Icon="@BUIIcons.UI.Notifications" />
            <BUISvgIcon Icon="@BUIIcons.UI.Email" />
    </DocDemo>

    <DocDemo Key="Sizes" Title="@Loc["Sizes"]">
            <BUISvgIcon Icon="@BUIIcons.MaterialIconsOutlined.i_star" Size="BUISize.Small" />
            <BUISvgIcon Icon="@BUIIcons.MaterialIconsOutlined.i_star" Size="BUISize.Medium" />
            <BUISvgIcon Icon="@BUIIcons.MaterialIconsOutlined.i_star" Size="BUISize.Large" />
    </DocDemo>

    <DocDemo Key="Colors" Title="@Loc["Colors"]">
            <BUISvgIcon Icon="@BUIIcons.UI.Favorite" Color="@PaletteColor.Primary" />
            <BUISvgIcon Icon="@BUIIcons.UI.Favorite" Color="@PaletteColor.Secondary" />
            <BUISvgIcon Icon="@BUIIcons.UI.Favorite" Color="@PaletteColor.Error" />
            <BUISvgIcon Icon="@BUIIcons.UI.Favorite" Color="@PaletteColor.Success" />
            <BUISvgIcon Icon="@BUIIcons.UI.Favorite" Color="@PaletteColor.Warning" />
    </DocDemo>

    <DocDemo Key="Clickable" Title="@Loc["Clickable"]">
            <BUISvgIcon Icon="@BUIIcons.MaterialIconsSharp.i_thumb_up"
                        Color="@PaletteColor.Primary"
                        Size="BUISize.Large"
                        OnClick="@(() => _clickCount++)" />
            <span>@Loc["Clicked"] @_clickCount @Loc["times"]</span>
    </DocDemo>

    <section class="doc-section">
        <h2 class="doc-section__title">@Loc["Properties"]</h2>
        <PropertyTable Properties="@BUISvgIconComponentInfo.Parameters" />
    </section>

</DocPage>

@code {
    private int _clickCount;
}
