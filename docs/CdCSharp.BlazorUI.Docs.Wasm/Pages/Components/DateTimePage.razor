@page "/components/datetime"

@inject IStringLocalizer<DateTimePage> Loc

<PageTitle>BlazorUI - BUIInputDateTime</PageTitle>

<DocPage Eyebrow="@Loc["Component"]" Title="@Loc["BUIInputDateTime"]"
         Lede="@Loc["Generic input for DateOnly, TimeOnly, DateTime, and DateTimeOffset. Culture-aware parsing and validation, plus standalone pickers."]"
         PageInstance="this">

    <DocDemo Key="Basic" Title="@Loc["Basic usage"]">
        <BUIInputDateTime TValue="DateTime ?" @bind-Value="_dateBasic" Label="@Loc["Basic"]" HelperText="@Loc["Select date and time"]" />
    </DocDemo>

    <DocDemo Key="DateInput" Title="@Loc["Date Input"]" Description="@("""Use <code>TValue="DateOnly"</code> for date-only input.""")">
        <BUIInputDateTime TValue="DateOnly ?" @bind-Value="_date" Label="@Loc["Only Date"]" />
    </DocDemo>

    <DocDemo Key="TimeInput" Title="@Loc["Time Input"]" Description="@("""Use <code>TValue="TimeOnly"</code> for time-only input.""")">
        <BUIInputDateTime TValue="TimeOnly ?" @bind-Value="_time" Label="@Loc["Only time"]" />
    </DocDemo>

    <DocDemo Key="Variants" Title="@Loc["Variants"]">
        <BUIInputDateTime @bind-Value="_outlinedValue" Label="@Loc["Outlined"]" Variant="BUIInputVariant.Outlined" />
        <BUIInputDateTime @bind-Value="_filledValue" Label="@Loc["Filled"]" Variant="BUIInputVariant.Filled" />
        <BUIInputDateTime @bind-Value="_standardValue" Label="@Loc["Standard"]" Variant="BUIInputVariant.Standard" />
    </DocDemo>

    <DocDemo Key="Sizes" Title="@Loc["Sizes"]">
        <BUIInputDateTime @bind-Value="_smallValue" Label="@Loc["Small"]" Size="SizeEnum.Small" />
        <BUIInputDateTime @bind-Value="_mediumValue" Label="@Loc["Medium (Default)"]" Size="SizeEnum.Medium" />
        <BUIInputDateTime @bind-Value="_largeValue" Label="@Loc["Large"]" Size="SizeEnum.Large" />
    </DocDemo>

    <DocDemo Key="ColorAndBackground" Title="@Loc["Color & Background"]">
        <BUIInputDateTime @bind-Value="_colorValue" Label="@Loc["Custom Color"]" Color="@PaletteColor.Secondary" BackgroundColor="@PaletteColor.SecondaryContrast" />
        <BUIInputDateTime @bind-Value="_backgroundValue" Label="@Loc["Custom Background"]" BackgroundColor="@PaletteColor.Secondary" Color="@PaletteColor.SecondaryContrast" />
    </DocDemo>

    <DocDemo Key="PrefixSuffix" Title="@Loc["Prefix & Suffix"]">
        <BUIInputDateTime @bind-Value="_prefixValue" Label="@Loc["With Prefix Icon"]"
                          PrefixIcon="@BUIIcons.MaterialIconsOutlined.i_palette" PrefixBackgroundColor="white" PrefixColor="black" />
        <BUIInputDateTime @bind-Value="_suffixValue" Label="@Loc["With Prefix Icon"]"
                          SuffixIcon="@BUIIcons.MaterialIconsOutlined.i_palette" SuffixBackgroundColor="white" SuffixColor="black" />
    </DocDemo>

    <DocDemo Key="ShadowAndBorder" Title="@Loc["Shadow & Border"]">
        <BUIInputDateTime @bind-Value="_shadowValue" Label="@Loc["Shadow"]" Shadow="@BUIShadowPresets.Elevation(2)" />
        <BUIInputDateTime @bind-Value="_pillValue" Label="@Loc["Pill border"]" Border="@BUIBorderPresets.Pill" />
        <BUIInputDateTime @bind-Value="_roundedValue" Label="@Loc["Rounded"]" Border="@BUIBorderPresets.RoundedLarge" />
    </DocDemo>

    <DocDemo Key="States" Title="@Loc["States"]">
        <BUIInputDateTime @bind-Value="_requiredValue" Label="@Loc["Required"]" Required="true" HelperText="@Loc["Required"]" />
        <BUIInputDateTime @bind-Value="_disabledValue" Label="@Loc["Disabled"]" Disabled="true" HelperText="@Loc["Disabled"]" />
        <BUIInputDateTime @bind-Value="_readOnlyValue" Label="@Loc["Read Only"]" ReadOnly="true" HelperText="@Loc["ReadOnly"]" />
    </DocDemo>

    <DocDemo Key="DatePicker" Title="@Loc["Date Picker"]" Description="@_datePickerDesc">
        <BUIDatePicker Density="DensityEnum.Compact" @bind-Value="_pickerDate" />
        <BUIDatePicker Density="DensityEnum.Standard" @bind-Value="_pickerDate" />
        <BUIDatePicker Density="DensityEnum.Comfortable" @bind-Value="_pickerDate" />
    </DocDemo>

    <DocDemo Key="TimePicker" Title="@Loc["Time Picker"]" Description="@_timePickerDesc">
        <BUITimePicker Density="DensityEnum.Compact" @bind-Value="_pickerTime" />
        <BUITimePicker Density="DensityEnum.Standard" @bind-Value="_pickerTime" />
        <BUITimePicker Density="DensityEnum.Comfortable" @bind-Value="_pickerTime" />
    </DocDemo>

    <section class="doc-section">
        <h2 class="doc-section__title">@Loc["Properties"]</h2>
        <PropertyTable Properties="@BUIInputDateTimeComponentInfo.Parameters" />
    </section>

</DocPage>

@code {
    private DateTime? _dateBasic = DateTime.Today;
    private DateOnly? _date = DateOnly.FromDateTime(DateTime.Today);
    private TimeOnly? _time = new(14, 30);
    private DateTime? _outlinedValue = DateTime.Now;
    private DateTime? _filledValue = DateTime.Now;
    private DateTime? _standardValue = DateTime.Now;
    private DateTime? _smallValue = DateTime.Now;
    private DateTime? _mediumValue = DateTime.Now;
    private DateTime? _largeValue = DateTime.Now;
    private DateTime? _colorValue = DateTime.Now;
    private DateTime? _backgroundValue = DateTime.Now;
    private DateTime? _prefixValue = DateTime.Now;
    private DateTime? _suffixValue = DateTime.Now;
    private DateTime? _requiredValue = DateTime.Now;
    private DateTime? _disabledValue = DateTime.Now;
    private DateTime? _readOnlyValue = DateTime.Now;
    private DateOnly? _pickerDate = DateOnly.FromDateTime(DateTime.Today);
    private TimeOnly? _pickerTime = new(9, 0);
    private DateTime? _shadowValue = DateTime.Now;
    private DateTime? _pillValue = DateTime.Now;
    private DateTime? _roundedValue = DateTime.Now;

    private string _datePickerDesc = string.Empty;
    private string _timePickerDesc = string.Empty;

    override protected void OnInitialized()
    {
        base.OnInitialized();
        _datePickerDesc = Loc[
            """
            <p class="doc-section__description"><code>BUIDatePicker</code> is a calendar-only component (no input).</p>
            <p class="doc-section__description"><code>Density</code> parameter affects datepicker spacing</p>
            """];
        _timePickerDesc = Loc[
            """
            <p class="doc-section__description"><code>BUITimePicker</code> is a clock-only component (no input).</p>
            """];
    }


}
