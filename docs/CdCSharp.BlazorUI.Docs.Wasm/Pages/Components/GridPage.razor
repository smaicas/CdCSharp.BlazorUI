@page "/components/grid"

@inject IStringLocalizer<GridPage> Loc

<PageTitle>BlazorUI - BUIGrid</PageTitle>

<DocPage Eyebrow="@Loc["Component"]" Title="@Loc["BUIGrid"]"
         Lede="@Loc["A 12-column responsive layout using BUIGrid + BUIGridItem. Breakpoint-aware spans, gaps, directions, offsets, and spacing."]"
         PageInstance="this">

    <DocDemo Key="Basic" Title="@Loc["Basic usage"]" Description="@Loc["Use integer Span (out of Columns, default 12) to size each item."]">
        <BUIGrid Gap="1rem">
            <BUIGridItem Span="6"><div class="demo-grid-cell">@Loc["Span 6"]</div></BUIGridItem>
            <BUIGridItem Span="6"><div class="demo-grid-cell">@Loc["Span 6"]</div></BUIGridItem>
            <BUIGridItem Span="4"><div class="demo-grid-cell">@Loc["Span 4"]</div></BUIGridItem>
            <BUIGridItem Span="4"><div class="demo-grid-cell">@Loc["Span 4"]</div></BUIGridItem>
            <BUIGridItem Span="4"><div class="demo-grid-cell">@Loc["Span 4"]</div></BUIGridItem>
        </BUIGrid>
    </DocDemo>

    <DocDemo Key="Responsive" Title="@Loc["Responsive spans"]" Description="@Loc["Per-breakpoint spans (Xs, Sm, Md, Lg, Xl) override Span."]">
        <BUIGrid Gap="1rem">
            <BUIGridItem Xs="12" Sm="6" Md="4" Lg="3"><div class="demo-grid-cell">xs:12 sm:6 md:4 lg:3</div></BUIGridItem>
            <BUIGridItem Xs="12" Sm="6" Md="4" Lg="3"><div class="demo-grid-cell">xs:12 sm:6 md:4 lg:3</div></BUIGridItem>
            <BUIGridItem Xs="12" Sm="6" Md="4" Lg="3"><div class="demo-grid-cell">xs:12 sm:6 md:4 lg:3</div></BUIGridItem>
            <BUIGridItem Xs="12" Sm="6" Md="12" Lg="3"><div class="demo-grid-cell">xs:12 sm:6 md:12 lg:3</div></BUIGridItem>
        </BUIGrid>
    </DocDemo>

    <DocDemo Key="Auto" Title="@Loc["Auto items"]" Description="@Loc["Auto=\"true\" sizes an item to its content."]">
        <BUIGrid Gap="1rem">
            <BUIGridItem Auto="true"><div class="demo-grid-cell">@Loc["Auto"]</div></BUIGridItem>
            <BUIGridItem Auto="true"><div class="demo-grid-cell">@Loc["Auto, wider content here"]</div></BUIGridItem>
            <BUIGridItem Span="4"><div class="demo-grid-cell">@Loc["Span 4 fills rest"]</div></BUIGridItem>
        </BUIGrid>
    </DocDemo>

    <DocDemo Key="Direction" Title="@Loc["Direction & alignment"]">
        <BUIGrid Direction="GridDirection.Column"
                 AlignItems="GridAlignItems.Center"
                 JustifyContent="GridJustifyContent.SpaceBetween"
                 Gap="0.5rem">
            <BUIGridItem Auto="true"><div class="demo-grid-cell">@Loc["Item A"]</div></BUIGridItem>
            <BUIGridItem Auto="true"><div class="demo-grid-cell">@Loc["Item B"]</div></BUIGridItem>
            <BUIGridItem Auto="true"><div class="demo-grid-cell">@Loc["Item C"]</div></BUIGridItem>
        </BUIGrid>
    </DocDemo>

    <DocDemo Key="Gaps" Title="@Loc["Gaps & spacing"]">
        <BUIGrid RowGap="2rem" ColumnGap="0.5rem" P="1rem" style="background: color-mix(in oklab, var(--palette-primary) 6%, transparent); border-radius: 0.5rem;">
            <BUIGridItem Span="3"><div class="demo-grid-cell">3</div></BUIGridItem>
            <BUIGridItem Span="3"><div class="demo-grid-cell">3</div></BUIGridItem>
            <BUIGridItem Span="3"><div class="demo-grid-cell">3</div></BUIGridItem>
            <BUIGridItem Span="3"><div class="demo-grid-cell">3</div></BUIGridItem>
            <BUIGridItem Span="6"><div class="demo-grid-cell">6</div></BUIGridItem>
            <BUIGridItem Span="6"><div class="demo-grid-cell">6</div></BUIGridItem>
        </BUIGrid>
    </DocDemo>

    <section class="doc-section">
        <h2 class="doc-section__title">@Loc["Properties"]</h2>

        <h3 class="doc-section__subtitle">BUIGrid</h3>
        <PropertyTable Properties="@BUIGridComponentInfo.Parameters" />

        <h3 class="doc-section__subtitle">BUIGridItem</h3>
        <PropertyTable Properties="@BUIGridItemComponentInfo.Parameters" />
    </section>

</DocPage>
