@page "/components/treeselector"

@inject IStringLocalizer<TreeSelectorPage> Loc

<PageTitle>BlazorUI - BUITreeSelector</PageTitle>

<DocPage Eyebrow="@Loc["Component"]" Title="@Loc["BUITreeSelector"]"
         Lede="@Loc["Hierarchical selection with single/multiple modes, optional checkboxes, cascading, and declarative or data-driven trees."]"
         PageInstance="this">

    <DocDemo Key="Single" Title="@Loc["Single selection"]">
        <div class="demo-stack">
            <div>@Loc["Selected"]: <code>@string.Join(", ", _single)</code></div>
            <div class="demo-panel" style="max-width: 360px;">
                <BUITreeSelector TItem="object"
                                 SelectedKeys="_single"
                                 SelectedKeysChanged="@(k => { _single = k; StateHasChanged(); })"
                                 SelectionMode="TreeSelectionMode.Single"
                                 ShowCheckboxes="false">
                    <BUITreeSelectorItem Text="@Loc["Alpha"]" Key="alpha" />
                    <BUITreeSelectorItem Text="@Loc["Beta"]" Key="beta">
                        <ChildContent>
                            <BUITreeSelectorItem Text="@Loc["Beta 1"]" Key="beta.1" />
                            <BUITreeSelectorItem Text="@Loc["Beta 2"]" Key="beta.2" />
                        </ChildContent>
                    </BUITreeSelectorItem>
                    <BUITreeSelectorItem Text="@Loc["Gamma"]" Key="gamma" />
                </BUITreeSelector>
            </div>
        </div>
    </DocDemo>

    <DocDemo Key="Checkboxes" Title="@Loc["Multiple with checkboxes"]">
        <div class="demo-stack">
            <div>@Loc["Selected"]: <code>@string.Join(", ", _checkbox)</code></div>
            <div class="demo-panel" style="max-width: 360px;">
                <BUITreeSelector TItem="object"
                                 SelectedKeys="_checkbox"
                                 SelectedKeysChanged="@(k => { _checkbox = k; StateHasChanged(); })"
                                 SelectionMode="TreeSelectionMode.Multiple"
                                 ShowCheckboxes="true">
                    <BUITreeSelectorItem Text="@Loc["Documents"]" Key="docs">
                        <ChildContent>
                            <BUITreeSelectorItem Text="@Loc["Work"]" Key="work">
                                <ChildContent>
                                    <BUITreeSelectorItem Text="Report.pdf" Key="report" />
                                    <BUITreeSelectorItem Text="Slides.pptx" Key="slides" />
                                </ChildContent>
                            </BUITreeSelectorItem>
                            <BUITreeSelectorItem Text="@Loc["Personal"]" Key="personal">
                                <ChildContent>
                                    <BUITreeSelectorItem Text="Photo.jpg" Key="photo" />
                                </ChildContent>
                            </BUITreeSelectorItem>
                        </ChildContent>
                    </BUITreeSelectorItem>
                </BUITreeSelector>
            </div>
        </div>
    </DocDemo>

    <DocDemo Key="Expanded" Title="@Loc["Fully expanded"]">
        <div class="demo-panel" style="max-width: 360px;">
            <BUITreeSelector TItem="object"
                             SelectedKeys="_expanded"
                             SelectedKeysChanged="@(k => { _expanded = k; StateHasChanged(); })"
                             ExpandAll="true"
                             ShowCheckboxes="false">
                <BUITreeSelectorItem Text="@Loc["Level 1"]" Key="l1">
                    <ChildContent>
                        <BUITreeSelectorItem Text="@Loc["Level 2"]" Key="l2">
                            <ChildContent>
                                <BUITreeSelectorItem Text="@Loc["Level 3"]" Key="l3">
                                    <ChildContent>
                                        <BUITreeSelectorItem Text="@Loc["Level 4"]" Key="l4" />
                                    </ChildContent>
                                </BUITreeSelectorItem>
                            </ChildContent>
                        </BUITreeSelectorItem>
                    </ChildContent>
                </BUITreeSelectorItem>
            </BUITreeSelector>
        </div>
    </DocDemo>

    <DocDemo Key="Icons" Title="@Loc["With icons"]">
        <div class="demo-panel" style="max-width: 360px;">
            <BUITreeSelector TItem="object"
                             SelectedKeys="_icons"
                             SelectedKeysChanged="@(k => { _icons = k; StateHasChanged(); })"
                             SelectionMode="TreeSelectionMode.Multiple">
                <BUITreeSelectorItem Text="@Loc["Navigation"]" Key="nav" Icon="@BUIIcons.UI.Home">
                    <ChildContent>
                        <BUITreeSelectorItem Text="@Loc["Search"]" Key="search" Icon="@BUIIcons.UI.Search" />
                        <BUITreeSelectorItem Text="@Loc["Settings"]" Key="settings" Icon="@BUIIcons.UI.Settings" />
                    </ChildContent>
                </BUITreeSelectorItem>
                <BUITreeSelectorItem Text="@Loc["Messages"]" Key="mail" Icon="@BUIIcons.UI.Email" />
            </BUITreeSelector>
        </div>
    </DocDemo>

    <section class="doc-section">
        <h2 class="doc-section__title">@Loc["Properties"]</h2>

        <h3 class="doc-section__subtitle">BUITreeSelector</h3>
        <PropertyTable Properties="@BUITreeSelectorComponentInfo.Parameters" />

        <h3 class="doc-section__subtitle">BUITreeSelectorItem</h3>
        <PropertyTable Properties="@BUITreeSelectorItemComponentInfo.Parameters" />
    </section>

</DocPage>

@code {
    private HashSet<string> _single = new();
    private HashSet<string> _checkbox = new();
    private HashSet<string> _expanded = new();
    private HashSet<string> _icons = new();
}
