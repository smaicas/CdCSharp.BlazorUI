@page "/components/textarea"

@inject IStringLocalizer<TextAreaPage> Loc

<PageTitle>BlazorUI - BUIInputTextArea</PageTitle>

<DocPage Eyebrow="@Loc["Component"]" Title="@Loc["BUIInputTextArea"]"
         Lede="@Loc["Multi-line text input with auto-resize, character limits, and the full InputText API surface."]"
         PageInstance="this">

    <DocDemo Key="Basic" Title="@Loc["Basic usage"]">
        <BUIInputTextArea @bind-Value="_basic" Label="@Loc["Description"]" HelperText="@Loc["Keep it short."]" />
    </DocDemo>

    <DocDemo Key="Variants" Title="@Loc["Variants"]">
            <BUIInputTextArea @bind-Value="_outlined" Variant="BUIInputVariant.Outlined" Label="@Loc["Outlined"]" />
            <BUIInputTextArea @bind-Value="_filled" Variant="BUIInputVariant.Filled" Label="@Loc["Filled"]" />
            <BUIInputTextArea @bind-Value="_standard" Variant="BUIInputVariant.Standard" Label="@Loc["Standard"]" />
    </DocDemo>

    <DocDemo Key="Sizes" Title="@Loc["Sizes"]">
            <BUIInputTextArea @bind-Value="_small" Size="SizeEnum.Small" Label="@Loc["Small"]" />
            <BUIInputTextArea @bind-Value="_medium" Size="SizeEnum.Medium" Label="@Loc["Medium (Default)"]" />
            <BUIInputTextArea @bind-Value="_large" Size="SizeEnum.Large" Label="@Loc["Large"]" />
    </DocDemo>

    <DocDemo Key="ColorAndBackground" Title="@Loc["Color & Background"]">
        <BUIInputTextArea @bind-Value="_colorValue" Label="@Loc["Custom Color & Background"]" Color="@PaletteColor.Secondary" BackgroundColor="@PaletteColor.SecondaryContrast" />
    </DocDemo>

    <DocDemo Key="AutoResize" Title="@Loc["Auto-resize"]" Description="@Loc["Grows with its content — no scrollbar until needed."]">
        <BUIInputTextArea @bind-Value="_auto" Label="@Loc["Notes"]" AutoResize="true" Rows="2" />
    </DocDemo>

    <DocDemo Key="Rows" Title="@Loc["Rows & max length"]">
        <BUIInputTextArea @bind-Value="_rows" Label="@Loc["Bio"]" Rows="5" MaxLength="200" HelperText="@($"{_rows.Length}/200")" />
    </DocDemo>

    <DocDemo Key="Resize" Title="@Loc["Resize behavior"]">
            <BUIInputTextArea @bind-Value="_resizeNone" Label="@Loc["No resize"]" Resize="TextAreaResize.None" />
            <BUIInputTextArea @bind-Value="_resizeBoth" Label="@Loc["Both axes"]" Resize="TextAreaResize.Both" />
    </DocDemo>

    <DocDemo Key="ShadowAndBorder" Title="@Loc["Shadow"]">
        <BUIInputTextArea @bind-Value="_shadowValue" Variant="BUIInputVariant.Outlined" Label="@Loc["Elevation Shadow"]" Shadow="@BUIShadowPresets.Elevation(2)" />
        <BUIInputTextArea @bind-Value="_shadowValue" Variant="BUIInputVariant.Outlined" Label="@Loc["Custom Shadow"]" Shadow="@(ShadowStyle.Create(5, 10, 0.14f, color: "purple"))" />
    </DocDemo>

    <DocDemo Key="States" Title="@Loc["States"]">
            <BUIInputTextArea @bind-Value="_required" Label="@Loc["Required"]" Required="true" />
            <BUIInputTextArea @bind-Value="_readonly" Label="@Loc["Read-only"]" ReadOnly="true" />
            <BUIInputTextArea @bind-Value="_disabled" Label="@Loc["Disabled"]" Disabled="true" />
            <BUIInputTextArea @bind-Value="_error" Label="@Loc["Error"]" Error="true" HelperText="@Loc["Invalid content"]" />
    </DocDemo>

    <section class="doc-section">
        <h2 class="doc-section__title">@Loc["Properties"]</h2>
        <PropertyTable Properties="@BUIInputTextAreaComponentInfo.Parameters" />
    </section>

</DocPage>

@code {
    private string _basic = "";
    private string _outlined = "";
    private string _filled = "";
    private string _standard = "";
    private string _small = "";
    private string _medium = "";
    private string _large = "";
    private string _colorValue = "";
    private string _backgroundValue = "";
    private string _auto = "Type to watch me grow...";
    private string _rows = "";
    private string _resizeNone = "";
    private string _resizeBoth = "";
    private string _shadowValue = "";
    private string _pill = "";
    private string _rounded = "";
    private string _disabled = "Disabled value";
    private string _readonly = "Read-only value";
    private string _required = "";
    private string _error = "invalid content";
}
