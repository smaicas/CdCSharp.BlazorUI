@page "/components/text"

<PageTitle>InputText — CdCSharp.BlazorUI</PageTitle>

<DocPage Eyebrow="Component"
         Title="InputText"
         Lede="Single-line text input with outlined, filled, and standard variants. Prefix/suffix slots, validation, and EditForm support built in.">

    <section class="doc-section">
        <h2 class="doc-section__title">Basic usage</h2>
        <ComponentDemo Definition="@BasicDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Variants</h2>
        <p class="doc-section__description">Three visual styles for every form aesthetic.</p>
        <ComponentDemo Definition="@VariantsDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Prefix &amp; suffix</h2>
        <p class="doc-section__description">Add icons or text to either side of the input.</p>
        <ComponentDemo Definition="@PrefixSuffixDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">States</h2>
        <ComponentDemo Definition="@StatesDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Sizes</h2>
        <ComponentDemo Definition="@SizesDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Properties</h2>
        <PropertyTable Properties="@_properties" />
    </section>

</DocPage>

@code {
    private string _basic = "";
    private string _outlined = "";
    private string _filled = "";
    private string _standard = "";
    private string _url = "https://";
    private string _search = "";
    private string _domain = "";
    private string _disabled = "Disabled value";
    private string _readonly = "Read-only value";
    private string _error = "invalid@";
    private string _small = "";
    private string _medium = "";
    private string _large = "";

    private ComponentDemoDefinition BasicDemo => new()
    {
        CodeTitle = "Basic.razor",
        Code = @"<BUIInputText @bind-Value=""_value""
              Label=""Your name""
              HelperText=""As it appears on your ID."" />",
        Demo = RenderBasic()
    };

    private RenderFragment RenderBasic() => __builder =>
    {
        <BUIInputText @bind-Value="_basic" Label="Your name" HelperText="As it appears on your ID." />
    };

    private ComponentDemoDefinition VariantsDemo => new()
    {
        CodeTitle = "Variants.razor",
        Code = @"<BUIInputText Variant=""BUIInputVariant.Outlined"" Label=""Outlined"" />
<BUIInputText Variant=""BUIInputVariant.Filled""   Label=""Filled"" />
<BUIInputText Variant=""BUIInputVariant.Standard"" Label=""Standard"" />",
        Demo = RenderVariants()
    };

    private RenderFragment RenderVariants() => __builder =>
    {
        <div class="demo-stack">
            <BUIInputText @bind-Value="_outlined" Variant="BUIInputVariant.Outlined" Label="Outlined" />
            <BUIInputText @bind-Value="_filled" Variant="BUIInputVariant.Filled" Label="Filled" />
            <BUIInputText @bind-Value="_standard" Variant="BUIInputVariant.Standard" Label="Standard" />
        </div>
    };

    private ComponentDemoDefinition PrefixSuffixDemo => new()
    {
        CodeTitle = "PrefixSuffix.razor",
        Code = @"<BUIInputText Label=""Website"" PrefixText=""https://"" />
<BUIInputText Label=""Search"" PrefixIcon=""@BUIIcons.MaterialIconsOutlined.i_search"" />
<BUIInputText Label=""Domain"" SuffixText="".com"" />",
        Demo = RenderPrefixSuffix()
    };

    private RenderFragment RenderPrefixSuffix() => __builder =>
    {
        <div class="demo-stack">
            <BUIInputText @bind-Value="_url" Label="Website" PrefixText="https://" />
            <BUIInputText @bind-Value="_search" Label="Search" PrefixIcon="@BUIIcons.MaterialIconsOutlined.i_search" />
            <BUIInputText @bind-Value="_domain" Label="Domain" SuffixText=".com" />
        </div>
    };

    private ComponentDemoDefinition StatesDemo => new()
    {
        CodeTitle = "States.razor",
        Code = @"<BUIInputText Label=""Disabled""  Disabled=""true"" />
<BUIInputText Label=""Read-only"" ReadOnly=""true"" />
<BUIInputText Label=""Required""  Required=""true"" />
<BUIInputText Label=""Error""     Error=""true"" HelperText=""Invalid email"" />
<BUIInputText Label=""Loading""   Loading=""true"" />",
        Demo = RenderStates()
    };

    private RenderFragment RenderStates() => __builder =>
    {
        <div class="demo-stack">
            <BUIInputText @bind-Value="_disabled" Label="Disabled" Disabled="true" />
            <BUIInputText @bind-Value="_readonly" Label="Read-only" ReadOnly="true" />
            <BUIInputText @bind-Value="_basic" Label="Required" Required="true" />
            <BUIInputText @bind-Value="_error" Label="Error" Error="true" HelperText="Invalid email" />
            <BUIInputText @bind-Value="_basic" Label="Loading" Loading="true" />
        </div>
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        CodeTitle = "Sizes.razor",
        Code = @"<BUIInputText Size=""SizeEnum.Small""  Label=""Small"" />
<BUIInputText Size=""SizeEnum.Medium"" Label=""Medium"" />
<BUIInputText Size=""SizeEnum.Large""  Label=""Large"" />",
        Demo = RenderSizes()
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <div class="demo-stack">
            <BUIInputText @bind-Value="_small" Size="SizeEnum.Small" Label="Small" />
            <BUIInputText @bind-Value="_medium" Size="SizeEnum.Medium" Label="Medium" />
            <BUIInputText @bind-Value="_large" Size="SizeEnum.Large" Label="Large" />
        </div>
    };

    private readonly PropertyDefinition[] _properties =
    [
        new("Value", "string?", "null", "Bound value"),
        new("Label", "string?", "null", "Floating label"),
        new("Placeholder", "string?", "null", "Placeholder text"),
        new("HelperText", "string?", "null", "Helper / validation text"),
        new("Variant", "BUIInputVariant", "Outlined", "Outlined / Filled / Standard"),
        new("Size", "SizeEnum", "Medium", "Component size"),
        new("Density", "DensityEnum", "Standard", "Spacing density"),
        new("Disabled", "bool", "false", "Disabled state"),
        new("ReadOnly", "bool", "false", "Read-only state"),
        new("Required", "bool", "false", "Required marker"),
        new("Error", "bool", "false", "Validation error state"),
        new("Loading", "bool", "false", "Loading indicator"),
        new("PrefixText / PrefixIcon", "string?", "null", "Left addon"),
        new("SuffixText / SuffixIcon", "string?", "null", "Right addon"),
        new("BackgroundColor / Color", "string?", "null", "Custom colors"),
        new("UpdateOnInput", "bool", "false", "Fire value updates on every keystroke"),
        new("OnInput", "EventCallback<string>", "—", "Raw input event")
    ];
}
