@page "/components/text"

@inject IStringLocalizer<InputTextPage> Loc

<PageTitle>BlazorUI - BUIInputText</PageTitle>

<DocPage Eyebrow="@Loc["Component"]" Title="@Loc["BUIInputText"]"
         Lede="@Loc["Single-line text input with outlined, filled, and standard variants. Prefix/suffix slots, validation, and EditForm support built in."]"
         PageInstance="this">

    <DocDemo Key="Basic" Title="@Loc["Basic usage"]">
        <BUIInputText @bind-Value="_basic" Label="@Loc["Your name"]" HelperText="@Loc["As it appears on your ID."]" />
    </DocDemo>

    <DocDemo Key="Variants" Title="@Loc["Variants"]" Description="@Loc["Three visual styles for every form aesthetic."]">
            <BUIInputText @bind-Value="_outlined" Variant="BUIInputVariant.Outlined" Label="@Loc["Outlined"]" />
            <BUIInputText @bind-Value="_filled" Variant="BUIInputVariant.Filled" Label="@Loc["Filled"]" />
            <BUIInputText @bind-Value="_standard" Variant="BUIInputVariant.Standard" Label="@Loc["Standard"]" />
    </DocDemo>

    <DocDemo Key="Sizes" Title="@Loc["Sizes"]">
            <BUIInputText @bind-Value="_small" Size="SizeEnum.Small" Label="@Loc["Small"]" />
            <BUIInputText @bind-Value="_medium" Size="SizeEnum.Medium" Label="@Loc["Medium (Default)"]" />
            <BUIInputText @bind-Value="_large" Size="SizeEnum.Large" Label="@Loc["Large"]" />
    </DocDemo>

    <DocDemo Key="ColorAndBackground" Title="@Loc["Color & Background"]">
        <BUIInputText @bind-Value="_colorValue" Label="@Loc["Custom Color & Background"]" Color="@PaletteColor.Secondary" BackgroundColor="@PaletteColor.SecondaryContrast" />
    </DocDemo>

    <DocDemo Key="PrefixSuffix" Title="@Loc["Prefix & Suffix"]" Description="@Loc["Add icons or text to either side of the input."]">
            <BUIInputText @bind-Value="_url" Label="@Loc["Website"]" PrefixText="https://" />
            <BUIInputText @bind-Value="_search" Label="@Loc["Search"]" PrefixIcon="@BUIIcons.MaterialIconsOutlined.i_search" />
            <BUIInputText @bind-Value="_domain" Label="@Loc["Domain"]" SuffixText=".com" />
    </DocDemo>

    <DocDemo Key="ShadowAndBorder" Title="@Loc["Shadow"]">
        <BUIInputText @bind-Value="_shadowValue" Variant="BUIInputVariant.Outlined" Label="@Loc["Elevation Shadow"]" Shadow="@BUIShadowPresets.Elevation(2)" />
        <BUIInputText @bind-Value="_shadowValue" Variant="BUIInputVariant.Outlined" Label="@Loc["Custom Shadow"]" Shadow="@(ShadowStyle.Create(5, 10, 0.14f, color: "purple"))" />
    </DocDemo>

    <DocDemo Key="States" Title="@Loc["States"]">
            <BUIInputText @bind-Value="_disabled" Label="@Loc["Disabled"]" Disabled="true" />
            <BUIInputText @bind-Value="_readonly" Label="@Loc["Read-only"]" ReadOnly="true" />
            <BUIInputText @bind-Value="_required" Label="@Loc["Required"]" Required="true" />
            <BUIInputText @bind-Value="_error" Label="@Loc["Error"]" Error="true" HelperText="@Loc["Invalid email"]" />
            <BUIInputText @bind-Value="_loading" Label="@Loc["Loading"]" Loading="true" />
    </DocDemo>

    <section class="doc-section">
        <h2 class="doc-section__title">@Loc["Properties"]</h2>
        <PropertyTable Properties="@BUIInputTextComponentInfo.Parameters" />
    </section>

</DocPage>

@code {
    private string _basic = "";
    private string _outlined = "";
    private string _filled = "";
    private string _standard = "";
    private string _small = "";
    private string _medium = "";
    private string _large = "";
    private string _colorValue = "";
    private string _backgroundValue = "";
    private string _url = "https://";
    private string _search = "";
    private string _domain = "";
    private string _shadowValue = "";
    private string _pill = "";
    private string _rounded = "";
    private string _disabled = "Disabled value";
    private string _readonly = "Read-only value";
    private string _required = "";
    private string _error = "invalid@";
    private string _loading = "";
}
