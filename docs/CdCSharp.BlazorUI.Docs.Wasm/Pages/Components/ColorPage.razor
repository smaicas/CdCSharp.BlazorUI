@page "/components/color"

<PageTitle>Color Picker — CdCSharp.BlazorUI</PageTitle>

<DocPage Eyebrow="Component" Title="Color Picker"
         Lede="Full-featured color input with HSL/RGB/Hex output, an inline or dropdown picker, copy and revert actions.">

    <section class="doc-section">
        <h2 class="doc-section__title">Basic usage</h2>
        <ComponentDemo Definition="@BasicDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Variants</h2>
        <ComponentDemo Definition="@VariantsDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Sizes</h2>
        <ComponentDemo Definition="@SizesDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Prefix & Suffix</h2>
        <ComponentDemo Definition="@PrefixSuffixDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Output formats</h2>
        <p class="doc-section__description">Pick the serialization format that matches your back-end.</p>
        <ComponentDemo Definition="@FormatDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Display modes</h2>
        <ComponentDemo Definition="@DisplayModeDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Clearable</h2>
        <ComponentDemo Definition="@ClearCopyDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">States</h2>
        <ComponentDemo Definition="@DisabledRequiredReadonlyDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Custom Picker Size</h2>
        <ComponentDemo Definition="@CustomPickerSizeDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Standalone picker</h2>
        <p class="doc-section__description">Use <code>BUIColorPicker</code> directly — no input field, just the picker.
        </p>
        <ComponentDemo Definition="@StandaloneDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Properties</h2>
        <PropertyTable Properties="@_properties" />
    </section>

</DocPage>

@code {
    private CssColor? _basic = new("#c41236");
    private CssColor? _outlinedValue = new("#c41236");
    private CssColor? _filledValue = new("#c41236");
    private CssColor? _standardValue = new("#c41236");
    private CssColor? _smallValue;
    private CssColor? _mediumValue;
    private CssColor? _largeValue;
    private CssColor? _prefixValue;
    private CssColor? _hex = new("#2a7fff");
    private CssColor? _rgba = new("rgba(42,127,255,1)");
    private CssColor? _hsl = new("#ff6b35");
    private CssColor? _inline = new("#10b981");
    private CssColor? _clearableNull;
    private CssColor? _requiredValue;
    private CssColor? _disabledValue;
    private CssColor? _readOnlyValue;
    private CssColor? _customPickerValue;
    private CssColor _clearableNotNull = new CssColor("#FFFFFF");
    private CssColor? _standalone = new("#c41236");

    private ComponentDemoDefinition BasicDemo => new()
    {
        CodeTitle = "Basic.razor",
        Code =
        """
        <BUIInputColor @bind-Value="_basic" Label="Brand color" HelperText="Pick anything, or paste a hex/rgb value." />
        """,
        Demo = RenderBasic()
    };

    private RenderFragment RenderBasic() => __builder =>
    {
        <BUIInputColor @bind-Value="_basic" Label="Brand color" HelperText="Pick anything, or paste a hex/rgb value." />
    };

    private ComponentDemoDefinition VariantsDemo => new()
    {
        Demo = RenderVariants(),
        Code =
        """
        <BUIInputColor @bind-Value="_outlinedValue" Variant="BUIInputVariant.Outlined" Label="Outlined" />
        <BUIInputColor @bind-Value="_filledValue" Variant="BUIInputVariant.Filled" Label="Filled" />
        <BUIInputColor @bind-Value="_standardValue" Variant="BUIInputVariant.Standard" Label="Standard" />
        """
    };

    private RenderFragment RenderVariants() => __builder =>
    {
        <BUIInputColor @bind-Value="_outlinedValue" Variant="BUIInputVariant.Outlined" Label="Outlined" />
        <BUIInputColor @bind-Value="_filledValue" Variant="BUIInputVariant.Filled" Label="Filled" />
        <BUIInputColor @bind-Value="_standardValue" Variant="BUIInputVariant.Standard" Label="Standard" />
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code =
        """
        <BUIInputColor @bind-Value="_smallValue" Label="Small" Size="SizeEnum.Small" />
        <BUIInputColor @bind-Value="_mediumValue" Label="Medium (Default)" Size="SizeEnum.Medium" />
        <BUIInputColor @bind-Value="_largeValue" Label="Large" Size="SizeEnum.Large" />
        """
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <BUIInputColor @bind-Value="_smallValue" Label="Small" Size="SizeEnum.Small" />
        <BUIInputColor @bind-Value="_mediumValue" Label="Medium (Default)" Size="SizeEnum.Medium" />
        <BUIInputColor @bind-Value="_largeValue" Label="Large" Size="SizeEnum.Large" />
    };

    private ComponentDemoDefinition PrefixSuffixDemo => new()
    {
        Demo = RenderPrefixSuffix(),
        Code =
        """
        <BUIInputColor @bind-Value="_prefixValue" Label="With Prefix Icon"
                       PrefixIcon="@BUIIcons.MaterialIconsOutlined.i_palette"
                       PrefixBackgroundColor="white"
                       PrefixColor="black" />
        <BUIInputColor @bind-Value="_prefixValue" Label="With Suffix Icon"
                       SuffixIcon="@BUIIcons.MaterialIconsOutlined.i_palette"
                       SuffixBackgroundColor="white"
                       SuffixColor="black" />
        """
    };

    private RenderFragment RenderPrefixSuffix() => __builder =>
    {
        <BUIInputColor @bind-Value="_prefixValue" Label="With Prefix Icon"
                       PrefixIcon="@BUIIcons.MaterialIconsOutlined.i_palette" PrefixBackgroundColor="white" PrefixColor="black" />
        <BUIInputColor @bind-Value="_prefixValue" Label="With Prefix Icon"
                       SuffixIcon="@BUIIcons.MaterialIconsOutlined.i_palette" SuffixBackgroundColor="white" SuffixColor="black" />
    };

    private ComponentDemoDefinition FormatDemo => new()
    {
        CodeTitle = "Format.razor",
        Code =
        """
        <BUIInputColor @bind-Value="_hex" Label="HEX" OutputFormat="ColorOutputFormats.Hex" />
        <BUIInputColor @bind-Value="_hex" Label="HEX" OutputFormat="ColorOutputFormats.HexA" />
        <BUIInputColor @bind-Value="_rgba" Label="RGB" OutputFormat="ColorOutputFormats.Rgb" />
        <BUIInputColor @bind-Value="_rgba" Label="RGB" OutputFormat="ColorOutputFormats.Rgba" />
        <BUIInputColor @bind-Value="_rgba" Label="RGB" OutputFormat="ColorOutputFormats.Optimized" />
        """,
        Demo = RenderFormat()
    };

    private RenderFragment RenderFormat() => __builder =>
    {
        <BUIInputColor @bind-Value="_hex" Label="HEX" OutputFormat="ColorOutputFormats.Hex" />
        <BUIInputColor @bind-Value="_hex" Label="HEX" OutputFormat="ColorOutputFormats.HexA" />
        <BUIInputColor @bind-Value="_rgba" Label="RGB" OutputFormat="ColorOutputFormats.Rgb" />
        <BUIInputColor @bind-Value="_rgba" Label="RGB" OutputFormat="ColorOutputFormats.Rgba" />
        <BUIInputColor @bind-Value="_rgba" Label="RGB" OutputFormat="ColorOutputFormats.Optimized" />
    };

    private ComponentDemoDefinition DisplayModeDemo => new()
    {
        CodeTitle = "DisplayMode.razor",
        Code =
        """
        <BUIInputColor @bind-Value="_inline" Label="Dropdown" DisplayMode="ColorPickerDisplayMode.Dropdown" />
        <BUIInputColor @bind-Value="_inline" Label="Modal" DisplayMode="ColorPickerDisplayMode.Modal" />
        """,
        Demo = RenderDisplayMode()
    };

    private RenderFragment RenderDisplayMode() => __builder =>
    {
        <BUIInputColor @bind-Value="_inline" Label="Dropdown" DisplayMode="ColorPickerDisplayMode.Dropdown" />
        <BUIInputColor @bind-Value="_inline" Label="Modal" DisplayMode="ColorPickerDisplayMode.Modal" />
    };

    private ComponentDemoDefinition ClearCopyDemo => new()
    {
        CodeTitle = "Clear.razor",
        Code =
        """
        <BUIInputColor @bind-Value="_clearableNull" HelperText="Clear reverts to initial value (nullable)"
                       Label="Clearable Nullable" Clearable="true" ShowCopyButton="true" />
        <BUIInputColor @bind-Value="_clearableNotNull" HelperText="Clear reverts to initial value (not nullable)"
                       Label="Clearable NotNullable" Clearable="true" ShowCopyButton="true" />
        """,
        Demo = RenderClearCopy()
    };

    private RenderFragment RenderClearCopy() => __builder =>
    {
        <BUIInputColor @bind-Value="_clearableNull" HelperText="Clear reverts to initial value (nullable)"
                       Label="Clearable Nullable" Clearable="true" ShowCopyButton="true" />
        <BUIInputColor @bind-Value="_clearableNotNull" HelperText="Clear reverts to initial value (not nullable)"
                       Label="Clearable NotNullable" Clearable="true" ShowCopyButton="true" />
    };

    private ComponentDemoDefinition DisabledRequiredReadonlyDemo => new()
    {
        Demo = RenderDisabledReadOnly(),
        Code =
        """
        <BUIInputColor @bind-Value="_requiredValue" Label="Required" Required="true" HelperText="Required"/>
        <BUIInputColor @bind-Value="_disabledValue" Label="Disabled" Disabled="true" HelperText="Disabled"/>
        <BUIInputColor @bind-Value="_readOnlyValue" Label="Read Only" ReadOnly="true" HelperText="ReadOnly"/>
        """
    };

    private RenderFragment RenderDisabledReadOnly() => __builder =>
    {
        <BUIInputColor @bind-Value="_requiredValue" Label="Required" Required="true" HelperText="Required" />
        <BUIInputColor @bind-Value="_disabledValue" Label="Disabled" Disabled="true" HelperText="Disabled" />
        <BUIInputColor @bind-Value="_readOnlyValue" Label="Read Only" ReadOnly="true" HelperText="ReadOnly" />
    };

    private ComponentDemoDefinition CustomPickerSizeDemo => new()
    {
        Demo = RenderCustomPickerSize(),
        Code =
        """
        <BUIInputColor @bind-Value="_customPickerValue" Label="Custom Picker Size" SelectionWidth="300" SelectionHeight="200"
                       HelperText="Custom picker size: 300x200" />
        """
    };

    private RenderFragment RenderCustomPickerSize() => __builder =>
    {
        <BUIInputColor @bind-Value="_customPickerValue" Label="Custom Picker Size" SelectionWidth="300" SelectionHeight="200"
                       HelperText="Custom picker size: 300x200" />
    };

    private ComponentDemoDefinition StandaloneDemo => new()
    {
        CodeTitle = "Standalone.razor",
        Code =
        """
        <BUIColorPicker @bind-Value="_standalone" />
        """,
        Demo = RenderStandalone()
    };

    private RenderFragment RenderStandalone() => __builder =>
    {
        <BUIColorPicker @bind-Value="_standalone" />
    };

    private readonly PropertyDefinition[] _properties =
    [
        new("Value", "CssColor?", "null", "Bound color"),
        new("Label / Placeholder / HelperText", "string?", "null", "Descriptive text"),
        new("DisplayMode", "ColorPickerDisplayMode", "Dropdown", "Dropdown / Inline"),
        new("OutputFormat", "ColorPickerOutputFormat", "Hex", "Hex / Rgb / Rgba / Hsl / Hsla"),
        new("Clearable", "bool", "false", "Show clear button"),
        new("ShowCopyButton", "bool", "false", "Show copy-to-clipboard button"),
        new("RevertText", "string", "Revert", "Label for revert action"),
        new("SelectionWidth / SelectionHeight", "int", "200 / 150", "Picker dimensions")
    ];
}
