@page "/components/checkbox"

@inject IStringLocalizer<CheckboxPage> Loc

<PageTitle>BlazorUI - BUIInputCheckbox</PageTitle>

<DocPage Eyebrow="@Loc["Component"]" Title="@Loc["BUIInputCheckbox"]"
         Lede="@Loc["Boolean input checkbox with label, helper text, and custom icons for checked/unchecked states. Optionally tri-state"]"
         PageInstance="this">

    <DocDemo Key="Basic" Title="@Loc["Basic usage"]">
        <BUIInputCheckbox @bind-Value="_basic" Label="@Loc["Accept terms"]" HelperText="@Loc["You must accept to continue."]" />
    </DocDemo>

    <DocDemo Key="Indeterminate" Title="@Loc["Indeterminate"]">
        <BUIInputCheckbox TValue="bool?" @bind-Value="_indeterminateValue" Label="@Loc["Tristate Checkbox"]"
                          HelperText="Nullability activates tri-state" />
    </DocDemo>

    <DocDemo Key="Sizes" Title="@Loc["Sizes"]">
        <BUIInputCheckbox @bind-Value="_small" Size="BUISize.Small" Label="@Loc["Small"]" />
        <BUIInputCheckbox @bind-Value="_medium" Size="BUISize.Medium" Label="@Loc["Medium"]" />
        <BUIInputCheckbox @bind-Value="_large" Size="BUISize.Large" Label="@Loc["Large"]" />
    </DocDemo>

    <DocDemo Key="Color" Title="@Loc["Color"]">
        <BUIInputCheckbox @bind-Value="_primary" Color="@PaletteColor.Primary" Label="@Loc["Primary"]" />
        <BUIInputCheckbox @bind-Value="_success" Color="@PaletteColor.Success" Label="@Loc["Success"]" />
        <BUIInputCheckbox @bind-Value="_warning" Color="@PaletteColor.Warning" Label="@Loc["Warning"]" />
        <BUIInputCheckbox @bind-Value="_custom1" Color="#DDAAAA" Label="@Loc["CustomHEX"]" />
        <BUIInputCheckbox @bind-Value="_custom2" Color="rgb(25,45,65)" Label="@Loc["CustomRGB"]" />
    </DocDemo>

    <DocDemo Key="Density" Title="@Loc["Density"]">
        <BUIInputCheckbox @bind-Value="_compactValue" Label="@Loc["Compact"]" Density="BUIDensity.Compact" />
        <br>
        <BUIInputCheckbox @bind-Value="_standardValue" Label="@Loc["Standard"]" Density="BUIDensity.Standard" />
        <br>
        <BUIInputCheckbox @bind-Value="_comfortableValue" Label="@Loc["Comfortable"]" Density="BUIDensity.Comfortable" />
    </DocDemo>

    <DocDemo Key="Icons" Title="@Loc["Custom Icons"]">
        <BUIInputCheckbox @bind-Value="_heart" CheckedIcon="@BUIIcons.MaterialIconsOutlined.i_favorite"
                          UncheckedIcon="@BUIIcons.MaterialIconsOutlined.i_favorite_border" Color="@PaletteColor.Error" Label="Favorite" />
        <BUIInputCheckbox @bind-Value="_star" CheckedIcon="@BUIIcons.MaterialIconsOutlined.i_star"
                          UncheckedIcon="@BUIIcons.MaterialIconsOutlined.i_star_border" Color="@PaletteColor.Warning" Label="Starred" />
    </DocDemo>

    <DocDemo Key="States" Title="@Loc["States"]">
        <BUIInputCheckbox @bind-Value="_required" Required="true" Label="@Loc["Required"]" />
        <BUIInputCheckbox @bind-Value="_readonly" ReadOnly="true" Label="@Loc["ReadOnly"]" />
        <BUIInputCheckbox @bind-Value="_disabled" Disabled="true" Label="@Loc["Disabled"]" />
    </DocDemo>

    <section class="doc-section">
        <h2 class="doc-section__title">@Loc["Properties"]</h2>
        <PropertyTable Properties="@BUIInputCheckboxComponentInfo.Parameters" />
    </section>

</DocPage>

@code {
    private bool _basic = true;
    private bool _primary = true;
    private bool _success = true;
    private bool _warning = true;
    private bool _custom1 = true;
    private bool _custom2 = true;
    private bool _small = true;
    private bool _medium = true;
    private bool _large = true;
    private bool _required = true;
    private bool _readonly = true;
    private bool _disabled = true;
    private bool _heart = true;
    private bool _star = true;
    private bool _compactValue = true;
    private bool _standardValue = true;
    private bool _comfortableValue = true;
    private bool? _indeterminateValue = true;

}
