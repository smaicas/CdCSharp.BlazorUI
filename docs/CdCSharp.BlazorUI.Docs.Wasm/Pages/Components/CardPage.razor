@page "/components/card"

@inject IStringLocalizer<CardPage> Loc

<PageTitle>BlazorUI - BUICard</PageTitle>

<DocPage Eyebrow="@Loc["Component"]" Title="@Loc["BUICard"]"
         Lede="@Loc["A flexible container for content — header, media, body, and actions in a single component."]"
         PageInstance="this">

    <DocDemo Key="Basic" Title="@Loc["Basic usage"]">
        <BUICard>
            <ChildContent>
                <p>@Loc["A simple card with only body content."]</p>
            </ChildContent>
        </BUICard>
    </DocDemo>

    <DocDemo Key="HeaderActions" Title="@Loc["With header & actions"]">
        <BUICard>
            <Header><h3 style="margin: 0;">@Loc["Invoice #4213"]</h3></Header>
            <ChildContent>
                <p>@Loc["Total: $240.00 — due April 30."]</p>
            </ChildContent>
            <Actions>
                <BUIButton Text="@Loc["Decline"]" />
                <BUIButton Text="@Loc["Pay"]" BackgroundColor="@PaletteColor.Primary" Color="@PaletteColor.PrimaryContrast" />
            </Actions>
        </BUICard>
    </DocDemo>

    <DocDemo Key="Media" Title="@Loc["With media"]" Description="@Loc["Media can be placed at Top (default), AfterHeader, BeforeActions, or Bottom."]">
        <BUICard MediaHeight="160px" Border="@BUIBorderPresets.Rounded">
            <Media>
                <div style="background: linear-gradient(135deg, var(--palette-primary), var(--palette-secondary)); width: 100%; height: 100%;"></div>
            </Media>
            <Header><h3 style="margin: 0;">@Loc["Featured"]</h3></Header>
            <ChildContent>
                <p>@Loc["Media area can contain any RenderFragment — image, gradient, or video."]</p>
            </ChildContent>
        </BUICard>
    </DocDemo>

    <DocDemo Key="Clickable" Title="@Loc["Clickable"]">
        <BUICard Clickable="true" OnClick="@(() => _clicks++)">
            <Header><h3 style="margin: 0;">@Loc["Clickable card"]</h3></Header>
            <ChildContent>
                <p>@Loc["Clicked"] @_clicks @Loc["time(s)."]</p>
            </ChildContent>
        </BUICard>
    </DocDemo>

    <DocDemo Key="ActionsAlignment" Title="@Loc["Actions alignment"]">
        <BUICard ActionsAlignment="CardActionsAlignment.SpaceBetween">
            <ChildContent><p>@Loc["Space-between actions."]</p></ChildContent>
            <Actions>
                <BUIButton Text="@Loc["Cancel"]" />
                <BUIButton Text="@Loc["Confirm"]" BackgroundColor="@PaletteColor.Primary" Color="@PaletteColor.PrimaryContrast" />
            </Actions>
        </BUICard>
    </DocDemo>

    <DocDemo Key="ShadowAndBorder" Title="@Loc["Shadow & Border"]">
            <BUICard Shadow="@BUIShadowPresets.Elevation(4)" Border="@BUIBorderPresets.RoundedLarge">
                <Header><h3 style="margin: 0;">@Loc["Elevated"]</h3></Header>
                <ChildContent><p>@Loc["Shadow + border combined for a polished look."]</p></ChildContent>
            </BUICard>
            <BUICard Border="@BUIBorderPresets.Dashed">
                <Header><h3 style="margin: 0;">@Loc["Dashed"]</h3></Header>
                <ChildContent><p>@Loc["Border only, no shadow."]</p></ChildContent>
            </BUICard>
            <BUICard Shadow="@BUIShadowPresets.Elevation(2)" Border="@BUIBorderPresets.Pill">
                <ChildContent><p>@Loc["Pill shape."]</p></ChildContent>
            </BUICard>
    </DocDemo>

    <section class="doc-section">
        <h2 class="doc-section__title">@Loc["Properties"]</h2>
        <PropertyTable Properties="@BUICardComponentInfo.Parameters" />
    </section>

</DocPage>

@code {
    private int _clicks;
}
