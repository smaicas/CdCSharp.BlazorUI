@page "/components/button"

@inject IStringLocalizer<ButtonPage> Loc

<PageTitle>BlazorUI - BUIButton</PageTitle>

<DocPage Eyebrow="@Loc["Component"]" Title="@Loc["BUIButton"]"
         Lede="@Loc["The workhorse of any UI. Multiple variants, sizes, loading states, icons, and colors — all driven by parameters."]"
         PageType="typeof(ButtonPage)">

    <DocDemo Key="Basic" Title="@Loc["Basic usage"]">
        <BUIButton Text="@Loc["Click me"]" OnClick="@(() => { })" />
    </DocDemo>

    <DocDemo Key="Sizes" Title="@Loc["Sizes"]">
        <div class="demo-row">
            <BUIButton Text="@Loc["Small"]" Size="SizeEnum.Small" />
            <BUIButton Text="@Loc["Medium"]" Size="SizeEnum.Medium" />
            <BUIButton Text="@Loc["Large"]" Size="SizeEnum.Large" />
        </div>
    </DocDemo>

    <DocDemo Key="Icons" Title="@Loc["Icons"]" Description="@Loc["Icons can be placed before or after the text."]">
        <div class="demo-row">
            <BUIButton Text="@Loc["Add"]" LeadingIcon="@BUIIcons.MaterialIconsOutlined.i_add" />
            <BUIButton Text="@Loc["Next"]" TrailingIcon="@BUIIcons.MaterialIconsOutlined.i_arrow_forward" />
            <BUIButton Text="@Loc["Save"]" LeadingIcon="@BUIIcons.MaterialIconsOutlined.i_save"
                       TrailingIcon="@BUIIcons.MaterialIconsOutlined.i_check" />
        </div>
    </DocDemo>

    <DocDemo Key="Colors" Title="@Loc["Colors"]" Description="@Loc["Use semantic PaletteColor values, or any CSS color string."]">
        <div class="demo-row">
            <BUIButton Text="@Loc["Primary"]" BackgroundColor="@PaletteColor.Primary" Color="@PaletteColor.PrimaryContrast" />
            <BUIButton Text="@Loc["Success"]" BackgroundColor="@PaletteColor.Success" Color="@PaletteColor.SuccessContrast" />
            <BUIButton Text="@Loc["Warning"]" BackgroundColor="@PaletteColor.Warning" Color="@PaletteColor.WarningContrast" />
            <BUIButton Text="@Loc["Error"]" BackgroundColor="@PaletteColor.Error" Color="@PaletteColor.ErrorContrast" />
        </div>
    </DocDemo>

    <DocDemo Key="Loading" Title="@Loc["Loading state"]" Description="@Loc["While Loading is true, the button is disabled and shows an indicator."]">
        <div class="demo-row">
            <BUIButton Text="@Loc["Submitting"]" Loading="true" />
            <BUIButton Text="@Loc["Ring"]" Loading="true" LoadingIndicatorVariant="BUILoadingIndicatorVariant.Ring" />
            <BUIButton Text="@Loc["Dots"]" Loading="true" LoadingIndicatorVariant="BUILoadingIndicatorVariant.Dots" />
            <BUIButton Text="@Loc["Bars"]" Loading="true" LoadingIndicatorVariant="BUILoadingIndicatorVariant.Bars" />
        </div>
    </DocDemo>

    <DocDemo Key="Disabled" Title="@Loc["Disabled"]">
        <BUIButton Text="@Loc["Disabled"]" Disabled="true" />
    </DocDemo>

    <DocDemo Key="FullWidth" Title="@Loc["Full width"]">
        <div style="width: 100%;">
            <BUIButton Text="@Loc["Full-width button"]" FullWidth="true" />
        </div>
    </DocDemo>

    <DocDemo Key="ShadowAndBorder" Title="@Loc["Shadow & Border"]">
        <div class="demo-row">
            <BUIButton Text="@Loc["Elevated"]" Shadow="@BUIShadowPresets.Elevation(3)" />
            <BUIButton Text="@Loc["Pill"]" Border="@BUIBorderPresets.Pill" />
            <BUIButton Text="@Loc["Rounded"]" Border="@BUIBorderPresets.RoundedLarge" />
            <BUIButton Text="@Loc["Strong"]" Border="@BUIBorderPresets.Strong" />
        </div>
    </DocDemo>

    <DocDemo Key="Transitions" Title="@Loc["Transitions"]" Description="@Loc["Built-in transition presets for hover/click feedback."]">
        <div class="demo-row">
            <BUIButton Text="@Loc["Hover scale"]" Transitions="@BUITransitionPresets.HoverScale" />
            <BUIButton Text="@Loc["Hover lift"]" Transitions="@BUITransitionPresets.HoverLift" />
            <BUIButton Text="@Loc["Material"]" Transitions="@BUITransitionPresets.MaterialButton" />
        </div>
    </DocDemo>

    <section class="doc-section">
        <h2 class="doc-section__title">@Loc["Properties"]</h2>
        <PropertyTable Properties="@BUIButtonComponentInfo.Parameters" />
    </section>

</DocPage>
