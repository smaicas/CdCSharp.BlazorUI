@page "/components/datacards"

<PageTitle>DataCards — CdCSharp.BlazorUI</PageTitle>

<DocPage Eyebrow="Component"
         Title="DataCards"
         Lede="The same column-driven data pipeline as DataGrid, rendered as a responsive card grid — sorting, filtering, pagination, selection, custom templates.">

    <section class="doc-section">
        <h2 class="doc-section__title">Basic usage</h2>
        <p class="doc-section__description">Declare <code>&lt;BUIDataColumn&gt;</code> entries for the fields to surface. Cards lay out automatically via <code>MinCardWidth</code>.</p>
        <ComponentDemo Definition="@BasicDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Custom card template</h2>
        <p class="doc-section__description">Provide a <code>CardTemplate</code> to completely own the card layout per item.</p>
        <ComponentDemo Definition="@TemplateDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Filtering &amp; sorting</h2>
        <p class="doc-section__description">Enable <code>Filterable</code> and <code>Sortable</code> to get a toolbar with search and sort controls.</p>
        <ComponentDemo Definition="@FilterSortDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Selection</h2>
        <p class="doc-section__description"><code>SelectionMode.Multiple</code> adds a checkbox per card and exposes the set via <code>@@bind-SelectedItems</code>.</p>
        <ComponentDemo Definition="@SelectionDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Card styling</h2>
        <p class="doc-section__description">Use <code>CardBorder</code>, <code>CardShadow</code>, and <code>CardBackground</code> for quick tweaks without CSS.</p>
        <ComponentDemo Definition="@StyleDemo" />
    </section>

    <section class="doc-section">
        <h2 class="doc-section__title">Properties</h2>
        <PropertyTable Properties="@_properties" />
    </section>

</DocPage>

@code {
    private record Product(int Id, string Name, string Category, decimal Price, int Stock);

    private readonly List<Product> _products =
    [
        new(1, "Aurora Lamp", "Lighting", 89.00m, 12),
        new(2, "Basalt Desk", "Furniture", 349.00m, 4),
        new(3, "Cobalt Chair", "Furniture", 199.00m, 0),
        new(4, "Drift Speaker", "Audio", 129.00m, 27),
        new(5, "Ember Kettle", "Kitchen", 59.00m, 8),
        new(6, "Fjord Mug", "Kitchen", 18.00m, 60)
    ];

    private HashSet<Product> _selected = [];

    private ComponentDemoDefinition BasicDemo => new()
    {
        CodeTitle = "Basic.razor",
        Code = @"<BUIDataCards TItem=""Product"" Items=""_products"" MinCardWidth=""240px"">
    <Columns>
        <BUIDataColumn TItem=""Product"" Header=""Name""     ValueSelector=""p => p.Name"" />
        <BUIDataColumn TItem=""Product"" Header=""Category"" ValueSelector=""p => p.Category"" />
        <BUIDataColumn TItem=""Product"" Header=""Price""    ValueSelector=""p => p.Price"" Format=""C"" />
        <BUIDataColumn TItem=""Product"" Header=""Stock""    ValueSelector=""p => p.Stock"" />
    </Columns>
</BUIDataCards>",
        Demo = RenderBasic()
    };

    private RenderFragment RenderBasic() => __builder =>
    {
        <BUIDataCards TItem="Product" Items="_products" MinCardWidth="240px">
            <Columns>
                <BUIDataColumn TItem="Product" Header="Name" ValueSelector="p => p.Name" />
                <BUIDataColumn TItem="Product" Header="Category" ValueSelector="p => p.Category" />
                <BUIDataColumn TItem="Product" Header="Price" ValueSelector="p => p.Price" Format="C" />
                <BUIDataColumn TItem="Product" Header="Stock" ValueSelector="p => p.Stock" />
            </Columns>
        </BUIDataCards>
    };

    private ComponentDemoDefinition TemplateDemo => new()
    {
        CodeTitle = "Template.razor",
        Code = @"<BUIDataCards TItem=""Product"" Items=""_products"">
    <Columns>
        <BUIDataColumn TItem=""Product"" Header=""Name"" ValueSelector=""p => p.Name"" />
    </Columns>
    <CardTemplate Context=""p"">
        <div style=""padding: 1rem;"">
            <h4 style=""margin: 0 0 .25rem 0;"">@p.Name</h4>
            <span style=""color: var(--palette-surfacecontrast); opacity:.7;"">@p.Category</span>
            <div style=""margin-top: .75rem; font-weight: 600;"">@p.Price.ToString(""C"")</div>
        </div>
    </CardTemplate>
</BUIDataCards>",
        Demo = RenderTemplate()
    };

    private RenderFragment RenderTemplate() => __builder =>
    {
        <BUIDataCards TItem="Product" Items="_products" MinCardWidth="220px">
            <Columns>
                <BUIDataColumn TItem="Product" Header="Name" ValueSelector="p => p.Name" />
            </Columns>
            <CardTemplate Context="p">
                <div style="padding: 1rem;">
                    <h4 style="margin: 0 0 .25rem 0;">@p.Name</h4>
                    <span style="opacity:.7;">@p.Category</span>
                    <div style="margin-top: .75rem; font-weight: 600;">@p.Price.ToString("C")</div>
                    <div style="margin-top: .25rem; font-size: .85em; color: var(--palette-@(p.Stock == 0 ? "error" : "success"));">
                        @(p.Stock == 0 ? "Out of stock" : $"{p.Stock} in stock")
                    </div>
                </div>
            </CardTemplate>
        </BUIDataCards>
    };

    private ComponentDemoDefinition FilterSortDemo => new()
    {
        CodeTitle = "FilterSort.razor",
        Code = @"<BUIDataCards TItem=""Product"" Items=""_products""
               Filterable=""true""
               Sortable=""true""
               PageSize=""4""
               ShowPageSizeSelector=""true"">
    <Columns>
        <BUIDataColumn TItem=""Product"" Header=""Name""     ValueSelector=""p => p.Name""     Sortable=""true"" />
        <BUIDataColumn TItem=""Product"" Header=""Category"" ValueSelector=""p => p.Category"" Sortable=""true"" />
        <BUIDataColumn TItem=""Product"" Header=""Price""    ValueSelector=""p => p.Price""    Sortable=""true"" Format=""C"" />
    </Columns>
</BUIDataCards>",
        Demo = RenderFilterSort()
    };

    private RenderFragment RenderFilterSort() => __builder =>
    {
        <BUIDataCards TItem="Product" Items="_products" Filterable="true" Sortable="true" PageSize="4" MinCardWidth="220px">
            <Columns>
                <BUIDataColumn TItem="Product" Header="Name" ValueSelector="p => p.Name" Sortable="true" />
                <BUIDataColumn TItem="Product" Header="Category" ValueSelector="p => p.Category" Sortable="true" />
                <BUIDataColumn TItem="Product" Header="Price" ValueSelector="p => p.Price" Sortable="true" Format="C" />
            </Columns>
        </BUIDataCards>
    };

    private ComponentDemoDefinition SelectionDemo => new()
    {
        CodeTitle = "Selection.razor",
        Code = @"<BUIDataCards TItem=""Product""
               Items=""_products""
               SelectionMode=""SelectionMode.Multiple""
               @bind-SelectedItems=""_selected"">
    <Columns>...</Columns>
</BUIDataCards>",
        Demo = RenderSelection()
    };

    private RenderFragment RenderSelection() => __builder =>
    {
        <div>
            <BUIDataCards TItem="Product"
                          Items="_products"
                          SelectionMode="SelectionMode.Multiple"
                          @bind-SelectedItems="_selected"
                          MinCardWidth="220px">
                <Columns>
                    <BUIDataColumn TItem="Product" Header="Name" ValueSelector="p => p.Name" />
                    <BUIDataColumn TItem="Product" Header="Price" ValueSelector="p => p.Price" Format="C" />
                </Columns>
            </BUIDataCards>
            <p style="margin-top: 1rem; color: var(--palette-surfacecontrast); opacity:.7;">
                Selected: @_selected.Count item(s)
            </p>
        </div>
    };

    private ComponentDemoDefinition StyleDemo => new()
    {
        CodeTitle = "Style.razor",
        Code = @"<BUIDataCards TItem=""Product"" Items=""_products""
               CardBorder=""@BUIBorderPresets.RoundedLarge""
               CardShadow=""@BUIShadowPresets.Elevation(2)"">
    <Columns>...</Columns>
</BUIDataCards>",
        Demo = RenderStyle()
    };

    private RenderFragment RenderStyle() => __builder =>
    {
        <BUIDataCards TItem="Product" Items="_products"
                      CardBorder="@BUIBorderPresets.RoundedLarge"
                      CardShadow="@BUIShadowPresets.Elevation(2)"
                      MinCardWidth="220px">
            <Columns>
                <BUIDataColumn TItem="Product" Header="Name" ValueSelector="p => p.Name" />
                <BUIDataColumn TItem="Product" Header="Category" ValueSelector="p => p.Category" />
                <BUIDataColumn TItem="Product" Header="Price" ValueSelector="p => p.Price" Format="C" />
            </Columns>
        </BUIDataCards>
    };

    private readonly PropertyDefinition[] _properties =
    [
        new("Items", "IEnumerable<TItem>?", "null", "The data source."),
        new("Columns", "RenderFragment?", "null", "Slot for <BUIDataColumn> entries."),
        new("CardTemplate", "RenderFragment<TItem>?", "null", "Fully custom card markup (bypasses column rendering)."),
        new("CardHeaderTemplate / CardFooterTemplate", "RenderFragment<TItem>?", "null", "Per-item header / footer slots when using default layout."),
        new("MinCardWidth", "string?", "\"280px\"", "CSS min card width. Uses auto-fill grid when set."),
        new("ColumnsCount", "int", "3", "Fixed column count when MinCardWidth is null."),
        new("Gap", "string", "\"1rem\"", "Spacing between cards."),
        new("Sortable / Filterable", "bool", "false", "Enable toolbar controls."),
        new("SelectionMode", "SelectionMode", "None", "None / Single / Multiple."),
        new("SelectedItems", "HashSet<TItem>?", "null", "Two-way bindable selected set."),
        new("PageSize", "int?", "null", "Rows per page (enables pagination)."),
        new("EnableVirtualization", "bool", "false", "Virtualize card rendering (requires Height)."),
        new("CardBorder / CardShadow / CardBackground", "BorderStyle? / ShadowStyle? / string?", "null", "Per-card styling overrides."),
        new("ItemPattern", "RowStylePattern?", "null", "Alternating-row / striped pattern for cards.")
    ];
}
