@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Core.Css

<PageTitle>DataGrid - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>BUIDataGrid</h1>

    <p class="doc-intro">
        <strong>BUIDataGrid</strong> is an interactive data grid with sorting, filtering,
        pagination, selection, and virtualization support. Built on top of BUITable.
    </p>

    <!-- BASIC USAGE -->
    <section class="doc-section">
        <h2>Basic usage</h2>
        <ComponentDemo Definition="@BasicUsageDemo" />
    </section>

    <!-- SORTING -->
    <section class="doc-section">
        <h2>Sorting</h2>
        <ComponentDemo Definition="@SortingDemo" />
    </section>

    <!-- FILTERING -->
    <section class="doc-section">
        <h2>Filtering</h2>
        <ComponentDemo Definition="@FilteringDemo" />
    </section>

    <!-- PAGINATION -->
    <section class="doc-section">
        <h2>Pagination</h2>
        <ComponentDemo Definition="@PaginationDemo" />
    </section>

    <!-- SELECTION SINGLE -->
    <section class="doc-section">
        <h2>Single selection</h2>
        <ComponentDemo Definition="@SelectionSingleDemo" />
        @if (_selectedOrders.Any())
        {
            <p>Selected: <strong>@_selectedOrders.First().OrderNumber</strong></p>
        }
    </section>

    <!-- SELECTION MULTIPLE -->
    <section class="doc-section">
        <h2>Multiple selection</h2>
        <ComponentDemo Definition="@SelectionMultipleDemo" />
        @if (_selectedProducts.Any())
        {
            <p>Selected (@_selectedProducts.Count): <strong>@string.Join(", ", _selectedProducts.Select(p => p.Name))</strong></p>
        }
    </section>

    <!-- COMPLETE EXAMPLE -->
    <section class="doc-section">
        <h2>Complete example (All features)</h2>
        <ComponentDemo Definition="@CompleteDemo" />
    </section>

    <!-- CUSTOM TEMPLATES -->
    <section class="doc-section">
        <h2>Custom cell templates</h2>
        <ComponentDemo Definition="@CustomTemplatesDemo" />
    </section>

    <!-- DENSITY -->
    <section class="doc-section">
        <h2>Density</h2>
        <ComponentDemo Definition="@DensityDemo" />
    </section>

    <!-- VIRTUALIZATION -->
    <section class="doc-section">
        <h2>Virtualization (1000 rows)</h2>
        <ComponentDemo Definition="@VirtualizationDemo" />
    </section>

    <!-- PROPERTIES -->
    <section class="doc-section">
        <h2>Properties</h2>
        <PropertyTable Properties="@DataGridProperties" />
    </section>

    <!-- COLUMN PROPERTIES -->
    <section class="doc-section">
        <h2>BUIDataGridColumn Properties</h2>
        <PropertyTable Properties="@ColumnProperties" />
    </section>

    <!-- EVENTS -->
    <section class="doc-section">
        <h2>Events</h2>
        <PropertyTable Properties="@EventProperties" />
    </section>
</div>

@code {
    private HashSet<Order> _selectedOrders = new();
    private HashSet<Product> _selectedProducts = new();

    private List<Product> _products = new();
    private List<Order> _orders = new();
    private List<LogEntry> _largeDataset = new();

    protected override void OnInitialized()
    {
        GenerateProducts();
        GenerateOrders();
        GenerateLargeDataset();
    }

    /* ===================== DATA GENERATION ===================== */

    private void GenerateProducts()
    {
        _products = new List<Product>
        {
            new() { Id = 1, Name = "Laptop Pro", Price = 1299.99m, Stock = 15, Category = "Electronics", InStock = true },
            new() { Id = 2, Name = "Wireless Mouse", Price = 29.99m, Stock = 50, Category = "Accessories", InStock = true },
            new() { Id = 3, Name = "Keyboard Mechanical", Price = 89.99m, Stock = 0, Category = "Accessories", InStock = false },
            new() { Id = 4, Name = "Monitor 27\"", Price = 349.99m, Stock = 8, Category = "Electronics", InStock = true },
            new() { Id = 5, Name = "USB-C Hub", Price = 49.99m, Stock = 25, Category = "Accessories", InStock = true },
            new() { Id = 6, Name = "Webcam HD", Price = 79.99m, Stock = 12, Category = "Electronics", InStock = true },
            new() { Id = 7, Name = "Desk Mat", Price = 19.99m, Stock = 100, Category = "Accessories", InStock = true },
            new() { Id = 8, Name = "Headphones", Price = 149.99m, Stock = 20, Category = "Electronics", InStock = true },
            new() { Id = 9, Name = "Cable Organizer", Price = 14.99m, Stock = 0, Category = "Accessories", InStock = false },
            new() { Id = 10, Name = "External SSD", Price = 199.99m, Stock = 5, Category = "Storage", InStock = true },
        };
    }

    private void GenerateOrders()
    {
        _orders = new List<Order>
        {
            new() { Id = 1, OrderNumber = "ORD-2024-001", Customer = "John Doe", Total = 1299.99m, Status = "Delivered", Date = DateTime.Now.AddDays(-5) },
            new() { Id = 2, OrderNumber = "ORD-2024-002", Customer = "Jane Smith", Total = 349.99m, Status = "Processing", Date = DateTime.Now.AddDays(-3) },
            new() { Id = 3, OrderNumber = "ORD-2024-003", Customer = "Bob Johnson", Total = 89.99m, Status = "Shipped", Date = DateTime.Now.AddDays(-2) },
            new() { Id = 4, OrderNumber = "ORD-2024-004", Customer = "Alice Williams", Total = 449.98m, Status = "Delivered", Date = DateTime.Now.AddDays(-7) },
            new() { Id = 5, OrderNumber = "ORD-2024-005", Customer = "Charlie Brown", Total = 199.99m, Status = "Cancelled", Date = DateTime.Now.AddDays(-1) },
        };
    }

    private void GenerateLargeDataset()
    {
        _largeDataset = Enumerable.Range(1, 1000)
            .Select(i => new LogEntry
            {
                Id = i,
                Timestamp = DateTime.Now.AddMinutes(-i),
                Level = i % 10 == 0 ? "Error" : i % 5 == 0 ? "Warning" : "Info",
                Message = $"Log message #{i}: This is a sample log entry for testing virtualization."
            })
            .ToList();
    }

    /* ===================== DEMOS ===================== */

    private ComponentDemoDefinition BasicUsageDemo => new()
    {
        Demo = RenderBasicUsage(),
        Code = """
<BUIDataGrid Items="products" TItem="Product">
    <Columns>
        <BUIDataGridColumnTyped Property="p => p.Id"
                               TItem="Product"
                               TValue="int"
                               Header="#"
                               Width="80px" />
        <BUIDataGridColumnTyped Property="p => p.Name"
                               TItem="Product"
                               TValue="string" />
        <BUIDataGridColumnTyped Property="p => p.Price"
                               TItem="Product"
                               TValue="decimal"
                               Format="C2"
                               Align="Right" />
    </Columns>
</BUIDataGrid>
"""
    };

    private ComponentDemoDefinition SortingDemo => new()
    {
        Demo = RenderSorting(),
        Code = """
<BUIDataGrid Items="products"
             TItem="Product"
             Sortable
             DefaultSortColumn="Name"
             DefaultSortDirection="SortDirection.Ascending">
    <Columns>
        <BUIDataGridColumnTyped Property="p => p.Name"
                               TItem="Product"
                               TValue="string"
                               Sortable />
        <BUIDataGridColumnTyped Property="p => p.Price"
                               TItem="Product"
                               TValue="decimal"
                               Format="C2"
                               Sortable />
        <BUIDataGridColumnTyped Property="p => p.Category"
                               TItem="Product"
                               TValue="string"
                               Sortable />
    </Columns>
</BUIDataGrid>
"""
    };

    private ComponentDemoDefinition FilteringDemo => new()
    {
        Demo = RenderFiltering(),
        Code = """
<BUIDataGrid Items="products"
             TItem="Product"
             Filterable
             FilterPlaceholder="Search products...">
    <Columns>
        <BUIDataGridColumnTyped Property="p => p.Name"
                               TItem="Product"
                               TValue="string"
                               Filterable />
        <BUIDataGridColumnTyped Property="p => p.Category"
                               TItem="Product"
                               TValue="string"
                               Filterable />
        <BUIDataGridColumnTyped Property="p => p.Price"
                               TItem="Product"
                               TValue="decimal"
                               Format="C2" />
    </Columns>
</BUIDataGrid>
"""
    };

    private ComponentDemoDefinition PaginationDemo => new()
    {
        Demo = RenderPagination(),
        Code = """
<BUIDataGrid Items="products"
             TItem="Product"
             PageSize="5"
             PageSizeOptions="new[] { 5, 10, 20 }"
             ShowPageSizeSelector>
    <Columns>
        <BUIDataGridColumnTyped Property="p => p.Name" TItem="Product" TValue="string" />
        <BUIDataGridColumnTyped Property="p => p.Price" TItem="Product" TValue="decimal" Format="C2" />
        <BUIDataGridColumnTyped Property="p => p.Category" TItem="Product" TValue="string" />
    </Columns>
</BUIDataGrid>
"""
    };

    private ComponentDemoDefinition SelectionSingleDemo => new()
    {
        Demo = RenderSelectionSingle(),
        Code = """
<BUIDataGrid Items="orders"
             TItem="Order"
             SelectionMode="SelectionMode.Single"
             @bind-SelectedItems="selectedOrders">
    <Columns>
        <BUIDataGridColumnTyped Property="o => o.OrderNumber" TItem="Order" TValue="string" />
        <BUIDataGridColumnTyped Property="o => o.Customer" TItem="Order" TValue="string" />
        <BUIDataGridColumnTyped Property="o => o.Total" TItem="Order" TValue="decimal" Format="C2" />
    </Columns>
</BUIDataGrid>
"""
    };

    private ComponentDemoDefinition SelectionMultipleDemo => new()
    {
        Demo = RenderSelectionMultiple(),
        Code = """
<BUIDataGrid Items="products"
             TItem="Product"
             SelectionMode="SelectionMode.Multiple"
             @bind-SelectedItems="selectedProducts">
    <Columns>
        <BUIDataGridColumnTyped Property="p => p.Name" TItem="Product" TValue="string" />
        <BUIDataGridColumnTyped Property="p => p.Price" TItem="Product" TValue="decimal" Format="C2" />
        <BUIDataGridColumnTyped Property="p => p.Stock" TItem="Product" TValue="int" />
    </Columns>
</BUIDataGrid>
"""
    };

    private ComponentDemoDefinition CompleteDemo => new()
    {
        Demo = RenderComplete(),
        Code = """
<BUIDataGrid Items="orders"
             TItem="Order"
             SelectionMode="SelectionMode.Multiple"
             Sortable
             Filterable
             PageSize="3"
             Density="DensityEnum.Compact">
    <Columns>
        <BUIDataGridColumnTyped Property="o => o.OrderNumber"
                               TItem="Order"
                               TValue="string"
                               Sortable
                               Filterable />
        <BUIDataGridColumnTyped Property="o => o.Customer"
                               TItem="Order"
                               TValue="string"
                               Sortable
                               Filterable />
        <BUIDataGridColumnTyped Property="o => o.Total"
                               TItem="Order"
                               TValue="decimal"
                               Format="C2"
                               Sortable
                               Align="Right" />
        <BUIDataGridColumnTyped Property="o => o.Status"
                               TItem="Order"
                               TValue="string"
                               Filterable />
    </Columns>
</BUIDataGrid>
"""
    };

    private ComponentDemoDefinition CustomTemplatesDemo => new()
    {
        Demo = RenderCustomTemplates(),
        Code = """
<BUIDataGrid Items="orders" TItem="Order" PageSize="5">
    <Columns>
        <BUIDataGridColumnTyped Property="o => o.OrderNumber" TItem="Order" TValue="string" />
        <BUIDataGridColumnTyped Property="o => o.Customer" TItem="Order" TValue="string" />

        <BUIDataGridColumn TItem="Order" Header="Status">
            <Template Context="order">
                <BUIBadge Color="@GetStatusColor(order.Status)">
                    @order.Status
                </BUIBadge>
            </Template>
        </BUIDataGridColumn>

        <BUIDataGridColumn TItem="Order" Header="Actions">
            <Template Context="order">
                <BUIButton Text="View" Size="SizeEnum.Small" />
            </Template>
        </BUIDataGridColumn>
    </Columns>
</BUIDataGrid>
"""
    };

    private ComponentDemoDefinition DensityDemo => new()
    {
        Demo = RenderDensity(),
        Code = """
<BUIDataGrid Items="products" TItem="Product" Density="DensityEnum.Compact">
    <Columns>...</Columns>
</BUIDataGrid>
"""
    };

    private ComponentDemoDefinition VirtualizationDemo => new()
    {
        Demo = RenderVirtualization(),
        Code = """
<BUIDataGrid Items="largeDataset"
             TItem="LogEntry"
             EnableVirtualization
             Height="400px"
             Sortable
             Filterable
             Density="DensityEnum.Compact">
    <Columns>
        <BUIDataGridColumnTyped Property="l => l.Id" TItem="LogEntry" TValue="int" Width="80px" Sortable />
        <BUIDataGridColumnTyped Property="l => l.Level" TItem="LogEntry" TValue="string" Width="100px" Sortable Filterable />
        <BUIDataGridColumnTyped Property="l => l.Message" TItem="LogEntry" TValue="string" Filterable />
    </Columns>
</BUIDataGrid>
"""
    };

    /* ===================== RENDER FRAGMENTS ===================== */

    private RenderFragment RenderBasicUsage() => __builder =>
    {
        <BUIDataGrid Items="_products.Take(5)" TItem="Product">
            <Columns>
                <BUIDataGridColumnTyped Property="p => p.Id" TItem="Product" TValue="int" Header="#" Width="80px" />
                <BUIDataGridColumnTyped Property="p => p.Name" TItem="Product" TValue="string" />
                <BUIDataGridColumnTyped Property="p => p.Price" TItem="Product" TValue="decimal" Format="C2" Align="TableColumnAlign.Right" />
            </Columns>
        </BUIDataGrid>
    };

    private RenderFragment RenderSorting() => __builder =>
    {
        <BUIDataGrid Items="_products"
                     TItem="Product"
                     Sortable
                     DefaultSortColumn="Name"
                     DefaultSortDirection="SortDirection.Ascending">
            <Columns>
                <BUIDataGridColumnTyped Property="p => p.Name" TItem="Product" TValue="string" Sortable />
                <BUIDataGridColumnTyped Property="p => p.Price" TItem="Product" TValue="decimal" Format="C2" Sortable Align="TableColumnAlign.Right" />
                <BUIDataGridColumnTyped Property="p => p.Category" TItem="Product" TValue="string" Sortable />
            </Columns>
        </BUIDataGrid>
    };

    private RenderFragment RenderFiltering() => __builder =>
    {
        <BUIDataGrid Items="_products"
                     TItem="Product"
                     Filterable
                     FilterPlaceholder="Search products...">
            <Columns>
                <BUIDataGridColumnTyped Property="p => p.Name" TItem="Product" TValue="string" Filterable />
                <BUIDataGridColumnTyped Property="p => p.Category" TItem="Product" TValue="string" Filterable />
                <BUIDataGridColumnTyped Property="p => p.Price" TItem="Product" TValue="decimal" Format="C2" Align="TableColumnAlign.Right" />
            </Columns>
        </BUIDataGrid>
    };

    private RenderFragment RenderPagination() => __builder =>
    {
        <BUIDataGrid Items="_products"
                     TItem="Product"
                     PageSize="5"
                     PageSizeOptions="new[] { 5, 10, 20 }"
                     ShowPageSizeSelector>
            <Columns>
                <BUIDataGridColumnTyped Property="p => p.Name" TItem="Product" TValue="string" />
                <BUIDataGridColumnTyped Property="p => p.Price" TItem="Product" TValue="decimal" Format="C2" />
                <BUIDataGridColumnTyped Property="p => p.Category" TItem="Product" TValue="string" />
            </Columns>
        </BUIDataGrid>
    };

    private RenderFragment RenderSelectionSingle() => __builder =>
    {
        <BUIDataGrid Items="_orders"
                     TItem="Order"
                     SelectionMode="SelectionMode.Single"
                     @bind-SelectedItems="_selectedOrders">
            <Columns>
                <BUIDataGridColumnTyped Property="o => o.OrderNumber" TItem="Order" TValue="string" />
                <BUIDataGridColumnTyped Property="o => o.Customer" TItem="Order" TValue="string" />
                <BUIDataGridColumnTyped Property="o => o.Total" TItem="Order" TValue="decimal" Format="C2" />
            </Columns>
        </BUIDataGrid>
    };

    private RenderFragment RenderSelectionMultiple() => __builder =>
    {
        <BUIDataGrid Items="_products"
                     TItem="Product"
                     SelectionMode="SelectionMode.Multiple"
                     @bind-SelectedItems="_selectedProducts"
                     PageSize="5">
            <Columns>
                <BUIDataGridColumnTyped Property="p => p.Name" TItem="Product" TValue="string" />
                <BUIDataGridColumnTyped Property="p => p.Price" TItem="Product" TValue="decimal" Format="C2" />
                <BUIDataGridColumnTyped Property="p => p.Stock" TItem="Product" TValue="int" />
            </Columns>
        </BUIDataGrid>
    };

    private RenderFragment RenderComplete() => __builder =>
    {
        <BUIDataGrid Items="_orders"
                     TItem="Order"
                     SelectionMode="SelectionMode.Multiple"
                     Sortable
                     Filterable
                     PageSize="3"
                     Density="DensityEnum.Compact">
            <Columns>
                <BUIDataGridColumnTyped Property="o => o.OrderNumber" TItem="Order" TValue="string" Sortable Filterable />
                <BUIDataGridColumnTyped Property="o => o.Customer" TItem="Order" TValue="string" Sortable Filterable />
                <BUIDataGridColumnTyped Property="o => o.Total" TItem="Order" TValue="decimal" Format="C2" Sortable Align="TableColumnAlign.Right" />
                <BUIDataGridColumnTyped Property="o => o.Status" TItem="Order" TValue="string" Filterable />
            </Columns>
        </BUIDataGrid>
    };

    private RenderFragment RenderCustomTemplates() => __builder =>
    {
        <BUIDataGrid Items="_orders" TItem="Order" PageSize="5">
            <Columns>
                <BUIDataGridColumnTyped Property="o => o.OrderNumber" TItem="Order" TValue="string" />
                <BUIDataGridColumnTyped Property="o => o.Customer" TItem="Order" TValue="string" />

                <BUIDataGridColumn TItem="Order" Header="Status">
                    <Template Context="order">
                        <BUIBadge Color="@GetStatusColor(order.Status)">
                            @order.Status
                        </BUIBadge>
                    </Template>
                </BUIDataGridColumn>

                <BUIDataGridColumn TItem="Order" Header="Actions">
                    <Template Context="order">
                        <BUIButton Text="View" Size="SizeEnum.Small" />
                    </Template>
                </BUIDataGridColumn>
            </Columns>
        </BUIDataGrid>
    };

    private RenderFragment RenderDensity() => __builder =>
    {
        <BUIDataGrid Items="_products.Take(5)" TItem="Product" Density="DensityEnum.Compact">
            <Columns>
                <BUIDataGridColumnTyped Property="p => p.Name" TItem="Product" TValue="string" />
                <BUIDataGridColumnTyped Property="p => p.Price" TItem="Product" TValue="decimal" Format="C2" />
                <BUIDataGridColumnTyped Property="p => p.Stock" TItem="Product" TValue="int" />
            </Columns>
        </BUIDataGrid>
    };

    private RenderFragment RenderVirtualization() => __builder =>
    {
        <BUIDataGrid Items="_largeDataset"
                     TItem="LogEntry"
                     EnableVirtualization
                     Height="400px"
                     Sortable
                     Filterable
                     Density="DensityEnum.Compact">
            <Columns>
                <BUIDataGridColumnTyped Property="l => l.Id" TItem="LogEntry" TValue="int" Width="80px" Sortable />
                <BUIDataGridColumnTyped Property="l => l.Level" TItem="LogEntry" TValue="string" Width="100px" Sortable Filterable />
                <BUIDataGridColumnTyped Property="l => l.Message" TItem="LogEntry" TValue="string" Filterable />
            </Columns>
        </BUIDataGrid>
    };

    /* ===================== HELPERS ===================== */

    private CssColor GetStatusColor(string status) => status switch
    {
        "Delivered" => BUIColor.Palette.Success,
        "Processing" => BUIColor.Palette.Info,
        "Shipped" => BUIColor.Palette.Primary,
        "Cancelled" => BUIColor.Palette.Error,
        _ => BUIColor.Palette.Surface
    };

    /* ===================== PROPERTIES ===================== */

    private List<PropertyDefinition> DataGridProperties = new()
    {
        new("Items", "IEnumerable<TItem>?", "null", "Data items to display"),
        new("Columns", "RenderFragment?", "null", "Column definitions"),
        new("SelectionMode", "SelectionMode", "None", "Selection mode (None, Single, Multiple)"),
        new("SelectedItems", "HashSet<TItem>?", "null", "Selected items (two-way binding)"),
        new("Sortable", "bool", "false", "Enable global sorting"),
        new("DefaultSortColumn", "string?", "null", "Default sort column"),
        new("DefaultSortDirection", "SortDirection?", "null", "Default sort direction"),
        new("Filterable", "bool", "false", "Enable global filtering"),
        new("FilterPlaceholder", "string", "Search...", "Filter input placeholder"),
        new("CustomFilter", "Func<TItem, string, bool>?", "null", "Custom filter function"),
        new("PageSize", "int?", "null", "Items per page (null = no pagination)"),
        new("ShowPageSizeSelector", "bool", "true", "Show page size dropdown"),
        new("PageSizeOptions", "int[]", "[10, 20, 50, 100]", "Available page sizes"),
        new("EnableVirtualization", "bool", "false", "Enable row virtualization (requires Height)"),
        new("Density", "DensityEnum", "Standard", "Grid density"),
        new("Hoverable", "bool", "true", "Enable row hover effect"),
        new("FixedHeader", "bool", "false", "Fix header when scrolling"),
        new("Height", "string?", "null", "Grid height (required for virtualization, optional for fixed header)"),
        new("OnRowClick", "EventCallback<TItem>", "-", "Row click event"),
        new("OnSort", "EventCallback<DataGridSortEventArgs>", "-", "Sort event"),
        new("OnFilter", "EventCallback<DataGridFilterEventArgs>", "-", "Filter event"),
        new("OnPageChange", "EventCallback<DataGridPageChangeEventArgs>", "-", "Page change event"),
    };

    private List<PropertyDefinition> ColumnProperties = new()
    {
        new("Property", "Expression<Func<TItem, TValue>>?", "null", "Property selector (typed columns)"),
        new("Header", "string?", "null", "Column header"),
        new("Sortable", "bool", "false", "Enable column sorting"),
        new("Filterable", "bool", "false", "Include column in filter"),
        new("Format", "string?", "null", "Value format string"),
        new("Align", "TableColumnAlign", "Left", "Column alignment"),
        new("Width", "string?", "null", "Column width"),
        new("Template", "RenderFragment<TItem>?", "null", "Custom cell template"),
        new("CustomComparer", "Func<TItem, TItem, int>?", "null", "Custom sort comparer"),
        new("CustomFilter", "Func<TItem, string, bool>?", "null", "Custom filter function"),
    };

    private List<PropertyDefinition> EventProperties = new()
    {
        new("DataGridSortEventArgs", "", "", "ColumnName: string, Direction: SortDirection"),
        new("DataGridFilterEventArgs", "", "", "FilterText: string"),
        new("DataGridPageChangeEventArgs", "", "", "Page: int, PageSize: int"),
        new("DataGridSelectionEventArgs<TItem>", "", "", "SelectedItems: IReadOnlySet<TItem>"),
    };

    /* ===================== MODELS ===================== */

    private class Product
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public decimal Price { get; set; }
        public int Stock { get; set; }
        public string Category { get; set; } = string.Empty;
        public bool InStock { get; set; }
    }

    private class Order
    {
        public int Id { get; set; }
        public string OrderNumber { get; set; } = string.Empty;
        public string Customer { get; set; } = string.Empty;
        public decimal Total { get; set; }
        public string Status { get; set; } = string.Empty;
        public DateTime Date { get; set; }
    }

    private class LogEntry
    {
        public int Id { get; set; }
        public DateTime Timestamp { get; set; }
        public string Level { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
    }
}