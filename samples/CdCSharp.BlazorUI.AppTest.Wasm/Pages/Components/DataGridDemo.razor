                </Columns>
            </BUIDataGrid>
        </div>
    };

    private void HandleSortEvent(DataGridSortEventArgs e)
    {
        _lastSortEvent = $"Column: {e.ColumnName}, Direction: {e.Direction} at {DateTime.Now:HH:mm:ss}";
        StateHasChanged();
    }

