    private RenderFragment RenderOnSort() => __builder =>
    {
        <div>
            <p><strong>Last sort event:</strong> @_lastSortEvent</p>
            <BUIDataGrid Items="_onSortData"
                         Sortable="true"
                         OnSort="HandleSortEvent">
                <Columns>
                    <BUIDataColumn TItem="Person" Property="@(p => p.Id)" Header="ID" Sortable="true" />
                    <BUIDataColumn TItem="Person" Property="@(p => p.Name)" Header="Name" Sortable="true" />
                    <BUIDataColumn TItem="Person" Property="@(p => p.Age)" Header="Age" Sortable="true" />
                </Columns>
            </BUIDataGrid>
        </div>
    };

    private void HandleSortEvent(DataCollectionSortEventArgs e)
    {
        _lastSortEvent = $"Column: {e.ColumnName}, Direction: {e.Direction} at {DateTime.Now:HH:mm:ss}";
        StateHasChanged();
    }
    #endregion

