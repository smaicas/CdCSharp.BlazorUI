        new Person { Id = 5, Name = "Charlie Brown", Email = "charlie@example.com", Age = 42 }
    };

    private static List<Person> GenerateLargeDataset()
    {
        List<Person> data = new();
        string[] firstNames = { "John", "Jane", "Bob", "Alice", "Charlie", "Diana", "Edward", "Fiona", "George", "Hannah" };
        string[] lastNames = { "Smith", "Johnson", "Williams", "Brown", "Jones", "Garcia", "Miller", "Davis", "Martinez", "Wilson" };
        for (int i = 1; i <= 50; i++)
        {
            string firstName = firstNames[(i - 1) % firstNames.Length];
            string lastName = lastNames[(i - 1) % lastNames.Length];
            data.Add(new Person
            {
                Id = i,
                Name = $"{firstName} {lastName}",
                Email = $"{firstName.ToLower()}.{lastName.ToLower()}@example.com",
                Age = 20 + (i % 45)
            });
        }
        return data;
    }

