                <BUIGridItem><div class="demo-box">Item 2</div></BUIGridItem>
                <BUIGridItem><div class="demo-box">Item 3</div></BUIGridItem>
            </BUIGrid>

            <h3>2rem Gap</h3>
            <BUIGrid Gap="2rem">
                <BUIGridItem><div class="demo-box">Item 1</div></BUIGridItem>
                <BUIGridItem><div class="demo-box">Item 2</div></BUIGridItem>
                <BUIGridItem><div class="demo-box">Item 3</div></BUIGridItem>
            </BUIGrid>

            <h3>Custom Row/Column Gap</h3>
            <BUIGrid RowGap="2rem" ColumnGap="0.5rem">
