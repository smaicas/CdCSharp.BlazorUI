@page "/demo/grid"

<PageTitle>Grid - CdCSharp.BlazorUI</PageTitle>

<h1>BUIGrid</h1>

<h2>Basic Usage</h2>
<ComponentDemo Definition="@BasicUsageDemo" />

<h2>Custom Columns</h2>
<ComponentDemo Definition="@ColumnsDemo" />

<h2>Gap</h2>
<ComponentDemo Definition="@GapDemo" />

<h2>Direction</h2>
<ComponentDemo Definition="@DirectionDemo" />

<h2>Responsive Direction</h2>
<ComponentDemo Definition="@ResponsiveDirectionDemo" />

<h2>Justify Content</h2>
<ComponentDemo Definition="@JustifyContentDemo" />

<h2>Align Items</h2>
<ComponentDemo Definition="@AlignItemsDemo" />

<h2>Wrap</h2>
<ComponentDemo Definition="@WrapDemo" />

<h2>Max Width</h2>
<ComponentDemo Definition="@MaxWidthDemo" />

<h2>Grid Item - Span</h2>
<ComponentDemo Definition="@SpanDemo" />

<h2>Grid Item - Responsive Span</h2>
<ComponentDemo Definition="@ResponsiveSpanDemo" />

<h2>Grid Item - Auto</h2>
<ComponentDemo Definition="@AutoDemo" />

<h2>Grid Item - Order</h2>
<ComponentDemo Definition="@OrderDemo" />

<h2>Grid Item - Offset</h2>
<ComponentDemo Definition="@OffsetDemo" />

<h2>Grid Item - Align Self</h2>
