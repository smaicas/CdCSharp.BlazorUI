                <BUIGridItem Span="3"><div class="demo-box">3 cols</div></BUIGridItem>
                <BUIGridItem Span="2"><div class="demo-box">2 cols</div></BUIGridItem>
                <BUIGridItem Span="2"><div class="demo-box">2 cols</div></BUIGridItem>
                <BUIGridItem Span="2"><div class="demo-box">2 cols</div></BUIGridItem>
            </BUIGrid>
        </div>
    };

    private ComponentDemoDefinition GapDemo => new()
    {
        Demo = RenderGap(),
        Code = """ """
    };

    private RenderFragment RenderGap() => __builder =>
    {
        <div>
            <h3>No Gap</h3>
            <BUIGrid Gap="0px">
                <BUIGridItem><div class="demo-box">Item 1</div></BUIGridItem>
                <BUIGridItem><div class="demo-box">Item 2</div></BUIGridItem>
                <BUIGridItem><div class="demo-box">Item 3</div></BUIGridItem>
            </BUIGrid>

            <h3>1rem Gap</h3>
            <BUIGrid Gap="1rem">
