<h2>Grid Item - Responsive Visibility</h2>
<ComponentDemo Definition="@VisibilityDemo" />

<h2>Nested Grids</h2>
<ComponentDemo Definition="@NestedDemo" />

<h2>Grid Item - Spacing (Padding & Margin)</h2>
<ComponentDemo Definition="@SpacingDemo" />

@code {
    private ComponentDemoDefinition BasicUsageDemo => new()
    {
        Demo = RenderBasicUsage(),
        Code = """ """
    };

    private RenderFragment RenderBasicUsage() => __builder =>
    {
        <BUIGrid>
            <BUIGridItem>
                <div class="demo-box">Item 1</div>
            </BUIGridItem>
            <BUIGridItem>
                <div class="demo-box">Item 2</div>
            </BUIGridItem>
            <BUIGridItem>
                <div class="demo-box">Item 3</div>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition ColumnsDemo => new()
    {
        Demo = RenderColumns(),
        Code = """ """
    };

    private RenderFragment RenderColumns() => __builder =>
    {
        <div>
            <h3>12 Columns (Default)</h3>
            <BUIGrid Columns="12">
                <BUIGridItem Span="6"><div class="demo-box">6 cols</div></BUIGridItem>
                <BUIGridItem Span="6"><div class="demo-box">6 cols</div></BUIGridItem>
                <BUIGridItem Span="4"><div class="demo-box">4 cols</div></BUIGridItem>
                <BUIGridItem Span="4"><div class="demo-box">4 cols</div></BUIGridItem>
