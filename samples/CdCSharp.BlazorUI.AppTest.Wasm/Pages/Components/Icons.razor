@page "/components/icons"

@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Core.Css

<PageTitle>Icons - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>BUISvgIcon</h1>

    <p class="doc-intro">
        <strong>BUISvgIcon</strong> provides a flexible way to render SVG icons with
        configurable size, color, accessibility attributes and interaction support.
    </p>

    <!-- BASIC -->
    <section class="doc-section">
        <h2>Basic usage</h2>
        <ComponentDemo Definition="@BasicDemo" />
    </section>

    <!-- SIZES -->
    <section class="doc-section">
        <h2>Sizes</h2>
        <ComponentDemo Definition="@SizesDemo" />
    </section>

    <!-- COLORS -->
    <section class="doc-section">
        <h2>Colors</h2>
        <ComponentDemo Definition="@ColorsDemo" />
    </section>

    <!-- TITLE / ACCESSIBILITY -->
    <section class="doc-section">
        <h2>Accessibility (Title)</h2>
        <ComponentDemo Definition="@TitleDemo" />
    </section>

    <!-- CLICK -->
    <section class="doc-section">
        <h2>Clickable icons</h2>
        <ComponentDemo Definition="@ClickDemo" />
        <p>Clicks: @Clicks</p>
    </section>

    <!-- VIEWBOX -->
    <section class="doc-section">
        <h2>Custom ViewBox</h2>
        <ComponentDemo Definition="@ViewBoxDemo" />
    </section>

    <!-- MATERIAL ICONS -->
    <section class="doc-section">
        <h2>Material icon examples</h2>
        <ComponentDemo Definition="@MaterialIconsDemo" />
    </section>

    <!-- BRAND ICONS -->
    <section class="doc-section">
        <h2>Brand icons</h2>
        <ComponentDemo Definition="@BrandIconsDemo" />
    </section>

    <!-- PROPERTIES -->
    <section class="doc-section">
        <h2>Properties</h2>
        <PropertyTable Properties="@Properties" />
    </section>
</div>

@code {
    private int Clicks;

    /* ===================== DEMOS ===================== */

    private ComponentDemoDefinition BasicDemo => new()
    {
        Demo = RenderBasic(),
        Code = """
<BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_favorite" />
"""
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """
<BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_star" Size="SizeEnum.Small" />
<BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_star" Size="SizeEnum.Medium" />
<BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_star" Size="SizeEnum.Large" />
"""
    };

    private ComponentDemoDefinition ColorsDemo => new()
    {
        Demo = RenderColors(),
        Code = """
<BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_check" Color="BUIColor.Green.Default" />
<BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_warning" Color="BUIColor.Orange.Default" />
<BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_error" Color="BUIColor.Red.Default" />
<BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_info" Color="BUIColor.Blue.Default" />
"""
    };

    private ComponentDemoDefinition TitleDemo => new()
    {
        Demo = RenderTitle(),
        Code = """
<BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_info"
            Title="Information icon" />
"""
    };

    private ComponentDemoDefinition ClickDemo => new()
    {
        Demo = RenderClick(),
        Code = """
<BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_favorite"
            Color="BUIColor.Red.Default"
            OnClick="@OnIconClick" />
"""
    };

    private ComponentDemoDefinition ViewBoxDemo => new()
    {
        Demo = RenderViewBox(),
        Code = """
<BUISvgIcon Icon="@CustomSvg"
            ViewBox="0 0 48 48" />
"""
    };

    private ComponentDemoDefinition MaterialIconsDemo => new()
    {
        Demo = RenderMaterialIcons(),
        Code = "// See rendered example"
    };

    private ComponentDemoDefinition BrandIconsDemo => new()
    {
        Demo = RenderBrandIcons(),
        Code = "// See rendered example"
    };

    /* ===================== RENDER FRAGMENTS ===================== */

    private RenderFragment RenderBasic() => __builder =>
    {
        <BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_favorite" />
        ;
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <div class="demo-row">
            <BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_star" Size="SizeEnum.Small" />
            <BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_star" Size="SizeEnum.Medium" />
            <BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_star" Size="SizeEnum.Large" />
        </div>
        ;
    };

    private RenderFragment RenderColors() => __builder =>
    {
        <div class="demo-row">
            <BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_check" Color="BUIColor.Green.Default" />
            <BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_warning" Color="BUIColor.Orange.Default" />
            <BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_error" Color="BUIColor.Red.Default" />
            <BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_info" Color="BUIColor.Blue.Default" />
        </div>
        ;
    };

    private RenderFragment RenderTitle() => __builder =>
    {
        <BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_info"
                    Title="Information icon" />
        ;
    };

    private RenderFragment RenderClick() => __builder =>
    {
        <BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_favorite"
                    Color="BUIColor.Red.Default"
                    OnClick="@OnIconClick" />
        ;
    };

    private RenderFragment RenderViewBox() => __builder =>
    {
        <BUISvgIcon Icon="@CustomSvg"
                    ViewBox="0 0 48 48" />
        ;
    };

    private RenderFragment RenderMaterialIcons() => __builder =>
    {
        <div class="icon-grid">
            @foreach (var icon in MaterialIcons)
            {
                <div class="icon-item">
                    <BUISvgIcon Icon="@icon.Value" Size="SizeEnum.Large" />
                    <code>@icon.Name</code>
                </div>
            }
        </div>
;
    };

    private RenderFragment RenderBrandIcons() => __builder =>
    {
        <div class="icon-grid">
            @foreach (var icon in BrandIcons)
            {
                <div class="icon-item">
                    <BUISvgIcon Icon="@icon.Value" Size="SizeEnum.Large" />
                    <code>@icon.Name</code>
                </div>
            }
        </div>
;
    };

    /* ===================== DATA ===================== */

    private void OnIconClick() => Clicks++;

    private const string CustomSvg =
        "<circle cx='24' cy='24' r='20' />";

    private record IconItem(string Name, string Value);

    private List<IconItem> MaterialIcons = new()
    {
        new("Home", BUIIcons.MaterialIconsRound.i_home),
        new("Settings", BUIIcons.MaterialIconsRound.i_settings),
        new("Search", BUIIcons.MaterialIconsRound.i_search),
        new("Favorite", BUIIcons.MaterialIconsRound.i_favorite),
        new("Star", BUIIcons.MaterialIconsRound.i_star),
    };

    private List<IconItem> BrandIcons = new()
    {
        new("GitHub", BUIIcons.Brands.GitHub),
        new("Twitter", BUIIcons.Brands.Twitter),
        new("LinkedIn", BUIIcons.Brands.LinkedIn),
        new("YouTube", BUIIcons.Brands.YouTube),
    };

    /* ===================== PROPERTIES ===================== */

    private List<PropertyDefinition> Properties = new()
    {
        new("Icon", "string", "required", "SVG content of the icon"),
        new("Size", "SizeEnum", "Medium", "Icon size"),
        new("Color", "CssColor?", "null", "Icon color"),
        new("Title", "string?", "null", "Accessibility title"),
        new("ViewBox", "string", "0 0 24 24", "SVG viewBox"),
        new("OnClick", "EventCallback<MouseEventArgs>", "-", "Click handler"),
    };
}
