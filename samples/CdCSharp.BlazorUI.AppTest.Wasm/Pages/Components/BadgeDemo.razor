@page "/demo/badge"

<PageTitle>Badge - CdCSharp.BlazorUI</PageTitle>

<h1>BUIBadge</h1>

<h2>Basic Usage</h2>
<ComponentDemo Definition="@BasicDemo" />

<h2>With Icon</h2>
<ComponentDemo Definition="@IconDemo" />

<h2>Dot Badge (Empty)</h2>
<ComponentDemo Definition="@DotDemo" />

<h2>Pill Shape</h2>
<ComponentDemo Definition="@PillDemo" />

<h2>Rounded</h2>
<ComponentDemo Definition="@RoundedDemo" />

<h2>Colors</h2>
<ComponentDemo Definition="@ColorsDemo" />

<h2>Sizes</h2>
<ComponentDemo Definition="@SizesDemo" />

<h2>Shadow</h2>
<ComponentDemo Definition="@ShadowDemo" />

<h1 style="margin-top: 3rem;">BUINotificationBadge</h1>

<h2>Basic Notification</h2>
<ComponentDemo Definition="@NotificationBasicDemo" />

<h2>Badge Positions</h2>
<ComponentDemo Definition="@NotificationPositionDemo" />

<h2>Dot Notification (No Content)</h2>
<ComponentDemo Definition="@NotificationDotDemo" />

<h2>Custom Content</h2>
<ComponentDemo Definition="@NotificationCustomDemo" />

<h2>Colors on Notification</h2>
<ComponentDemo Definition="@NotificationColorsDemo" />

@code {

    [CascadingParameter] public BUIPalette Palette { get; set; } = default!;

    private ComponentDemoDefinition BasicDemo => new()
    {
        Demo = RenderBasic(),
        Code = """ """
    };

    private RenderFragment RenderBasic() => __builder =>
    {
        <BUIBadge>New</BUIBadge>
    };

    private ComponentDemoDefinition IconDemo => new()
    {
        Demo = RenderIcon(),
        Code = """ """
    };

    private RenderFragment RenderIcon() => __builder =>
    {
        <BUIBadge>
            <BUISvgIcon Icon="@BUIIcons.MaterialIconsOutlined.i_star" Size="SizeEnum.Small" />
            Featured
        </BUIBadge>
    };

    private ComponentDemoDefinition DotDemo => new()
    {
        Demo = RenderDot(),
        Code = """ """
    };

    private RenderFragment RenderDot() => __builder =>
    {
        <BUIGrid Gap="1rem" Direction="GridDirection.Row" AlignItems="GridAlignItems.Center">
            <BUIGridItem Auto="true">
                <BUIBadge />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition PillDemo => new()
    {
        Demo = RenderPill(),
        Code = """ """
    };

    private RenderFragment RenderPill() => __builder =>
    {
        <BUIBadge Border="@BUIBorderPresets.Pill">Pill Badge</BUIBadge>
    };

    private ComponentDemoDefinition RoundedDemo => new()
    {
        Demo = RenderRounded(),
        Code = """ """
    };

    private RenderFragment RenderRounded() => __builder =>
    {
        <BUIBadge Border="@BUIBorderPresets.Rounded">Rounded</BUIBadge>
    };

    private ComponentDemoDefinition ColorsDemo => new()
    {
        Demo = RenderColors(),
        Code = """ """
    };

    private RenderFragment RenderColors() => __builder =>
    {
        <BUIGrid Gap="1rem" Direction="GridDirection.Row">
            <BUIGridItem Auto="true">
                <BUIBadge BackgroundColor="@Palette.Primary"
                          Color="@Palette.PrimaryContrast">Primary</BUIBadge>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUIBadge BackgroundColor="@Palette.Error"
                          Color="@Palette.ErrorContrast">Error</BUIBadge>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUIBadge BackgroundColor="@Palette.Success"
                          Color="@Palette.SuccessContrast">Success</BUIBadge>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """ """
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <BUIGrid Gap="1rem" Direction="GridDirection.Row" AlignItems="GridAlignItems.Center">
            <BUIGridItem Auto="true">
                <BUIBadge Size="SizeEnum.Small">Small</BUIBadge>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUIBadge Size="SizeEnum.Medium">Medium</BUIBadge>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUIBadge Size="SizeEnum.Large">Large</BUIBadge>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition ShadowDemo => new()
    {
        Demo = RenderShadow(),
        Code = """ """
    };

    private RenderFragment RenderShadow() => __builder =>
    {
        <BUIGrid Gap="1rem" Direction="GridDirection.Row" AlignItems="GridAlignItems.Center">
            <BUIGridItem Auto="true">
                <BUIBadge Shadow="BUIShadowPresets.Elevation(10)">Elevation 10</BUIBadge>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUIBadge Shadow="BUIShadowPresets.Elevation(24)">Elevation 24</BUIBadge>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition NotificationBasicDemo => new()
    {
        Demo = RenderNotificationBasic(),
        Code = """ """
    };

    private RenderFragment RenderNotificationBasic() => __builder =>
    {
        <BUINotificationBadge>
            <ChildContent>
                <BUIButton OnClick="@(() => { })">Messages</BUIButton>
            </ChildContent>
            <BadgeContent>3</BadgeContent>
        </BUINotificationBadge>
    };

    private ComponentDemoDefinition NotificationPositionDemo => new()
    {
        Demo = RenderNotificationPosition(),
        Code = """ """
    };

    private RenderFragment RenderNotificationPosition() => __builder =>
    {
        <BUIGrid Gap="2rem" Direction="GridDirection.Row">
            <BUIGridItem Auto="true">
                <BUINotificationBadge Position="BadgePosition.TopRight">
                    <ChildContent>
                        <BUISvgIcon Icon="@BUIIcons.UI.Notifications" Size="SizeEnum.Large" />
                    </ChildContent>
                    <BadgeContent>5</BadgeContent>
                </BUINotificationBadge>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUINotificationBadge Position="BadgePosition.TopLeft">
                    <ChildContent>
                        <BUISvgIcon Icon="@BUIIcons.UI.Notifications" Size="SizeEnum.Large" />
                    </ChildContent>
                    <BadgeContent>5</BadgeContent>
                </BUINotificationBadge>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUINotificationBadge Position="BadgePosition.BottomRight">
                    <ChildContent>
                        <BUISvgIcon Icon="@BUIIcons.UI.Notifications" Size="SizeEnum.Large" />
                    </ChildContent>
                    <BadgeContent>5</BadgeContent>
                </BUINotificationBadge>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUINotificationBadge Position="BadgePosition.BottomLeft">
                    <ChildContent>
                        <BUISvgIcon Icon="@BUIIcons.UI.Notifications" Size="SizeEnum.Large" />
                    </ChildContent>
                    <BadgeContent>5</BadgeContent>
                </BUINotificationBadge>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUINotificationBadge Border="BorderStyle.Create().Radius(9999)" Position="BadgePosition.TopRight">
                    <ChildContent>
                        <BUISvgIcon Icon="@BUIIcons.UI.Notifications" Size="SizeEnum.Large" />
                    </ChildContent>
                    <BadgeContent>5</BadgeContent>
                </BUINotificationBadge>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUINotificationBadge Border="BorderStyle.Create().Radius(9999)" Position="BadgePosition.TopLeft">
                    <ChildContent>
                        <BUISvgIcon Icon="@BUIIcons.UI.Notifications" Size="SizeEnum.Large" />
                    </ChildContent>
                    <BadgeContent>5</BadgeContent>
                </BUINotificationBadge>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUINotificationBadge Border="BorderStyle.Create().Radius(9999)" Position="BadgePosition.BottomRight">
                    <ChildContent>
                        <BUISvgIcon Icon="@BUIIcons.UI.Notifications" Size="SizeEnum.Large" />
                    </ChildContent>
                    <BadgeContent>5</BadgeContent>
                </BUINotificationBadge>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUINotificationBadge Border="BorderStyle.Create().Radius(9999)" Position="BadgePosition.BottomLeft">
                    <ChildContent>
                        <BUISvgIcon Icon="@BUIIcons.UI.Notifications" Size="SizeEnum.Large" />
                    </ChildContent>
                    <BadgeContent>5</BadgeContent>
                </BUINotificationBadge>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition NotificationDotDemo => new()
    {
        Demo = RenderNotificationDot(),
        Code = """ """
    };

    private RenderFragment RenderNotificationDot() => __builder =>
    {
        <BUIGrid Gap="2rem" Direction="GridDirection.Row">
            <BUIGridItem Auto="true">
                <BUINotificationBadge>
                    <ChildContent>
                        <BUISvgIcon Icon="@BUIIcons.UI.Email" Size="SizeEnum.Large" />
                    </ChildContent>
                </BUINotificationBadge>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition NotificationCustomDemo => new()
    {
        Demo = RenderNotificationCustom(),
        Code = """ """
    };

    private RenderFragment RenderNotificationCustom() => __builder =>
    {
        <BUIGrid Gap="2rem" Direction="GridDirection.Row">
            <BUIGridItem Auto="true">
                <BUINotificationBadge>
                    <ChildContent>
                        <BUIButton OnClick="@(() => { })">Inbox</BUIButton>
                    </ChildContent>
                    <BadgeContent>99+</BadgeContent>
                </BUINotificationBadge>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUINotificationBadge>
                    <ChildContent>
                        <BUIButton OnClick="@(() => { })">Updates</BUIButton>
                    </ChildContent>
                    <BadgeContent>
                        <BUISvgIcon Icon="@BUIIcons.MaterialIconsOutlined.i_star" Size="SizeEnum.Small" />
                    </BadgeContent>
                </BUINotificationBadge>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition NotificationColorsDemo => new()
    {
        Demo = RenderNotificationColors(),
        Code = """ """
    };

    private RenderFragment RenderNotificationColors() => __builder =>
    {
        <BUIGrid Gap="2rem" Direction="GridDirection.Row">
            <BUIGridItem Auto="true">
                <BUINotificationBadge BackgroundColor="@Palette.Error" Color="@Palette.ErrorContrast">
                    <ChildContent>
                        <BUISvgIcon Icon="@BUIIcons.UI.Email" Size="SizeEnum.Large" />
                    </ChildContent>
                    <BadgeContent>!</BadgeContent>
                </BUINotificationBadge>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUINotificationBadge BackgroundColor="@Palette.Success" Color="@Palette.SuccessContrast">
                    <ChildContent>
                        <BUISvgIcon Icon="@BUIIcons.UI.Email" Size="SizeEnum.Large" />
                    </ChildContent>
                </BUINotificationBadge>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUINotificationBadge BackgroundColor="@Palette.Warning" Color="@Palette.WarningContrast">
                    <ChildContent>
                        <BUISvgIcon Icon="@BUIIcons.UI.Email" Size="SizeEnum.Large" />
                    </ChildContent>
                    <BadgeContent>3</BadgeContent>
                </BUINotificationBadge>
            </BUIGridItem>
        </BUIGrid>
    };
}