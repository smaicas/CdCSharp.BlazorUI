@page "/demo/cultureselector"
@using CdCSharp.BlazorUI.Components.Wasm
@using System.Globalization

<PageTitle>Culture Selector - CdCSharp.BlazorUI</PageTitle>

<h1>BUICultureSelector</h1>

<h2>Dropdown Variant</h2>
<ComponentDemo Definition="@DropdownVariantDemo" />

<h2>Flags Variant</h2>
<ComponentDemo Definition="@FlagsVariantDemo" />

<h2>Show Name Options</h2>
<ComponentDemo Definition="@ShowNameDemo" />

<h2>Current Culture Info</h2>
<ComponentDemo Definition="@CurrentCultureDemo" />

<h2>Properties</h2>
<PropertyTable Properties="@_properties" />

@code {
    private ComponentDemoDefinition DropdownVariantDemo => new()
    {
        Demo = RenderDropdownVariant(),
        Code = """ """
    };

    private RenderFragment RenderDropdownVariant() => __builder =>
    {
        <BUICultureSelector Variant="BUICultureSelectorVariant.Dropdown" />
    };

    private ComponentDemoDefinition FlagsVariantDemo => new()
    {
        Demo = RenderFlagsVariant(),
        Code = """ """
    };

    private RenderFragment RenderFlagsVariant() => __builder =>
    {
        <BUICultureSelector Variant="BUICultureSelectorVariant.Flags" />
    };

    private ComponentDemoDefinition ShowNameDemo => new()
    {
        Demo = RenderShowName(),
        Code = """ """
    };

    private RenderFragment RenderShowName() => __builder =>
    {
        <BUIGrid Gap="2rem">
            <BUIGridItem>
                <p>Flags with names:</p>
                <BUICultureSelector Variant="BUICultureSelectorVariant.Flags" ShowName="true" />
            </BUIGridItem>
            <BUIGridItem>
                <p>Flags without names:</p>
                <BUICultureSelector Variant="BUICultureSelectorVariant.Flags" ShowName="false" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition CurrentCultureDemo => new()
    {
        Demo = RenderCurrentCulture(),
        Code = """ """
    };

    private RenderFragment RenderCurrentCulture() => __builder =>
    {
        <div style="padding: 1rem; border: 1px solid var(--palette-backgroundcontrast); border-radius: 8px;">
            <p><strong>CurrentCulture:</strong> @CultureInfo.CurrentCulture.Name (@CultureInfo.CurrentCulture.DisplayName)</p>
            <p><strong>CurrentUICulture:</strong> @CultureInfo.CurrentUICulture.Name (@CultureInfo.CurrentUICulture.DisplayName)</p>
            <p><strong>Date format:</strong> @DateTime.Now.ToString("D")</p>
            <p><strong>Number format:</strong> @(1234.56.ToString("C"))</p>
        </div>
    };

    private readonly PropertyDefinition[] _properties =
    [
        new("Variant", "BUICultureSelectorVariant", "Dropdown", "Visual variant (Dropdown or Flags)"),
        new("ShowName", "bool", "true", "Show culture name next to flag")
    ];
}