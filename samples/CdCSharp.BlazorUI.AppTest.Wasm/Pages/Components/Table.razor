@page "/components/table"

@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Core.Css

<PageTitle>BUITable - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>BUITable</h1>

    <p class="doc-intro">
        <strong>BUITable</strong> is a powerful and flexible data table component
        supporting sorting, filtering, pagination, selection modes,
        responsive variants, cards layout, virtualization and custom templates.
    </p>

    <!-- BASIC -->
    <section class="doc-section">
        <h2>Basic usage</h2>
        <ComponentDemo Definition="@BasicDemo" />
    </section>

    <!-- VARIANTS -->
    <section class="doc-section">
        <h2>Variants</h2>
        <ComponentDemo Definition="@VariantsDemo" />
    </section>

    <!-- DENSITY -->
    <section class="doc-section">
        <h2>Density</h2>
        <ComponentDemo Definition="@DensityDemo" />
    </section>

    <!-- SORTING -->
    <section class="doc-section">
        <h2>Sorting</h2>
        <ComponentDemo Definition="@SortingDemo" />
    </section>

    <!-- FILTERING -->
    <section class="doc-section">
        <h2>Filtering</h2>
        <ComponentDemo Definition="@FilteringDemo" />
    </section>

    <!-- PAGINATION -->
    <section class="doc-section">
        <h2>Pagination</h2>
        <ComponentDemo Definition="@PaginationDemo" />
    </section>

    <!-- SELECTION -->
    <section class="doc-section">
        <h2>Selection</h2>
        <ComponentDemo Definition="@SelectionDemo" />
        <p>Selected: @_selected.Count</p>
    </section>

    <!-- FIXED HEADER -->
    <section class="doc-section">
        <h2>Fixed header</h2>
        <ComponentDemo Definition="@FixedHeaderDemo" />
    </section>

    <!-- VIRTUALIZATION -->
    <section class="doc-section">
        <h2>Virtualization</h2>
        <ComponentDemo Definition="@VirtualizationDemo" />
    </section>

    <!-- ROW TEMPLATE -->
    <section class="doc-section">
        <h2>Custom row template</h2>
        <ComponentDemo Definition="@RowTemplateDemo" />
    </section>

    <!-- EMPTY -->
    <section class="doc-section">
        <h2>Empty state</h2>
        <ComponentDemo Definition="@EmptyDemo" />
    </section>

    <!-- PROPERTIES -->
    <section class="doc-section">
        <h2>Properties</h2>
        <PropertyTable Properties="@Properties" />
    </section>
</div>

@code {

    /* ===================== DATA ===================== */

    private List<User> Users = Enumerable.Range(1, 50)
        .Select(i => new User
        {
            Id = i,
            Name = $"User {i}",
            Role = i % 3 == 0 ? "Admin" : "User",
            Age = 18 + (i % 30)
        })
        .ToList();

    private List<User> EmptyUsers = [];

    private HashSet<User> _selected = [];

    /* ===================== DEMOS ===================== */

    private ComponentDemoDefinition BasicDemo => new()
    {
        Demo = RenderBasic(),
        Code = """
<BUITable Items="Users">
    <BUITableColumn TItem="User" TValue="int"
                    Property="u => u.Id" />
    <BUITableColumn TItem="User" TValue="string"
                    Property="u => u.Name" />
    <BUITableColumn TItem="User" TValue="string"
                    Property="u => u.Role" />
</BUITable>
"""
    };

    private ComponentDemoDefinition VariantsDemo => new()
    {
        Demo = RenderVariants(),
        Code = """
<BUITable Items="Users" Variant="BUITableVariant.Striped" />
<BUITable Items="Users" Variant="BUITableVariant.Bordered" />
"""
    };

    private ComponentDemoDefinition DensityDemo => new()
    {
        Demo = RenderDensity(),
        Code = """
<BUITable Items="Users" Density="DensityEnum.Compact" />
"""
    };

    private ComponentDemoDefinition SortingDemo => new()
    {
        Demo = RenderSorting(),
        Code = """
<BUITable Items="Users" Sortable>
    <BUITableColumn Property="u => u.Id" Sortable />
    <BUITableColumn Property="u => u.Name" Sortable />
</BUITable>
"""
    };

    private ComponentDemoDefinition FilteringDemo => new()
    {
        Demo = RenderFiltering(),
        Code = """
<BUITable Items="Users" Filterable />
"""
    };

    private ComponentDemoDefinition PaginationDemo => new()
    {
        Demo = RenderPagination(),
        Code = """
<BUITable Items="Users" Pageable PageSize="10" />
"""
    };

    private ComponentDemoDefinition SelectionDemo => new()
    {
        Demo = RenderSelection(),
        Code = """
<BUITable Items="Users"
          SelectionMode="SelectionMode.Multiple"
          SelectedItems="@_selected"
          SelectedItemsChanged="@OnSelectedChanged" />
"""
    };

    private ComponentDemoDefinition FixedHeaderDemo => new()
    {
        Demo = RenderFixedHeader(),
        Code = """
<BUITable Items="Users"
          FixedHeader
          Height="300px" />
"""
    };

    private ComponentDemoDefinition VirtualizationDemo => new()
    {
        Demo = RenderVirtualization(),
        Code = """
<BUITable Items="Users"
          EnableVirtualization
          Height="300px" />
"""
    };

    private ComponentDemoDefinition RowTemplateDemo => new()
    {
        Demo = RenderRowTemplate(),
        Code = """
<BUITable Items="Users">
    <BUITableColumn Header="User">
        <Template Context="u">
            <strong>@u.Name</strong>
        </Template>
    </BUITableColumn>
</BUITable>
"""
    };

    private ComponentDemoDefinition EmptyDemo => new()
    {
        Demo = RenderEmpty(),
        Code = """
<BUITable Items="EmptyUsers" />
"""
    };

    /* ===================== RENDER FRAGMENTS ===================== */

    private RenderFragment RenderBasic() => __builder =>
    {
        <BUITable Items="Users">
            <BUITableColumn TItem="User" TValue="int" Property="u => u.Id" />
            <BUITableColumn TItem="User" TValue="string" Property="u => u.Name" />
            <BUITableColumn TItem="User" TValue="string" Property="u => u.Role" />
        </BUITable>;
    };

    private RenderFragment RenderVariants() => __builder =>
    {
        <div class="demo-column">
            <BUITable Items="Users" Variant="BUITableVariant.Striped" />
            <BUITable Items="Users" Variant="BUITableVariant.Bordered" />
        </div>;
    };

    private RenderFragment RenderDensity() => __builder =>
    {
        <BUITable Items="Users" Density="DensityEnum.Compact" />;
    };

    private RenderFragment RenderSorting() => __builder =>
    {
        <BUITable Items="Users" Sortable>
            <BUITableColumn TItem="User" TValue="int" Property="u => u.Id" Sortable />
            <BUITableColumn TItem="User" TValue="string"  Property="u => u.Name" Sortable />
            <BUITableColumn TItem="User" TValue="int" Property="u => u.Age" Sortable />
        </BUITable>;
    };

    private RenderFragment RenderFiltering() => __builder =>
    {
        <BUITable Items="Users" Filterable />;
    };

    private RenderFragment RenderPagination() => __builder =>
    {
        <BUITable Items="Users" Pageable PageSize="10" />;
    };

    private RenderFragment RenderSelection() => __builder =>
    {
        <BUITable Items="Users"
                  SelectionMode="SelectionMode.Multiple"
                  SelectedItems="@_selected"
                  SelectedItemsChanged="@((HashSet<User> items) => OnSelectedChanged(items))" />;
    };

    private RenderFragment RenderFixedHeader() => __builder =>
    {
        <BUITable Items="Users"
                  FixedHeader
                  Height="300px" />;
    };

    private RenderFragment RenderVirtualization() => __builder =>
    {
        <BUITable Items="Users"
                  EnableVirtualization
                  Height="300px" />;
    };

    private RenderFragment RenderRowTemplate() => __builder =>
    {
        <BUITable Items="Users">
            <BUITableColumn Header="User" TItem="User" TValue="User">
                <Template Context="u">
                    <strong>@u.Name</strong> (@u.Role)
                </Template>
            </BUITableColumn>
        </BUITable>;
    };

    private RenderFragment RenderEmpty() => __builder =>
    {
        <BUITable Items="EmptyUsers" />;
    };

    /* ===================== EVENTS ===================== */

    private void OnSelectedChanged(HashSet<User> items)
    {
        _selected = items;
    }

    /* ===================== PROPERTIES ===================== */

    private List<PropertyDefinition> Properties = new()
    {
        new("Items", "IEnumerable<TItem>", "-", "Items source"),
        new("Variant", "BUITableVariant?", "Default", "Table visual variant"),
        new("Density", "DensityEnum", "Standard", "Row density"),
        new("Sortable", "bool", "false", "Enable sorting"),
        new("Filterable", "bool", "false", "Enable filtering"),
        new("Pageable", "bool", "false", "Enable pagination"),
        new("PageSize", "int", "20", "Rows per page"),
        new("SelectionMode", "SelectionMode", "None", "Row selection mode"),
        new("FixedHeader", "bool", "false", "Sticky header"),
        new("Height", "string?", "null", "Scrollable height"),
        new("EnableVirtualization", "bool", "false", "Virtualize rows"),
        new("HeaderTemplate", "RenderFragment?", "null", "Custom header"),
        new("RowTemplate", "RenderFragment<TItem>?", "null", "Custom row"),
        new("EmptyContent", "RenderFragment?", "null", "Empty content"),
    };

    /* ===================== MODEL ===================== */

    private sealed class User
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Role { get; set; } = "";
        public int Age { get; set; }
    }
}
