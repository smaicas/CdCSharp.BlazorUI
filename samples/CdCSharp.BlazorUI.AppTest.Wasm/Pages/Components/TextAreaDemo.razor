@page "/demo/textarea"

<PageTitle>TextArea - CdCSharp.BlazorUI</PageTitle>

<h1>BUIInputTextArea</h1>

<h2>Basic Usage</h2>
<ComponentDemo Definition="@BasicUsageDemo" />

<h2>With Label</h2>
<ComponentDemo Definition="@WithLabelDemo" />

<h2>Custom Rows</h2>
<ComponentDemo Definition="@RowsDemo" />

<h2>Max Length</h2>
<ComponentDemo Definition="@MaxLengthDemo" />

<h2>Auto Resize</h2>
<ComponentDemo Definition="@AutoResizeDemo" />

<h2>Resize Options</h2>
<ComponentDemo Definition="@ResizeDemo" />

<h2>Variants</h2>
<ComponentDemo Definition="@VariantsDemo" />

<h2>Sizes</h2>
<ComponentDemo Definition="@SizesDemo" />

<h2>Disabled</h2>
<ComponentDemo Definition="@DisabledDemo" />

<h2>ReadOnly</h2>
<ComponentDemo Definition="@ReadOnlyDemo" />

@code {
    private string _basicValue = "";
    private string _labelValue = "";
    private string _rowsValue = "";
    private string _maxLengthValue = "";
    private string _autoResizeValue = "";
    private string _noneResize = "";
    private string _bothResize = "";
    private string _verticalResize = "";
    private string _horizontalResize = "";
    private string _outlinedValue = "";
    private string _filledValue = "";
    private string _standardValue = "";
    private string _smallValue = "";
    private string _mediumValue = "";
    private string _largeValue = "";
    private string _disabledValue = "Disabled content";
    private string _readOnlyValue = "Read-only content";

    private ComponentDemoDefinition BasicUsageDemo => new()
    {
        Demo = RenderBasicUsage(),
        Code = """ """
    };

    private RenderFragment RenderBasicUsage() => __builder =>
    {
        <BUIInputTextArea @bind-Value="_basicValue" />
    };

    private ComponentDemoDefinition WithLabelDemo => new()
    {
        Demo = RenderWithLabel(),
        Code = """ """
    };

    private RenderFragment RenderWithLabel() => __builder =>
    {
        <BUIInputTextArea @bind-Value="_labelValue"
                          Label="Description"
                          Placeholder="Enter your description..."
                          HelperText="Please provide detailed information" />
    };

    private ComponentDemoDefinition RowsDemo => new()
    {
        Demo = RenderRows(),
        Code = """ """
    };

    private RenderFragment RenderRows() => __builder =>
    {
        <BUIInputTextArea @bind-Value="_rowsValue"
                          Label="Custom Rows (10)"
                          Rows="10" />
    };

    private ComponentDemoDefinition MaxLengthDemo => new()
    {
        Demo = RenderMaxLength(),
        Code = """ """
    };

    private RenderFragment RenderMaxLength() => __builder =>
    {
        <BUIInputTextArea @bind-Value="_maxLengthValue"
                          Label="Max Length (200)"
                          MaxLength="200"
                          HelperText="Maximum 200 characters" />
    };

    private ComponentDemoDefinition AutoResizeDemo => new()
    {
        Demo = RenderAutoResize(),
        Code = """ """
    };

    private RenderFragment RenderAutoResize() => __builder =>
    {
        <BUIInputTextArea @bind-Value="_autoResizeValue"
                          Label="Auto Resize"
                          AutoResize="true"
                          Placeholder="This textarea will grow as you type..." />
    };

    private ComponentDemoDefinition ResizeDemo => new()
    {
        Demo = RenderResize(),
        Code = """ """
    };

    private RenderFragment RenderResize() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUIInputTextArea @bind-Value="_noneResize"
                                  Label="None (Default)"
                                  Resize="TextAreaResize.None" />
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputTextArea @bind-Value="_bothResize"
                                  Label="Both"
                                  Resize="TextAreaResize.Both" />
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputTextArea @bind-Value="_verticalResize"
                                  Label="Vertical"
                                  Resize="TextAreaResize.Vertical" />
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputTextArea @bind-Value="_horizontalResize"
                                  Label="Horizontal"
                                  Resize="TextAreaResize.Horizontal" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition VariantsDemo => new()
    {
        Demo = RenderVariants(),
        Code = """ """
    };

    private RenderFragment RenderVariants() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUIInputTextArea @bind-Value="_outlinedValue"
                                  Label="Outlined"
                                  Variant="BUIInputVariant.Outlined" />
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputTextArea @bind-Value="_filledValue"
                                  Label="Filled"
                                  Variant="BUIInputVariant.Filled" />
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputTextArea @bind-Value="_standardValue"
                                  Label="Standard"
                                  Variant="BUIInputVariant.Standard" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """ """
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUIInputTextArea @bind-Value="_smallValue" Label="Small" Size="BUISize.Small" />
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputTextArea @bind-Value="_mediumValue" Label="Medium (Default)" Size="BUISize.Medium" />
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputTextArea @bind-Value="_largeValue" Label="Large" Size="BUISize.Large" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition DisabledDemo => new()
    {
        Demo = RenderDisabled(),
        Code = """ """
    };

    private RenderFragment RenderDisabled() => __builder =>
    {
        <BUIInputTextArea @bind-Value="_disabledValue" Label="Disabled" Disabled="true" />
    };

    private ComponentDemoDefinition ReadOnlyDemo => new()
    {
        Demo = RenderReadOnly(),
        Code = """ """
    };

    private RenderFragment RenderReadOnly() => __builder =>
    {
        <BUIInputTextArea @bind-Value="_readOnlyValue" Label="ReadOnly" ReadOnly="true" />
    };
}