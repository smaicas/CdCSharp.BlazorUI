@page "/demo/genericswitch"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared

<PageTitle>Generic Switch - CdCSharp.BlazorUI</PageTitle>

<h1>BUISwitch (Generic)</h1>

<h2>Basic Usage - Boolean</h2>
<ComponentDemo Definition="@BasicUsageDemo" />

<h2>String Options</h2>
<ComponentDemo Definition="@StringOptionsDemo" />

<h2>With Label</h2>
<ComponentDemo Definition="@WithLabelDemo" />

<h2>Sizes</h2>
<ComponentDemo Definition="@SizesDemo" />

<h2>Density</h2>
<ComponentDemo Definition="@DensityDemo" />

<h2>With Icons</h2>
<ComponentDemo Definition="@IconsDemo" />

<h2>Custom Colors</h2>
<ComponentDemo Definition="@ColorsDemo" />

<h2>Disabled</h2>
<ComponentDemo Definition="@DisabledDemo" />

<h2>Properties</h2>
<PropertyTable Properties="@_properties" />

@code {
    private bool _basicValue = false;
    private string? _stringValue = "option1";
    private bool _labelValue = true;
    private bool _smallValue = false;
    private bool _mediumValue = true;
    private bool _largeValue = false;
    private bool _compactValue = false;
    private bool _standardValue = true;
    private bool _comfortableValue = false;
    private bool _iconsValue = true;
    private bool _colorsValue = true;
    private bool _disabledValue = true;

    private ComponentDemoDefinition BasicUsageDemo => new()
    {
        Demo = RenderBasicUsage(),
        Code = """ """
    };

    private RenderFragment RenderBasicUsage() => __builder =>
    {
        <BUISwitch @bind-Value="_basicValue" OptionInactive="true" OptionActive="false" />
    };

    private ComponentDemoDefinition StringOptionsDemo => new()
    {
        Demo = RenderStringOptions(),
        Code = """ """
    };

    private RenderFragment RenderStringOptions() => __builder =>
    {
        <div>
            <BUISwitch @bind-Value="_stringValue" OptionInactive="@("option1")" OptionActive="@("option2")" />
            <p>Current value: @_stringValue</p>
        </div>
    };

    private ComponentDemoDefinition WithLabelDemo => new()
    {
        Demo = RenderWithLabel(),
        Code = """ """
    };

    private RenderFragment RenderWithLabel() => __builder =>
    {
        <BUISwitch @bind-Value="_labelValue" OptionInactive="true" OptionActive="false" Label="Enable feature" />
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """ """
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUISwitch @bind-Value="_smallValue" OptionInactive="true" OptionActive="false" Label="Small" Size="SizeEnum.Small" />
            </BUIGridItem>
            <BUIGridItem>
                <BUISwitch @bind-Value="_mediumValue" OptionInactive="true" OptionActive="false" Label="Medium (Default)" Size="SizeEnum.Medium" />
            </BUIGridItem>
            <BUIGridItem>
                <BUISwitch @bind-Value="_largeValue" OptionInactive="true" OptionActive="false" Label="Large" Size="SizeEnum.Large" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition DensityDemo => new()
    {
        Demo = RenderDensity(),
        Code = """ """
    };

    private RenderFragment RenderDensity() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUISwitch @bind-Value="_compactValue" OptionInactive="true" OptionActive="false" Label="Compact" Density="DensityEnum.Compact" />
            </BUIGridItem>
            <BUIGridItem>
                <BUISwitch @bind-Value="_standardValue" OptionInactive="true" OptionActive="false" Label="Standard (Default)" Density="DensityEnum.Standard" />
            </BUIGridItem>
            <BUIGridItem>
                <BUISwitch @bind-Value="_comfortableValue" OptionInactive="true" OptionActive="false" Label="Comfortable" Density="DensityEnum.Comfortable" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition IconsDemo => new()
    {
        Demo = RenderIcons(),
        Code = """ """
    };

    private RenderFragment RenderIcons() => __builder =>
    {
        <BUISwitch @bind-Value="_iconsValue"
                   Label="Dark Mode"
                   OptionInactive="true"
                   OptionActive="false"
                   IconInactive="@BUIIcons.MaterialIconsRound.i_light_mode"
                   IconActive="@BUIIcons.MaterialIconsRound.i_dark_mode" />
    };

    private ComponentDemoDefinition ColorsDemo => new()
    {
        Demo = RenderColors(),
        Code = """ """
    };

    private RenderFragment RenderColors() => __builder =>
    {
        <BUISwitch @bind-Value="_colorsValue"
                   Label="Custom Colors"
                   OptionInactive="true"
                   OptionActive="false"
                   TrackColorInactive="BUIColor.Palette.Error"
                   TrackColorActive="BUIColor.Palette.Success" />
    };

    private ComponentDemoDefinition DisabledDemo => new()
    {
        Demo = RenderDisabled(),
        Code = """ """
    };

    private RenderFragment RenderDisabled() => __builder =>
    {
        <BUISwitch @bind-Value="_disabledValue" OptionInactive="true" OptionActive="false" Label="Disabled switch" IsDisabled="true" />
    };

    private readonly PropertyDefinition[] _properties =
    [
            new("Value", "TValue", "-", "Current value"),
            new("OptionInactive", "TValue", "-", "Value when inactive"),
            new("OptionActive", "TValue", "-", "Value when active"),
            new("Label", "string?", "null", "Label text"),
            new("HelperText", "string?", "null", "Helper text"),
            new("Size", "SizeEnum", "Medium", "Component size"),
            new("Density", "DensityEnum", "Standard", "Spacing density"),
            new("IsDisabled", "bool", "false", "Disable switch"),
            new("IconInactive", "string?", "null", "Icon when inactive"),
            new("IconActive", "string?", "null", "Icon when active"),
            new("TrackColorInactive", "CssColor?", "null", "Track color when inactive"),
            new("TrackColorActive", "CssColor?", "null", "Track color when active")
    ];
}