@page "/components/buttons"

@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Core.Css
@using CdCSharp.BlazorUI.AppTest.Wasm.Pages.Components
@using Microsoft.AspNetCore.Components

<PageTitle>Buttons - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>@BUIButtonDoc.Definition.Name</h1>

    <p class="doc-intro">
        <strong>@BUIButtonDoc.Definition.Name</strong> is a highly customizable button component supporting
        icons, loading states, ripple effects, elevation, transitions, colors,
        borders, density, sizes and more.
    </p>

    @* Iterar automáticamente sobre los demos generados *@
    @foreach (var demo in BUIButtonDoc.Definition.Demos)
    {
        <section class="doc-section">
            <h2>@demo.Code.Split('\n')[0] ...</h2> @* opcional: tomar la primera línea del código como título *@
            <ComponentDemo Definition="demo" />
        </section>
    }

    @* Mostrar propiedades automáticamente *@
    <section class="doc-section">
        <h2>Properties</h2>
        <PropertyTable Properties="BUIButtonDoc.Definition.Parameters"
                       Descriptions="@(new Dictionary<string, string>()
                                                  {
                                              { " Text", "Button text" },
                                              { "LeadingIcon" , "Icon before text" },
                                              { "TrailingIcon" , "Icon after text" },
                                              { "Disabled" , "Disable the button" },
                                              { "Size" , "Button size" },
                                              { "Density" , "Button density" },
                                              { "FullWidth" , "Takes full width" },
                                              { "IsLoading" , "Loading state" },
                                              { "LoadingIndicatorVariant" , "Loading indicator type" },
                                              { "Elevation" , "Elevation level" },
                                              { "ElevationColor" , "Elevation shadow color" },
                                              { "DisableRipple" , "Disable ripple effect" },
                                              { "RippleColor" , "Ripple color" },
                                              { "RippleDuration" , "Ripple duration (ms)" },
                                              { "Border" , "Border style" },
                                              { "BackgroundColor" , "Background color" },
                                              { "Color" , "Text and icon color" }
                                              })" />
    </section>
</div>