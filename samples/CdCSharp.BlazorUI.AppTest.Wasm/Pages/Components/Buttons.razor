@page "/components/buttons"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared

<PageTitle>Buttons - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>Buttons</h1>
    <p class="doc-intro">
        The BUIButton component is a versatile button with support for loading states, icons,
        ripple effects, elevation, transitions, borders, and more.
    </p>

    <div class="doc-section">
        <h2>Basic Usage</h2>
        <ComponentDemo Code="@basicUsageCode">
            <Demo>
                <BUIButton Text="Click Me" OnClick="@(() => Console.WriteLine("Clicked!"))" />
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Sizes</h2>
        <ComponentDemo Code="@sizesCode">
            <Demo>
                <div class="demo-row">
                    <BUIButton Text="Small" Size="SizeEnum.Small" />
                    <BUIButton Text="Medium" Size="SizeEnum.Medium" />
                    <BUIButton Text="Large" Size="SizeEnum.Large" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Loading States</h2>
        <ComponentDemo Code="@loadingCode">
            <Demo>
                <div class="demo-row">
                    <BUIButton Text="Loading Spinner" IsLoading="true" LoadingIndicatorVariant="BUILoadingIndicatorVariant.Spinner" />
                    <BUIButton Text="Loading Dots" IsLoading="true" LoadingIndicatorVariant="BUILoadingIndicatorVariant.Dots" />
                    <BUIButton Text="Loading Pulse" IsLoading="true" LoadingIndicatorVariant="BUILoadingIndicatorVariant.Pulse" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Icons</h2>
        <ComponentDemo Code="@iconsCode">
            <Demo>
                <div class="demo-row">
                    <BUIButton Text="Save" LeadingIcon="@BUIIcons.MaterialIconsRound.i_save" />
                    <BUIButton Text="Delete" TrailingIcon="@BUIIcons.MaterialIconsRound.i_delete" />
                    <BUIButton Text="Edit" LeadingIcon="@BUIIcons.MaterialIconsRound.i_edit" TrailingIcon="@BUIIcons.MaterialIconsRound.i_chevron_right" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Elevation</h2>
        <ComponentDemo Code="@elevationCode">
            <Demo>
                <div class="demo-row">
                    <BUIButton Text="No Elevation" Elevation="0" />
                    <BUIButton Text="Low" Elevation="2" />
                    <BUIButton Text="Medium" Elevation="4" />
                    <BUIButton Text="High" Elevation="8" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Borders</h2>
        <ComponentDemo Code="@bordersCode">
            <Demo>
                <div class="demo-row">
                    <BUIButton Text="Default Border" Border="@BUIBorderPresets.Default" />
                    <BUIButton Text="Primary Border" Border="@BUIBorderPresets.Primary" />
                    <BUIButton Text="Rounded" Border="@BUIBorderPresets.Rounded" />
                    <BUIButton Text="Pill" Border="@BUIBorderPresets.Pill" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Density</h2>
        <ComponentDemo Code="@densityCode">
            <Demo>
                <div class="demo-row">
                    <BUIButton Text="Comfortable" Density="DensityEnum.Comfortable" />
                    <BUIButton Text="Standard" Density="DensityEnum.Standard" />
                    <BUIButton Text="Compact" Density="DensityEnum.Compact" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Transitions</h2>
        <ComponentDemo Code="@transitionsCode">
            <Demo>
                <div class="demo-row">
                    <BUIButton Text="Hover Scale" Transitions="@BUITransitionPresets.HoverScale" />
                    <BUIButton Text="Hover Lift" Transitions="@BUITransitionPresets.HoverLift" />
                    <BUIButton Text="Hover Glow" Transitions="@BUITransitionPresets.HoverGlow" />
                    <BUIButton Text="Focus Ring" Transitions="@BUITransitionPresets.FocusRing" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Properties</h2>
        <PropertyTable TItem="ButtonProperty" Items="@ButtonProperties">
            <PropertyTemplate Context="prop">
                <td><code>@prop.Name</code></td>
                <td><code>@prop.Type</code></td>
                <td><code>@prop.Default</code></td>
                <td>@prop.Description</td>
            </PropertyTemplate>
        </PropertyTable>
    </div>
</div>

@code {
    private string basicUsageCode = @"<BUIButton Text=""Click Me"" OnClick=""@(() => Console.WriteLine(""Clicked!""))"" />";

    private string sizesCode = @"<BUIButton Text=""Small"" Size=""SizeEnum.Small"" />
<BUIButton Text=""Medium"" Size=""SizeEnum.Medium"" />
<BUIButton Text=""Large"" Size=""SizeEnum.Large"" />";

    private string loadingCode = @"<BUIButton Text=""Loading Spinner""
          IsLoading=""true""
          LoadingIndicatorVariant=""UILoadingIndicatorVariant.Spinner"" />";

    private string iconsCode = @"<BUIButton Text=""Save"" LeadingIcon=""@BUIIcons.MaterialIconsRound.i_save"" />
<BUIButton Text=""Delete"" TrailingIcon=""@BUIIcons.MaterialIconsRound.i_delete"" />";

    private string elevationCode = @"<BUIButton Text=""No Elevation"" Elevation=""0"" />
<BUIButton Text=""Low"" Elevation=""2"" />
<BUIButton Text=""Medium"" Elevation=""4"" />
<BUIButton Text=""High"" Elevation=""8"" />";

    private string bordersCode = @"<BUIButton Text=""Default Border"" Border=""@BorderPresets.Default"" />
<BUIButton Text=""Primary Border"" Border=""@BorderPresets.Primary"" />
<BUIButton Text=""Rounded"" Border=""@BorderPresets.Rounded"" />
<BUIButton Text=""Pill"" Border=""@BorderPresets.Pill"" />";

    private string densityCode = @"<BUIButton Text=""Comfortable"" Density=""DensityEnum.Comfortable"" />
<BUIButton Text=""Standard"" Density=""DensityEnum.Standard"" />
<BUIButton Text=""Compact"" Density=""DensityEnum.Compact"" />";

    private string transitionsCode = @"<BUIButton Text=""Hover Scale"" Transitions=""@BUITransitionPresets.HoverScale"" />
<BUIButton Text=""Hover Lift"" Transitions=""@BUITransitionPresets.HoverLift"" />";

    private record ButtonProperty(string Name, string Type, string Default, string Description);

    private List<ButtonProperty> ButtonProperties = new()
    {
        new("Text", "string?", "null", "The text content of the button"),
        new("OnClick", "EventCallback<MouseEventArgs>", "-", "Click event handler"),
        new("Disabled", "bool", "false", "Whether the button is disabled"),
        new("Size", "SizeEnum", "Medium", "Size of the button (Small, Medium, Large)"),
        new("Density", "DensityEnum", "Standard", "Density of the button"),
        new("IsLoading", "bool", "false", "Whether the button is in loading state"),
        new("LoadingIndicatorVariant", "UILoadingIndicatorVariant?", "null", "Type of loading indicator"),
        new("LeadingIcon", "string?", "null", "Icon to display before the text"),
        new("TrailingIcon", "string?", "null", "Icon to display after the text"),
        new("Elevation", "int?", "null", "Elevation level (0-24)"),
        new("Border", "BorderStyle?", "null", "Border style for all sides"),
        new("BorderTop", "BorderStyle?", "null", "Top border style"),
        new("BorderRight", "BorderStyle?", "null", "Right border style"),
        new("BorderBottom", "BorderStyle?", "null", "Bottom border style"),
        new("BorderLeft", "BorderStyle?", "null", "Left border style"),
        new("DisableRipple", "bool", "false", "Whether to disable ripple effect"),
        new("RippleColor", "CssColor?", "null", "Custom color for ripple effect"),
        new("RippleDuration", "int?", "null", "Ripple animation duration in milliseconds"),
        new("FullWidth", "bool", "false", "Whether the button should take full width"),
        new("Transitions", "BUITransitions?", "null", "Transition animations"),
        new("BackgroundColor", "CssColor?", "null", "Background color"),
        new("Color", "CssColor?", "null", "Text color"),
    };
}