            <BUIGridItem Auto="true">
                <BUIButton Text="Small" Size="SizeEnum.Small" OnClick="@(() => { })" />
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUIButton Text="Medium (Default)" Size="SizeEnum.Medium" OnClick="@(() => { })" />
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUIButton Text="Large" Size="SizeEnum.Large" OnClick="@(() => { })" />
            </BUIGridItem>
        </BUIGrid>
