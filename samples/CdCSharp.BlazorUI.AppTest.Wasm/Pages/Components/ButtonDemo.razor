@page "/demo/button"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared

<PageTitle>Button - CdCSharp.BlazorUI</PageTitle>

<h1>BUIButton</h1>

<h2>Basic Usage</h2>
<ComponentDemo Definition="@BasicUsageDemo" />

<h2>With Icons</h2>
<ComponentDemo Definition="@IconsDemo" />

<h2>Variants</h2>
<ComponentDemo Definition="@VariantsDemo" />

<h2>Sizes</h2>
<ComponentDemo Definition="@SizesDemo" />

<h2>Density</h2>
<ComponentDemo Definition="@DensityDemo" />

<h2>Full Width</h2>
<ComponentDemo Definition="@FullWidthDemo" />

<h2>Colors</h2>
<ComponentDemo Definition="@ColorsDemo" />

<h2>Loading State</h2>
<ComponentDemo Definition="@LoadingDemo" />

<h2>Disabled</h2>
<ComponentDemo Definition="@DisabledDemo" />

<h2>With Shadow</h2>
<ComponentDemo Definition="@ShadowDemo" />

<h2>Without Ripple</h2>
<ComponentDemo Definition="@NoRippleDemo" />

<h2>With Border</h2>
<ComponentDemo Definition="@BorderDemo" />

<h2>With Transitions</h2>
<ComponentDemo Definition="@TransitionsDemo" />

<h2>Properties</h2>
<PropertyTable Properties="@_properties" />

@code {

    [CascadingParameter] public BUIPalette Palette { get; set; } = default!;

    private ComponentDemoDefinition BasicUsageDemo => new()
    {
        Demo = RenderBasicUsage(),
        Code = """ """
    };

    private RenderFragment RenderBasicUsage() => __builder =>
    {
        <BUIButton Text="Click me" OnClick="@(() => { })" />
    };

    private ComponentDemoDefinition IconsDemo => new()
    {
        Demo = RenderIcons(),
        Code = """ """
    };

    private RenderFragment RenderIcons() => __builder =>
    {
        <BUIGrid Gap="1rem" Direction="GridDirection.Row">
            <BUIGridItem Auto="true">
                <BUIButton Text="Leading Icon"
                           LeadingIcon="@BUIIcons.UI.Add"
                           OnClick="@(() => {})" />
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUIButton Text="Trailing Icon"
                           TrailingIcon="@BUIIcons.UI.ArrowForward"
                           OnClick="@(() => {})" />
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUIButton Text="Both Icons"
                           LeadingIcon="@BUIIcons.UI.Save"
                           TrailingIcon="@BUIIcons.UI.ChevronRight"
                           OnClick="@(() => {})" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition VariantsDemo => new()
    {
        Demo = RenderVariants(),
        Code = """ """
    };

    private RenderFragment RenderVariants() => __builder =>
    {
        <BUIGrid Gap="1rem" Direction="GridDirection.Row">
            <BUIGridItem Auto="true">
                <BUIButton Text="Default"
                           Variant="BUIButtonVariant.Default"
                           OnClick="@(() => {})" />
            </BUIGridItem>
        </BUIGrid>
    };

