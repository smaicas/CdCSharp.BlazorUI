@page "/components/theme-switch"

@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Components.Layout
@using CdCSharp.BlazorUI.Core.Css

<PageTitle>Theme Selector - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>BUIThemeSelector</h1>

    <p class="doc-intro">
        <strong>BUIThemeSelector</strong> provides a UI control to switch between
        application themes using the configured <code>IThemeJsInterop</code> service.
        It does not define themes, but triggers theme changes through the theme system.
    </p>

    <!-- VARIANTS -->
    <section class="doc-section">
        <h2>Variants</h2>
        <ComponentDemo Definition="@VariantsDemo" />
    </section>

    <!-- AVAILABLE THEMES -->
    <section class="doc-section">
        <h2>Available themes</h2>
        <ComponentDemo Definition="@AvailableThemesDemo" />
    </section>

    <!-- ICON VISIBILITY -->
    <section class="doc-section">
        <h2>Show or hide icon</h2>
        <ComponentDemo Definition="@ShowIconDemo" />
    </section>

    <!-- CUSTOM ICONS -->
    <section class="doc-section">
        <h2>Custom theme icons</h2>
        <ComponentDemo Definition="@ThemeIconsDemo" />
    </section>

    <!-- THEME CHANGE EVENT -->
    <section class="doc-section">
        <h2>Theme change event</h2>
        <ComponentDemo Definition="@OnThemeChangedDemo" />
        <p>Last theme: <strong>@LastTheme</strong></p>
    </section>

    <!-- HOW IT WORKS -->
    <section class="doc-section">
        <h2>How it works</h2>
        <ul>
            <li>Reads the current theme from <code>IThemeJsInterop</code></li>
            <li>Requests theme changes using <code>ToggleThemeAsync</code></li>
            <li>Does not manage persistence or CSS variables</li>
            <li>Theme logic lives outside of the component</li>
        </ul>
    </section>

    <!-- PROPERTIES -->
    <section class="doc-section">
        <h2>Properties</h2>
        <PropertyTable Properties="@Properties" />
    </section>
</div>

@code {
    private string? LastTheme;

    /* ===================== DEMOS ===================== */

    private ComponentDemoDefinition VariantsDemo => new()
    {
        Demo = RenderVariants(),
        Code = """
<BUIThemeSelector Variant="BUIThemeSelectorVariant.Default" />
<BUIThemeSelector Variant="BUIThemeSelectorVariant.SunMoon" />
"""
    };

    private ComponentDemoDefinition AvailableThemesDemo => new()
    {
        Demo = RenderAvailableThemes(),
        Code = """
<BUIThemeSelector AvailableThemes="new[] { "light", "dark", "high-contrast" }" />
"""
    };

    private ComponentDemoDefinition ShowIconDemo => new()
    {
        Demo = RenderShowIcon(),
        Code = """
<BUIThemeSelector ShowIcon="false" />
"""
    };

    private ComponentDemoDefinition ThemeIconsDemo => new()
    {
        Demo = RenderThemeIcons(),
        Code = """
<BUIThemeSelector ThemeIcons="new Dictionary<string, string>
{
    ["light"] = "☀️",
    ["dark"] = "🌙",
    ["high-contrast"] = "⚡"
}" />
"""
    };

    private ComponentDemoDefinition OnThemeChangedDemo => new()
    {
        Demo = RenderOnThemeChanged(),
        Code = """
<BUIThemeSelector OnThemeChanged="OnThemeChanged" />
"""
    };

    /* ===================== RENDER FRAGMENTS ===================== */

    private RenderFragment RenderVariants() => __builder =>
    {
        <div class="demo-row">
            <BUIThemeSelector Variant="BUIThemeSelectorVariant.Default" />
            <BUIThemeSelector Variant="BUIThemeSelectorVariant.SunMoon" />
        </div>
        ;
    };

    private RenderFragment RenderAvailableThemes() => __builder =>
    {
        <BUIThemeSelector AvailableThemes="@(["light", "dark", "high-contrast"])" />
        ;
    };

    private RenderFragment RenderShowIcon() => __builder =>
    {
        <BUIThemeSelector ShowIcon="false" />
        ;
    };

    private RenderFragment RenderThemeIcons() => __builder =>
    {
        <BUIThemeSelector ThemeIcons="CustomIcons" />
        ;
    };

    private RenderFragment RenderOnThemeChanged() => __builder =>
    {
        <BUIThemeSelector OnThemeChanged="OnThemeChanged" />
        ;
    };

    /* ===================== DATA ===================== */

    private Dictionary<string, string> CustomIcons = new()
    {
        ["light"] = "☀️",
        ["dark"] = "🌙",
        ["high-contrast"] = "⚡"
    };

    private void OnThemeChanged(string theme)
    {
        LastTheme = theme;
    }

    /* ===================== PROPERTIES ===================== */

    private List<PropertyDefinition> Properties = new()
    {
        new("Variant", "BUIThemeSelectorVariant?", "Default", "Visual variant of the selector"),
        new("AvailableThemes", "string[]", "light, dark", "Themes that can be toggled"),
        new("ShowIcon", "bool", "true", "Show icon in default variant"),
        new("ThemeIcons", "Dictionary<string, string>?", "null", "Custom icons per theme"),
        new("OnThemeChanged", "EventCallback<string>", "-", "Invoked when the theme changes"),
    };
}
