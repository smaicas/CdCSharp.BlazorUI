@page "/demo/timepicker"

<PageTitle>Time Picker - CdCSharp.BlazorUI</PageTitle>

<h1>BUITimePicker</h1>

<h2>Basic Usage</h2>
<ComponentDemo Definition="@BasicUsageDemo" />

<h2>Sizes</h2>
<ComponentDemo Definition="@SizesDemo" />

<h2>Density</h2>
<ComponentDemo Definition="@DensityDemo" />

<h2>Selected Time Display</h2>
<ComponentDemo Definition="@SelectedTimeDemo" />

@code {
    private TimeOnly? _basicValue = TimeOnly.FromDateTime(DateTime.Now);
    private TimeOnly? _smallValue = TimeOnly.FromDateTime(DateTime.Now);
    private TimeOnly? _mediumValue = TimeOnly.FromDateTime(DateTime.Now);
    private TimeOnly? _largeValue = TimeOnly.FromDateTime(DateTime.Now);
    private TimeOnly? _compactValue = TimeOnly.FromDateTime(DateTime.Now);
    private TimeOnly? _standardValue = TimeOnly.FromDateTime(DateTime.Now);
    private TimeOnly? _comfortableValue = TimeOnly.FromDateTime(DateTime.Now);
    private TimeOnly? _selectedValue = TimeOnly.FromDateTime(DateTime.Now);

    private ComponentDemoDefinition BasicUsageDemo => new()
    {
        Demo = RenderBasicUsage(),
        Code = """ """
    };

    private RenderFragment RenderBasicUsage() => __builder =>
    {
        <BUITimePicker @bind-Value="_basicValue" />
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """ """
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <BUIGrid Gap="2rem" Direction="GridDirection.Row">
            <BUIGridItem>
                <h4>Small</h4>
                <BUITimePicker @bind-Value="_smallValue" Size="SizeEnum.Small" />
            </BUIGridItem>
            <BUIGridItem>
                <h4>Medium (Default)</h4>
                <BUITimePicker @bind-Value="_mediumValue" Size="SizeEnum.Medium" />
            </BUIGridItem>
            <BUIGridItem>
                <h4>Large</h4>
                <BUITimePicker @bind-Value="_largeValue" Size="SizeEnum.Large" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition DensityDemo => new()
    {
        Demo = RenderDensity(),
        Code = """ """
    };

    private RenderFragment RenderDensity() => __builder =>
    {
        <BUIGrid Gap="2rem" Direction="GridDirection.Row">
            <BUIGridItem>
                <h4>Compact</h4>
                <BUITimePicker @bind-Value="_compactValue" Density="DensityEnum.Compact" />
            </BUIGridItem>
            <BUIGridItem>
                <h4>Standard</h4>
                <BUITimePicker @bind-Value="_standardValue" Density="DensityEnum.Standard" />
            </BUIGridItem>
            <BUIGridItem>
                <h4>Comfortable</h4>
                <BUITimePicker @bind-Value="_comfortableValue" Density="DensityEnum.Comfortable" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition SelectedTimeDemo => new()
    {
        Demo = RenderSelectedTime(),
        Code = """ """
    };

    private RenderFragment RenderSelectedTime() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUITimePicker @bind-Value="_selectedValue" />
            </BUIGridItem>
            <BUIGridItem>
                <p><strong>Selected Time:</strong> @_selectedValue?.ToString("T")</p>
            </BUIGridItem>
        </BUIGrid>
    };
}