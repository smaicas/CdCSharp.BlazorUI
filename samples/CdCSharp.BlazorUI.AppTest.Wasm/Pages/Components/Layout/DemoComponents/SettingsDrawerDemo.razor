@* === Shared/SettingsDrawerDemo.razor === *@

@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Components.Forms
@using CdCSharp.BlazorUI.Core.Css

@implements IModalContent

<div class="settings-drawer-demo">
    <h3>Settings</h3>

    <div class="settings-drawer-demo__section">
        <h4>Notifications</h4>
        <BUIInputSwitch @bind-Value="_enableNotifications"
                        Label="Enable notifications" />
        <BUIInputSwitch @bind-Value="_soundEnabled"
                        Label="Sound" />
    </div>

    <div class="settings-drawer-demo__section">
        <h4>Appearance</h4>
        <BUIInputSwitch @bind-Value="_darkMode"
                        Label="Dark mode" />
    </div>

    <div class="settings-drawer-demo__actions">
        <BUIButton Text="Close"
                   OnClick="HandleClose"
                   FullWidth="true" />
    </div>
</div>

@code {
    [Parameter] public ModalReference ModalRef { get; set; } = default!;

    private bool _enableNotifications = true;
    private bool _soundEnabled = true;
    private bool _darkMode = false;

    private async Task HandleClose() => await ModalRef.CloseAsync();
}