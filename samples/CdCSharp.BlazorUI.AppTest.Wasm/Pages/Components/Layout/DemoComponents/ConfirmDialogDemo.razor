@* === Shared/ConfirmDialogDemo.razor === *@

@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Core.Css

@implements IModalContent

<div class="confirm-dialog-demo">
    <p class="confirm-dialog-demo__message">@Message</p>

    <div class="confirm-dialog-demo__actions">
        <BUIButton Text="Cancel"
                   OnClick="HandleCancel" />
        <BUIButton Text="Confirm"
                   OnClick="HandleConfirm"
                   BackgroundColor="BUIColor.Palette.Primary"
                   Color="BUIColor.Palette.PrimaryContrast" />
    </div>
</div>

@code {
    [Parameter] public ModalReference ModalRef { get; set; } = default!;
    [Parameter] public string Message { get; set; } = "Are you sure?";

    private async Task HandleConfirm() => await ModalRef.CloseAsync(true);
    private async Task HandleCancel() => await ModalRef.CloseAsync(false);
}