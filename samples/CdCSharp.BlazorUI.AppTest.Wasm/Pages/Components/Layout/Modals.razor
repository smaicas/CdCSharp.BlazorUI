@* === Pages/Components/Modals.razor === *@

@page "/components/modals"

@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Components.Layout.Modal.Services
@using CdCSharp.BlazorUI.Core.Css

@inject IModalService ModalService

<PageTitle>Modals - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>Modals</h1>

    <p class="doc-intro">
        <strong>BUIDialog</strong> and <strong>BUIDrawer</strong> are modal components for displaying
        content in overlay panels. They support declarative usage, programmatic invocation via service,
        stacking, focus trapping, keyboard navigation, and customizable transitions.
    </p>

    <!-- BASIC DIALOG -->
    <section class="doc-section">
        <h2>Basic Dialog</h2>
        <ComponentDemo Definition="@BasicDialogDemo" />
    </section>

    <!-- DIALOG WITH FOOTER -->
    <section class="doc-section">
        <h2>Dialog with Footer</h2>
        <ComponentDemo Definition="@DialogWithFooterDemo" />
    </section>

    <!-- FULLSCREEN DIALOG -->
    <section class="doc-section">
        <h2>Fullscreen Dialog</h2>
        <ComponentDemo Definition="@FullscreenDialogDemo" />
    </section>

    <!-- DIALOG SIZES -->
    <section class="doc-section">
        <h2>Dialog Sizes</h2>
        <ComponentDemo Definition="@DialogSizesDemo" />
    </section>

    <!-- BASIC DRAWER -->
    <section class="doc-section">
        <h2>Basic Drawer</h2>
        <ComponentDemo Definition="@BasicDrawerDemo" />
    </section>

    <!-- DRAWER POSITIONS -->
    <section class="doc-section">
        <h2>Drawer Positions</h2>
        <ComponentDemo Definition="@DrawerPositionsDemo" />
    </section>

    <!-- DRAWER SIZES -->
    <section class="doc-section">
        <h2>Drawer Sizes</h2>
        <ComponentDemo Definition="@DrawerSizesDemo" />
    </section>

    <!-- CLOSE OPTIONS -->
    <section class="doc-section">
        <h2>Close Options</h2>
        <ComponentDemo Definition="@CloseOptionsDemo" />
    </section>

    <!-- PROGRAMMATIC DIALOG -->
    <section class="doc-section">
        <h2>Programmatic Dialog (Service)</h2>
        <ComponentDemo Definition="@ProgrammaticDialogDemo" />
        @if (_confirmResult.HasValue)
        {
            <p class="demo-result">Result: @(_confirmResult.Value ? "Confirmed" : "Cancelled")</p>
        }
    </section>

    <!-- PROGRAMMATIC DRAWER -->
    <section class="doc-section">
        <h2>Programmatic Drawer (Service)</h2>
        <ComponentDemo Definition="@ProgrammaticDrawerDemo" />
    </section>

    <!-- STACKED MODALS -->
    <section class="doc-section">
        <h2>Stacked Modals</h2>
        <ComponentDemo Definition="@StackedModalsDemo" />
    </section>

    <!-- DIALOG PROPERTIES -->
    <section class="doc-section">
        <h2>BUIDialog Properties</h2>
        <PropertyTable Properties="@DialogProperties" />
    </section>

    <!-- DRAWER PROPERTIES -->
    <section class="doc-section">
        <h2>BUIDrawer Properties</h2>
        <PropertyTable Properties="@DrawerProperties" />
    </section>

    <!-- SERVICE METHODS -->
    <section class="doc-section">
        <h2>IModalService Methods</h2>
        <PropertyTable Properties="@ServiceMethods" />
    </section>
</div>

<!-- DECLARATIVE DIALOGS -->
<BUIDialog @bind-Open="_showBasicDialog" Title="Basic Dialog">
    <Content>
        <p>This is a basic dialog with a title and content.</p>
        <p>Click outside, press Escape, or click the X button to close.</p>
    </Content>
</BUIDialog>

<BUIDialog @bind-Open="_showFooterDialog" Title="Confirm Action">
    <Content>
        <p>Are you sure you want to proceed with this action?</p>
        <p>This operation cannot be undone.</p>
    </Content>
    <Footer>
        <BUIButton Text="Cancel"
                   OnClick="() => _showFooterDialog = false" />
        <BUIButton Text="Confirm"
                   OnClick="HandleFooterConfirm"
                   BackgroundColor="BUIColor.Palette.Primary"
                   Color="BUIColor.Palette.PrimaryContrast" />
    </Footer>
</BUIDialog>

<BUIDialog @bind-Open="_showFullscreenDialog"
           Title="Fullscreen Dialog"
           FullScreen="true">
    <Content>
        <p>This dialog takes up the entire screen.</p>
        <p>Useful for complex forms or immersive content.</p>
    </Content>
    <Footer>
        <BUIButton Text="Close" OnClick="() => _showFullscreenDialog = false" />
    </Footer>
</BUIDialog>

<BUIDialog @bind-Open="_showSmallDialog"
           Title="Small Dialog"
           MinWidth="200px"
           MaxWidth="300px">
    <Content>
        <p>A compact dialog.</p>
    </Content>
</BUIDialog>

<BUIDialog @bind-Open="_showLargeDialog"
           Title="Large Dialog"
           MinWidth="600px"
           MaxWidth="800px">
    <Content>
        <p>A larger dialog with more space for content.</p>
        <p>
            Lorem ipsum dolor sit amet, consectetur adipiscing elit.
            Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
        </p>
    </Content>
</BUIDialog>

<BUIDialog @bind-Open="_showNoCloseDialog"
           Title="Restricted Close"
           Closable="false"
           CloseOnOverlayClick="false"
           CloseOnEscape="false">
    <Content>
        <p>This dialog can only be closed via the button below.</p>
        <p>Overlay click and Escape key are disabled.</p>
    </Content>
    <Footer>
        <BUIButton Text="Close"
                   OnClick="() => _showNoCloseDialog = false"
                   BackgroundColor="BUIColor.Palette.Primary"
                   Color="BUIColor.Palette.PrimaryContrast" />
    </Footer>
</BUIDialog>

<!-- DECLARATIVE DRAWERS -->
<BUIDrawer @bind-Open="_showBasicDrawer" Position="DrawerPosition.Right">
    <Header>Navigation</Header>
    <ChildContent>
        <p>This is a basic drawer from the right.</p>
        <p>Perfect for navigation menus or settings panels.</p>
    </ChildContent>
</BUIDrawer>

<BUIDrawer @bind-Open="_showLeftDrawer" Position="DrawerPosition.Left">
    <Header>Left Drawer</Header>
    <ChildContent>
        <p>Drawer from the left side.</p>
    </ChildContent>
</BUIDrawer>

<BUIDrawer @bind-Open="_showTopDrawer" Position="DrawerPosition.Top" Size="200px">
    <Header>Top Drawer</Header>
    <ChildContent>
        <p>Drawer from the top.</p>
    </ChildContent>
</BUIDrawer>

<BUIDrawer @bind-Open="_showBottomDrawer" Position="DrawerPosition.Bottom" Size="200px">
    <Header>Bottom Drawer</Header>
    <ChildContent>
        <p>Drawer from the bottom.</p>
    </ChildContent>
</BUIDrawer>

<BUIDrawer @bind-Open="_showNarrowDrawer" Position="DrawerPosition.Right" Size="200px">
    <Header>Narrow</Header>
    <ChildContent>
        <p>A narrow drawer.</p>
    </ChildContent>
</BUIDrawer>

<BUIDrawer @bind-Open="_showWideDrawer" Position="DrawerPosition.Right" Size="500px">
    <Header>Wide Drawer</Header>
    <ChildContent>
        <p>A wider drawer with more space.</p>
    </ChildContent>
</BUIDrawer>

<!-- STACKED DIALOG -->
<BUIDialog @bind-Open="_showFirstStackedDialog" Title="First Dialog">
    <Content>
        <p>This is the first dialog.</p>
        <p>Click the button below to open a second dialog on top.</p>
    </Content>
    <Footer>
        <BUIButton Text="Open Second Dialog"
                   OnClick="() => _showSecondStackedDialog = true"
                   BackgroundColor="BUIColor.Palette.Primary"
                   Color="BUIColor.Palette.PrimaryContrast" />
    </Footer>
</BUIDialog>

<BUIDialog @bind-Open="_showSecondStackedDialog" Title="Second Dialog">
    <Content>
        <p>This is the second dialog, stacked on top of the first.</p>
        <p>The first dialog is hidden but will reappear when you close this one.</p>
    </Content>
    <Footer>
        <BUIButton Text="Close" OnClick="() => _showSecondStackedDialog = false" />
    </Footer>
</BUIDialog>

@code {
    /* ===================== STATE ===================== */

    private bool _showBasicDialog;
    private bool _showFooterDialog;
    private bool _showFullscreenDialog;
    private bool _showSmallDialog;
    private bool _showLargeDialog;
    private bool _showNoCloseDialog;

    private bool _showBasicDrawer;
    private bool _showLeftDrawer;
    private bool _showTopDrawer;
    private bool _showBottomDrawer;
    private bool _showNarrowDrawer;
    private bool _showWideDrawer;

    private bool _showFirstStackedDialog;
    private bool _showSecondStackedDialog;

    private bool? _confirmResult;

    /* ===================== HANDLERS ===================== */

    private void HandleFooterConfirm()
    {
        _showFooterDialog = false;
    }

    private async Task OpenProgrammaticDialog()
    {
        _confirmResult = await ModalService.ShowDialogAsync<ConfirmDialogDemo, bool>(
            new { Message = "Do you want to save changes?" },
            new DialogOptions { Title = "Save Changes" }
        );
    }

    private async Task OpenProgrammaticDrawer()
    {
        await ModalService.ShowDrawerAsync<SettingsDrawerDemo>(
            options: new DrawerOptions
            {
                Position = DrawerPosition.Right,
                Size = "350px"
            }
        );
    }

    /* ===================== DEMOS ===================== */

    private ComponentDemoDefinition BasicDialogDemo => new()
    {
        Demo = RenderBasicDialog(),
        Code = """
<BUIButton Text="Open Dialog" OnClick="() => _showDialog = true" />

<BUIDialog @bind-Open="_showDialog" Title="Basic Dialog">
    <Content>
        <p>This is a basic dialog with a title and content.</p>
    </Content>
</BUIDialog>
"""
    };

    private ComponentDemoDefinition DialogWithFooterDemo => new()
    {
        Demo = RenderDialogWithFooter(),
        Code = """
<BUIDialog @bind-Open="_showDialog" Title="Confirm Action">
    <Content>
        <p>Are you sure you want to proceed?</p>
    </Content>
    <Footer>
        <BUIButton Text="Cancel" OnClick="() => _showDialog = false" />
        <BUIButton Text="Confirm" OnClick="HandleConfirm"
                   BackgroundColor="BUIColor.Palette.Primary" />
    </Footer>
</BUIDialog>
"""
    };

    private ComponentDemoDefinition FullscreenDialogDemo => new()
    {
        Demo = RenderFullscreenDialog(),
        Code = """
<BUIDialog @bind-Open="_showDialog"
           Title="Fullscreen Dialog"
           FullScreen="true">
    <Content>
        <p>This dialog takes up the entire screen.</p>
    </Content>
</BUIDialog>
"""
    };

    private ComponentDemoDefinition DialogSizesDemo => new()
    {
        Demo = RenderDialogSizes(),
        Code = """
<BUIDialog @bind-Open="_showSmall"
           Title="Small"
           MinWidth="200px"
           MaxWidth="300px">
    ...
</BUIDialog>

<BUIDialog @bind-Open="_showLarge"
           Title="Large"
           MinWidth="600px"
           MaxWidth="800px">
    ...
</BUIDialog>
"""
    };

    private ComponentDemoDefinition BasicDrawerDemo => new()
    {
        Demo = RenderBasicDrawer(),
        Code = """
<BUIButton Text="Open Drawer" OnClick="() => _showDrawer = true" />

<BUIDrawer @bind-Open="_showDrawer" Position="DrawerPosition.Right">
    <Header>Navigation</Header>
    <ChildContent>
        <p>Drawer content here.</p>
    </ChildContent>
</BUIDrawer>
"""
    };

    private ComponentDemoDefinition DrawerPositionsDemo => new()
    {
        Demo = RenderDrawerPositions(),
        Code = """
<BUIDrawer @bind-Open="_open" Position="DrawerPosition.Left">...</BUIDrawer>
<BUIDrawer @bind-Open="_open" Position="DrawerPosition.Right">...</BUIDrawer>
<BUIDrawer @bind-Open="_open" Position="DrawerPosition.Top">...</BUIDrawer>
<BUIDrawer @bind-Open="_open" Position="DrawerPosition.Bottom">...</BUIDrawer>
"""
    };

    private ComponentDemoDefinition DrawerSizesDemo => new()
    {
        Demo = RenderDrawerSizes(),
        Code = """
<BUIDrawer @bind-Open="_open" Size="200px">...</BUIDrawer>
<BUIDrawer @bind-Open="_open" Size="500px">...</BUIDrawer>
"""
    };

    private ComponentDemoDefinition CloseOptionsDemo => new()
    {
        Demo = RenderCloseOptions(),
        Code = """
<BUIDialog @bind-Open="_showDialog"
           Title="Restricted Close"
           Closable="false"
           CloseOnOverlayClick="false"
           CloseOnEscape="false">
    <Content>
        <p>Can only close via button.</p>
    </Content>
    <Footer>
        <BUIButton Text="Close" OnClick="() => _showDialog = false" />
    </Footer>
</BUIDialog>
"""
    };

    private ComponentDemoDefinition ProgrammaticDialogDemo => new()
    {
        Demo = RenderProgrammaticDialog(),
        Code = """
@inject IModalService ModalService

<BUIButton Text="Open Confirm" OnClick="OpenConfirm" />

@code {
    private async Task OpenConfirm()
    {
        bool confirmed = await ModalService.ShowDialogAsync<ConfirmDialog, bool>(
            new { Message = "Save changes?" },
            new DialogOptions { Title = "Confirm" }
        );

        if (confirmed) { /* handle */ }
    }
}

// ConfirmDialog.razor
@implements IModalContent

<p>@Message</p>
<BUIButton Text="Cancel" OnClick="() => ModalRef.CloseAsync(false)" />
<BUIButton Text="Confirm" OnClick="() => ModalRef.CloseAsync(true)" />

@code {
    [Parameter] public ModalReference ModalRef { get; set; }
    [Parameter] public string Message { get; set; }
}
"""
    };

    private ComponentDemoDefinition ProgrammaticDrawerDemo => new()
    {
        Demo = RenderProgrammaticDrawer(),
        Code = """
@inject IModalService ModalService

<BUIButton Text="Open Settings" OnClick="OpenSettings" />

@code {
    private async Task OpenSettings()
    {
        await ModalService.ShowDrawerAsync<SettingsPanel>(
            options: new DrawerOptions
            {
                Position = DrawerPosition.Right,
                Size = "350px"
            }
        );
    }
}
"""
    };

    private ComponentDemoDefinition StackedModalsDemo => new()
    {
        Demo = RenderStackedModals(),
        Code = """
<BUIDialog @bind-Open="_showFirst" Title="First Dialog">
    <Content>
        <p>First dialog content.</p>
    </Content>
    <Footer>
        <BUIButton Text="Open Second"
                   OnClick="() => _showSecond = true" />
    </Footer>
</BUIDialog>

<BUIDialog @bind-Open="_showSecond" Title="Second Dialog">
    <Content>
        <p>Stacked on top. First dialog will reappear on close.</p>
    </Content>
</BUIDialog>
"""
    };

    /* ===================== RENDER FRAGMENTS ===================== */

    private RenderFragment RenderBasicDialog() => __builder =>
    {
        <BUIButton Text="Open Dialog"
                   OnClick="() => _showBasicDialog = true" />
    };

    private RenderFragment RenderDialogWithFooter() => __builder =>
    {
        <BUIButton Text="Open Dialog with Footer"
                   OnClick="() => _showFooterDialog = true" />
    };

    private RenderFragment RenderFullscreenDialog() => __builder =>
    {
        <BUIButton Text="Open Fullscreen"
                   OnClick="() => _showFullscreenDialog = true" />
    };

    private RenderFragment RenderDialogSizes() => __builder =>
    {
        <div class="demo-row">
            <BUIButton Text="Small (300px)"
                       OnClick="() => _showSmallDialog = true" />
            <BUIButton Text="Large (800px)"
                       OnClick="() => _showLargeDialog = true" />
        </div>
    };

    private RenderFragment RenderBasicDrawer() => __builder =>
    {
        <BUIButton Text="Open Drawer"
                   OnClick="() => _showBasicDrawer = true" />
    };

    private RenderFragment RenderDrawerPositions() => __builder =>
    {
        <div class="demo-row">
            <BUIButton Text="Left"
                       OnClick="() => _showLeftDrawer = true" />
            <BUIButton Text="Right"
                       OnClick="() => _showBasicDrawer = true" />
            <BUIButton Text="Top"
                       OnClick="() => _showTopDrawer = true" />
            <BUIButton Text="Bottom"
                       OnClick="() => _showBottomDrawer = true" />
        </div>
    };

    private RenderFragment RenderDrawerSizes() => __builder =>
    {
        <div class="demo-row">
            <BUIButton Text="Narrow (200px)"
                       OnClick="() => _showNarrowDrawer = true" />
            <BUIButton Text="Wide (500px)"
                       OnClick="() => _showWideDrawer = true" />
        </div>
    };

    private RenderFragment RenderCloseOptions() => __builder =>
    {
        <BUIButton Text="Open Restricted Dialog"
                   OnClick="() => _showNoCloseDialog = true" />
    };

    private RenderFragment RenderProgrammaticDialog() => __builder =>
    {
        <BUIButton Text="Open Confirm Dialog"
                   OnClick="OpenProgrammaticDialog" />
    };

    private RenderFragment RenderProgrammaticDrawer() => __builder =>
    {
        <BUIButton Text="Open Settings Drawer"
                   OnClick="OpenProgrammaticDrawer" />
    };

    private RenderFragment RenderStackedModals() => __builder =>
    {
        <BUIButton Text="Open Stacked Dialogs"
                   OnClick="() => _showFirstStackedDialog = true" />
    };

    /* ===================== PROPERTIES ===================== */

    private List<PropertyDefinition> DialogProperties = new()
    {
        new("Open", "bool", "false", "Controls dialog visibility"),
        new("OpenChanged", "EventCallback<bool>", "-", "Callback when Open changes"),
        new("Title", "string?", "null", "Dialog title text"),
        new("Header", "RenderFragment?", "null", "Custom header content"),
        new("Content", "RenderFragment?", "null", "Dialog body content"),
        new("Footer", "RenderFragment?", "null", "Footer content (usually buttons)"),
        new("Closable", "bool", "true", "Show close button"),
        new("CloseOnOverlayClick", "bool", "true", "Close when clicking overlay"),
        new("CloseOnEscape", "bool", "true", "Close on Escape key"),
        new("MinWidth", "string?", "300px", "Minimum dialog width"),
        new("MaxWidth", "string?", "90vw", "Maximum dialog width"),
        new("MinHeight", "string?", "null", "Minimum dialog height"),
        new("MaxHeight", "string?", "90vh", "Maximum dialog height"),
        new("FullScreen", "bool", "false", "Display in fullscreen mode"),
        new("Transitions", "BUITransitions?", "null", "Custom transitions"),
    };

    private List<PropertyDefinition> DrawerProperties = new()
    {
        new("Open", "bool", "false", "Controls drawer visibility"),
        new("OpenChanged", "EventCallback<bool>", "-", "Callback when Open changes"),
        new("Header", "RenderFragment?", "null", "Drawer header content"),
        new("ChildContent", "RenderFragment?", "null", "Drawer body content"),
        new("Footer", "RenderFragment?", "null", "Footer content"),
        new("Position", "DrawerPosition", "Right", "Slide direction (Left, Right, Top, Bottom)"),
        new("Size", "string", "300px", "Width (Left/Right) or Height (Top/Bottom)"),
        new("Closable", "bool", "true", "Show close button"),
        new("CloseOnOverlayClick", "bool", "true", "Close when clicking overlay"),
        new("CloseOnEscape", "bool", "true", "Close on Escape key"),
        new("Transitions", "BUITransitions?", "null", "Custom transitions"),
    };

    private List<PropertyDefinition> ServiceMethods = new()
    {
        new("ShowDialogAsync<T>", "Task", "-", "Show dialog without result"),
        new("ShowDialogAsync<T, TResult>", "Task<TResult?>", "-", "Show dialog and await result"),
        new("ShowDrawerAsync<T>", "Task", "-", "Show drawer without result"),
        new("ShowDrawerAsync<T, TResult>", "Task<TResult?>", "-", "Show drawer and await result"),
        new("CloseAsync", "Task", "-", "Close topmost modal"),
        new("CloseAllAsync", "Task", "-", "Close all modals"),
    };
}