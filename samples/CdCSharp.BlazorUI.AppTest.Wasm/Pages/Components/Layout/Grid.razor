@page "/components/grid"

@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components.Layout
@using CdCSharp.BlazorUI.Core.Abstractions.Behaviors.Design
@using CdCSharp.BlazorUI.Core.Css

<PageTitle>Grid - CdCSharp.BlazorUI</PageTitle>

<style>
    .bui-grid-item {
        background-color: var(--palette-surface);
        border: 1px solid var(--palette-secondary);
        border-radius: 4px;
        text-align: center;
        font-weight: 500;
    }
</style>

<div class="doc-page">
    <h1>BUIGrid System</h1>

    <p class="doc-intro">
        <strong>BUIGrid</strong> is a flexible, responsive grid system based on flexbox.
        It includes three components: <code>BUIGridContainer</code>, <code>BUIGrid</code>, and <code>BUIGridItem</code>.
        Supports 12-column layout, responsive breakpoints, gap control, and density.
    </p>

    <!-- BASIC GRID -->
    <section class="doc-section">
        <h2>Basic Grid</h2>
        <ComponentDemo Definition="@BasicGridDemo" />
    </section>

    <!-- CONTAINER -->
    <section class="doc-section">
        <h2>Grid Container</h2>
        <ComponentDemo Definition="@ContainerDemo" />
    </section>

    <!-- RESPONSIVE COLUMNS -->
    <section class="doc-section">
        <h2>Responsive Columns</h2>
        <ComponentDemo Definition="@ResponsiveDemo" />
    </section>

    <!-- GAP CONTROL -->
    <section class="doc-section">
        <h2>Gap Control</h2>
        <ComponentDemo Definition="@GapDemo" />
    </section>

    <!-- RESPONSIVE GAP -->
    <section class="doc-section">
        <h2>Responsive Gap</h2>
        <ComponentDemo Definition="@ResponsiveGapDemo" />
    </section>

    <!-- DIRECTION -->
    <section class="doc-section">
        <h2>Direction</h2>
        <ComponentDemo Definition="@DirectionDemo" />
    </section>

    <!-- RESPONSIVE DIRECTION -->
    <section class="doc-section">
        <h2>Responsive Direction</h2>
        <ComponentDemo Definition="@ResponsiveDirectionDemo" />
    </section>

    <!-- JUSTIFY & ALIGN -->
    <section class="doc-section">
        <h2>Justify Content & Align Items</h2>
        <ComponentDemo Definition="@JustifyAlignDemo" />
    </section>

    <!-- OFFSET -->
    <section class="doc-section">
        <h2>Offset</h2>
        <ComponentDemo Definition="@OffsetDemo" />
    </section>

    <!-- ORDER -->
    <section class="doc-section">
        <h2>Order</h2>
        <ComponentDemo Definition="@OrderDemo" />
    </section>

    <!-- AUTO LAYOUT -->
    <section class="doc-section">
        <h2>Auto Layout</h2>
        <ComponentDemo Definition="@AutoLayoutDemo" />
    </section>

    <!-- HIDE/SHOW -->
    <section class="doc-section">
        <h2>Responsive Visibility</h2>
        <ComponentDemo Definition="@VisibilityDemo" />
    </section>

    <!-- DENSITY -->
    <section class="doc-section">
        <h2>Density</h2>
        <ComponentDemo Definition="@DensityDemo" />
    </section>

    <!-- SPACING -->
    <section class="doc-section">
        <h2>Spacing (Padding & Margin)</h2>
        <ComponentDemo Definition="@SpacingDemo" />
    </section>

    <!-- NESTED GRIDS -->
    <section class="doc-section">
        <h2>Nested Grids</h2>
        <ComponentDemo Definition="@NestedDemo" />
    </section>

    <!-- PROPERTIES - CONTAINER -->
    <section class="doc-section">
        <h2>BUIGridContainer Properties</h2>
        <PropertyTable Properties="@ContainerProperties" />
    </section>

    <!-- PROPERTIES - GRID -->
    <section class="doc-section">
        <h2>BUIGrid Properties</h2>
        <PropertyTable Properties="@GridProperties" />
    </section>

    <!-- PROPERTIES - GRID ITEM -->
    <section class="doc-section">
        <h2>BUIGridItem Properties</h2>
        <PropertyTable Properties="@GridItemProperties" />
    </section>
</div>

