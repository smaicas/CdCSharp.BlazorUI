@page "/components/tree-menu"

@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Core.Css

<PageTitle>Tree Menu - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>BUITreeMenu</h1>

    <p class="doc-intro">
        <strong>BUITreeMenu</strong> is a hierarchical navigation menu component supporting
        declarative and data-bound modes, lazy loading, horizontal/vertical orientations,
        inline/flyout expansion, hover/click triggers, and navigation integration.
    </p>

    <!-- BASIC DECLARATIVE -->
    <section class="doc-section">
        <h2>Basic declarative usage</h2>
        <ComponentDemo Definition="@BasicDeclarativeDemo" />
    </section>

    <!-- DATA BOUND -->
    <section class="doc-section">
        <h2>Data-bound mode</h2>
        <ComponentDemo Definition="@DataBoundDemo" />
    </section>

    <!-- WITH NAVIGATION -->
    <section class="doc-section">
        <h2>With navigation</h2>
        <ComponentDemo Definition="@NavigationDemo" />
    </section>

    <!-- HORIZONTAL -->
    <section class="doc-section">
        <h2>Horizontal orientation</h2>
        <ComponentDemo Definition="@HorizontalDemo" />
    </section>

    <!-- FLYOUT -->
    <section class="doc-section">
        <h2>Flyout mode</h2>
        <ComponentDemo Definition="@FlyoutDemo" />
    </section>

    <!-- HOVER TRIGGER -->
    <section class="doc-section">
        <h2>Hover trigger</h2>
        <ComponentDemo Definition="@HoverTriggerDemo" />
    </section>

    <!-- SIZES -->
    <section class="doc-section">
        <h2>Sizes</h2>
        <ComponentDemo Definition="@SizesDemo" />
    </section>

    <!-- CUSTOM CONTENT -->
    <section class="doc-section">
        <h2>Custom node content</h2>
        <ComponentDemo Definition="@CustomContentDemo" />
    </section>

    <!-- LAZY LOADING -->
    <section class="doc-section">
        <h2>Lazy loading</h2>
        <ComponentDemo Definition="@LazyLoadingDemo" />
    </section>

    <!-- PROPERTIES -->
    <section class="doc-section">
        <h2>Properties</h2>
        <PropertyTable Properties="@Properties" />
    </section>

    <!-- ITEM PROPERTIES -->
    <section class="doc-section">
        <h2>BUITreeMenuItem Properties</h2>
        <PropertyTable Properties="@ItemProperties" />
    </section>
</div>

@code {
    private string? _lastNavigated;

    public class MenuItem
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public string? Icon { get; set; }
        public string? Href { get; set; }
        public List<MenuItem>? Children { get; set; }
    }

    private List<MenuItem> MenuItems =>
    [
        new() {
            Id = "dashboard",
            Name = "Dashboard",
            Icon = BUIIcons.MaterialIconsOutlined.i_home,
            Href = "/dashboard"
        },
        new() {
            Id = "products",
            Name = "Products",
            Icon = BUIIcons.MaterialIconsOutlined.i_inbox,
            Children = [
                new() { Id = "all", Name = "All Products", Href = "/products" },
                new() { Id = "categories", Name = "Categories", Href = "/products/categories" },
                new() { Id = "inventory", Name = "Inventory", Href = "/products/inventory" }
            ]
        },
        new() {
            Id = "settings",
            Name = "Settings",
            Icon = BUIIcons.UI.Settings,
            Href = "/settings"
        }
    ];

    /* ===================== DEMOS ===================== */

    private ComponentDemoDefinition BasicDeclarativeDemo => new()
    {
        Demo = RenderBasicDeclarative(),
        Code = """
<BUITreeMenu TItem="object">
    <BUITreeMenuItem Text="Home" Icon="@BUIIcons.UI.Home" />
    <BUITreeMenuItem Text="Products" Icon="@BUIIcons.UI.Box" InitiallyExpanded>
        <ChildContent>
            <BUITreeMenuItem Text="All Products" />
            <BUITreeMenuItem Text="Categories" />
        </ChildContent>
    </BUITreeMenuItem>
    <BUITreeMenuItem Text="Settings" Icon="@BUIIcons.UI.Settings" />
</BUITreeMenu>
"""
    };

    private ComponentDemoDefinition DataBoundDemo => new()
    {
        Demo = RenderDataBound(),
        Code = """
<BUITreeMenu TItem="MenuItem"
             Items="@MenuItems"
             KeySelector="@(x => x.Id)"
             ChildrenSelector="@(x => x.Children)">
    <NodeTemplate Context="node">
        @if (!string.IsNullOrEmpty(node.Item?.Icon))
        {
            <BUISvgIcon Icon="@node.Item.Icon" />
        }
        <span>@node.Item?.Name</span>
    </NodeTemplate>
</BUITreeMenu>
"""
    };

    private ComponentDemoDefinition NavigationDemo => new()
    {
        Demo = RenderNavigation(),
        Code = """
<BUITreeMenu TItem="object" OnNavigate="@HandleNavigate">
    <BUITreeMenuItem Text="Dashboard" Href="/dashboard" Icon="@BUIIcons.UI.Home" />
    <BUITreeMenuItem Text="Products" Icon="@BUIIcons.UI.Box">
        <ChildContent>
            <BUITreeMenuItem Text="All" Href="/products" />
            <BUITreeMenuItem Text="Categories" Href="/products/categories" />
        </ChildContent>
    </BUITreeMenuItem>
</BUITreeMenu>
"""
    };

    private ComponentDemoDefinition HorizontalDemo => new()
    {
        Demo = RenderHorizontal(),
        Code = """
<BUITreeMenu TItem="object"
             Orientation="TreeMenuOrientation.Horizontal"
             ExpandMode="TreeMenuExpandMode.Flyout">
    <BUITreeMenuItem Text="File">
        <ChildContent>
            <BUITreeMenuItem Text="New" />
            <BUITreeMenuItem Text="Open" />
            <BUITreeMenuItem Text="Save" />
        </ChildContent>
    </BUITreeMenuItem>
    <BUITreeMenuItem Text="Edit">
        <ChildContent>
            <BUITreeMenuItem Text="Undo" />
            <BUITreeMenuItem Text="Redo" />
        </ChildContent>
    </BUITreeMenuItem>
    <BUITreeMenuItem Text="Help" />
</BUITreeMenu>
"""
    };

    private ComponentDemoDefinition FlyoutDemo => new()
    {
        Demo = RenderFlyout(),
        Code = """
<BUITreeMenu TItem="object" ExpandMode="TreeMenuExpandMode.Flyout">
    <BUITreeMenuItem Text="Menu 1">
        <ChildContent>
            <BUITreeMenuItem Text="Submenu 1.1">
                <ChildContent>
                    <BUITreeMenuItem Text="Item 1.1.1" />
                    <BUITreeMenuItem Text="Item 1.1.2" />
                </ChildContent>
            </BUITreeMenuItem>
            <BUITreeMenuItem Text="Submenu 1.2" />
        </ChildContent>
    </BUITreeMenuItem>
    <BUITreeMenuItem Text="Menu 2" />
</BUITreeMenu>
"""
    };

    private ComponentDemoDefinition HoverTriggerDemo => new()
    {
        Demo = RenderHoverTrigger(),
        Code = """
<BUITreeMenu TItem="object"
             Trigger="TreeMenuTrigger.Hover"
             ExpandMode="TreeMenuExpandMode.Flyout">
    <BUITreeMenuItem Text="Hover me">
        <ChildContent>
            <BUITreeMenuItem Text="Child 1" />
            <BUITreeMenuItem Text="Child 2" />
        </ChildContent>
    </BUITreeMenuItem>
</BUITreeMenu>
"""
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """
<BUITreeMenu TItem="object" Size="SizeEnum.Small">...</BUITreeMenu>
<BUITreeMenu TItem="object" Size="SizeEnum.Medium">...</BUITreeMenu>
<BUITreeMenu TItem="object" Size="SizeEnum.Large">...</BUITreeMenu>
"""
    };

    private ComponentDemoDefinition CustomContentDemo => new()
    {
        Demo = RenderCustomContent(),
        Code = """
<BUITreeMenu TItem="object">
    <BUITreeMenuItem Key="custom">
        <NodeContent>
            <div style="display: flex; align-items: center; gap: 8px;">
                <BUISvgIcon Icon="@BUIIcons.UI.Star" />
                <strong style="color: var(--palette-primary);">Premium</strong>
                <span class="badge">NEW</span>
            </div>
        </NodeContent>
    </BUITreeMenuItem>
</BUITreeMenu>
"""
    };

    private ComponentDemoDefinition LazyLoadingDemo => new()
    {
        Demo = RenderLazyLoading(),
        Code = """
<BUITreeMenu TItem="MenuItem"
             Items="@LazyItems"
             KeySelector="@(x => x.Id)"
             ChildrenSelector="@(x => x.Children)"
             HasChildrenSelector="@(x => x.Children?.Count > 0)"
             OnLoadChildren="@LoadChildrenAsync">
    <NodeTemplate Context="node">
        <span>@node.Item?.Name</span>
    </NodeTemplate>
</BUITreeMenu>
"""
    };

    /* ===================== RENDER FRAGMENTS ===================== */

    private RenderFragment RenderBasicDeclarative() => __builder =>
    {
        <BUITreeMenu TItem="object">
            <BUITreeMenuItem Text="Home" Icon="@BUIIcons.MaterialIconsOutlined.i_home" />
            <BUITreeMenuItem Text="Products" Icon="@BUIIcons.MaterialIconsOutlined.i_inbox" InitiallyExpanded>
                <ChildContent>
                    <BUITreeMenuItem Text="All Products" />
                    <BUITreeMenuItem Text="Categories" />
                </ChildContent>
            </BUITreeMenuItem>
            <BUITreeMenuItem Text="Settings" Icon="@BUIIcons.UI.Settings" />
        </BUITreeMenu>
        ;
    };

    private RenderFragment RenderDataBound() => __builder =>
    {
        <BUITreeMenu TItem="MenuItem"
                     Items="@MenuItems"
                     KeySelector="@(x => x.Id)"
                     ChildrenSelector="@(x => x.Children)">
            <NodeTemplate Context="node">
                @if (!string.IsNullOrEmpty(node.Item?.Icon))
                {
                    <BUISvgIcon Icon="@node.Item.Icon" Size="SizeEnum.Small" />
                }
                <span>@node.Item?.Name</span>
            </NodeTemplate>
        </BUITreeMenu>
;
    };

    private RenderFragment RenderNavigation() => __builder =>
    {
        <div>
            <BUITreeMenu TItem="object" OnNavigate="@HandleNavigate">
                <BUITreeMenuItem Text="Dashboard" Href="/dashboard" Icon="@BUIIcons.MaterialIconsOutlined.i_home" />
                <BUITreeMenuItem Text="Products" Icon="@BUIIcons.MaterialIconsOutlined.i_inbox">
                    <ChildContent>
                        <BUITreeMenuItem Text="All" Href="/products" />
                        <BUITreeMenuItem Text="Categories" Href="/products/categories" />
                    </ChildContent>
                </BUITreeMenuItem>
            </BUITreeMenu>
            @if (!string.IsNullOrEmpty(_lastNavigated))
            {
                <p style="margin-top: 1rem;">Last navigated: @_lastNavigated</p>
            }
        </div>
;
    };

    private RenderFragment RenderHorizontal() => __builder =>
    {
        <BUITreeMenu TItem="object"
                     Orientation="TreeMenuOrientation.Horizontal"
                     ExpandMode="TreeMenuExpandMode.Flyout">
            <BUITreeMenuItem Text="File">
                <ChildContent>
                    <BUITreeMenuItem Text="New" />
                    <BUITreeMenuItem Text="Open" />
                    <BUITreeMenuItem Text="Save" />
                </ChildContent>
            </BUITreeMenuItem>
            <BUITreeMenuItem Text="Edit">
                <ChildContent>
                    <BUITreeMenuItem Text="Undo" />
                    <BUITreeMenuItem Text="Redo" />
                </ChildContent>
            </BUITreeMenuItem>
            <BUITreeMenuItem Text="Help" />
        </BUITreeMenu>
        ;
    };

    private RenderFragment RenderFlyout() => __builder =>
    {
        <div style="min-height: 150px;">
            <BUITreeMenu TItem="object" ExpandMode="TreeMenuExpandMode.Flyout">
                <BUITreeMenuItem Text="Menu 1">
                    <ChildContent>
                        <BUITreeMenuItem Text="Submenu 1.1">
                            <ChildContent>
                                <BUITreeMenuItem Text="Item 1.1.1" />
                                <BUITreeMenuItem Text="Item 1.1.2" />
                            </ChildContent>
                        </BUITreeMenuItem>
                        <BUITreeMenuItem Text="Submenu 1.2" />
                    </ChildContent>
                </BUITreeMenuItem>
                <BUITreeMenuItem Text="Menu 2" />
            </BUITreeMenu>
        </div>
        ;
    };

    private RenderFragment RenderHoverTrigger() => __builder =>
    {
        <div style="min-height: 100px;">
            <BUITreeMenu TItem="object"
                         Trigger="TreeMenuTrigger.Hover"
                         ExpandMode="TreeMenuExpandMode.Flyout">
                <BUITreeMenuItem Text="Hover me">
                    <ChildContent>
                        <BUITreeMenuItem Text="Child 1" />
                        <BUITreeMenuItem Text="Child 2" />
                    </ChildContent>
                </BUITreeMenuItem>
            </BUITreeMenu>
        </div>
        ;
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <div class="demo-row" style="align-items: flex-start; gap: 2rem;">
            <div>
                <h4>Small</h4>
                <BUITreeMenu TItem="object" Size="SizeEnum.Small">
                    <BUITreeMenuItem Text="Item 1" />
                    <BUITreeMenuItem Text="Item 2" />
                </BUITreeMenu>
            </div>
            <div>
                <h4>Medium</h4>
                <BUITreeMenu TItem="object" Size="SizeEnum.Medium">
                    <BUITreeMenuItem Text="Item 1" />
                    <BUITreeMenuItem Text="Item 2" />
                </BUITreeMenu>
            </div>
            <div>
                <h4>Large</h4>
                <BUITreeMenu TItem="object" Size="SizeEnum.Large">
                    <BUITreeMenuItem Text="Item 1" />
                    <BUITreeMenuItem Text="Item 2" />
                </BUITreeMenu>
            </div>
        </div>
        ;
    };

    private RenderFragment RenderCustomContent() => __builder =>
    {
        <BUITreeMenu TItem="object">
            <BUITreeMenuItem Key="custom">
                <NodeContent>
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <BUISvgIcon Icon="@BUIIcons.MaterialIconsOutlined.i_star" Size="SizeEnum.Small" />
                        <strong style="color: var(--palette-primary);">Premium Feature</strong>
                        <span style="background: var(--palette-success); color: white; padding: 2px 6px; border-radius: 4px; font-size: 0.75rem;">NEW</span>
                    </div>
                </NodeContent>
            </BUITreeMenuItem>
            <BUITreeMenuItem Text="Regular Item" />
        </BUITreeMenu>
        ;
    };

    private List<MenuItem> LazyItems =>
    [
        new() { Id = "root1", Name = "Folder 1", Children = [] },
        new() { Id = "root2", Name = "Folder 2", Children = [] }
    ];

    private async Task<IEnumerable<MenuItem>> LoadChildrenAsync(MenuItem parent)
    {
        await Task.Delay(1000);
        return
        [
            new() { Id = $"{parent.Id}_1", Name = $"{parent.Name} - Child 1" },
            new() { Id = $"{parent.Id}_2", Name = $"{parent.Name} - Child 2" }
        ];
    }

    private RenderFragment RenderLazyLoading() => __builder =>
    {
        <BUITreeMenu TItem="MenuItem"
                     Items="@LazyItems"
                     KeySelector="@(x => x.Id)"
                     ChildrenSelector="@(x => x.Children)"
                     HasChildrenSelector="@(_ => true)"
                     OnLoadChildren="@LoadChildrenAsync">
            <NodeTemplate Context="node">
                <BUISvgIcon Icon="@BUIIcons.MaterialIconsOutlined.i_folder" Size="SizeEnum.Small" />
                <span>@node.Item?.Name</span>
            </NodeTemplate>
        </BUITreeMenu>
        ;
    };

    private void HandleNavigate(string href)
    {
        _lastNavigated = href;
    }

    /* ===================== PROPERTIES ===================== */

    private List<PropertyDefinition> Properties =
    [
        new("ChildContent", "RenderFragment?", "null", "Declarative menu items"),
        new("Items", "IEnumerable<TItem>?", "null", "Data source for data-bound mode"),
        new("KeySelector", "Func<TItem, string>?", "null", "Selector for unique key"),
        new("ChildrenSelector", "Func<TItem, IEnumerable<TItem>?>?", "null", "Selector for children"),
        new("HasChildrenSelector", "Func<TItem, bool>?", "null", "Selector to check if has children"),
        new("OnLoadChildren", "Func<TItem, Task<IEnumerable<TItem>>>?", "null", "Lazy load children"),
        new("NodeTemplate", "RenderFragment<TreeMenuNode<TItem>>?", "null", "Custom node template"),
        new("ExpandedKeys", "HashSet<string>?", "null", "Currently expanded keys"),
        new("ExpandedKeysChanged", "EventCallback<HashSet<string>>", "-", "Expanded keys changed event"),
        new("ExpandAll", "bool", "false", "Expand all nodes initially"),
        new("Orientation", "TreeMenuOrientation", "Vertical", "Menu orientation"),
        new("Trigger", "TreeMenuTrigger", "Click", "Expand trigger (Click/Hover)"),
        new("ExpandMode", "TreeMenuExpandMode", "Inline", "Expansion mode (Inline/Flyout)"),
        new("Size", "SizeEnum", "Medium", "Menu size"),
        new("Collapsible", "bool", "true", "Allow collapsing items"),
        new("OnNodeClick", "EventCallback<TreeNodeEventArgs>", "-", "Node click event"),
        new("OnNavigate", "EventCallback<string>", "-", "Navigation event")
    ];

    private List<PropertyDefinition> ItemProperties =
    [
        new("Key", "string?", "auto", "Unique identifier"),
        new("Text", "string?", "null", "Display text"),
        new("Icon", "string?", "null", "Icon path"),
        new("Href", "string?", "null", "Navigation URL"),
        new("Target", "string?", "null", "Link target (_blank, etc.)"),
        new("Match", "NavLinkMatch", "Prefix", "URL matching mode"),
        new("Disabled", "bool", "false", "Disable the item"),
        new("InitiallyExpanded", "bool", "false", "Start expanded"),
        new("OnClick", "EventCallback", "-", "Click event"),
        new("NodeContent", "RenderFragment?", "null", "Custom content"),
        new("ChildContent", "RenderFragment?", "null", "Child items")
    ];
}