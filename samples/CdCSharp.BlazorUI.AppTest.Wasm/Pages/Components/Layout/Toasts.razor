@* === Pages/Components/Toasts.razor === *@

@page "/components/toasts"

@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Components.Layout
@using CdCSharp.BlazorUI.Components.Layout.Toast.Services
@using CdCSharp.BlazorUI.Core.Css

@inject IToastService ToastService

<PageTitle>Toasts - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>Toasts</h1>

    <p class="doc-intro">
        <strong>BUIToast</strong> provides lightweight, non-blocking notifications that appear temporarily
        to inform users about actions, events, or system status. Toasts support auto-dismiss, manual control,
        pause on hover, multiple positions, animations, and stacking.
    </p>

    <!-- BASIC TOAST -->
    <section class="doc-section">
        <h2>Basic Toast</h2>
        <ComponentDemo Definition="@BasicToastDemo" />
    </section>

    <!-- TOAST POSITIONS -->
    <section class="doc-section">
        <h2>Toast Positions</h2>
        <ComponentDemo Definition="@PositionsDemo" />
    </section>

    <!-- AUTO DISMISS -->
    <section class="doc-section">
        <h2>Auto Dismiss Durations</h2>
        <ComponentDemo Definition="@AutoDismissDemo" />
    </section>

    <!-- PERSISTENT TOAST -->
    <section class="doc-section">
        <h2>Persistent Toast</h2>
        <ComponentDemo Definition="@PersistentToastDemo" />
    </section>

    <!-- ANIMATIONS -->
    <section class="doc-section">
        <h2>Animation Types</h2>
        <ComponentDemo Definition="@AnimationsDemo" />
    </section>

    <!-- CUSTOM CONTENT -->
    <section class="doc-section">
        <h2>Custom Content</h2>
        <ComponentDemo Definition="@CustomContentDemo" />
    </section>

    <!-- COMPONENT TOAST -->
    <section class="doc-section">
        <h2>Component Toast</h2>
        <ComponentDemo Definition="@ComponentToastDemo" />
    </section>

    <!-- INTERACTIVE TOAST -->
    <section class="doc-section">
        <h2>Interactive Toast</h2>
        <ComponentDemo Definition="@InteractiveToastDemo" />
    </section>

    <!-- STACKING -->
    <section class="doc-section">
        <h2>Stacking Toasts</h2>
        <ComponentDemo Definition="@StackingDemo" />
    </section>

    <!-- CLOSE OPTIONS -->
    <section class="doc-section">
        <h2>Close Options</h2>
        <ComponentDemo Definition="@CloseOptionsDemo" />
    </section>

    <!-- TOAST OPTIONS PROPERTIES -->
    <section class="doc-section">
        <h2>ToastOptions Properties</h2>
        <PropertyTable Properties="@ToastOptionsProperties" />
    </section>

    <!-- TOAST ANIMATION PROPERTIES -->
    <section class="doc-section">
        <h2>ToastAnimation Properties</h2>
        <PropertyTable Properties="@ToastAnimationProperties" />
    </section>

    <!-- SERVICE METHODS -->
    <section class="doc-section">
        <h2>IToastService Methods</h2>
        <PropertyTable Properties="@ServiceMethods" />
    </section>

    <!-- ENUMS -->
    <section class="doc-section">
        <h2>Enums</h2>
        <div class="enum-tables">
            <div>
                <h3>ToastPosition</h3>
                <PropertyTable Properties="@ToastPositionEnum" />
            </div>
            <div>
                <h3>ToastAnimationType</h3>
                <PropertyTable Properties="@ToastAnimationTypeEnum" />
            </div>
        </div>
    </section>
</div>

@code {
    /* ===================== HANDLERS ===================== */

    private void ShowBasicToast()
    {
        ToastService.Show(ShowBasicToast_Toast());
    }

    private void ShowPositionToast(ToastPosition position)
    {
        ToastService.Show(ShowPositionToast_Toast(position), new ToastOptions { Position = position });
    }

    private void ShowQuickToast()
    {
        ToastService.Show(ShowQuickToast_Toast(), ToastOptions.Quick);
    }

    private void ShowDefaultToast()
    {
        ToastService.Show(ShowDefaultToast_Toast(), ToastOptions.Default);
    }

    private void ShowLongToast()
    {
        ToastService.Show(ShowLongToast_Toast(), ToastOptions.Long);
    }

    private void ShowPersistentToast()
    {
        ToastService.Show(ShowPersistentToast_Toast(), ToastOptions.Persistent);
    }

    private void ShowAnimationToast(ToastAnimationType animationType)
    {
        ToastService.Show(ShowAnimationToast_Toast(animationType), new ToastOptions
        {
            Animation = new ToastAnimation { Type = animationType }
        });
    }

    private void ShowCustomContent()
    {
        ToastService.Show(ShowCustomContent_Toast(), new ToastOptions { Duration = TimeSpan.FromSeconds(6) });
    }

    private void ShowComponentToast()
    {
        ToastService.Show<NotificationToastComponent>(
            new Dictionary<string, object?>
            {
                ["Title"] = "New Message",
                ["Message"] = "You have a new message from Sarah.",
                ["Icon"] = "mail"
            },
            new ToastOptions { Duration = TimeSpan.FromSeconds(7) }
        );
    }

    private void ShowInteractiveToast()
    {
        ToastService.Show(ShowInteractiveToast_Toast(), new ToastOptions
        {
            AutoDismiss = false,
            Position = ToastPosition.BottomRight
        });
    }

    private void HandleToastAction()
    {
        ToastService.CloseAll();
        ToastService.Show(HandleToastAction_Toast(), ToastOptions.Quick);
    }

    private void ShowMultipleToasts()
    {
        for (int i = 1; i <= 5; i++)
        {
            int toastNumber = i;
            ToastService.Show(ShowMultipleToasts_Toast(toastNumber), new ToastOptions
            {
                Position = ToastPosition.TopRight,
                Duration = TimeSpan.FromSeconds(5 + toastNumber)
            });
        }
    }

    private void ShowNotClosableToast()
    {
        ToastService.Show(ShowNotClosableToast_Toast(), new ToastOptions
        {
            Closable = false,
            Duration = TimeSpan.FromSeconds(3)
        });
    }

    private void ShowWithCallbacks()
    {
        ToastService.Show(ShowWithCallbacks_Toast(), new ToastOptions
        {
            OnClick = () => Console.WriteLine("Toast clicked!"),
            OnClose = () => Console.WriteLine("Toast closed!"),
            Duration = TimeSpan.FromSeconds(5)
        });
    }

    /* ===================== TOAST CONTENT FRAGMENTS ===================== */

    private RenderFragment ShowBasicToast_Toast() => __builder =>
    {
        <div>
            <strong>Success!</strong>
            <p style="margin: 0.25rem 0 0 0;">Your changes have been saved.</p>
        </div>
    };

    private RenderFragment ShowPositionToast_Toast(ToastPosition position) => __builder =>
    {
        <div>Toast from <strong>@position</strong></div>
    };

    private RenderFragment ShowQuickToast_Toast() => __builder =>
    {
        <div>Quick message (2 seconds)</div>
    };

    private RenderFragment ShowDefaultToast_Toast() => __builder =>
    {
        <div>Default duration (5 seconds)</div>
    };

    private RenderFragment ShowLongToast_Toast() => __builder =>
    {
        <div>Longer message (10 seconds)</div>
    };

    private RenderFragment ShowPersistentToast_Toast() => __builder =>
    {
        <div>
            <strong>Persistent Toast</strong>
            <p style="margin: 0.25rem 0 0 0;">This will stay until you close it.</p>
        </div>
    };

    private RenderFragment ShowAnimationToast_Toast(ToastAnimationType animationType) => __builder =>
    {
        string animationName = animationType switch
        {
            ToastAnimationType.None => "No animation",
            ToastAnimationType.Fade => "Fade",
            ToastAnimationType.Slide => "Slide",
            ToastAnimationType.SlideAndFade => "Slide & Fade",
            _ => "Unknown"
        };

        <div>Animation: <strong>@animationName</strong></div>
    };

    private RenderFragment ShowCustomContent_Toast() => __builder =>
    {
        <div style="display: flex; align-items: center; gap: 0.75rem;">
            <div style="flex-shrink: 0; width: 40px; height: 40px; border-radius: 50%; background: var(--palette-primary); display: flex; align-items: center; justify-content: center; color: var(--palette-primary-contrast);">
                <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                </svg>
            </div>
            <div>
                <strong style="display: block; margin-bottom: 0.25rem;">File uploaded successfully</strong>
                <span style="font-size: 0.875rem; opacity: 0.8;">document.pdf (2.4 MB)</span>
            </div>
        </div>
    };

    private RenderFragment ShowInteractiveToast_Toast() => __builder =>
    {
        <div>
            <strong style="display: block; margin-bottom: 0.5rem;">Update Available</strong>
            <p style="margin: 0 0 0.75rem 0; font-size: 0.875rem;">A new version is ready to install.</p>
            <div style="display: flex; gap: 0.5rem;">
                <button @onclick="HandleToastAction"
                        style="padding: 0.375rem 0.75rem; border: 1px solid currentColor; border-radius: 4px; background: transparent; color: inherit; cursor: pointer; font-size: 0.875rem;">
                    Update Now
                </button>
                <button style="padding: 0.375rem 0.75rem; border: none; border-radius: 4px; background: transparent; color: inherit; cursor: pointer; font-size: 0.875rem; opacity: 0.7;">
                    Later
                </button>
            </div>
        </div>
    };

    private RenderFragment HandleToastAction_Toast() => __builder =>
    {
        <div>Update started...</div>
    };

    private RenderFragment ShowMultipleToasts_Toast(int toastNumber) => __builder =>
    {
        <div>Toast #@toastNumber</div>
    };

    private RenderFragment ShowNotClosableToast_Toast() => __builder =>
    {
        <div>
            <strong>Processing...</strong>
            <p style="margin: 0.25rem 0 0 0;">Cannot be closed manually</p>
        </div>
    };

    private RenderFragment ShowWithCallbacks_Toast() => __builder =>
    {
        <div>Click me or wait for auto-close</div>
    };

    /* ===================== DEMOS ===================== */

    private ComponentDemoDefinition BasicToastDemo => new()
    {
        Demo = RenderBasicToast(),
        Code = """
@inject IToastService ToastService

<BUIButton Text="Show Toast" OnClick="ShowToast" />

@code {
    private void ShowToast()
    {
        ToastService.Show(ShowToast_Content());
    }

    private RenderFragment ShowToast_Content() => __builder =>
    {
        <div>
            <strong>Success!</strong>
            <p style="margin: 0.25rem 0 0 0;">Your changes have been saved.</p>
        </div>
    };
}
"""
    };

    private ComponentDemoDefinition PositionsDemo => new()
    {
        Demo = RenderPositions(),
        Code = """
private void ShowToast(ToastPosition position)
{
    ToastService.Show(Content(), new ToastOptions { Position = position });
}

private RenderFragment Content() => __builder =>
{
    <div>Toast content</div>
};

// Available positions:
// ToastPosition.TopLeft, TopCenter, TopRight
// ToastPosition.BottomLeft, BottomCenter, BottomRight
"""
    };

    private ComponentDemoDefinition AutoDismissDemo => new()
    {
        Demo = RenderAutoDismiss(),
        Code = """
// Quick (2 seconds)
ToastService.Show(content, ToastOptions.Quick);

// Default (5 seconds)
ToastService.Show(content, ToastOptions.Default);

// Long (10 seconds)
ToastService.Show(content, ToastOptions.Long);

// Custom duration
ToastService.Show(content, new ToastOptions
{
    Duration = TimeSpan.FromSeconds(7)
});
"""
    };

    private ComponentDemoDefinition PersistentToastDemo => new()
    {
        Demo = RenderPersistent(),
        Code = """
private void ShowPersistent()
{
    ToastService.Show(Content(), ToastOptions.Persistent);
}

private RenderFragment Content() => __builder =>
{
    <div>
        <strong>Persistent Toast</strong>
        <p style="margin: 0.25rem 0 0 0;">This will stay until you close it.</p>
    </div>
};
"""
    };

    private ComponentDemoDefinition AnimationsDemo => new()
    {
        Demo = RenderAnimations(),
        Code = """
ToastService.Show(content, new ToastOptions
{
    Animation = ToastAnimation.SlideAndFade
    // ToastAnimation.FadeOnly
    // ToastAnimation.SlideOnly
    // ToastAnimation.None
});

// Custom animation
ToastService.Show(content, new ToastOptions
{
    Animation = new ToastAnimation
    {
        Type = ToastAnimationType.Slide,
        Duration = TimeSpan.FromMilliseconds(500),
        Easing = "cubic-bezier(0.4, 0, 0.2, 1)"
    }
});
"""
    };

    private ComponentDemoDefinition CustomContentDemo => new()
    {
        Demo = RenderCustomContent(),
        Code = """
private void ShowCustom()
{
    ToastService.Show(CustomContent(), new ToastOptions { Duration = TimeSpan.FromSeconds(6) });
}

private RenderFragment CustomContent() => __builder =>
{
    <div style="display: flex; align-items: center; gap: 0.75rem;">
        <div style="flex-shrink: 0; width: 40px; height: 40px; border-radius: 50%; background: var(--palette-primary); display: flex; align-items: center; justify-content: center; color: var(--palette-primary-contrast);">
            <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
            </svg>
        </div>
        <div>
            <strong style="display: block; margin-bottom: 0.25rem;">File uploaded successfully</strong>
            <span style="font-size: 0.875rem; opacity: 0.8;">document.pdf (2.4 MB)</span>
        </div>
    </div>
};
"""
    };

    private ComponentDemoDefinition ComponentToastDemo => new()
    {
        Demo = RenderComponentToast(),
        Code = """
ToastService.Show<NotificationToast>(
    new Dictionary<string, object?>
    {
        ["Title"] = "New Message",
        ["Message"] = "You have a new message from Sarah.",
        ["Icon"] = "mail"
    },
    new ToastOptions { Duration = TimeSpan.FromSeconds(7) }
);

// NotificationToast.razor
<div style="display: flex; gap: 0.75rem;">
    <div>@Icon</div>
    <div>
        <strong>@Title</strong>
        <p>@Message</p>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; }
    [Parameter] public string Message { get; set; }
    [Parameter] public string Icon { get; set; }
}
"""
    };

    private ComponentDemoDefinition InteractiveToastDemo => new()
    {
        Demo = RenderInteractive(),
        Code = """
private void ShowInteractive()
{
    ToastService.Show(InteractiveContent(), new ToastOptions { AutoDismiss = false });
}

private RenderFragment InteractiveContent() => __builder =>
{
    <div>
        <strong style="display: block; margin-bottom: 0.5rem;">Update Available</strong>
        <p style="margin: 0 0 0.75rem 0; font-size: 0.875rem;">A new version is ready to install.</p>
        <div style="display: flex; gap: 0.5rem;">
            <button @onclick="HandleUpdate"
                    style="padding: 0.375rem 0.75rem; border: 1px solid currentColor; border-radius: 4px; background: transparent; color: inherit; cursor: pointer; font-size: 0.875rem;">
                Update Now
            </button>
            <button style="padding: 0.375rem 0.75rem; border: none; border-radius: 4px; background: transparent; color: inherit; cursor: pointer; font-size: 0.875rem; opacity: 0.7;">
                Later
            </button>
        </div>
    </div>
};
"""
    };

    private ComponentDemoDefinition StackingDemo => new()
    {
        Demo = RenderStacking(),
        Code = """
// Multiple toasts will stack automatically
for (int i = 1; i <= 5; i++)
{
    int toastNumber = i;
    ToastService.Show(Content(toastNumber));
}

private RenderFragment Content(int number) => __builder =>
{
    <div>Toast #@number</div>
};

// Control max visible per position in BUIToastHost
<BUIToastHost MaxVisiblePerPosition="5" />
"""
    };

    private ComponentDemoDefinition CloseOptionsDemo => new()
    {
        Demo = RenderCloseOptions(),
        Code = """
// Not closable manually (auto-dismiss only)
ToastService.Show(content, new ToastOptions
{
    Closable = false,
    Duration = TimeSpan.FromSeconds(3)
});

// With callbacks
ToastService.Show(content, new ToastOptions
{
    OnClick = () => Console.WriteLine("Clicked!"),
    OnClose = () => Console.WriteLine("Closed!")
});
"""
    };

    /* ===================== RENDER FRAGMENTS ===================== */

    private RenderFragment RenderBasicToast() => __builder =>
    {
        <BUIButton Text="Show Toast"
                   OnClick="ShowBasicToast" />
    };

    private RenderFragment RenderPositions() => __builder =>
    {
        <div class="demo-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem;">
            <BUIButton Text="Top Left"
                       OnClick="() => ShowPositionToast(ToastPosition.TopLeft)" />
            <BUIButton Text="Top Center"
                       OnClick="() => ShowPositionToast(ToastPosition.TopCenter)" />
            <BUIButton Text="Top Right"
                       OnClick="() => ShowPositionToast(ToastPosition.TopRight)" />
            <BUIButton Text="Bottom Left"
                       OnClick="() => ShowPositionToast(ToastPosition.BottomLeft)" />
            <BUIButton Text="Bottom Center"
                       OnClick="() => ShowPositionToast(ToastPosition.BottomCenter)" />
            <BUIButton Text="Bottom Right"
                       OnClick="() => ShowPositionToast(ToastPosition.BottomRight)" />
        </div>
    };

    private RenderFragment RenderAutoDismiss() => __builder =>
    {
        <div class="demo-row">
            <BUIButton Text="Quick (2s)"
                       OnClick="ShowQuickToast" />
            <BUIButton Text="Default (5s)"
                       OnClick="ShowDefaultToast" />
            <BUIButton Text="Long (10s)"
                       OnClick="ShowLongToast" />
        </div>
    };

    private RenderFragment RenderPersistent() => __builder =>
    {
        <BUIButton Text="Show Persistent Toast"
                   OnClick="ShowPersistentToast" />
    };

    private RenderFragment RenderAnimations() => __builder =>
    {
        <div class="demo-row">
            <BUIButton Text="None"
                       OnClick="() => ShowAnimationToast(ToastAnimationType.None)" />
            <BUIButton Text="Fade"
                       OnClick="() => ShowAnimationToast(ToastAnimationType.Fade)" />
            <BUIButton Text="Slide"
                       OnClick="() => ShowAnimationToast(ToastAnimationType.Slide)" />
            <BUIButton Text="Slide & Fade"
                       OnClick="() => ShowAnimationToast(ToastAnimationType.SlideAndFade)" />
        </div>
    };

    private RenderFragment RenderCustomContent() => __builder =>
    {
        <BUIButton Text="Show Custom Toast"
                   OnClick="ShowCustomContent" />
    };

    private RenderFragment RenderComponentToast() => __builder =>
    {
        <BUIButton Text="Show Component Toast"
                   OnClick="ShowComponentToast" />
    };

    private RenderFragment RenderInteractive() => __builder =>
    {
        <BUIButton Text="Show Interactive Toast"
                   OnClick="ShowInteractiveToast" />
    };

    private RenderFragment RenderStacking() => __builder =>
    {
        <BUIButton Text="Show 5 Toasts"
                   OnClick="ShowMultipleToasts" />
    };

    private RenderFragment RenderCloseOptions() => __builder =>
    {
        <div class="demo-row">
            <BUIButton Text="Not Closable"
                       OnClick="ShowNotClosableToast" />
            <BUIButton Text="With Callbacks"
                       OnClick="ShowWithCallbacks" />
        </div>
    };

    /* ===================== PROPERTIES ===================== */

    private List<PropertyDefinition> ToastOptionsProperties = new()
    {
        new("Position", "ToastPosition", "TopRight", "Screen position for the toast"),
        new("Animation", "ToastAnimation", "SlideAndFade", "Animation configuration"),
        new("AutoDismiss", "bool", "true", "Auto-close after duration"),
        new("Duration", "TimeSpan", "5 seconds", "Time before auto-dismiss"),
        new("Closable", "bool", "true", "Show close button"),
        new("OnClick", "Action?", "null", "Callback when toast is clicked"),
        new("OnClose", "Action?", "null", "Callback when toast closes"),
        new("CssClass", "string?", "null", "Additional CSS class"),
    };

    private List<PropertyDefinition> ToastAnimationProperties = new()
    {
        new("Type", "ToastAnimationType", "SlideAndFade", "Animation type"),
        new("Duration", "TimeSpan", "300ms", "Animation duration"),
        new("Easing", "string", "ease-out", "CSS easing function"),
    };

    private List<PropertyDefinition> ServiceMethods = new()
    {
        new("Show(RenderFragment, ToastOptions?)", "void", "-", "Show toast with render fragment"),
        new("Show(Action<RenderTreeBuilder>, ToastOptions?)", "void", "-", "Show toast with builder action"),
        new("Show<TComponent>(ToastOptions?)", "void", "-", "Show toast with component (no params)"),
        new("Show<TComponent>(IDictionary<string, object?>?, ToastOptions?)", "void", "-", "Show toast with component and parameters"),
        new("Pause(Guid)", "void", "-", "Pause auto-dismiss timer"),
        new("Resume(Guid)", "void", "-", "Resume auto-dismiss timer"),
        new("Close(Guid)", "void", "-", "Close specific toast"),
        new("CloseAll()", "void", "-", "Close all active toasts"),
    };

    private List<PropertyDefinition> ToastPositionEnum = new()
    {
        new("TopLeft", "-", "-", "Top-left corner"),
        new("TopCenter", "-", "-", "Top-center"),
        new("TopRight", "-", "-", "Top-right corner (default)"),
        new("BottomLeft", "-", "-", "Bottom-left corner"),
        new("BottomCenter", "-", "-", "Bottom-center"),
        new("BottomRight", "-", "-", "Bottom-right corner"),
    };

    private List<PropertyDefinition> ToastAnimationTypeEnum = new()
    {
        new("None", "-", "-", "No animation"),
        new("Fade", "-", "-", "Fade in/out"),
        new("Slide", "-", "-", "Slide from edge"),
        new("SlideAndFade", "-", "-", "Combined slide and fade (default)"),
    };
}