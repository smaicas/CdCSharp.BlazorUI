    <ChildContent>
        <p>Click anywhere on this card to trigger an action.</p>
    </ChildContent>
</BUICard>
"""
    };
    private RenderFragment RenderClickableCard() => __builder =>
    {
        <BUICard Title="Click Me"
                 Subtitle="This card is interactive"
                 Clickable="true"
                 OnClick="HandleCardClick">
            <ChildContent>
                <p>Click anywhere on this card to trigger an action.</p>
            </ChildContent>
        </BUICard>
        ;
    };

