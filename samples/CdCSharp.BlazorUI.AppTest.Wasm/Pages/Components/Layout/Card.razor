@code {
    private ComponentDemoDefinition BasicCardDemo => new()
    {
        Demo = RenderBasicCard(),
        Code = """
<BUICard Title="Card Title"
         Subtitle="Card subtitle">
    <ChildContent>
        <p>This is the main content of the card. It can contain any content you want.</p>
    </ChildContent>
</BUICard>
"""
    };
    private RenderFragment RenderBasicCard() => __builder =>
    {
        <BUICard Title="Card Title"
                 Subtitle="Card subtitle">
            <ChildContent>
                <p>This is the main content of the card. It can contain any content you want.</p>
            </ChildContent>
        </BUICard>
        ;
    };
    private ComponentDemoDefinition CustomHeaderCardDemo => new()
    {
        Demo = RenderCustomHeaderCard(),
        Code = """
<BUICard>
    <Header>
        <div style="display: flex; align-items: center; gap: 1rem;">
            <BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_verified_user" />
            <div>
                <h3>Custom Header</h3>
                <p>With custom layout</p>
            </div>
        </div>
    </Header>
    <ChildContent>
        <p>Card content goes here.</p>
    </ChildContent>
</BUICard>
"""
    };
    private RenderFragment RenderCustomHeaderCard() => __builder =>
    {
        <BUICard Title="Beautiful Landscape"
                 Subtitle="Nature photography"
                 MediaHeight="300px">
            <Media>
                <img src="https://picsum.photos/800/300" alt="Random landscape" />
            </Media>
            <ChildContent>
                <p>A stunning view of nature captured in perfect lighting conditions.</p>
            </ChildContent>
            <Actions>
                <BUIButton Text="Share" Variant="BUIButtonVariant.Default" />
                <BUIButton Text="Learn More" Variant="BUIButtonVariant.Default" />
            </Actions>
        </BUICard>
        ;
    };
    private ComponentDemoDefinition ImageCardDemo => new()
    {
        Demo = RenderImageCard(),
