@page "/components/loading"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared

<PageTitle>Loading Indicators - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>Loading Indicators</h1>
    <p class="doc-intro">
        Loading indicators provide visual feedback during asynchronous operations. 
        The library includes several variants suitable for different scenarios.
    </p>

    <div class="doc-section">
        <h2>Variants</h2>
        <ComponentDemo Code="@variantsCode">
            <Demo>
                <div class="loading-grid">
                    <div class="loading-item">
                        <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" />
                        <span>Spinner</span>
                    </div>
                    <div class="loading-item">
                        <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Dots" />
                        <span>Dots</span>
                    </div>
                    <div class="loading-item">
                        <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Pulse" />
                        <span>Pulse</span>
                    </div>
                    <div class="loading-item">
                        <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.LinearIndeterminate" />
                        <span>LinearIndeterminate</span>
                    </div>
                    <div class="loading-item">
                        <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.CircularProgress" />
                        <span>CircularProgress</span>
                    </div>
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Sizes</h2>
        <ComponentDemo Code="@sizesCode">
            <Demo>
                <div class="demo-row">
                    <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Size="SizeEnum.Small" />
                    <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Size="SizeEnum.Medium" />
                    <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Size="SizeEnum.Large" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Colors</h2>
        <ComponentDemo Code="@colorsCode">
            <Demo>
                <div class="demo-row">
                    <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Color="@BUIColor.Blue.Default" />
                    <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Color="@BUIColor.Green.Default" />
                    <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Color="@BUIColor.Red.Default" />
                    <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" class="color-primary" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Integration with Buttons</h2>
        <ComponentDemo Code="@buttonIntegrationCode">
            <Demo>
                <div class="demo-row">
                    <BUIButton Text="Loading..." 
                             IsLoading="true" 
                             LoadingIndicatorVariant="BUILoadingIndicatorVariant.Spinner" />
                    <BUIButton Text="Saving..." 
                             IsLoading="true" 
                             LoadingIndicatorVariant="BUILoadingIndicatorVariant.Dots" 
                             Color="@BUIColor.Green.Default" />
                    <BUIButton Text="Processing..." 
                             IsLoading="true" 
                             LoadingIndicatorVariant="BUILoadingIndicatorVariant.Pulse" 
                             Size="SizeEnum.Large" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Loading States in Components</h2>
        <ComponentDemo Code="@loadingStateCode">
            <Demo>
                <div class="loading-state-demo">
                    @if (_isLoading)
                    {
                        <div class="loading-overlay">
                            <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.CircularProgress" Size="SizeEnum.Large" />
                            <p>Loading data...</p>
                        </div>
                    }
                    else
                    {
                        <div class="content">
                            <h4>Content Loaded</h4>
                            <p>This content appears after loading.</p>
                        </div>
                    }
                    <BUIButton Text="@(_isLoading ? "Loading..." : "Simulate Load")" 
                             OnClick="SimulateLoading" 
                             IsLoading="_isLoading"
                             LoadingIndicatorVariant="BUILoadingIndicatorVariant.Dots" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Properties</h2>
        <PropertyTable TItem="LoadingProperty" Items="@LoadingProperties">
            <PropertyTemplate Context="prop">
                <td><code>@prop.Name</code></td>
                <td><code>@prop.Type</code></td>
                <td><code>@prop.Default</code></td>
                <td>@prop.Description</td>
            </PropertyTemplate>
        </PropertyTable>
    </div>
</div>

@code {
    private bool _isLoading = false;

    private async Task SimulateLoading()
    {
        _isLoading = true;
        await Task.Delay(2000);
        _isLoading = false;
    }

    private string variantsCode = @"<BUILoadingIndicator Variant=""BUILoadingIndicatorVariant.Spinner"" />
<BUILoadingIndicator Variant=""BUILoadingIndicatorVariant.Dots"" />
<BUILoadingIndicator Variant=""BUILoadingIndicatorVariant.Pulse"" />
<BUILoadingIndicator Variant=""BUILoadingIndicatorVariant.Bar"" />
<BUILoadingIndicator Variant=""BUILoadingIndicatorVariant.Ring"" />";

    private string sizesCode = @"<BUILoadingIndicator Variant=""BUILoadingIndicatorVariant.Spinner"" Size=""SizeEnum.Small"" />
<BUILoadingIndicator Variant=""BUILoadingIndicatorVariant.Spinner"" Size=""SizeEnum.Medium"" />
<BUILoadingIndicator Variant=""BUILoadingIndicatorVariant.Spinner"" Size=""SizeEnum.Large"" />";

    private string colorsCode = @"<BUILoadingIndicator Variant=""BUILoadingIndicatorVariant.Spinner"" Color=""@UIColor.Blue"" />
<BUILoadingIndicator Variant=""BUILoadingIndicatorVariant.Spinner"" Color=""@UIColor.Green"" />
<BUILoadingIndicator Variant=""BUILoadingIndicatorVariant.Spinner"" Color=""var(--palette-primary)"" />";

    private string buttonIntegrationCode = @"<BUIButton Text=""Loading..."" 
         IsLoading=""true"" 
         LoadingIndicatorVariant=""BUILoadingIndicatorVariant.Spinner"" />";

    private string loadingStateCode = @"@if (_isLoading)
{
    <div class=""loading-overlay"">
        <BUILoadingIndicator Variant=""BUILoadingIndicatorVariant.Ring"" Size=""SizeEnum.Large"" />
        <p>Loading data...</p>
    </div>
}
else
{
    <div class=""content"">
        <h4>Content Loaded</h4>
        <p>This content appears after loading.</p>
    </div>
}";

    private record LoadingProperty(string Name, string Type, string Default, string Description);

    private List<LoadingProperty> LoadingProperties = new()
    {
        new("Variant", "BUILoadingIndicatorVariant", "Spinner", "The visual style of the loading indicator"),
        new("Size", "SizeEnum", "Medium", "Size of the loading indicator"),
        new("Color", "string?", "null", "Color of the loading indicator (CSS color or UIColor)"),
    };
}