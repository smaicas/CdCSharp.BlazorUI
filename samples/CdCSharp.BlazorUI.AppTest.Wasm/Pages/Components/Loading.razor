@page "/components/loading"

@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Core.Css

<PageTitle>Loading Indicators - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>BUILoadingIndicator</h1>

    <p class="doc-intro">
        <strong>BUILoadingIndicator</strong> provides visual feedback during asynchronous
        operations, offering multiple variants and sizes to fit different use cases.
    </p>

    <!-- VARIANTS -->
    <section class="doc-section">
        <h2>Variants</h2>
        <ComponentDemo Definition="@VariantsDemo" />
    </section>

    <!-- SIZES -->
    <section class="doc-section">
        <h2>Sizes</h2>
        <ComponentDemo Definition="@SizesDemo" />
    </section>

    <!-- COLORS -->
    <section class="doc-section">
        <h2>Colors</h2>
        <ComponentDemo Definition="@ColorsDemo" />
    </section>

    <!-- BUTTON INTEGRATION -->
    <section class="doc-section">
        <h2>Integration with buttons</h2>
        <ComponentDemo Definition="@ButtonIntegrationDemo" />
    </section>

    <!-- LOADING STATE -->
    <section class="doc-section">
        <h2>Loading states</h2>
        <ComponentDemo Definition="@LoadingStateDemo" />
    </section>

    <!-- PROPERTIES -->
    <section class="doc-section">
        <h2>Properties</h2>
        <PropertyTable Properties="@Properties" />
    </section>
</div>

@code {
    private bool IsLoading;

    /* ===================== DEMOS ===================== */

    private ComponentDemoDefinition VariantsDemo => new()
    {
        Demo = RenderVariants(),
        Code = """
<BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" />
<BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Dots" />
<BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Pulse" />
<BUILoadingIndicator Variant="BUILoadingIndicatorVariant.LinearIndeterminate" />
<BUILoadingIndicator Variant="BUILoadingIndicatorVariant.CircularProgress" />
"""
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """
<BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Size="SizeEnum.Small" />
<BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Size="SizeEnum.Medium" />
<BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Size="SizeEnum.Large" />
"""
    };

    private ComponentDemoDefinition ColorsDemo => new()
    {
        Demo = RenderColors(),
        Code = """
<BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Color="BUIColor.Blue.Default" />
<BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Color="BUIColor.Green.Default" />
<BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Color="BUIColor.Red.Default" />
"""
    };

    private ComponentDemoDefinition ButtonIntegrationDemo => new()
    {
        Demo = RenderButtonIntegration(),
        Code = """
<BUIButton Text="Loading..."
           IsLoading
           LoadingIndicatorVariant="BUILoadingIndicatorVariant.Spinner" />

<BUIButton Text="Saving..."
           IsLoading
           LoadingIndicatorVariant="BUILoadingIndicatorVariant.Dots"
           Color="BUIColor.Green.Default" />

<BUIButton Text="Processing..."
           IsLoading
           LoadingIndicatorVariant="BUILoadingIndicatorVariant.Pulse"
           Size="SizeEnum.Large" />
"""
    };

    private ComponentDemoDefinition LoadingStateDemo => new()
    {
        Demo = RenderLoadingState(),
        Code = """
@if (IsLoading)
{
    <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.CircularProgress"
                          Size="SizeEnum.Large" />
}
"""
    };

    /* ===================== RENDER FRAGMENTS ===================== */

    private RenderFragment RenderVariants() => __builder =>
    {
        <div class="loading-grid">
            <div class="loading-item">
                <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" />
                <span>Spinner</span>
            </div>
            <div class="loading-item">
                <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Dots" />
                <span>Dots</span>
            </div>
            <div class="loading-item">
                <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Pulse" />
                <span>Pulse</span>
            </div>
            <div class="loading-item">
                <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.LinearIndeterminate" />
                <span>Linear</span>
            </div>
            <div class="loading-item">
                <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.CircularProgress" />
                <span>Circular</span>
            </div>
        </div>
        ;
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <div class="demo-row">
            <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Size="SizeEnum.Small" />
            <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Size="SizeEnum.Medium" />
            <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Size="SizeEnum.Large" />
        </div>
        ;
    };

    private RenderFragment RenderColors() => __builder =>
    {
        <div class="demo-row">
            <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Color="BUIColor.Blue.Default" />
            <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Color="BUIColor.Green.Default" />
            <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Color="BUIColor.Red.Default" />
        </div>
        ;
    };

    private RenderFragment RenderButtonIntegration() => __builder =>
    {
        <div class="demo-row">
            <BUIButton Text="Loading..."
                       IsLoading
                       LoadingIndicatorVariant="BUILoadingIndicatorVariant.Spinner" />

            <BUIButton Text="Saving..."
                       IsLoading
                       LoadingIndicatorVariant="BUILoadingIndicatorVariant.Dots"
                       Color="BUIColor.Green.Default" />

            <BUIButton Text="Processing..."
                       IsLoading
                       LoadingIndicatorVariant="BUILoadingIndicatorVariant.Pulse"
                       Size="SizeEnum.Large" />
        </div>
        ;
    };

    private RenderFragment RenderLoadingState() => __builder =>
    {
        <div class="loading-state-demo">
            @if (IsLoading)
            {
                <div class="loading-overlay">
                    <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.CircularProgress"
                                         Size="SizeEnum.Large" />
                    <p>Loading data...</p>
                </div>
            }
            else
            {
                <div class="content">
                    <h4>Content loaded</h4>
                    <p>This content appears after loading.</p>
                </div>
            }

            <BUIButton Text="Simulate load"
                       OnClick="@SimulateLoading"
                       IsLoading="@IsLoading"
                       LoadingIndicatorVariant="BUILoadingIndicatorVariant.Dots" />
        </div>
;
    };

    /* ===================== LOGIC ===================== */

    private async Task SimulateLoading()
    {
        IsLoading = true;
        await Task.Delay(2000);
        IsLoading = false;
    }

    /* ===================== PROPERTIES ===================== */

    private List<PropertyDefinition> Properties = new()
    {
        new("Variant", "BUILoadingIndicatorVariant", "Spinner", "Visual style of the indicator"),
        new("Size", "SizeEnum", "Medium", "Indicator size"),
        new("Color", "CssColor?", "null", "Indicator color"),
    };
}
