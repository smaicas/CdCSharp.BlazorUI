@page "/demo/radio"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared

<PageTitle>Radio - CdCSharp.BlazorUI</PageTitle>

<h1>BUIInputRadio</h1>

<h2>Basic Usage</h2>
<ComponentDemo Definition="@BasicUsageDemo" />

<h2>With Label</h2>
<ComponentDemo Definition="@WithLabelDemo" />

<h2>Orientation</h2>
<ComponentDemo Definition="@OrientationDemo" />

<h2>Sizes</h2>
<ComponentDemo Definition="@SizesDemo" />

<h2>Colors</h2>
<ComponentDemo Definition="@ColorsDemo" />

<h2>Density</h2>
<ComponentDemo Definition="@DensityDemo" />

<h2>Custom Icons</h2>
<ComponentDemo Definition="@CustomIconsDemo" />

<h2>Clearable</h2>
<ComponentDemo Definition="@ClearableDemo" />

<h2>Disabled</h2>
<ComponentDemo Definition="@DisabledDemo" />

@code {
    private string? _basicValue = "option1";
    private string? _labelValue = "option2";
    private string? _verticalValue = "option1";
    private string? _horizontalValue = "option2";
    private string? _smallValue = "option1";
    private string? _mediumValue = "option2";
    private string? _largeValue = "option3";
    private string? _primaryValue = "option1";
    private string? _secondaryValue = "option2";
    private string? _compactValue = "option1";
    private string? _standardValue = "option2";
    private string? _comfortableValue = "option1";
    private string? _customIconValue = "option1";
    private string? _clearableValue = "option2";
    private string? _disabledValue = "option1";

    private ComponentDemoDefinition BasicUsageDemo => new()
    {
        Demo = RenderBasicUsage(),
        Code = """ """
    };

    private RenderFragment RenderBasicUsage() => __builder =>
    {
        <BUIInputRadio @bind-Value="_basicValue">
            <RadioOption Value="@("option1")">Option 1</RadioOption>
            <RadioOption Value="@("option2")">Option 2</RadioOption>
            <RadioOption Value="@("option3")">Option 3</RadioOption>
        </BUIInputRadio>
    };

    private ComponentDemoDefinition WithLabelDemo => new()
    {
        Demo = RenderWithLabel(),
        Code = """ """
    };

    private RenderFragment RenderWithLabel() => __builder =>
    {
        <BUIInputRadio @bind-Value="_labelValue"
                       Label="Choose an option"
                       HelperText="Select one of the available options">
            <RadioOption Value="@("option1")">Option 1</RadioOption>
            <RadioOption Value="@("option2")">Option 2</RadioOption>
            <RadioOption Value="@("option3")">Option 3</RadioOption>
        </BUIInputRadio>
    };

    private ComponentDemoDefinition OrientationDemo => new()
    {
        Demo = RenderOrientation(),
        Code = """ """
    };

    private RenderFragment RenderOrientation() => __builder =>
    {
        <BUIGrid Gap="2rem">
            <BUIGridItem>
                <BUIInputRadio @bind-Value="_verticalValue"
                               Label="Vertical (Default)"
                               Orientation="RadioOrientation.Vertical">
                    <RadioOption Value="@("option1")">Option 1</RadioOption>
                    <RadioOption Value="@("option2")">Option 2</RadioOption>
                    <RadioOption Value="@("option3")">Option 3</RadioOption>
                </BUIInputRadio>
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputRadio @bind-Value="_horizontalValue"
                               Label="Horizontal"
                               Orientation="RadioOrientation.Horizontal">
                    <RadioOption Value="@("option1")">Option 1</RadioOption>
                    <RadioOption Value="@("option2")">Option 2</RadioOption>
                    <RadioOption Value="@("option3")">Option 3</RadioOption>
                </BUIInputRadio>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """ """
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUIInputRadio @bind-Value="_smallValue" Label="Small" Size="SizeEnum.Small">
                    <RadioOption Value="@("option1")">Option 1</RadioOption>
                    <RadioOption Value="@("option2")">Option 2</RadioOption>
                    <RadioOption Value="@("option3")">Option 3</RadioOption>
                </BUIInputRadio>
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputRadio @bind-Value="_mediumValue" Label="Medium (Default)" Size="SizeEnum.Medium">
                    <RadioOption Value="@("option1")">Option 1</RadioOption>
                    <RadioOption Value="@("option2")">Option 2</RadioOption>
                    <RadioOption Value="@("option3")">Option 3</RadioOption>
                </BUIInputRadio>
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputRadio @bind-Value="_largeValue" Label="Large" Size="SizeEnum.Large">
                    <RadioOption Value="@("option1")">Option 1</RadioOption>
                    <RadioOption Value="@("option2")">Option 2</RadioOption>
                    <RadioOption Value="@("option3")">Option 3</RadioOption>
                </BUIInputRadio>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition ColorsDemo => new()
    {
        Demo = RenderColors(),
        Code = """ """
    };

    private RenderFragment RenderColors() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUIInputRadio @bind-Value="_primaryValue" Label="Primary" Color="BUIColor.Palette.Primary">
                    <RadioOption Value="@("option1")">Option 1</RadioOption>
                    <RadioOption Value="@("option2")">Option 2</RadioOption>
                </BUIInputRadio>
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputRadio @bind-Value="_secondaryValue" Label="Secondary" Color="BUIColor.Palette.Secondary">
                    <RadioOption Value="@("option1")">Option 1</RadioOption>
                    <RadioOption Value="@("option2")">Option 2</RadioOption>
                </BUIInputRadio>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition DensityDemo => new()
    {
        Demo = RenderDensity(),
        Code = """ """
    };

    private RenderFragment RenderDensity() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUIInputRadio @bind-Value="_compactValue" Label="Compact" Density="DensityEnum.Compact">
                    <RadioOption Value="@("option1")">Option 1</RadioOption>
                    <RadioOption Value="@("option2")">Option 2</RadioOption>
                </BUIInputRadio>
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputRadio @bind-Value="_standardValue" Label="Standard (Default)" Density="DensityEnum.Standard">
                    <RadioOption Value="@("option1")">Option 1</RadioOption>
                    <RadioOption Value="@("option2")">Option 2</RadioOption>
                </BUIInputRadio>
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputRadio @bind-Value="_comfortableValue" Label="Comfortable" Density="DensityEnum.Comfortable">
                    <RadioOption Value="@("option1")">Option 1</RadioOption>
                    <RadioOption Value="@("option2")">Option 2</RadioOption>
                </BUIInputRadio>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition CustomIconsDemo => new()
    {
        Demo = RenderCustomIcons(),
        Code = """ """
    };

    private RenderFragment RenderCustomIcons() => __builder =>
    {
        <BUIInputRadio @bind-Value="_customIconValue"
                       Label="Custom Icons"
                       CheckedIcon="@BUIIcons.MaterialIconsRound.i_star"
                       UncheckedIcon="@BUIIcons.MaterialIconsRound.i_star_border">
            <RadioOption Value="@("option1")">Option 1</RadioOption>
            <RadioOption Value="@("option2")">Option 2</RadioOption>
        </BUIInputRadio>
    };

    private ComponentDemoDefinition ClearableDemo => new()
    {
        Demo = RenderClearable(),
        Code = """ """
    };

    private RenderFragment RenderClearable() => __builder =>
    {
        <BUIInputRadio @bind-Value="_clearableValue"
                       Label="Clearable"
                       Clearable="true"
                       ClearText="Clear selection">
            <RadioOption Value="@("option1")">Option 1</RadioOption>
            <RadioOption Value="@("option2")">Option 2</RadioOption>
            <RadioOption Value="@("option3")">Option 3</RadioOption>
        </BUIInputRadio>
    };

    private ComponentDemoDefinition DisabledDemo => new()
    {
        Demo = RenderDisabled(),
        Code = """ """
    };

    private RenderFragment RenderDisabled() => __builder =>
    {
        <BUIInputRadio @bind-Value="_disabledValue" Label="Disabled" Disabled="true">
            <RadioOption Value="@("option1")">Option 1</RadioOption>
            <RadioOption Value="@("option2")">Option 2</RadioOption>
        </BUIInputRadio>
    };
}