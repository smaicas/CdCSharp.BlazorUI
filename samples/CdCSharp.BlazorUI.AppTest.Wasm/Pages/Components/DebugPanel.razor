@implements IAsyncDisposable
@inject IJSRuntime JS

<!-- Panel de Debug Flotante -->
<div class="debug-panel @(_isOpen ? "open" : "")">
    <!-- Header del Panel -->
    <div class="debug-header">
        <button @onclick="TogglePanel" class="btn-close">⚒️</button>
    </div>

    @if (_isOpen)
    {
        <!-- Navegación por Tabs -->
        <div class="debug-tabs">
            @foreach (var tab in _tabs)
            {
                <button class="tab-btn @(_activeTab == tab ? "active" : "")"
                        @onclick="() => SetActiveTab(tab)">
                    @tab
                </button>
            }
        </div>

        <!-- Contenido según Tab Activo -->
        <div class="debug-content">
            @switch (_activeTab)
            {
                case "Visual":
                    @RenderVisualTab()
                    break;
                case "Theme":
                    @RenderThemeTab()
                    break;
                case "A11Y":
                    @RenderAccessibilityTab()
                    break;
                case "Performance":
                    @RenderPerformanceTab()
                    break;
                case "Network":
                    @RenderNetworkTab()
                    break;
                case "Inspector":
                    @RenderInspectorTab()
                    break;
                case "Config":
                    @RenderConfigTab()
                    break;
            }
        </div>
    }
</div>

@code {
    // Referencias y estado del componente
    private IJSObjectReference? _jsModule;
    private DotNetObjectReference<DebugPanel>? _dotNetRef;
    private bool _isOpen = false;
    private string _activeTab = "Visual";
    private readonly string[] _tabs = { "Visual", "Theme", "A11Y", "Performance", "Network", "Inspector", "Config" };

    // Estado Visual
    private VisualState _visualState = new();

    // Estado de Performance
    private PerformanceMetrics _metrics = new();
    private System.Timers.Timer? _metricsTimer;

    // Estado de Accesibilidad
    private AccessibilityReport _a11yReport = new();

    // Variables CSS
    private List<CssVariable> _cssVariables = new();

    // Inspector
    private ElementInfo? _selectedElement;

    // Network/CPU
    private NetworkState _networkState = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Cargar módulo JS
                _jsModule = await JS.InvokeAsync<IJSObjectReference>(
                    "import", "./js/DebugPanel.js");

                // Crear referencia .NET para callbacks
                _dotNetRef = DotNetObjectReference.Create(this);

                // Inicializar el módulo JS con referencia .NET
                await _jsModule.InvokeVoidAsync("initialize", _dotNetRef);

                // Cargar estado persistido
                await LoadPersistedState();

                // Iniciar timer de métricas
                StartMetricsTimer();

                StateHasChanged();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error inicializando DebugPanel: {ex.Message}");
            }
        }
    }

    // ============================================================
    // MÉTODOS DE NAVEGACIÓN Y TOGGLE
    // ============================================================

    private async Task TogglePanel()
    {
        _isOpen = !_isOpen;
        if (_jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("togglePanel", _isOpen);
        }
    }

    private void SetActiveTab(string tab)
    {
        _activeTab = tab;
    }

    // ============================================================
    // RENDERIZADO DE TABS
    // ============================================================

    private RenderFragment RenderVisualTab() => __builder =>
    {
        <div class="tab-section">
            <h4>Overlays Visuales</h4>

            <label class="toggle-control">
                <input type="checkbox" @bind="_visualState.XRayMode"
                       @bind:after="@(() => ApplyVisualMode("xray", _visualState.XRayMode))" />
                <span>Rayos X (Outline)</span>
            </label>

            <label class="toggle-control">
                <input type="checkbox" @bind="_visualState.GridMode"
                       @bind:after="@(() => ApplyVisualMode("grid", _visualState.GridMode))" />
                <span>Grid de Diseño</span>
            </label>

            <label class="toggle-control">
                <input type="checkbox" @bind="_visualState.ColumnsMode"
                       @bind:after="@(() => ApplyVisualMode("columns", _visualState.ColumnsMode))" />
                <span>Columnas Responsivas</span>
            </label>

            <label class="toggle-control">
                <input type="checkbox" @bind="_visualState.BreakpointsMode"
                       @bind:after="@(() => ApplyVisualMode("breakpoints", _visualState.BreakpointsMode))" />
                <span>Breakpoints</span>
            </label>

            <label class="toggle-control">
                <input type="checkbox" @bind="_visualState.HoverInfoMode"
                       @bind:after="@(() => ApplyVisualMode("hoverInfo", _visualState.HoverInfoMode))" />
                <span>Hover Info</span>
            </label>

            <h4>Filtros Visuales</h4>

            <label class="toggle-control">
                <input type="checkbox" @bind="_visualState.GrayscaleMode"
                       @bind:after="@(() => ApplyFilter("grayscale", _visualState.GrayscaleMode))" />
                <span>Escala de Grises</span>
            </label>

            <label class="toggle-control">
                <input type="checkbox" @bind="_visualState.HighContrastMode"
                       @bind:after="@(() => ApplyFilter("highContrast", _visualState.HighContrastMode))" />
                <span>Alto Contraste</span>
            </label>

            <label class="toggle-control">
                <input type="checkbox" @bind="_visualState.ReducedMotion"
                       @bind:after="@(() => ApplyFilter("reducedMotion", _visualState.ReducedMotion))" />
                <span>Reducir Animaciones</span>
            </label>

            <label class="select-control">
                <span>Simulación Color-Blind:</span>
                <select @bind="_visualState.ColorBlindMode"
                        @bind:after="() => ApplyColorBlindFilter(_visualState.ColorBlindMode)">
                    <option value="none">Ninguno</option>
                    <option value="protanopia">Protanopia</option>
                    <option value="deuteranopia">Deuteranopia</option>
                    <option value="tritanopia">Tritanopia</option>
                </select>
            </label>

            <h4>Animaciones</h4>

            <label class="slider-control">
                <span>Velocidad (@(_visualState.AnimationSpeed)x):</span>
                <input type="range" min="0.1" max="2" step="0.1"
                       @bind="_visualState.AnimationSpeed"
                       @bind:after="() => ApplyAnimationSpeed(_visualState.AnimationSpeed)" />
            </label>
        </div>
    };

    private RenderFragment RenderThemeTab() => __builder =>
    {
        <div class="tab-section">
            <h4>Variables CSS</h4>

            <button class="btn-action" @onclick="LoadCssVariables">Cargar Variables</button>
            <button class="btn-action" @onclick="ResetCssVariables">Reset</button>

            <div class="css-vars-list">
                @foreach (var cssVar in _cssVariables)
                {
                    <div class="css-var-item">
                        <label>@cssVar.Name</label>
                        <input type="text" @bind="cssVar.Value"
                               @bind:after="() => UpdateCssVariable(cssVar.Name, cssVar.Value)" />
                    </div>
                }
            </div>

            <h4>Gestión de Tema</h4>

            <button class="btn-action" @onclick="ExportTheme">Exportar JSON</button>
            <button class="btn-action" @onclick="ImportTheme">Importar JSON</button>
        </div>
    };

    private RenderFragment RenderAccessibilityTab() => __builder =>
    {
        <div class="tab-section">
            <h4>Análisis de Accesibilidad</h4>

            <button class="btn-action" @onclick="RunA11yAnalysis">Analizar Página</button>

            @if (_a11yReport.Issues.Any())
            {
                <div class="a11y-report">
                    <p><strong>Problemas encontrados: @_a11yReport.Issues.Count</strong></p>

                    @foreach (var issue in _a11yReport.Issues)
                    {
                        <div class="a11y-issue @issue.Severity">
                            <span class="severity">[@issue.Severity]</span>
                            <span>@issue.Message</span>
                            <small>Elementos: @issue.Count</small>
                        </div>
                    }
                </div>
            }

            <h4>Simulaciones</h4>

            <label class="toggle-control">
                <input type="checkbox" @bind="_visualState.HighlightA11yIssues"
                       @bind:after="() => HighlightA11yIssues(_visualState.HighlightA11yIssues)" />
                <span>Resaltar Problemas</span>
            </label>
        </div>
    };

    private RenderFragment RenderPerformanceTab() => __builder =>
    {
        <div class="tab-section">
            <h4>Métricas en Tiempo Real</h4>

            <div class="metric-row">
                <span>FPS:</span>
                <strong>@_metrics.Fps.ToString("F1")</strong>
            </div>

            <div class="metric-row">
                <span>Memoria:</span>
                <strong>@(_metrics.MemoryMB.ToString("F2")) MB</strong>
            </div>

            <div class="metric-row">
                <span>Renders:</span>
                <strong>@_metrics.RenderCount</strong>
            </div>

            <div class="metric-row">
                <span>Latencia Render:</span>
                <strong>@(_metrics.RenderLatency.ToString("F2")) ms</strong>
            </div>

            <div class="metric-row">
                <span>JS Interop:</span>
                <strong>@(_metrics.JsInteropLatency.ToString("F2")) ms</strong>
            </div>

            <button class="btn-action" @onclick="ClearMetrics">Limpiar Métricas</button>
        </div>
    };

    private RenderFragment RenderNetworkTab() => __builder =>
    {
        <div class="tab-section">
            <h4>Simulación de Red</h4>

            <label class="select-control">
                <span>Latencia:</span>
                <select @bind="_networkState.Latency"
                        @bind:after="() => ApplyNetworkLatency(_networkState.Latency)">
                    <option value="0">Sin latencia</option>
                    <option value="500">500ms (Lenta)</option>
                    <option value="2000">2s (Muy lenta)</option>
                    <option value="5000">5s (Offline)</option>
                </select>
            </label>

            <label class="select-control">
                <span>CPU Throttle:</span>
                <select @bind="_networkState.CpuThrottle"
                        @bind:after="() => ApplyCpuThrottle(_networkState.CpuThrottle)">
                    <option value="1">Normal</option>
                    <option value="2">2x más lento</option>
                    <option value="4">4x más lento</option>
                    <option value="6">6x más lento</option>
                </select>
            </label>

            <label class="toggle-control">
                <input type="checkbox" @bind="_networkState.OfflineMode"
                       @bind:after="() => ApplyOfflineMode(_networkState.OfflineMode)" />
                <span>Modo Offline</span>
            </label>
        </div>
    };

    private RenderFragment RenderInspectorTab() => __builder =>
    {
        <div class="tab-section">
            <h4>Inspector de Elementos</h4>

            <button class="btn-action" @onclick="EnableInspector">
                @(_visualState.InspectorMode ? "Desactivar" : "Activar") Inspector
            </button>

            @if (_selectedElement != null)
            {
                <div class="element-info">
                    <div class="info-row">
                        <span>Tag:</span>
                        <strong>@_selectedElement.TagName</strong>
                    </div>

                    @if (!string.IsNullOrEmpty(_selectedElement.Id))
                    {
                        <div class="info-row">
                            <span>ID:</span>
                            <strong>@_selectedElement.Id</strong>
                        </div>
                    }

                    @if (_selectedElement.ClassList.Any())
                    {
                        <div class="info-row">
                            <span>Classes:</span>
                            <strong>@string.Join(", ", _selectedElement.ClassList)</strong>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_selectedElement.Role))
                    {
                        <div class="info-row">
                            <span>Role:</span>
                            <strong>@_selectedElement.Role</strong>
                        </div>
                    }

                    <div class="info-row">
                        <span>Display:</span>
                        <strong>@_selectedElement.Display</strong>
                    </div>

                    <div class="info-row">
                        <span>Dimensions:</span>
                        <strong>@_selectedElement.Width x @_selectedElement.Height</strong>
                    </div>
                </div>
            }
        </div>
    };

    private RenderFragment RenderConfigTab() => __builder =>
    {
        <div class="tab-section">
            <h4>Configuración</h4>

            <button class="btn-action" @onclick="ExportConfig">Exportar Config</button>
            <button class="btn-action" @onclick="ImportConfig">Importar Config</button>
            <button class="btn-action" @onclick="SaveState">Guardar Estado</button>
            <button class="btn-action" @onclick="ResetAll">Reset Todo</button>

            <div class="info-box">
                <p><small>Hotkey: <strong>Ctrl+D</strong> para toggle</small></p>
                <p><small>Estado persiste en localStorage</small></p>
            </div>
        </div>
    };

    // ============================================================
    // MÉTODOS DE APLICACIÓN DE EFECTOS VISUALES
    // ============================================================

    private async Task ApplyVisualMode(string mode, bool enabled)
    {
        if (_jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("applyVisualMode", mode, enabled);
            await SaveState();
        }
    }

    private async Task ApplyFilter(string filter, bool enabled)
    {
        if (_jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("applyFilter", filter, enabled);
            await SaveState();
        }
    }

    private async Task ApplyColorBlindFilter(string mode)
    {
        if (_jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("applyColorBlindFilter", mode);
            await SaveState();
        }
    }

    private async Task ApplyAnimationSpeed(double speed)
    {
        if (_jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("applyAnimationSpeed", speed);
            await SaveState();
        }
    }

    // ============================================================
    // MÉTODOS DE CSS VARIABLES
    // ============================================================

    private async Task LoadCssVariables()
    {
        if (_jsModule != null)
        {
            try
            {
                var vars = await _jsModule.InvokeAsync<List<CssVariable>>("getCssVariables");
                _cssVariables = vars ?? new List<CssVariable>();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error cargando CSS variables: {ex.Message}");
            }
        }
    }

    private async Task UpdateCssVariable(string name, string value)
    {
        if (_jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("setCssVariable", name, value);
            await SaveState();
        }
    }

    private async Task ResetCssVariables()
    {
        if (_jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("resetCssVariables");
            _cssVariables.Clear();
        }
    }

    private async Task ExportTheme()
    {
        if (_jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("exportTheme");
        }
    }

    private async Task ImportTheme()
    {
        if (_jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("importTheme");
        }
    }

    // ============================================================
    // MÉTODOS DE ACCESIBILIDAD
    // ============================================================

    private async Task RunA11yAnalysis()
    {
        if (_jsModule != null)
        {
            try
            {
                var report = await _jsModule.InvokeAsync<AccessibilityReport>("analyzeAccessibility");
                _a11yReport = report ?? new AccessibilityReport();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error en análisis A11Y: {ex.Message}");
            }
        }
    }

    private async Task HighlightA11yIssues(bool enabled)
    {
        if (_jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("highlightA11yIssues", enabled);
        }
    }

    // ============================================================
    // MÉTODOS DE PERFORMANCE
    // ============================================================

    private void StartMetricsTimer()
    {
        _metricsTimer = new System.Timers.Timer(1000); // Cada segundo
        _metricsTimer.Elapsed += async (sender, e) => await UpdateMetrics();
        _metricsTimer.Start();
    }

    private async Task UpdateMetrics()
    {
        if (_jsModule != null)
        {
            try
            {
                var metrics = await _jsModule.InvokeAsync<PerformanceMetrics>("getPerformanceMetrics");
                _metrics = metrics ?? new PerformanceMetrics();
                _metrics.RenderCount++;

                await InvokeAsync(StateHasChanged);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error actualizando métricas: {ex.Message}");
            }
        }
    }

    private void ClearMetrics()
    {
        _metrics = new PerformanceMetrics();
    }

    // ============================================================
    // MÉTODOS DE NETWORK/CPU
    // ============================================================

    private async Task ApplyNetworkLatency(int latency)
    {
        if (_jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("applyNetworkLatency", latency);
            await SaveState();
        }
    }

    private async Task ApplyCpuThrottle(int throttle)
    {
        if (_jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("applyCpuThrottle", throttle);
            await SaveState();
        }
    }

    private async Task ApplyOfflineMode(bool enabled)
    {
        if (_jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("applyOfflineMode", enabled);
            await SaveState();
        }
    }

    // ============================================================
    // MÉTODOS DE INSPECTOR
    // ============================================================

    private async Task EnableInspector()
    {
        _visualState.InspectorMode = !_visualState.InspectorMode;

        if (_jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("enableInspector", _visualState.InspectorMode);
        }
    }

    [JSInvokable]
    public async Task OnElementSelected(ElementInfo element)
    {
        _selectedElement = element;
        await InvokeAsync(StateHasChanged);
    }

    // ============================================================
    // PERSISTENCIA DE ESTADO
    // ============================================================

    private async Task SaveState()
    {
        if (_jsModule != null)
        {
            var state = new DebugState
            {
                VisualState = _visualState,
                NetworkState = _networkState,
                CssVariables = _cssVariables
            };

            await _jsModule.InvokeVoidAsync("saveState", state);
        }
    }

    private async Task LoadPersistedState()
    {
        if (_jsModule != null)
        {
            try
            {
                var state = await _jsModule.InvokeAsync<DebugState>("loadState");
                if (state != null)
                {
                    _visualState = state.VisualState ?? new();
                    _networkState = state.NetworkState ?? new();
                    _cssVariables = state.CssVariables ?? new();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error cargando estado: {ex.Message}");
            }
        }
    }

    private async Task ExportConfig()
    {
        if (_jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("exportConfig");
        }
    }

    private async Task ImportConfig()
    {
        if (_jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("importConfig");
        }
    }

    private async Task ResetAll()
    {
        _visualState = new();
        _networkState = new();
        _cssVariables.Clear();
        _metrics = new();
        _a11yReport = new();
        _selectedElement = null;

        if (_jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("resetAll");
        }
    }

    // ============================================================
    // CLEANUP Y DISPOSICIÓN
    // ============================================================

    public async ValueTask DisposeAsync()
    {
        _metricsTimer?.Dispose();

        if (_jsModule != null)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("cleanup");
                await _jsModule.DisposeAsync();
            }
            catch { }
        }

        _dotNetRef?.Dispose();
    }

    // ============================================================
    // CLASES DE DATOS
    // ============================================================

    public class VisualState
    {
        public bool XRayMode { get; set; }
        public bool GridMode { get; set; }
        public bool ColumnsMode { get; set; }
        public bool BreakpointsMode { get; set; }
        public bool HoverInfoMode { get; set; }
        public bool GrayscaleMode { get; set; }
        public bool HighContrastMode { get; set; }
        public bool ReducedMotion { get; set; }
        public string ColorBlindMode { get; set; } = "none";
        public double AnimationSpeed { get; set; } = 1.0;
        public bool InspectorMode { get; set; }
        public bool HighlightA11yIssues { get; set; }
    }

    public class NetworkState
    {
        public int Latency { get; set; }
        public int CpuThrottle { get; set; } = 1;
        public bool OfflineMode { get; set; }
    }

    public class PerformanceMetrics
    {
        public double Fps { get; set; }
        public double MemoryMB { get; set; }
        public int RenderCount { get; set; }
        public double RenderLatency { get; set; }
        public double JsInteropLatency { get; set; }
    }

    public class CssVariable
    {
        public string Name { get; set; } = "";
        public string Value { get; set; } = "";
    }

    public class AccessibilityReport
    {
        public List<A11yIssue> Issues { get; set; } = new();
    }

    public class A11yIssue
    {
        public string Severity { get; set; } = "";
        public string Message { get; set; } = "";
        public int Count { get; set; }
    }

    public class ElementInfo
    {
        public string TagName { get; set; } = "";
        public string Id { get; set; } = "";
        public List<string> ClassList { get; set; } = new();
        public string Role { get; set; } = "";
        public string AriaLabel { get; set; } = "";
        public string Alt { get; set; } = "";
        public string Display { get; set; } = "";
        public int Width { get; set; }
        public int Height { get; set; }
        public string TextContent { get; set; } = "";
    }

    public class DebugState
    {
        public VisualState? VisualState { get; set; }
        public NetworkState? NetworkState { get; set; }
        public List<CssVariable>? CssVariables { get; set; }
    }
}