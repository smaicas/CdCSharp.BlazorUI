@page "/demo/checkbox"

<PageTitle>Checkbox - CdCSharp.BlazorUI</PageTitle>

<h1>BUIInputCheckbox</h1>

<h2>Basic Usage</h2>
<ComponentDemo Definition="@BasicUsageDemo" />

<h2>With Label</h2>
<ComponentDemo Definition="@WithLabelDemo" />

<h2>With Helper Text</h2>
<ComponentDemo Definition="@HelperTextDemo" />

<h2>Sizes</h2>
<ComponentDemo Definition="@SizesDemo" />

<h2>Colors</h2>
<ComponentDemo Definition="@ColorsDemo" />

<h2>Density</h2>
<ComponentDemo Definition="@DensityDemo" />

<h2>Custom Icons</h2>
<ComponentDemo Definition="@CustomIconsDemo" />

<h2>States</h2>
<ComponentDemo Definition="@StatesDemo" />

<h2>Indeterminate (Tri-State)</h2>
<ComponentDemo Definition="@IndeterminateDemo" />

@code {
    [CascadingParameter] public BUIPalette Palette { get; set; } = default!;

    private bool _basicValue;
    private bool _labelValue;
    private bool _helperValue;
    private bool _smallValue;
    private bool _mediumValue = true;
    private bool _largeValue;
    private bool _primaryValue = true;
    private bool _secondaryValue = true;
    private bool _successValue = true;
    private bool _errorValue = true;
    private bool _compactValue;
    private bool _standardValue = true;
    private bool _comfortableValue;
    private bool _customIconValue;
    private bool _disabledOnValue = true;
    private bool _disabledOffValue;
    private bool _requiredValue;
    private bool? _indeterminateValue = null;

    private ComponentDemoDefinition BasicUsageDemo => new()
    {
        Demo = RenderBasicUsage(),
        Code = """ """
    };

    private RenderFragment RenderBasicUsage() => __builder =>
    {
        <BUIInputCheckbox @bind-Value="_basicValue" />
    };

    private ComponentDemoDefinition WithLabelDemo => new()
    {
        Demo = RenderWithLabel(),
        Code = """ """
    };

    private RenderFragment RenderWithLabel() => __builder =>
    {
        <BUIInputCheckbox @bind-Value="_labelValue" Label="Accept terms and conditions" />
    };

    private ComponentDemoDefinition HelperTextDemo => new()
    {
        Demo = RenderHelperText(),
        Code = """ """
    };

    private RenderFragment RenderHelperText() => __builder =>
    {
        <BUIInputCheckbox @bind-Value="_helperValue"
                          Label="Subscribe to newsletter"
                          HelperText="We'll send you weekly updates about new features" />
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """ """
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUIInputCheckbox @bind-Value="_smallValue" Label="Small" Size="BUISize.Small" />
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputCheckbox @bind-Value="_mediumValue" Label="Medium (Default)" Size="BUISize.Medium" />
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputCheckbox @bind-Value="_largeValue" Label="Large" Size="BUISize.Large" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition ColorsDemo => new()
    {
        Demo = RenderColors(),
        Code = """ """
    };

    private RenderFragment RenderColors() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUIInputCheckbox @bind-Value="_primaryValue" Label="Primary" Color="@Palette.Primary" />
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputCheckbox @bind-Value="_secondaryValue" Label="Secondary" Color="@Palette.Secondary" />
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputCheckbox @bind-Value="_successValue" Label="Success" Color="@Palette.Success" />
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputCheckbox @bind-Value="_errorValue" Label="Error" Color="@Palette.Error" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition DensityDemo => new()
    {
        Demo = RenderDensity(),
        Code = """ """
    };

    private RenderFragment RenderDensity() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUIInputCheckbox @bind-Value="_compactValue" Label="Compact" Density="BUIDensity.Compact" />
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputCheckbox @bind-Value="_standardValue" Label="Standard (Default)" Density="BUIDensity.Standard" />
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputCheckbox @bind-Value="_comfortableValue" Label="Comfortable" Density="BUIDensity.Comfortable" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition CustomIconsDemo => new()
    {
        Demo = RenderCustomIcons(),
        Code = """ """
    };

    private RenderFragment RenderCustomIcons() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUIInputCheckbox @bind-Value="_customIconValue"
                                  Label="Custom Icons"
                                  CheckedIcon="@BUIIcons.MaterialIconsRound.i_favorite"
                                  UncheckedIcon="@BUIIcons.MaterialIconsRound.i_favorite_border" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition StatesDemo => new()
    {
        Demo = RenderStates(),
        Code = """ """
    };

    private RenderFragment RenderStates() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUIInputCheckbox @bind-Value="_disabledOnValue" Label="Disabled (Checked)" Disabled="true" />
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputCheckbox @bind-Value="_disabledOffValue" Label="Disabled (Unchecked)" Disabled="true" />
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputCheckbox @bind-Value="_requiredValue" Label="Required field" Required="true" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition IndeterminateDemo => new()
    {
        Demo = RenderIndeterminate(),
        Code = """ """
    };

    private RenderFragment RenderIndeterminate() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUIInputCheckbox TValue="bool?"
                                  @bind-Value="_indeterminateValue"
                                  Label="Tristate Checkbox"
                                  HelperText="Click to cycle through: unchecked → indeterminate → checked" />
            </BUIGridItem>
            <BUIGridItem>
                <p><strong>Current State:</strong> @(_indeterminateValue switch { null => "Indeterminate", true => "Checked", false => "Unchecked" })</p>
            </BUIGridItem>
        </BUIGrid>
    };
}