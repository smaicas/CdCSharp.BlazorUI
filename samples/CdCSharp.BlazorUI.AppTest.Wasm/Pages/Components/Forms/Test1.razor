@page "/test1"

@* === BUIInputDropdown básico === *@
<BUIInputDropdown TValue="string" @bind-Value="country" Label="Country" Placeholder="Select...">
    <DropdownOption Value="@("es")" Text="Spain" />
    <DropdownOption Value="@("fr")" Text="France" />
    <DropdownOption Value="@("de")" Text="Germany" />
</BUIInputDropdown>

@* === BUIInputDropdown con templates personalizados === *@
<BUIInputDropdown TValue="string"
                  @bind-Value="country"
                  Label="Country"
                  Searchable="true">
    <NoOptionsTemplate>
        <span>⚠️ No countries configured</span>
    </NoOptionsTemplate>
    <NoResultsTemplate Context="ctx">
        <span>No results for "<strong>@ctx.SearchText</strong>"</span>
    </NoResultsTemplate>
    <ChildContent>
        <DropdownOption Value="@("es")" Text="Spain" />
        <DropdownOption Value="@("fr")" Text="France" />
    </ChildContent>
</BUIInputDropdown>

@* === BUIInputDropdown selección múltiple === *@
<BUIInputDropdown TValue="List<string>" @bind-Value="selectedCountries" Label="Countries">
    <DropdownOption Value="@("es")" Text="Spain" />
    <DropdownOption Value="@("fr")" Text="France" />
    <DropdownOption Value="@("de")" Text="Germany" />
</BUIInputDropdown>

@* === BUIInputDropdownTree básico === *@
<BUIInputDropdownTree TItem="Category"
                      TValue="Category"
                      Items="@categories"
                      KeySelector="@(c => c.Id)"
                      ChildrenSelector="@(c => c.Children)"
                      DisplayTextSelector="@(c => c.Name)"
                      @bind-Value="selectedCategory"
                      Label="Category"
                      Placeholder="Select category..." />

@* === BUIInputDropdownTree selección múltiple con cascada === *@
<BUIInputDropdownTree TItem="Department"
                      TValue="List<Department>"
                      Items="@departments"
                      KeySelector="@(d => d.Id)"
                      ChildrenSelector="@(d => d.SubDepartments)"
                      DisplayTextSelector="@(d => d.Name)"
                      @bind-Value="selectedDepartments"
                      Label="Departments"
                      SelectionCascade="TreeSelectionCascade.Children"
                      ExpandAll="true" />

@code {
    private string? country;
    private List<string> selectedCountries = new();
    private Category? selectedCategory;
    private List<Department> selectedDepartments = new();

    private List<Category> categories = new()
    {
        new Category("1", "Electronics", new()
        {
            new Category("1.1", "Phones", null),
            new Category("1.2", "Laptops", null)
        }),
        new Category("2", "Clothing", null)
    };

    private List<Department> departments = new();

    public record Category(string Id, string Name, List<Category>? Children);
    public record Department(string Id, string Name, List<Department>? SubDepartments);
}