@page "/components/forms/input-textarea"

@using System.ComponentModel.DataAnnotations
@using CdCSharp.BlazorUI.Components.Forms
@using CdCSharp.BlazorUI.Components.Forms.TextArea
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared

<PageTitle>InputTextArea - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>BUITextArea</h1>

    <p class="doc-intro">
        <strong>BUITextArea</strong> is a multi-line text input component with support for
        auto-resize, validation, and multiple visual variants. It extends the native textarea
        with extensive styling and behavioral options.
    </p>

    <!-- BASIC -->
    <section class="doc-section">
        <h2>Basic usage</h2>
        <ComponentDemo Definition="@BasicDemo" />
    </section>

    <!-- VARIANTS -->
    <section class="doc-section">
        <h2>Variants</h2>
        <ComponentDemo Definition="@VariantsDemo" />
    </section>

    <!-- AUTO RESIZE -->
    <section class="doc-section">
        <h2>Auto-resize</h2>
        <ComponentDemo Definition="@AutoResizeDemo" />
    </section>

    <!-- RESIZE MODES -->
    <section class="doc-section">
        <h2>Resize modes</h2>
        <ComponentDemo Definition="@ResizeModesDemo" />
    </section>

    <!-- SIZE -->
    <section class="doc-section">
        <h2>Sizes</h2>
        <ComponentDemo Definition="@SizesDemo" />
    </section>

    <!-- DENSITY -->
    <section class="doc-section">
        <h2>Density</h2>
        <ComponentDemo Definition="@DensityDemo" />
    </section>

    <!-- ROWS AND COLS -->
    <section class="doc-section">
        <h2>Rows and columns</h2>
        <ComponentDemo Definition="@RowsColsDemo" />
    </section>

    <!-- MAX LENGTH -->
    <section class="doc-section">
        <h2>Max length</h2>
        <ComponentDemo Definition="@MaxLengthDemo" />
    </section>

    <!-- READONLY / DISABLED -->
    <section class="doc-section">
        <h2>ReadOnly & Disabled</h2>
        <ComponentDemo Definition="@StateDemo" />
    </section>

    <!-- VALIDATION -->
    <section class="doc-section">
        <h2>Validation</h2>
        <ComponentDemo Definition="@ValidationDemo" />
    </section>

    <!-- CURRENT VALUE -->
    <section class="doc-section">
        <h2>Current value</h2>
        <pre class="demo-output">@(string.IsNullOrEmpty(Model.Comment) ? "(empty)" : Model.Comment)</pre>
    </section>

    <!-- FULL WIDTH -->
    <section class="doc-section">
        <h2>Full Width</h2>
        <ComponentDemo Definition="@FullWidthDemo" />
    </section>

    <!-- PROPERTIES -->
    <section class="doc-section">
        <h2>Properties</h2>
        <PropertyTable Properties="@Properties" />
    </section>

</div>

@code {
    /* ===================== MODEL ===================== */

    private DemoModel Model = new();

    private class DemoModel
    {
        public string? Comment { get; set; }

        [Required]
        [MinLength(10, ErrorMessage = "Comment must be at least 10 characters")]
        [MaxLength(500, ErrorMessage = "Comment cannot exceed 500 characters")]
        public string? ValidatedComment { get; set; }
    }

    /* ===================== DEMOS ===================== */

    private ComponentDemoDefinition BasicDemo => new()
    {
        Demo = RenderBasic(),
        Code = """
<BUIInputTextArea Label="Comments"
             Placeholder="Enter your comments here..."
             @bind-Value="model.Comment" />
"""
    };

    private ComponentDemoDefinition VariantsDemo => new()
    {
        Demo = RenderVariants(),
        Code = """
<BUIInputTextArea Label="Outlined"
             Variant="BUIInputVariant.Outlined"
             Placeholder="Outlined variant..."
             @bind-Value="model.Comment" />

<BUIInputTextArea Label="Filled"
             Variant="BUIInputVariant.Filled"
             Placeholder="Filled variant..."
             @bind-Value="model.Comment" />

<BUIInputTextArea Label="Standard"
             Variant="BUIInputVariant.Standard"
             Placeholder="Standard variant..."
             @bind-Value="model.Comment" />
"""
    };

    private ComponentDemoDefinition AutoResizeDemo => new()
    {
        Demo = RenderAutoResize(),
        Code = """
<BUIInputTextArea Label="Auto-resize enabled"
             Placeholder="Start typing and watch it grow..."
             AutoResize="true"
             Resize="TextAreaResize.None"
             @bind-Value="model.Comment" />
"""
    };

    private ComponentDemoDefinition ResizeModesDemo => new()
    {
        Demo = RenderResizeModes(),
        Code = """
<BUIInputTextArea Label="None"
             Resize="TextAreaResize.None"
             @bind-Value="model.Comment" />

<BUIInputTextArea Label="Vertical"
             Resize="TextAreaResize.Vertical"
             @bind-Value="model.Comment" />

<BUIInputTextArea Label="Horizontal"
             Resize="TextAreaResize.Horizontal"
             @bind-Value="model.Comment" />

<BUIInputTextArea Label="Both"
             Resize="TextAreaResize.Both"
             @bind-Value="model.Comment" />
"""
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """
<BUIInputTextArea Label="Small"
             Size="SizeEnum.Small"
             @bind-Value="model.Comment" />

<BUIInputTextArea Label="Medium"
             Size="SizeEnum.Medium"
             @bind-Value="model.Comment" />

<BUIInputTextArea Label="Large"
             Size="SizeEnum.Large"
             @bind-Value="model.Comment" />
"""
    };

    private ComponentDemoDefinition DensityDemo => new()
    {
        Demo = RenderDensity(),
        Code = """
<BUIInputTextArea Label="Comfortable"
             Density="DensityEnum.Comfortable"
             @bind-Value="model.Comment" />

<BUIInputTextArea Label="Standard"
             Density="DensityEnum.Standard"
             @bind-Value="model.Comment" />

<BUIInputTextArea Label="Compact"
             Density="DensityEnum.Compact"
             @bind-Value="model.Comment" />
"""
    };

    private ComponentDemoDefinition RowsColsDemo => new()
    {
        Demo = RenderRowsCols(),
        Code = """
<BUIInputTextArea Label="3 rows"
             Rows="3"
             @bind-Value="model.Comment" />

<BUIInputTextArea Label="6 rows"
             Rows="6"
             @bind-Value="model.Comment" />

<BUIInputTextArea Label="10 rows"
             Rows="10"
             @bind-Value="model.Comment" />
"""
    };

    private ComponentDemoDefinition MaxLengthDemo => new()
    {
        Demo = RenderMaxLength(),
        Code = """
<BUIInputTextArea Label="Max 100 characters"
             MaxLength="100"
             HelperText="@($"{model.Comment?.Length ?? 0}/100 characters")"
             @bind-Value="model.Comment" />
"""
    };

    private ComponentDemoDefinition StateDemo => new()
    {
        Demo = RenderStates(),
        Code = """
<BUIInputTextArea Label="ReadOnly"
             ReadOnly
             @bind-Value="model.Comment" />

<BUIInputTextArea Label="Disabled"
             Disabled
             @bind-Value="model.Comment" />
"""
    };

    private ComponentDemoDefinition ValidationDemo => new()
    {
        Demo = RenderValidation(),
        Code = """
<EditForm Model="model">
    <DataAnnotationsValidator />

    <BUIInputTextArea Label="Validated comment"
                 HelperText="Between 10 and 500 characters"
                 Required
                 @bind-Value="model.ValidatedComment" />
</EditForm>
"""
    };

    /* ===================== RENDER FRAGMENTS ===================== */

    private RenderFragment RenderBasic() => __builder =>
    {
        <BUIInputTextArea Label="Comments"
                          Placeholder="Enter your comments here..."
                          @bind-Value="Model.Comment" />
    };

    private RenderFragment RenderVariants() => __builder =>
    {
        <div class="demo-column">
            <BUIInputTextArea Label="Outlined"
                              Variant="BUIInputVariant.Outlined"
                              Placeholder="Outlined variant..."
                              @bind-Value="Model.Comment" />

            <BUIInputTextArea Label="Filled"
                              Variant="BUIInputVariant.Filled"
                              Placeholder="Filled variant..."
                              @bind-Value="Model.Comment" />

            <BUIInputTextArea Label="Standard"
                              Variant="BUIInputVariant.Standard"
                              Placeholder="Standard variant..."
                              @bind-Value="Model.Comment" />
        </div>
    };

    private RenderFragment RenderAutoResize() => __builder =>
    {
        <BUIInputTextArea Label="Auto-resize enabled"
                          Placeholder="Start typing and watch it grow..."
                          AutoResize="true"
                          Resize="TextAreaResize.None"
                          @bind-Value="Model.Comment" />
    };

    private RenderFragment RenderResizeModes() => __builder =>
    {
        <div class="demo-column">
            <BUIInputTextArea Label="None"
                              Resize="TextAreaResize.None"
                              HelperText="User cannot resize"
                              @bind-Value="Model.Comment" />

            <BUIInputTextArea Label="Vertical"
                              Resize="TextAreaResize.Vertical"
                              HelperText="Resize vertically only"
                              @bind-Value="Model.Comment" />

            <BUIInputTextArea Label="Horizontal"
                              Resize="TextAreaResize.Horizontal"
                              HelperText="Resize horizontally only"
                              @bind-Value="Model.Comment" />

            <BUIInputTextArea Label="Both"
                              Resize="TextAreaResize.Both"
                              HelperText="Resize in both directions"
                              @bind-Value="Model.Comment" />
        </div>
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <div class="demo-column">
            <BUIInputTextArea Label="Small"
                              Size="SizeEnum.Small"
                              @bind-Value="Model.Comment" />

            <BUIInputTextArea Label="Medium"
                              Size="SizeEnum.Medium"
                              @bind-Value="Model.Comment" />

            <BUIInputTextArea Label="Large"
                              Size="SizeEnum.Large"
                              @bind-Value="Model.Comment" />
        </div>
    };

    private RenderFragment RenderDensity() => __builder =>
    {
        <div class="demo-column">
            <BUIInputTextArea Label="Comfortable"
                              Density="DensityEnum.Comfortable"
                              @bind-Value="Model.Comment" />

            <BUIInputTextArea Label="Standard"
                              Density="DensityEnum.Standard"
                              @bind-Value="Model.Comment" />

            <BUIInputTextArea Label="Compact"
                              Density="DensityEnum.Compact"
                              @bind-Value="Model.Comment" />
        </div>
    };

    private RenderFragment RenderRowsCols() => __builder =>
    {
        <div class="demo-column">
            <BUIInputTextArea Label="3 rows"
                              Rows="3"
                              @bind-Value="Model.Comment" />

            <BUIInputTextArea Label="6 rows"
                              Rows="6"
                              @bind-Value="Model.Comment" />

            <BUIInputTextArea Label="10 rows"
                              Rows="10"
                              @bind-Value="Model.Comment" />
        </div>
    };

    private RenderFragment RenderMaxLength() => __builder =>
    {
        <BUIInputTextArea Label="Max 100 characters"
                          MaxLength="100"
                          HelperText="@($"{Model.Comment?.Length ?? 0}/100 characters")"
                          @bind-Value="Model.Comment" />
    };

    private RenderFragment RenderStates() => __builder =>
    {
        <div class="demo-column">
            <BUIInputTextArea Label="ReadOnly"
                              ReadOnly
                              @bind-Value="Model.Comment" />

            <BUIInputTextArea Label="Disabled"
                              Disabled
                              @bind-Value="Model.Comment" />
        </div>
    };

    private RenderFragment RenderValidation() => __builder =>
    {
        <EditForm Model="Model">
            <DataAnnotationsValidator />

            <BUIInputTextArea Label="Validated comment"
                              HelperText="Between 10 and 500 characters"
                              Required
                              @bind-Value="Model.ValidatedComment" />
        </EditForm>
    };

    private ComponentDemoDefinition FullWidthDemo => new()
    {
        Demo = RenderFullWidth(),
        Code = """
<BUIInputTextArea Label="Default width"
             Placeholder="Normal width textarea..."
             @bind-Value="model.Comment" />

<BUIInputTextArea Label="Full width"
             FullWidth="true"
             Placeholder="This textarea spans the full container width..."
             @bind-Value="model.Comment" />
"""
    };

    private RenderFragment RenderFullWidth() => __builder =>
    {
        <div class="demo-column">
            <BUIInputTextArea Label="Default width"
                              Placeholder="Normal width textarea..."
                              @bind-Value="Model.Comment" />

            <BUIInputTextArea Label="Full width"
                              FullWidth="true"
                              Placeholder="This textarea spans the full container width..."
                              @bind-Value="Model.Comment" />
        </div>
    };

    /* ===================== PROPERTIES ===================== */

    private List<PropertyDefinition> Properties = new()
    {
        new("Value", "string?", "null", "Bound value"),
        new("ValueChanged", "EventCallback<string>", "-", "Raised when the value changes"),
        new("Label", "string?", "null", "Input label"),
        new("Placeholder", "string?", "null", "Placeholder text"),
        new("HelperText", "string?", "null", "Helper text below the input"),
        new("Rows", "int?", "3", "Number of visible text rows"),
        new("Cols", "int?", "null", "Number of visible text columns"),
        new("MaxLength", "int?", "null", "Maximum character length"),
        new("AutoResize", "bool", "false", "Automatically resize based on content"),
        new("Resize", "TextAreaResize", "Vertical", "User resize behavior (None, Vertical, Horizontal, Both)"),
        new("UpdateOnInput", "bool", "false", "Update value on input instead of change"),
        new("OnInput", "EventCallback<string>", "-", "Raised on input event"),
        new("Required", "bool", "false", "Marks the field as required"),
        new("ReadOnly", "bool", "false", "Makes the input read-only"),
        new("Disabled", "bool", "false", "Disables the input"),
        new("Size", "SizeEnum", "Medium", "Input size"),
        new("Density", "DensityEnum", "Standard", "Input density"),
        new("Variant", "BUITextAreaVariant", "Outlined", "Visual variant (Outlined, Filled, Standard)"),
        new("FullWidth", "bool", "false", "Makes the input full width"),
        new("IsLoading", "bool", "false", "Shows loading indicator"),
        new("LoadingIndicatorVariant", "BUILoadingIndicatorVariant?", "null", "Loading indicator style"),
    };
}