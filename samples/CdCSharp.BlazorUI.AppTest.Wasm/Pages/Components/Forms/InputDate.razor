@page "/components/forms/input-date"
@using CdCSharp.BlazorUI.Components.Forms

<h3>Test de componentes de fecha</h3>

<div style="display: flex; flex-direction: column; gap: 1rem;">
    <div>
        <span>DateOnly:</span>
        <BUIInputDateTime @bind-Value="dateOnlyValue" />
        <p>Valor: @dateOnlyValue</p>
    </div>

    <div>
        <span>TimeOnly:</span>
        <BUIInputDateTime @bind-Value="timeOnlyValue" />
        <p>Valor: @timeOnlyValue</p>
    </div>

    <div>
        <span>DateTime:</span>
        <BUIInputDateTime @bind-Value="dateTimeValue" />
        <p>Valor: @dateTimeValue</p>
    </div>

    <div>
        <span>DateTimeOffset:</span>
        <BUIInputDateTime @bind-Value="dateTimeOffsetValue" />
        <p>Valor: @dateTimeOffsetValue</p>
    </div>

    <div>
        <span>Nullable DateTime:</span>
        <BUIInputDateTime @bind-Value="nullableDateTimeValue" />
        <p>Valor: @(nullableDateTimeValue?.ToString() ?? "null")</p>
    </div>
</div>

@code {
    private DateOnly dateOnlyValue = DateOnly.FromDateTime(DateTime.Now);
    private TimeOnly timeOnlyValue = TimeOnly.FromDateTime(DateTime.Now);
    private DateTime dateTimeValue = DateTime.Now;
    private DateTimeOffset dateTimeOffsetValue = DateTimeOffset.Now;
    private DateTime? nullableDateTimeValue = DateTime.Now;
}