@page "/components/forms/input-dropdown"

@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Components.Forms
@using CdCSharp.BlazorUI.Components.Forms.Dropdown
@using CdCSharp.BlazorUI.Core.Search

<PageTitle>Dropdown - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>BUIInputDropdown</h1>

    <p class="doc-intro">
        <strong>BUIInputDropdown</strong> is a flexible dropdown selector with support for single and multiple selection,
        search filtering, keyboard navigation, custom templates, and intelligent positioning.
    </p>

    <!-- BASIC USAGE -->
    <section class="doc-section">
        <h2>Basic usage</h2>
        <ComponentDemo Definition="@BasicUsageDemo" />
        <p class="demo-result">Selected: <strong>@(SelectedBasic ?? "None")</strong></p>
    </section>

    <!-- VARIANTS -->
    <section class="doc-section">
        <h2>Variants</h2>
        <p>Three built-in variants: <code>Outlined</code>, <code>Filled</code>, and <code>Standard</code>.</p>
        <ComponentDemo Definition="@VariantsDemo" />
    </section>

    <!-- WITH LABEL AND HELPER -->
    <section class="doc-section">
        <h2>Label and helper text</h2>
        <ComponentDemo Definition="@LabelHelperDemo" />
    </section>

    <!-- WITH OBJECTS -->
    <section class="doc-section">
        <h2>With objects</h2>
        <p>Bind to complex objects, not just strings:</p>
        <ComponentDemo Definition="@ObjectsDemo" />
        <p class="demo-result">Selected: <strong>@(SelectedPerson?.Name ?? "None")</strong></p>
    </section>

    <!-- CUSTOM TEMPLATE -->
    <section class="doc-section">
        <h2>Custom template</h2>
        <p>Use <code>ChildContent</code> inside DropdownOption for custom rendering:</p>
        <ComponentDemo Definition="@CustomTemplateDemo" />
        <p class="demo-result">Selected: <strong>@(SelectedPersonTemplate?.Name ?? "None")</strong></p>
    </section>

    <!-- MULTIPLE SELECTION -->
    <section class="doc-section">
        <h2>Multiple selection</h2>
        <p>Use array or list type for multiple selection:</p>
        <ComponentDemo Definition="@MultipleDemo" />
        <p class="demo-result">Selected: <strong>@(string.Join(", ", SelectedPeople?.Select(p => p.Name) ?? Array.Empty<string>()))</strong></p>
    </section>

    <!-- SEARCHABLE -->
    <section class="doc-section">
        <h2>Searchable</h2>
        <p>Enable search with different modes: Smart, StartsWith, Contains, Fuzzy:</p>
        <ComponentDemo Definition="@SearchableDemo" />
        <p class="demo-result">Selected: <strong>@(SelectedCountry?.Name ?? "None")</strong></p>
    </section>

    <!-- CUSTOM EMPTY TEMPLATES -->
    <section class="doc-section">
        <h2>Custom empty templates</h2>
        <p>Customize the "no options" and "no results" messages with <code>NoOptionsTemplate</code> and <code>NoResultsTemplate</code>:</p>
        <ComponentDemo Definition="@EmptyTemplatesDemo" />
    </section>

    <!-- SIZES -->
    <section class="doc-section">
        <h2>Sizes</h2>
        <ComponentDemo Definition="@SizesDemo" />
    </section>

    <!-- PLACEMENT -->
    <section class="doc-section">
        <h2>Placement</h2>
        <p>Control menu position relative to trigger:</p>
        <ComponentDemo Definition="@PlacementDemo" />
    </section>

    <!-- STATES -->
    <section class="doc-section">
        <h2>States</h2>
        <ComponentDemo Definition="@StatesDemo" />
    </section>

    <!-- DISABLED OPTIONS -->
    <section class="doc-section">
        <h2>Disabled options</h2>
        <ComponentDemo Definition="@DisabledOptionsDemo" />
        <p class="demo-result">Selected: <strong>@(SelectedWithDisabled ?? "None")</strong></p>
    </section>

    <!-- DENSITY -->
    <section class="doc-section">
        <h2>Density</h2>
        <ComponentDemo Definition="@DensityDemo" />
    </section>

    <!-- ==================== DROPDOWN TREE ==================== -->
    <h1 class="section-divider">BUIInputDropdownTree</h1>

    <p class="doc-intro">
        <strong>BUIInputDropdownTree</strong> combines a dropdown trigger with a tree selector,
        allowing hierarchical data selection with expand/collapse, cascading selection, and all dropdown features.
    </p>

    <!-- TREE BASIC -->
    <section class="doc-section">
        <h2>Basic tree dropdown</h2>
        <p>Select from a hierarchical structure:</p>
        <ComponentDemo Definition="@TreeBasicDemo" />
        <p class="demo-result">Selected: <strong>@(SelectedCategory?.Name ?? "None")</strong></p>
    </section>

    <!-- TREE VARIANTS -->
    <section class="doc-section">
        <h2>Tree variants</h2>
        <ComponentDemo Definition="@TreeVariantsDemo" />
    </section>

    <!-- TREE MULTIPLE -->
    <section class="doc-section">
        <h2>Multiple selection tree</h2>
        <p>Select multiple nodes from the tree:</p>
        <ComponentDemo Definition="@TreeMultipleDemo" />
        <p class="demo-result">Selected: <strong>@(string.Join(", ", SelectedCategories?.Select(c => c.Name) ?? Array.Empty<string>()))</strong></p>
    </section>

    <!-- TREE CASCADE -->
    <section class="doc-section">
        <h2>Selection cascade</h2>
        <p>Automatically select children, parents, or both when a node is selected:</p>
        <ComponentDemo Definition="@TreeCascadeDemo" />
        <p class="demo-result">Selected: <strong>@(string.Join(", ", SelectedCascade?.Select(c => c.Name) ?? Array.Empty<string>()))</strong></p>
    </section>

    <!-- TREE CUSTOM TEMPLATE -->
    <section class="doc-section">
        <h2>Custom node template</h2>
        <ComponentDemo Definition="@TreeCustomTemplateDemo" />
    </section>

    <!-- PROPERTIES - BUIInputDropdown -->
    <section class="doc-section">
        <h2>Properties - BUIInputDropdown</h2>
        <PropertyTable Properties="@DropdownProperties" />
    </section>

    <!-- PROPERTIES - DropdownOption -->
    <section class="doc-section">
        <h2>Properties - DropdownOption</h2>
        <PropertyTable Properties="@OptionProperties" />
    </section>

    <!-- PROPERTIES - BUIInputDropdownTree -->
    <section class="doc-section">
        <h2>Properties - BUIInputDropdownTree</h2>
        <PropertyTable Properties="@TreeProperties" />
    </section>
</div>

<style>
    .person-item {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .person-email {
        font-size: 0.875rem;
        opacity: 0.7;
    }

    .demo-result {
        margin-top: 1rem;
        padding: 0.5rem;
        background: rgba(0, 0, 0, 0.05);
        border-radius: 4px;
        font-family: monospace;
    }

    [data-theme="dark"] .demo-result {
        background: rgba(255, 255, 255, 0.05);
    }

    .section-divider {
        margin-top: 4rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(0, 0, 0, 0.12);
    }

    [data-theme="dark"] .section-divider {
        border-top-color: rgba(255, 255, 255, 0.12);
    }

    .category-node {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .category-count {
        font-size: 0.75rem;
        opacity: 0.6;
        background: rgba(0,0,0,0.1);
        padding: 0.125rem 0.5rem;
        border-radius: 10px;
    }

    .no-results-custom {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        padding: 1rem;
    }

    .no-results-hint {
        font-size: 0.875rem;
        opacity: 0.6;
    }
</style>

@code {
    private string? SelectedBasic;
    private string? SelectedLabel;
    private Person? SelectedPerson;
    private Person? SelectedPersonTemplate;
    private Person[]? SelectedPeople = Array.Empty<Person>();
    private Country? SelectedCountry;
    private string? SelectedWithDisabled;
    private string? SelectedEmptyTemplate;

    private Category? SelectedCategory;
    private List<Category>? SelectedCategories = new();
    private List<Category>? SelectedCascade = new();
    private Category? SelectedTreeTemplate;

    private string? _variantOutlined;
    private string? _variantFilled;
    private string? _variantStandard;
    private string? _sizeSmall;
    private string? _sizeMedium;
    private string? _sizeLarge;
    private string? _placementAuto;
    private string? _placementTop;
    private string? _placementBottom;
    private string? _stateDisabled;
    private string? _stateLoading;
    private string? _densityComfortable;
    private string? _densityStandard;
    private string? _densityCompact;

    private Category? _treeVariantOutlined;
    private Category? _treeVariantFilled;
    private Category? _treeVariantStandard;

    private List<Person> People = new()
    {
        new Person(1, "Alice Johnson", "alice@example.com"),
        new Person(2, "Bob Smith", "bob@example.com"),
        new Person(3, "Charlie Brown", "charlie@example.com"),
        new Person(4, "Diana Ross", "diana@example.com"),
        new Person(5, "Edward Norton", "edward@example.com")
    };

    private List<Country> Countries = new()
    {
        new Country("US", "United States"),
        new Country("GB", "United Kingdom"),
        new Country("CA", "Canada"),
        new Country("AU", "Australia"),
        new Country("DE", "Germany"),
        new Country("FR", "France"),
        new Country("ES", "Spain"),
        new Country("IT", "Italy"),
        new Country("JP", "Japan"),
        new Country("CN", "China"),
        new Country("BR", "Brazil"),
        new Country("MX", "Mexico"),
        new Country("AR", "Argentina"),
        new Country("CL", "Chile"),
        new Country("CO", "Colombia")
    };

    private List<Category> Categories = new()
    {
        new Category("1", "Electronics", 150, new()
        {
            new Category("1.1", "Phones", 45, new()
            {
                new Category("1.1.1", "Smartphones", 30, null),
                new Category("1.1.2", "Feature Phones", 15, null)
            }),
            new Category("1.2", "Computers", 60, new()
            {
                new Category("1.2.1", "Laptops", 35, null),
                new Category("1.2.2", "Desktops", 25, null)
            }),
            new Category("1.3", "Accessories", 45, null)
        }),
        new Category("2", "Clothing", 200, new()
        {
            new Category("2.1", "Men", 80, null),
            new Category("2.2", "Women", 90, null),
            new Category("2.3", "Kids", 30, null)
        }),
        new Category("3", "Home & Garden", 75, null)
    };

    public record Person(int Id, string Name, string Email);
    public record Country(string Code, string Name);
    public record Category(string Id, string Name, int ProductCount, List<Category>? Children);

    /* ===================== DEMOS ===================== */

    private ComponentDemoDefinition BasicUsageDemo => new()
    {
        Demo = RenderBasicUsage(),
        Code = """
<BUIInputDropdown @bind-Value="selected" Placeholder="Select an option">
    <DropdownOption Value="@("option1")" Text="Option 1" />
    <DropdownOption Value="@("option2")" Text="Option 2" />
    <DropdownOption Value="@("option3")" Text="Option 3" />
</BUIInputDropdown>
"""
    };

    private ComponentDemoDefinition VariantsDemo => new()
    {
        Demo = RenderVariants(),
        Code = """
<BUIInputDropdown @bind-Value="value"
                  Variant="BUIInputDropdownVariant.Outlined"
                  Placeholder="Outlined">
    ...
</BUIInputDropdown>

<BUIInputDropdown @bind-Value="value"
                  Variant="BUIInputDropdownVariant.Filled"
                  Placeholder="Filled">
    ...
</BUIInputDropdown>

<BUIInputDropdown @bind-Value="value"
                  Variant="BUIInputDropdownVariant.Standard"
                  Placeholder="Standard">
    ...
</BUIInputDropdown>
"""
    };

    private ComponentDemoDefinition LabelHelperDemo => new()
    {
        Demo = RenderLabelHelper(),
        Code = """
<BUIInputDropdown @bind-Value="selected"
                  Label="Required Field"
                  HelperText="Please select one option"
                  Required="true"
                  Placeholder="Select...">
    <DropdownOption Value="@("opt1")" Text="Option 1" />
    <DropdownOption Value="@("opt2")" Text="Option 2" />
</BUIInputDropdown>
"""
    };

    private ComponentDemoDefinition ObjectsDemo => new()
    {
        Demo = RenderObjects(),
        Code = """
<BUIInputDropdown @bind-Value="selectedPerson" Placeholder="Select a person" Label="Person">
    @foreach (Person person in people)
    {
        <DropdownOption Value="person" Text="@person.Name" />
    }
</BUIInputDropdown>
"""
    };

    private ComponentDemoDefinition CustomTemplateDemo => new()
    {
        Demo = RenderCustomTemplate(),
        Code = """
<BUIInputDropdown @bind-Value="selectedPerson" Placeholder="Select a person" Label="Person">
    @foreach (Person person in people)
    {
        <DropdownOption Value="person">
            <div class="person-item">
                <strong>@person.Name</strong>
                <span class="person-email">@person.Email</span>
            </div>
        </DropdownOption>
    }
</BUIInputDropdown>
"""
    };

    private ComponentDemoDefinition MultipleDemo => new()
    {
        Demo = RenderMultiple(),
        Code = """
<BUIInputDropdown @bind-Value="selectedPeople" Placeholder="Select people" Label="Multiple selection">
    @foreach (Person person in people)
    {
        <DropdownOption Value="person" Text="@person.Name" />
    }
</BUIInputDropdown>

@code {
    private Person[]? selectedPeople = Array.Empty<Person>();
}
"""
    };

    private ComponentDemoDefinition SearchableDemo => new()
    {
        Demo = RenderSearchable(),
        Code = """
<BUIInputDropdown @bind-Value="selectedCountry"
                  Placeholder="Search countries..."
                  Label="Country"
                  Searchable="true"
                  SearchMode="SearchMode.Smart">
    @foreach (Country country in countries)
    {
        <DropdownOption Value="country" Text="@country.Name" />
    }
</BUIInputDropdown>
"""
    };

    private ComponentDemoDefinition EmptyTemplatesDemo => new()
    {
        Demo = RenderEmptyTemplates(),
        Code = """
<BUIInputDropdown @bind-Value="selected"
                  Placeholder="Search..."
                  Searchable="true">
    <NoOptionsTemplate>
        <div>⚠️ No options configured</div>
    </NoOptionsTemplate>
    <NoResultsTemplate Context="ctx">
        <div class="no-results-custom">
            <span>No results for "<strong>@ctx.SearchText</strong>"</span>
            <span class="no-results-hint">@ctx.TotalOptionsCount options available</span>
        </div>
    </NoResultsTemplate>
    <ChildContent>
        <DropdownOption Value="@("a")" Text="Alpha" />
        <DropdownOption Value="@("b")" Text="Beta" />
    </ChildContent>
</BUIInputDropdown>
"""
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """
<BUIInputDropdown @bind-Value="value" Size="SizeEnum.Small" Placeholder="Small">...</BUIInputDropdown>
<BUIInputDropdown @bind-Value="value" Size="SizeEnum.Medium" Placeholder="Medium">...</BUIInputDropdown>
<BUIInputDropdown @bind-Value="value" Size="SizeEnum.Large" Placeholder="Large">...</BUIInputDropdown>
"""
    };

    private ComponentDemoDefinition PlacementDemo => new()
    {
        Demo = RenderPlacement(),
        Code = """
<BUIInputDropdown @bind-Value="value" Placement="DropdownPlacement.Auto" Placeholder="Auto">...</BUIInputDropdown>
<BUIInputDropdown @bind-Value="value" Placement="DropdownPlacement.Top" Placeholder="Top">...</BUIInputDropdown>
<BUIInputDropdown @bind-Value="value" Placement="DropdownPlacement.Bottom" Placeholder="Bottom">...</BUIInputDropdown>
"""
    };

    private ComponentDemoDefinition StatesDemo => new()
    {
        Demo = RenderStates(),
        Code = """
<BUIInputDropdown @bind-Value="value" Disabled="true" Placeholder="Disabled">...</BUIInputDropdown>
<BUIInputDropdown @bind-Value="value" IsLoading="true" LoadingIndicatorVariant="..." Placeholder="Loading">...</BUIInputDropdown>
"""
    };

    private ComponentDemoDefinition DisabledOptionsDemo => new()
    {
        Demo = RenderDisabledOptions(),
        Code = """
<BUIInputDropdown @bind-Value="selected" Placeholder="Select an option">
    <DropdownOption Value="@("opt1")" Text="Available Option 1" />
    <DropdownOption Value="@("opt2")" Text="Disabled Option" Disabled="true" />
    <DropdownOption Value="@("opt3")" Text="Available Option 2" />
</BUIInputDropdown>
"""
    };

    private ComponentDemoDefinition DensityDemo => new()
    {
        Demo = RenderDensity(),
        Code = """
<BUIInputDropdown @bind-Value="value" Density="DensityEnum.Comfortable" Placeholder="Comfortable">...</BUIInputDropdown>
<BUIInputDropdown @bind-Value="value" Density="DensityEnum.Standard" Placeholder="Standard">...</BUIInputDropdown>
<BUIInputDropdown @bind-Value="value" Density="DensityEnum.Compact" Placeholder="Compact">...</BUIInputDropdown>
"""
    };

    /* ===================== TREE DEMOS ===================== */

    private ComponentDemoDefinition TreeBasicDemo => new()
    {
        Demo = RenderTreeBasic(),
        Code = """
<BUIInputDropdownTree TItem="Category"
                      TValue="Category"
                      Items="@categories"
                      KeySelector="@(c => c.Id)"
                      ChildrenSelector="@(c => c.Children)"
                      DisplayTextSelector="@(c => c.Name)"
                      @bind-Value="selectedCategory"
                      Label="Category"
                      Placeholder="Select category..." />

@code {
    public record Category(string Id, string Name, List<Category>? Children);
}
"""
    };

    private ComponentDemoDefinition TreeVariantsDemo => new()
    {
        Demo = RenderTreeVariants(),
        Code = """
<BUIInputDropdownTree ... Variant="BUIInputDropdownTreeVariant.Outlined" Placeholder="Outlined" />
<BUIInputDropdownTree ... Variant="BUIInputDropdownTreeVariant.Filled" Placeholder="Filled" />
<BUIInputDropdownTree ... Variant="BUIInputDropdownTreeVariant.Standard" Placeholder="Standard" />
"""
    };

    private ComponentDemoDefinition TreeMultipleDemo => new()
    {
        Demo = RenderTreeMultiple(),
        Code = """
<BUIInputDropdownTree TItem="Category"
                      TValue="List<Category>"
                      Items="@categories"
                      KeySelector="@(c => c.Id)"
                      ChildrenSelector="@(c => c.Children)"
                      DisplayTextSelector="@(c => c.Name)"
                      @bind-Value="selectedCategories"
                      Label="Categories"
                      Placeholder="Select categories..."
                      ShowCheckboxes="true" />
"""
    };

    private ComponentDemoDefinition TreeCascadeDemo => new()
    {
        Demo = RenderTreeCascade(),
        Code = """
<BUIInputDropdownTree TItem="Category"
                      TValue="List<Category>"
                      Items="@categories"
                      KeySelector="@(c => c.Id)"
                      ChildrenSelector="@(c => c.Children)"
                      DisplayTextSelector="@(c => c.Name)"
                      @bind-Value="selected"
                      Label="With cascade"
                      SelectionCascade="TreeSelectionCascade.Children"
                      ExpandAll="true" />
"""
    };

    private ComponentDemoDefinition TreeCustomTemplateDemo => new()
    {
        Demo = RenderTreeCustomTemplate(),
        Code = """
<BUIInputDropdownTree TItem="Category"
                      TValue="Category"
                      Items="@categories"
                      KeySelector="@(c => c.Id)"
                      ChildrenSelector="@(c => c.Children)"
                      DisplayTextSelector="@(c => c.Name)"
                      @bind-Value="selected"
                      Label="With custom template">
    <NodeTemplate Context="node">
        <div class="category-node">
            <span>@node.Text</span>
            @if (node.Item != null)
            {
                <span class="category-count">@node.Item.ProductCount items</span>
            }
        </div>
    </NodeTemplate>
</BUIInputDropdownTree>
"""
    };

    /* ===================== RENDER FRAGMENTS ===================== */

    private RenderFragment RenderBasicUsage() => __builder =>
    {
        <BUIInputDropdown @bind-Value="SelectedBasic" Placeholder="Select an option">
            <DropdownOption Value="@("option1")" Text="Option 1" />
            <DropdownOption Value="@("option2")" Text="Option 2" />
            <DropdownOption Value="@("option3")" Text="Option 3" />
            <DropdownOption Value="@("option4")" Text="Option 4" />
            <DropdownOption Value="@("option5")" Text="Option 5" />
        </BUIInputDropdown>
    };

    private RenderFragment RenderVariants() => __builder =>
    {
        <div class="demo-row">
            <BUIInputDropdown @bind-Value="_variantOutlined"
                              Variant="BUIInputDropdownVariant.Outlined"
                              Placeholder="Outlined">
                <DropdownOption Value="@("opt1")" Text="Option 1" />
                <DropdownOption Value="@("opt2")" Text="Option 2" />
            </BUIInputDropdown>

            <BUIInputDropdown @bind-Value="_variantFilled"
                              Variant="BUIInputDropdownVariant.Filled"
                              Placeholder="Filled">
                <DropdownOption Value="@("opt1")" Text="Option 1" />
                <DropdownOption Value="@("opt2")" Text="Option 2" />
            </BUIInputDropdown>

            <BUIInputDropdown @bind-Value="_variantStandard"
                              Variant="BUIInputDropdownVariant.Standard"
                              Placeholder="Standard">
                <DropdownOption Value="@("opt1")" Text="Option 1" />
                <DropdownOption Value="@("opt2")" Text="Option 2" />
            </BUIInputDropdown>
        </div>
    };

    private RenderFragment RenderLabelHelper() => __builder =>
    {
        <BUIInputDropdown @bind-Value="SelectedLabel"
                          Label="Required Field"
                          HelperText="Please select one option"
                          Required="true"
                          Placeholder="Select...">
            <DropdownOption Value="@("opt1")" Text="Option 1" />
            <DropdownOption Value="@("opt2")" Text="Option 2" />
            <DropdownOption Value="@("opt3")" Text="Option 3" />
        </BUIInputDropdown>
    };

    private RenderFragment RenderObjects() => __builder =>
    {
        <BUIInputDropdown @bind-Value="SelectedPerson" Placeholder="Select a person" Label="Person">
            @foreach (Person person in People)
            {
                <DropdownOption Value="person" Text="@person.Name" />
            }
        </BUIInputDropdown>
    };

    private RenderFragment RenderCustomTemplate() => __builder =>
    {
        <BUIInputDropdown @bind-Value="SelectedPersonTemplate" Placeholder="Select a person" Label="Person with details">
            @foreach (Person person in People)
            {
                <DropdownOption Value="person">
                    <div class="person-item">
                        <strong>@person.Name</strong>
                        <span class="person-email">@person.Email</span>
                    </div>
                </DropdownOption>
            }
        </BUIInputDropdown>
    };

    private RenderFragment RenderMultiple() => __builder =>
    {
        <BUIInputDropdown @bind-Value="SelectedPeople" Placeholder="Select people" Label="Multiple selection">
            @foreach (Person person in People)
            {
                <DropdownOption Value="person" Text="@person.Name" />
            }
        </BUIInputDropdown>
    };

    private RenderFragment RenderSearchable() => __builder =>
    {
        <BUIInputDropdown @bind-Value="SelectedCountry"
                          Placeholder="Search countries..."
                          Label="Country"
                          Searchable="true"
                          SearchMode="SearchMode.Smart">
            @foreach (Country country in Countries)
            {
                <DropdownOption Value="country" Text="@country.Name" />
            }
        </BUIInputDropdown>
    };

    private RenderFragment RenderEmptyTemplates() => __builder =>
    {
        <BUIInputDropdown @bind-Value="SelectedEmptyTemplate"
                          Placeholder="Search..."
                          Searchable="true">
            <NoOptionsTemplate>
                <div>⚠️ No options configured</div>
            </NoOptionsTemplate>
            <NoResultsTemplate Context="ctx">
                <div class="no-results-custom">
                    <span>No results for "<strong>@ctx.SearchText</strong>"</span>
                    <span class="no-results-hint">@ctx.TotalOptionsCount options available</span>
                </div>
            </NoResultsTemplate>
            <ChildContent>
                <DropdownOption Value="@("alpha")" Text="Alpha" />
                <DropdownOption Value="@("beta")" Text="Beta" />
                <DropdownOption Value="@("gamma")" Text="Gamma" />
            </ChildContent>
        </BUIInputDropdown>
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <div class="demo-row">
            <BUIInputDropdown @bind-Value="_sizeSmall" Size="SizeEnum.Small" Placeholder="Small">
                <DropdownOption Value="@("opt1")" Text="Option 1" />
                <DropdownOption Value="@("opt2")" Text="Option 2" />
            </BUIInputDropdown>

            <BUIInputDropdown @bind-Value="_sizeMedium" Size="SizeEnum.Medium" Placeholder="Medium">
                <DropdownOption Value="@("opt1")" Text="Option 1" />
                <DropdownOption Value="@("opt2")" Text="Option 2" />
            </BUIInputDropdown>

            <BUIInputDropdown @bind-Value="_sizeLarge" Size="SizeEnum.Large" Placeholder="Large">
                <DropdownOption Value="@("opt1")" Text="Option 1" />
                <DropdownOption Value="@("opt2")" Text="Option 2" />
            </BUIInputDropdown>
        </div>
    };

    private RenderFragment RenderPlacement() => __builder =>
    {
        <div class="demo-row">
            <BUIInputDropdown @bind-Value="_placementAuto" Placement="DropdownPlacement.Auto" Placeholder="Auto">
                <DropdownOption Value="@("opt1")" Text="Option 1" />
                <DropdownOption Value="@("opt2")" Text="Option 2" />
            </BUIInputDropdown>

            <BUIInputDropdown @bind-Value="_placementTop" Placement="DropdownPlacement.Top" Placeholder="Top">
                <DropdownOption Value="@("opt1")" Text="Option 1" />
                <DropdownOption Value="@("opt2")" Text="Option 2" />
            </BUIInputDropdown>

            <BUIInputDropdown @bind-Value="_placementBottom" Placement="DropdownPlacement.Bottom" Placeholder="Bottom">
                <DropdownOption Value="@("opt1")" Text="Option 1" />
                <DropdownOption Value="@("opt2")" Text="Option 2" />
            </BUIInputDropdown>
        </div>
    };

    private RenderFragment RenderStates() => __builder =>
    {
        <div class="demo-row">
            <BUIInputDropdown @bind-Value="_stateDisabled" Disabled="true" Placeholder="Disabled">
                <DropdownOption Value="@("opt1")" Text="Option 1" />
            </BUIInputDropdown>

            <BUIInputDropdown @bind-Value="_stateLoading"
                              IsLoading="true"
                              LoadingIndicatorVariant="BUILoadingIndicatorVariant.Spinner"
                              Placeholder="Loading">
                <DropdownOption Value="@("opt1")" Text="Option 1" />
            </BUIInputDropdown>
        </div>
    };

    private RenderFragment RenderDisabledOptions() => __builder =>
    {
        <BUIInputDropdown @bind-Value="SelectedWithDisabled" Placeholder="Select an option">
            <DropdownOption Value="@("opt1")" Text="Available Option 1" />
            <DropdownOption Value="@("opt2")" Text="Disabled Option" Disabled="true" />
            <DropdownOption Value="@("opt3")" Text="Available Option 2" />
            <DropdownOption Value="@("opt4")" Text="Another Disabled" Disabled="true" />
            <DropdownOption Value="@("opt5")" Text="Available Option 3" />
        </BUIInputDropdown>
    };

    private RenderFragment RenderDensity() => __builder =>
    {
        <div class="demo-row">
            <BUIInputDropdown @bind-Value="_densityComfortable" Density="DensityEnum.Comfortable" Placeholder="Comfortable">
                <DropdownOption Value="@("opt1")" Text="Option 1" />
                <DropdownOption Value="@("opt2")" Text="Option 2" />
            </BUIInputDropdown>

            <BUIInputDropdown @bind-Value="_densityStandard" Density="DensityEnum.Standard" Placeholder="Standard">
                <DropdownOption Value="@("opt1")" Text="Option 1" />
                <DropdownOption Value="@("opt2")" Text="Option 2" />
            </BUIInputDropdown>

            <BUIInputDropdown @bind-Value="_densityCompact" Density="DensityEnum.Compact" Placeholder="Compact">
                <DropdownOption Value="@("opt1")" Text="Option 1" />
                <DropdownOption Value="@("opt2")" Text="Option 2" />
            </BUIInputDropdown>
        </div>
    };

    /* ===================== TREE RENDER FRAGMENTS ===================== */

    private RenderFragment RenderTreeBasic() => __builder =>
    {
        <BUIInputDropdownTree TItem="Category"
                              TValue="Category"
                              Items="@Categories"
                              KeySelector="@(c => c.Id)"
                              ChildrenSelector="@(c => c.Children)"
                              DisplayTextSelector="@(c => c.Name)"
                              @bind-Value="SelectedCategory"
                              Label="Category"
                              Placeholder="Select category..." />
    };

    private RenderFragment RenderTreeVariants() => __builder =>
    {
        <div class="demo-row">
            <BUIInputDropdownTree TItem="Category"
                                  TValue="Category"
                                  Items="@Categories"
                                  KeySelector="@(c => c.Id)"
                                  ChildrenSelector="@(c => c.Children)"
                                  DisplayTextSelector="@(c => c.Name)"
                                  @bind-Value="_treeVariantOutlined"
                                  Variant="BUIInputDropdownTreeVariant.Outlined"
                                  Placeholder="Outlined" />

            <BUIInputDropdownTree TItem="Category"
                                  TValue="Category"
                                  Items="@Categories"
                                  KeySelector="@(c => c.Id)"
                                  ChildrenSelector="@(c => c.Children)"
                                  DisplayTextSelector="@(c => c.Name)"
                                  @bind-Value="_treeVariantFilled"
                                  Variant="BUIInputDropdownTreeVariant.Filled"
                                  Placeholder="Filled" />

            <BUIInputDropdownTree TItem="Category"
                                  TValue="Category"
                                  Items="@Categories"
                                  KeySelector="@(c => c.Id)"
                                  ChildrenSelector="@(c => c.Children)"
                                  DisplayTextSelector="@(c => c.Name)"
                                  @bind-Value="_treeVariantStandard"
                                  Variant="BUIInputDropdownTreeVariant.Standard"
                                  Placeholder="Standard" />
        </div>
    };

    private RenderFragment RenderTreeMultiple() => __builder =>
    {
        <BUIInputDropdownTree TItem="Category"
                              TValue="List<Category>"
                              Items="@Categories"
                              KeySelector="@(c => c.Id)"
                              ChildrenSelector="@(c => c.Children)"
                              DisplayTextSelector="@(c => c.Name)"
                              @bind-Value="SelectedCategories"
                              Label="Categories"
                              Placeholder="Select categories..."
                              ShowCheckboxes="true"
                              ExpandAll="true" />
    };

    private RenderFragment RenderTreeCascade() => __builder =>
    {
        <BUIInputDropdownTree TItem="Category"
                              TValue="List<Category>"
                              Items="@Categories"
                              KeySelector="@(c => c.Id)"
                              ChildrenSelector="@(c => c.Children)"
                              DisplayTextSelector="@(c => c.Name)"
                              @bind-Value="SelectedCascade"
                              Label="With cascade (select parent to select all children)"
                              Placeholder="Select..."
                              SelectionCascade="TreeSelectionCascade.Children"
                              ShowCheckboxes="true"
                              ExpandAll="true" />
    };

    private RenderFragment RenderTreeCustomTemplate() => __builder =>
    {
        <BUIInputDropdownTree TItem="Category"
                              TValue="Category"
                              Items="@Categories"
                              KeySelector="@(c => c.Id)"
                              ChildrenSelector="@(c => c.Children)"
                              DisplayTextSelector="@(c => c.Name)"
                              @bind-Value="SelectedTreeTemplate"
                              Label="With custom template"
                              Placeholder="Select category..."
                              ExpandAll="true">
            <NodeTemplate Context="node">
                <div class="category-node">
                    <span>@node.Text</span>
                    @if (node.Item != null)
                    {
                        <span class="category-count">@node.Item.ProductCount items</span>
                    }
                </div>
            </NodeTemplate>
        </BUIInputDropdownTree>
    };

