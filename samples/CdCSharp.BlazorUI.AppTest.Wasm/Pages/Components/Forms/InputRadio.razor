@page "/components/forms/input-radio"

@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Components.Forms
@using CdCSharp.BlazorUI.Core.Css

<PageTitle>Radio Buttons - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>BUIInputRadio</h1>

    <p class="doc-intro">
        <strong>BUIInputRadio</strong> is a radio button group component that supports
        declarative options, default values via <code>@("bind-Value")</code>, a clear button (via <code>Clearable</code>),
        custom content, orientation, colors, sizes and density.
    </p>

    <section class="doc-section">
        <h2>Basic usage</h2>
        <ComponentDemo Definition="@BasicUsageDemo" />
        <p>Selected: <strong>@(BasicValue ?? "null")</strong></p>
    </section>

    <section class="doc-section">
        <h2>Initial value</h2>
        <p>Set the initial selection by assigning a value to the variable bound via <code>@("bind-Value")</code>.</p>
        <ComponentDemo Definition="@InitialValueDemo" />
        <p>Selected: <strong>@(InitialValue ?? "null")</strong></p>
    </section>

    <section class="doc-section">
        <h2>Clearable</h2>
        <p>Set <code>Clearable="true"</code> to show a Clear button for resetting the selection.</p>
        <ComponentDemo Definition="@ClearableDemo" />
        <p>Selected: <strong>@(ClearableValue ?? "null")</strong></p>
    </section>

    <section class="doc-section">
        <h2>Non-clearable</h2>
        <p>If <code>Clearable</code> is not set (default false), no Clear button is shown.</p>
        <ComponentDemo Definition="@NonClearableDemo" />
        <p>Selected: <strong>@NonClearableValue</strong></p>
    </section>

    <section class="doc-section">
        <h2>Orientation</h2>
        <ComponentDemo Definition="@OrientationDemo" />
    </section>

    <section class="doc-section">
        <h2>Sizes</h2>
        <ComponentDemo Definition="@SizesDemo" />
    </section>

    <section class="doc-section">
        <h2>Density</h2>
        <ComponentDemo Definition="@DensityDemo" />
    </section>

    <section class="doc-section">
        <h2>Colors</h2>
        <ComponentDemo Definition="@ColorsDemo" />
    </section>

    <section class="doc-section">
        <h2>Custom content</h2>
        <p>Use <code>ChildContent</code> inside RadioOption for custom rendering.</p>
        <ComponentDemo Definition="@CustomContentDemo" />
        <p>Selected: <strong>@(CustomValue ?? "null")</strong></p>
    </section>

    <section class="doc-section">
        <h2>Disabled options</h2>
        <ComponentDemo Definition="@DisabledOptionsDemo" />
        <p>Selected: <strong>@(DisabledOptionsValue ?? "null")</strong></p>
    </section>

    <section class="doc-section">
        <h2>Disabled group</h2>
        <ComponentDemo Definition="@DisabledGroupDemo" />
    </section>

    <section class="doc-section">
        <h2>With Enum type</h2>
        <ComponentDemo Definition="@EnumDemo" />
        <p>Selected: <strong>@EnumValue</strong></p>
    </section>

    <section class="doc-section">
        <h2>Complex Types</h2>
        <p>
            When using classes as values, <strong>BUIInputRadio</strong> compares them using <code>EqualityComparer&lt;object&gt;.Default</code>.
            By default, C# compares classes by reference. To allow matching by value, you can use <code>record</code> or <code>IEquatable</code>.
        </p>

        <h3>Option A: Using records (Recommended)</h3>
        <p>Records automatically implement value-based equality.</p>
        <ComponentDemo Definition="@RecordDemo" />
        <p>Selected: <strong>@(SelectedProduct?.Name ?? "null")</strong></p>

        <h3>Option B: Implementing IEquatable</h3>
        <p>Ideal for existing classes where you want to control equality logic.</p>
        <ComponentDemo Definition="@PersonDemo" />
        <p>Selected: <strong>@(SelectedPerson?.Name ?? "null")</strong></p>
    </section>

    <section class="doc-section">
        <h2>Helper text</h2>
        <ComponentDemo Definition="@HelperTextDemo" />
    </section>

    <section class="doc-section">
        <h2>Properties - BUIInputRadio</h2>
        <PropertyTable Properties="@RadioProperties" />
    </section>

    <section class="doc-section">
        <h2>Properties - RadioOption</h2>
        <PropertyTable Properties="@OptionProperties" />
    </section>
</div>

@code {
    /* ===================== MODELS ===================== */

    public enum Priority { Low, Medium, High, Critical }

    public record Product(int Id, string Name);

    public class Person : IEquatable<Person>
    {
        public string Name { get; set; } = string.Empty;
        public int Age { get; set; }

        public bool Equals(Person? other) =>
            other != null && Name == other.Name && Age == other.Age;

        public override bool Equals(object? obj) => Equals(obj as Person);
        public override int GetHashCode() => HashCode.Combine(Name, Age);
    }

    /* ===================== VALUES ===================== */
    private string? BasicValue;
    private string? InitialValue = "Medium";
    private string? ClearableValue;
    private string NonClearableValue = "Medium";
    private string? CustomValue;
    private string? DisabledOptionsValue;
    private Priority EnumValue = Priority.Medium;
    private Person? SelectedPerson;
    private Product? SelectedProduct;

    /* ===================== DEMOS (CODE STRINGS) ===================== */

    private ComponentDemoDefinition BasicUsageDemo => new()
    {
        Demo = RenderBasicUsage(),
        Code = """
<BUIInputRadio @bind-Value="BasicValue" Label="Select size">
    <RadioOption Value="@("Small")">Small</RadioOption>
    <RadioOption Value="@("Medium")">Medium</RadioOption>
    <RadioOption Value="@("Large")">Large</RadioOption>
</BUIInputRadio>

@code {
    private string? BasicValue;
}
"""
    };

    private ComponentDemoDefinition InitialValueDemo => new()
    {
        Demo = RenderInitialValue(),
        Code = """
<BUIInputRadio @bind-Value="InitialValue" Label="Select size">
    <RadioOption Value="@("Small")">Small</RadioOption>
    <RadioOption Value="@("Medium")">Medium</RadioOption>
    <RadioOption Value="@("Large")">Large</RadioOption>
</BUIInputRadio>

@code {
    private string? InitialValue = "Medium";
}
"""
    };

    private ComponentDemoDefinition ClearableDemo => new()
    {
        Demo = RenderClearable(),
        Code = """
<BUIInputRadio @bind-Value="ClearableValue" Label="Select size (optional)" Clearable="true">
    <RadioOption Value="@("Small")">Small</RadioOption>
    <RadioOption Value="@("Medium")">Medium</RadioOption>
    <RadioOption Value="@("Large")">Large</RadioOption>
</BUIInputRadio>
"""
    };

    private ComponentDemoDefinition NonClearableDemo => new()
    {
        Demo = RenderNonClearable(),
        Code = """
<BUIInputRadio @bind-Value="NonClearableValue" Label="Select size (required)">
    <RadioOption Value="@("Small")">Small</RadioOption>
    <RadioOption Value="@("Medium")">Medium</RadioOption>
    <RadioOption Value="@("Large")">Large</RadioOption>
</BUIInputRadio>
"""
    };

    private ComponentDemoDefinition OrientationDemo => new()
    {
        Demo = RenderOrientation(),
        Code = """
<BUIInputRadio @bind-Value="_val" Label="Horizontal" Orientation="RadioOrientation.Horizontal">
    <RadioOption Value="@("A")">Option A</RadioOption>
    <RadioOption Value="@("B")">Option B</RadioOption>
</BUIInputRadio>
"""
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """
<BUIInputRadio @bind-Value="_val" Label="Small" Size="SizeEnum.Small">
    <RadioOption Value="@("A")">Option A</RadioOption>
</BUIInputRadio>
"""
    };

    private ComponentDemoDefinition DensityDemo => new()
    {
        Demo = RenderDensity(),
        Code = """
<BUIInputRadio @bind-Value="_val" Label="Compact" Density="DensityEnum.Compact">
    <RadioOption Value="@("A")">Option A</RadioOption>
</BUIInputRadio>
"""
    };

    private ComponentDemoDefinition ColorsDemo => new()
    {
        Demo = RenderColors(),
        Code = """
<BUIInputRadio @bind-Value="_val" Label="Success" Color="BUIColor.Palette.Success">
    <RadioOption Value="@("A")">Option A</RadioOption>
</BUIInputRadio>
"""
    };

    private ComponentDemoDefinition CustomContentDemo => new()
    {
        Demo = RenderCustomContent(),
        Code = """
<BUIInputRadio @bind-Value="CustomValue" Label="Select plan">
    <RadioOption Value="@("pro")">
        <div style="display: flex; flex-direction: column;">
            <strong style="color: var(--palette-primary);">Pro</strong>
            <small style="opacity: 0.7;">Advanced features</small>
        </div>
    </RadioOption>
</BUIInputRadio>
"""
    };

    private ComponentDemoDefinition DisabledOptionsDemo => new()
    {
        Demo = RenderDisabledOptions(),
        Code = """
<BUIInputRadio @bind-Value="DisabledOptionsValue" Label="Select tier">
    <RadioOption Value="@("basic")">Basic</RadioOption>
    <RadioOption Value="@("premium")" Disabled="true">Premium</RadioOption>
</BUIInputRadio>
"""
    };

    private ComponentDemoDefinition DisabledGroupDemo => new()
    {
        Demo = RenderDisabledGroup(),
        Code = """
<BUIInputRadio @bind-Value="_val" Label="Disabled group" Disabled="true">
    <RadioOption Value="@("A")">Option A</RadioOption>
</BUIInputRadio>
"""
    };

    private ComponentDemoDefinition EnumDemo => new()
    {
        Demo = RenderEnum(),
        Code = """
<BUIInputRadio @bind-Value="EnumValue" Label="Priority">
    <RadioOption Value="Priority.Low">Low</RadioOption>
    <RadioOption Value="Priority.Medium">Medium</RadioOption>
</BUIInputRadio>

@code {
    public enum Priority { Low, Medium, High, Critical }
    private Priority EnumValue = Priority.Medium;
}
"""
    };

    private ComponentDemoDefinition RecordDemo => new()
    {
        Demo = RenderRecord(),
        Code = """
<BUIInputRadio @bind-Value="SelectedProduct" Label="Select Product">
    <RadioOption Value="@(new Product(1, "Laptop"))">Laptop</RadioOption>
    <RadioOption Value="@(new Product(2, "Phone"))">Phone</RadioOption>
</BUIInputRadio>

@code {
    public record Product(int Id, string Name);
    private Product? SelectedProduct;
}
"""
    };

    private ComponentDemoDefinition PersonDemo => new()
    {
        Demo = RenderPerson(),
        Code = """
<BUIInputRadio @bind-Value="SelectedPerson" Label="Select Person">
    <RadioOption Value="@(new Person { Name = "Alice", Age = 25 })">Alice</RadioOption>
    <RadioOption Value="@(new Person { Name = "Bob", Age = 30 })">Bob</RadioOption>
</BUIInputRadio>

@code {
    public class Person : IEquatable<Person> {
        public string Name { get; set; }
        public int Age { get; set; }
        public bool Equals(Person? other) => other != null && Name == other.Name && Age == other.Age;
        public override bool Equals(object? obj) => Equals(obj as Person);
        public override int GetHashCode() => HashCode.Combine(Name, Age);
    }
    private Person? SelectedPerson;
}
"""
    };

    private ComponentDemoDefinition HelperTextDemo => new()
    {
        Demo = RenderHelperText(),
        Code = """
<BUIInputRadio @bind-Value="_val" Label="Preference" HelperText="Helper info">
    <RadioOption Value="@("A")">Option A</RadioOption>
</BUIInputRadio>
"""
    };

    /* ===================== RENDER FRAGMENTS ===================== */
    private string? _orientationVertical = "A";
    private string? _orientationHorizontal = "A";
    private string _sizeSmall = "A";
    private string _sizeMedium = "A";
    private string _sizeLarge = "A";
    private string _densityComfortable = "A";
    private string _densityStandard = "A";
    private string _densityCompact = "A";
    private string _colorPrimary = "A";
    private string _colorSuccess = "A";
    private string _colorCustom = "A";
    private string _disabledGroup = "A";
    private string _helperText = "email";

    private RenderFragment RenderBasicUsage() => __builder =>
    {
        <BUIInputRadio @bind-Value="BasicValue" Label="Select size">
            <RadioOption Value="@("Small")">Small</RadioOption>
            <RadioOption Value="@("Medium")">Medium</RadioOption>
            <RadioOption Value="@("Large")">Large</RadioOption>
        </BUIInputRadio>
    };

    private RenderFragment RenderInitialValue() => __builder =>
    {
        <BUIInputRadio @bind-Value="InitialValue" Label="Select size">
            <RadioOption Value="@("Small")">Small</RadioOption>
            <RadioOption Value="@("Medium")">Medium</RadioOption>
            <RadioOption Value="@("Large")">Large</RadioOption>
        </BUIInputRadio>
    };

    private RenderFragment RenderClearable() => __builder =>
    {
        <BUIInputRadio @bind-Value="ClearableValue" Label="Select size (optional)" Clearable="true">
            <RadioOption Value="@("Small")">Small</RadioOption>
            <RadioOption Value="@("Medium")">Medium</RadioOption>
            <RadioOption Value="@("Large")">Large</RadioOption>
        </BUIInputRadio>
    };

    private RenderFragment RenderNonClearable() => __builder =>
    {
        <BUIInputRadio @bind-Value="NonClearableValue" Label="Select size (required)">
            <RadioOption Value="@("Small")">Small</RadioOption>
            <RadioOption Value="@("Medium")">Medium</RadioOption>
            <RadioOption Value="@("Large")">Large</RadioOption>
        </BUIInputRadio>
    };

    private RenderFragment RenderOrientation() => __builder =>
    {
        <div class="demo-row" style="display: flex; gap: 3rem; align-items: flex-start;">
            <BUIInputRadio @bind-Value="_orientationVertical" Label="Vertical (default)" Orientation="RadioOrientation.Vertical">
                <RadioOption Value="@("A")">Option A</RadioOption>
                <RadioOption Value="@("B")">Option B</RadioOption>
            </BUIInputRadio>
            <BUIInputRadio @bind-Value="_orientationHorizontal" Label="Horizontal" Orientation="RadioOrientation.Horizontal">
                <RadioOption Value="@("A")">Option A</RadioOption>
                <RadioOption Value="@("B")">Option B</RadioOption>
            </BUIInputRadio>
        </div>
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <div class="demo-row" style="display: flex; gap: 2rem;">
            <BUIInputRadio @bind-Value="_sizeSmall" Label="Small" Size="SizeEnum.Small"><RadioOption Value="@("A")">A</RadioOption></BUIInputRadio>
            <BUIInputRadio @bind-Value="_sizeMedium" Label="Medium" Size="SizeEnum.Medium"><RadioOption Value="@("A")">A</RadioOption></BUIInputRadio>
            <BUIInputRadio @bind-Value="_sizeLarge" Label="Large" Size="SizeEnum.Large"><RadioOption Value="@("A")">A</RadioOption></BUIInputRadio>
        </div>
    };

    private RenderFragment RenderDensity() => __builder =>
    {
        <div class="demo-row" style="display: flex; gap: 2rem;">
            <BUIInputRadio @bind-Value="_densityComfortable" Label="Comfortable" Density="DensityEnum.Comfortable"><RadioOption Value="@("A")">A</RadioOption><RadioOption Value="@("B")">B</RadioOption></BUIInputRadio>
            <BUIInputRadio @bind-Value="_densityStandard" Label="Standard" Density="DensityEnum.Standard"><RadioOption Value="@("A")">A</RadioOption><RadioOption Value="@("B")">B</RadioOption></BUIInputRadio>
            <BUIInputRadio @bind-Value="_densityCompact" Label="Compact" Density="DensityEnum.Compact"><RadioOption Value="@("A")">A</RadioOption><RadioOption Value="@("B")">B</RadioOption></BUIInputRadio>
        </div>
    };

    private RenderFragment RenderColors() => __builder =>
    {
        <div class="demo-row" style="display: flex; gap: 2rem;">
            <BUIInputRadio @bind-Value="_colorPrimary" Label="Primary"><RadioOption Value="@("A")">A</RadioOption></BUIInputRadio>
            <BUIInputRadio @bind-Value="_colorSuccess" Label="Success" Color="BUIColor.Palette.Success"><RadioOption Value="@("A")">A</RadioOption></BUIInputRadio>
            <BUIInputRadio @bind-Value="_colorCustom" Label="Custom" Color="BUIColor.OrangeRed.Default"><RadioOption Value="@("A")">A</RadioOption></BUIInputRadio>
        </div>
    };

    private RenderFragment RenderCustomContent() => __builder =>
    {
        <BUIInputRadio @bind-Value="CustomValue" Label="Select plan">
            <RadioOption Value="@("free")">
                <div style="display: flex; flex-direction: column;"><strong>Free</strong><small style="opacity: 0.7;">Basic features</small></div>
            </RadioOption>
            <RadioOption Value="@("pro")">
                <div style="display: flex; flex-direction: column;"><strong style="color: var(--palette-primary);">Pro</strong><small style="opacity: 0.7;">Advanced features</small></div>
            </RadioOption>
        </BUIInputRadio>
    };

    private RenderFragment RenderDisabledOptions() => __builder =>
    {
        <BUIInputRadio @bind-Value="DisabledOptionsValue" Label="Select tier">
            <RadioOption Value="@("basic")">Basic</RadioOption>
            <RadioOption Value="@("premium")" Disabled="true">Premium (Coming soon)</RadioOption>
        </BUIInputRadio>
    };

    private RenderFragment RenderDisabledGroup() => __builder =>
    {
        <BUIInputRadio @bind-Value="_disabledGroup" Label="Disabled group" Disabled="true">
            <RadioOption Value="@("A")">Option A</RadioOption>
            <RadioOption Value="@("B")">Option B</RadioOption>
        </BUIInputRadio>
    };

    private RenderFragment RenderEnum() => __builder =>
    {
        <BUIInputRadio @bind-Value="EnumValue" Label="Priority" Orientation="RadioOrientation.Horizontal">
            <RadioOption Value="Priority.Low">Low</RadioOption>
            <RadioOption Value="Priority.Medium">Medium</RadioOption>
            <RadioOption Value="Priority.High">High</RadioOption>
            <RadioOption Value="Priority.Critical">Critical</RadioOption>
        </BUIInputRadio>
    };

    private RenderFragment RenderRecord() => __builder =>
    {
        <BUIInputRadio @bind-Value="SelectedProduct" Label="Select Product">
            <RadioOption Value="@(new Product(1, "Laptop"))">Laptop</RadioOption>
            <RadioOption Value="@(new Product(2, "Phone"))">Phone</RadioOption>
        </BUIInputRadio>
    };

    private RenderFragment RenderPerson() => __builder =>
    {
        <BUIInputRadio @bind-Value="SelectedPerson" Label="Select a person">
            <RadioOption Value="@(new Person { Name = "Alice", Age = 25 })">Alice</RadioOption>
            <RadioOption Value="@(new Person { Name = "Bob", Age = 30 })">Bob</RadioOption>
            <RadioOption Value="@(new Person { Name = "Charlie", Age = 35 })">Charlie</RadioOption>
        </BUIInputRadio>
    };

    private RenderFragment RenderHelperText() => __builder =>
    {
        <BUIInputRadio @bind-Value="_helperText" Label="Notification preference" HelperText="Choose how you want to receive notifications">
            <RadioOption Value="@("email")">Email</RadioOption>
            <RadioOption Value="@("sms")">SMS</RadioOption>
        </BUIInputRadio>
    };

    /* ===================== PROPERTIES ===================== */

    private List<PropertyDefinition> RadioProperties = new()
    {
        new("Value", "TValue", "-", "Current selected value"),
        new("ValueChanged", "EventCallback<TValue>", "-", "Value change callback"),
        new("Label", "string?", "null", "Group label"),
        new("HelperText", "string?", "null", "Helper text below the group"),
        new("Orientation", "RadioOrientation", "Vertical", "Layout orientation"),
        new("Size", "SizeEnum", "Medium", "Radio button size"),
        new("Density", "DensityEnum", "Standard", "Spacing density"),
        new("Color", "CssColor?", "null", "Selected state color"),
        new("Disabled", "bool", "false", "Disable entire group"),
        new("Clearable", "bool", "false", "Shows a clear button"),
        new("ChildContent", "RenderFragment?", "null", "RadioOption elements"),
    };

    private List<PropertyDefinition> OptionProperties = new()
    {
        new("Value", "TOption", "-", "Option value"),
        new("Disabled", "bool", "false", "Disable this option"),
        new("ChildContent", "RenderFragment?", "null", "Display content"),
    };
}