}

<BUIInputDateTime Label="Today's date" @bind-Value="InitialModel.DateOnlyToday" />
<BUIInputDateTime Label="Current time" @bind-Value="InitialModel.TimeOnlyNow" />
<BUIInputDateTime Label="2:30 PM" @bind-Value="InitialModel.DateTimePM" />
<BUIInputDateTime Label="9:15 AM" @bind-Value="InitialModel.TimeOnlyAM" />
"""
