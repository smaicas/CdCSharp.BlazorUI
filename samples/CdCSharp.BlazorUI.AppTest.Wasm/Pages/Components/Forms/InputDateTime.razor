@page "/components/forms/input-datetime"

@using System.ComponentModel.DataAnnotations
@using CdCSharp.BlazorUI.Components.Forms
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared

<PageTitle>InputDateTime - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>BUIInputDateTime</h1>

    <p class="doc-intro">
        <strong>BUIInputDateTime</strong> is a strongly-typed date and time input component.
        The rendered UI, formatting and picker behavior are automatically determined
        by the type of the bound value.
    </p>

    <!-- BASIC -->
    <section class="doc-section">
        <h2>Basic usage</h2>
        <ComponentDemo Definition="@BasicDemo" />
    </section>

    <!-- DATE ONLY -->
    <section class="doc-section">
        <h2>DateOnly</h2>
        <ComponentDemo Definition="@DateOnlyDemo" />
    </section>

    <!-- TIME ONLY -->
    <section class="doc-section">
        <h2>TimeOnly</h2>
        <ComponentDemo Definition="@TimeOnlyDemo" />
    </section>

    <!-- DATETIME -->
    <section class="doc-section">
        <h2>DateTime</h2>
        <ComponentDemo Definition="@DateTimeDemo" />
    </section>

    <!-- DATETIME OFFSET -->
    <section class="doc-section">
        <h2>DateTimeOffset</h2>
        <ComponentDemo Definition="@DateTimeOffsetDemo" />
    </section>

    <!-- INITIAL VALUES -->
    <section class="doc-section">
        <h2>Initial values</h2>
        <p>Components with pre-populated values. Notice how AM/PM initializes correctly for PM times.</p>
        <ComponentDemo Definition="@InitialValuesDemo" />
    </section>

    <!-- AM/PM TIME FORMATS -->
    <section class="doc-section">
        <h2>AM/PM time handling</h2>
        <p>Testing different times of day with 12-hour format to ensure AM/PM toggle works correctly.</p>
        <ComponentDemo Definition="@AmPmDemo" />
    </section>

    <!-- CLEAR FUNCTIONALITY -->
    <section class="doc-section">
        <h2>Clear functionality</h2>
        <p>Test the clear button behavior and how it resets to initial values.</p>
        <ComponentDemo Definition="@ClearDemo" />
    </section>

    <!-- VALIDATION -->
    <section class="doc-section">
        <h2>Validation</h2>
        <p>Form validation with required fields.</p>
        <ComponentDemo Definition="@ValidationDemo" />
    </section>

    <!-- PREFIX & SUFFIX -->
    <section class="doc-section">
        <h2>Prefix & Suffix</h2>
        <ComponentDemo Definition="@PrefixSuffixDemo" />
    </section>

    <!-- VARIANTS -->
    <section class="doc-section">
        <h2>Variants</h2>
        <ComponentDemo Definition="@VariantsDemo" />
    </section>

    <!-- SIZE -->
    <section class="doc-section">
        <h2>Sizes</h2>
        <ComponentDemo Definition="@SizesDemo" />
    </section>

    <!-- DENSITY -->
    <section class="doc-section">
        <h2>Density</h2>
        <ComponentDemo Definition="@DensityDemo" />
    </section>

    <!-- COLORS -->
    <section class="doc-section">
        <h2>Colors</h2>
        <ComponentDemo Definition="@ColorsDemo" />
    </section>

    <!-- READONLY / DISABLED -->
    <section class="doc-section">
        <h2>ReadOnly & Disabled</h2>
        <ComponentDemo Definition="@StateDemo" />
    </section>

    <!-- EDGE CASES -->
    <section class="doc-section">
        <h2>Edge cases</h2>
        <p>Testing boundary conditions and special scenarios.</p>
        <ComponentDemo Definition="@EdgeCasesDemo" />
    </section>

    <!-- CURRENT VALUES -->
    <section class="doc-section">
        <h2>Current values</h2>
        <pre class="demo-output">
DateOnly: @Model.DateOnly
TimeOnly: @Model.TimeOnly
DateTime: @Model.DateTime
DateTimeOffset: @Model.DateTimeOffset

Initial Values Model:
DateOnly (Today): @InitialModel.DateOnlyToday
TimeOnly (Now): @InitialModel.TimeOnlyNow
DateTime (PM): @InitialModel.DateTimePM
TimeOnly (AM): @InitialModel.TimeOnlyAM

Clear Test Model:
WithInitial: @ClearModel.WithInitial
WithoutInitial: @ClearModel.WithoutInitial

AM/PM Test Model:
Midnight: @AmPmModel.Midnight
Noon: @AmPmModel.Noon
Morning: @AmPmModel.Morning
Afternoon: @AmPmModel.Afternoon
Evening: @AmPmModel.Evening

Edge Cases Model:
LeapYear: @EdgeCasesModel.LeapYear
EndOfMonth: @EdgeCasesModel.EndOfMonth
YearBoundary: @EdgeCasesModel.YearBoundary
        </pre>
    </section>

    <!-- PROPERTIES -->
    <section class="doc-section">
        <h2>Properties</h2>
        <PropertyTable Properties="@Properties" />
    </section>
</div>

@code {
    /* ===================== MODELS ===================== */

    private DemoModel Model = new();
    private InitialValuesModel InitialModel = new();
    private ClearDemoModel ClearModel = new();
    private AmPmDemoModel AmPmModel = new();
    private EdgeCasesModelClass EdgeCasesModel = new();
    private ValidationModelClass ValidationModel = new();

    private class DemoModel
    {
        [Required] public DateOnly? DateOnly { get; set; }
        [Required] public TimeOnly? TimeOnly { get; set; }
        [Required] public DateTime? DateTime { get; set; }
        [Required] public DateTimeOffset? DateTimeOffset { get; set; }
    }

    private class InitialValuesModel
    {
        public DateOnly? DateOnlyToday { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public TimeOnly? TimeOnlyNow { get; set; } = TimeOnly.FromDateTime(DateTime.Now);
        public DateTime? DateTimePM { get; set; } = new DateTime(2024, 6, 15, 14, 30, 0); // 2:30 PM
        public TimeOnly? TimeOnlyAM { get; set; } = new TimeOnly(9, 15); // 9:15 AM
    }

    private class ClearDemoModel
    {
        public DateTime? WithInitial { get; set; } = new DateTime(2024, 1, 1, 12, 0, 0);
        public DateTime? WithoutInitial { get; set; }
    }

    private class AmPmDemoModel
    {
        public DateTime? MidnightDate { get; set; } = new DateTime(2024, 6, 15, 0, 0, 0); // 12:00 AM
        public TimeOnly? Midnight { get; set; } = new TimeOnly(0, 0); // 12:00 AM
        public TimeOnly? Noon { get; set; } = new TimeOnly(12, 0); // 12:00 PM
        public TimeOnly? Morning { get; set; } = new TimeOnly(9, 30); // 9:30 AM
        public TimeOnly? Afternoon { get; set; } = new TimeOnly(14, 45); // 2:45 PM
        public TimeOnly? Evening { get; set; } = new TimeOnly(23, 59); // 11:59 PM
    }

    private class EdgeCasesModelClass
    {
        public DateOnly? LeapYear { get; set; } = new DateOnly(2024, 2, 29);
        public DateOnly? EndOfMonth { get; set; } = new DateOnly(2024, 1, 31);
        public DateTime? YearBoundary { get; set; } = new DateTime(2024, 12, 31, 23, 59, 59);
    }

    private class ValidationModelClass
    {
        [Required(ErrorMessage = "Date is required")]
        public DateOnly? RequiredDate { get; set; }

        [Required(ErrorMessage = "Time is required")]
        public TimeOnly? RequiredTime { get; set; }

        [Required(ErrorMessage = "DateTime is required")]
        public DateTime? RequiredDateTime { get; set; }
    }

    /* ===================== DEMOS ===================== */

    private ComponentDemoDefinition BasicDemo => new()
    {
        Demo = RenderBasic(),
        Code = """
<EditForm Model="model">
    <DataAnnotationsValidator />

    <BUIInputDateTime Label="Date"
                      Required
                      @bind-Value="model.DateOnly" />
</EditForm>
"""
    };

    private ComponentDemoDefinition DateOnlyDemo => new()
    {
        Demo = RenderDateOnly(),
        Code = """
<BUIInputDateTime Label="DateOnly"
                  Required
                  @bind-Value="model.DateOnly" />
"""
    };

    private ComponentDemoDefinition TimeOnlyDemo => new()
