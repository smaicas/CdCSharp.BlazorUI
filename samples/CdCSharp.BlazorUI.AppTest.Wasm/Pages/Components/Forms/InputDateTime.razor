@page "/components/forms/input-datetime"

@using System.ComponentModel.DataAnnotations
@using CdCSharp.BlazorUI.Components.Forms
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared

<PageTitle>InputDateTime - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>BUIInputDateTime</h1>

    <p class="doc-intro">
        <strong>BUIInputDateTime</strong> is a strongly-typed date and time input component.
        The rendered UI, formatting and picker behavior are automatically determined
        by the type of the bound value.
    </p>

    <!-- BASIC -->
    <section class="doc-section">
        <h2>Basic usage</h2>
        <ComponentDemo Definition="@BasicDemo" />
    </section>

    <!-- DATE ONLY -->
    <section class="doc-section">
        <h2>DateOnly</h2>
        <ComponentDemo Definition="@DateOnlyDemo" />
    </section>

    <!-- TIME ONLY -->
    <section class="doc-section">
        <h2>TimeOnly</h2>
        <ComponentDemo Definition="@TimeOnlyDemo" />
    </section>

    <!-- DATETIME -->
    <section class="doc-section">
        <h2>DateTime</h2>
        <ComponentDemo Definition="@DateTimeDemo" />
    </section>

    <!-- DATETIME OFFSET -->
    <section class="doc-section">
        <h2>DateTimeOffset</h2>
        <ComponentDemo Definition="@DateTimeOffsetDemo" />
    </section>

    <!-- SIZE -->
    <section class="doc-section">
        <h2>Sizes</h2>
        <ComponentDemo Definition="@SizesDemo" />
    </section>

    <!-- DENSITY -->
    <section class="doc-section">
        <h2>Density</h2>
        <ComponentDemo Definition="@DensityDemo" />
    </section>

    <!-- READONLY / DISABLED -->
    <section class="doc-section">
        <h2>ReadOnly & Disabled</h2>
        <ComponentDemo Definition="@StateDemo" />
    </section>

    <!-- CURRENT VALUES -->
    <section class="doc-section">
        <h2>Current values</h2>
        <pre class="demo-output">
DateOnly: @Model.DateOnly
TimeOnly: @Model.TimeOnly
DateTime: @Model.DateTime
DateTimeOffset: @Model.DateTimeOffset
        </pre>
    </section>

    <!-- PROPERTIES -->
    <section class="doc-section">
        <h2>Properties</h2>
        <PropertyTable Properties="@Properties" />
    </section>
</div>

@code {
    /* ===================== MODEL ===================== */

    private DemoModel Model = new();

    private class DemoModel
    {
        [Required] public DateOnly? DateOnly { get; set; }
        [Required] public TimeOnly? TimeOnly { get; set; }
        [Required] public DateTime? DateTime { get; set; }
        [Required] public DateTimeOffset? DateTimeOffset { get; set; }
    }

    /* ===================== DEMOS ===================== */

    private ComponentDemoDefinition BasicDemo => new()
    {
        Demo = RenderBasic(),
        Code = """
<EditForm Model="model">
    <DataAnnotationsValidator />

    <BUIInputDateTime Label="Date"
                      Required
                      @bind-Value="model.DateOnly" />
</EditForm>
"""
    };

    private ComponentDemoDefinition DateOnlyDemo => new()
    {
        Demo = RenderDateOnly(),
        Code = """
<BUIInputDateTime Label="DateOnly"
                  Required
                  @bind-Value="model.DateOnly" />
"""
    };

    private ComponentDemoDefinition TimeOnlyDemo => new()
    {
        Demo = RenderTimeOnly(),
        Code = """
<BUIInputDateTime Label="TimeOnly"
                  Required
                  @bind-Value="model.TimeOnly" />
"""
    };

    private ComponentDemoDefinition DateTimeDemo => new()
    {
        Demo = RenderDateTime(),
        Code = """
<BUIInputDateTime Label="DateTime"
                  HelperText="Select date and time"
                  Required
                  @bind-Value="model.DateTime" />
"""
    };

    private ComponentDemoDefinition DateTimeOffsetDemo => new()
    {
        Demo = RenderDateTimeOffset(),
        Code = """
<BUIInputDateTime Label="DateTimeOffset"
                  Required
                  @bind-Value="model.DateTimeOffset" />
"""
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """
<BUIInputDateTime Label="Small"
                  Size="SizeEnum.Small"
                  @bind-Value="model.DateOnly" />

<BUIInputDateTime Label="Medium"
                  Size="SizeEnum.Medium"
                  @bind-Value="model.DateOnly" />

<BUIInputDateTime Label="Large"
                  Size="SizeEnum.Large"
                  @bind-Value="model.DateOnly" />
"""
    };

    private ComponentDemoDefinition DensityDemo => new()
    {
        Demo = RenderDensity(),
        Code = """
<BUIInputDateTime Label="Comfortable"
                  Density="DensityEnum.Comfortable"
                  @bind-Value="model.DateOnly" />

<BUIInputDateTime Label="Standard"
                  Density="DensityEnum.Standard"
                  @bind-Value="model.DateOnly" />

<BUIInputDateTime Label="Compact"
                  Density="DensityEnum.Compact"
                  @bind-Value="model.DateOnly" />
"""
    };

    private ComponentDemoDefinition StateDemo => new()
    {
        Demo = RenderStates(),
        Code = """
<BUIInputDateTime Label="ReadOnly"
                  ReadOnly
                  @bind-Value="model.DateOnly" />

<BUIInputDateTime Label="Disabled"
                  Disabled
                  @bind-Value="model.DateOnly" />
"""
    };

    /* ===================== RENDER FRAGMENTS ===================== */

    private RenderFragment RenderBasic() => __builder =>
    {
        <EditForm Model="Model">
            <DataAnnotationsValidator />
            <BUIInputDateTime Label="Date"
                              Required
                              @bind-Value="Model.DateOnly" />
        </EditForm>
        ;
    };

    private RenderFragment RenderDateOnly() => __builder =>
    {
        <BUIInputDateTime Label="DateOnly"
                          Required
                          @bind-Value="Model.DateOnly" />
        ;
    };

    private RenderFragment RenderTimeOnly() => __builder =>
    {
        <BUIInputDateTime Label="TimeOnly"
                          Required
                          @bind-Value="Model.TimeOnly" />
        ;
    };

    private RenderFragment RenderDateTime() => __builder =>
    {
        <BUIInputDateTime Label="DateTime"
                          HelperText="Select date and time"
                          Required
                          @bind-Value="Model.DateTime" />
        ;
    };

    private RenderFragment RenderDateTimeOffset() => __builder =>
    {
        <BUIInputDateTime Label="DateTimeOffset"
                          Required
                          @bind-Value="Model.DateTimeOffset" />
        ;
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <div class="demo-column">
            <BUIInputDateTime Label="Small"
                              Size="SizeEnum.Small"
                              @bind-Value="Model.DateOnly" />
            <BUIInputDateTime Label="Medium"
                              Size="SizeEnum.Medium"
                              @bind-Value="Model.DateOnly" />
            <BUIInputDateTime Label="Large"
                              Size="SizeEnum.Large"
                              @bind-Value="Model.DateOnly" />
        </div>
        ;
    };

    private RenderFragment RenderDensity() => __builder =>
    {
        <div class="demo-column">
            <BUIInputDateTime Label="Comfortable"
                              Density="DensityEnum.Comfortable"
                              @bind-Value="Model.DateOnly" />
            <BUIInputDateTime Label="Standard"
                              Density="DensityEnum.Standard"
                              @bind-Value="Model.DateOnly" />
            <BUIInputDateTime Label="Compact"
                              Density="DensityEnum.Compact"
                              @bind-Value="Model.DateOnly" />
        </div>
        ;
    };

    private RenderFragment RenderStates() => __builder =>
    {
        <div class="demo-column">
            <BUIInputDateTime Label="ReadOnly"
                              ReadOnly
                              @bind-Value="Model.DateOnly" />
            <BUIInputDateTime Label="Disabled"
                              Disabled
                              @bind-Value="Model.DateOnly" />
        </div>
        ;
    };

    /* ===================== PROPERTIES ===================== */

    private List<PropertyDefinition> Properties = new()
    {
        new("Value", "TValue", "null", "Bound value. Determines input behavior."),
        new("ValueChanged", "EventCallback<TValue>", "-", "Raised when the value changes"),
        new("Label", "string?", "null", "Input label"),
        new("HelperText", "string?", "null", "Helper text below the input"),
        new("Required", "bool", "false", "Marks the field as required"),
        new("ReadOnly", "bool", "false", "Makes the input read-only"),
        new("Disabled", "bool", "false", "Disables the input"),
        new("Size", "SizeEnum", "Medium", "Input size"),
        new("Density", "DensityEnum", "Standard", "Input density"),
    };
}
