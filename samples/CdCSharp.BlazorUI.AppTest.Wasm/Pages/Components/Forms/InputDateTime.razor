<BUIInputDateTime Label="Midnight (12:00 AM)" @bind-Value="AmPmModel.Midnight" />
<BUIInputDateTime Label="Noon (12:00 PM)" @bind-Value="AmPmModel.Noon" />
<BUIInputDateTime Label="Morning (9:30 AM)" @bind-Value="AmPmModel.Morning" />
<BUIInputDateTime Label="Afternoon (2:45 PM)" @bind-Value="AmPmModel.Afternoon" />
<BUIInputDateTime Label="Evening (11:59 PM)" @bind-Value="AmPmModel.Evening" />
"""
    };

    private ComponentDemoDefinition ClearDemo => new()
    {
        Demo = RenderClear(),
        Code = """
private ClearDemoModel ClearModel = new();

private class ClearDemoModel
{
    public DateTime? WithInitial { get; set; } = new DateTime(2024, 1, 1, 12, 0, 0);
    public DateTime? WithoutInitial { get; set; }
}

<BUIInputDateTime Label="With initial value (clears to initial)"
                  HelperText="Clear button resets to January 1, 2024"
                  @bind-Value="ClearModel.WithInitial" />

<BUIInputDateTime Label="Without initial value (clears to null)"
                  HelperText="Clear button removes all content"
                  @bind-Value="ClearModel.WithoutInitial" />
"""
    };

    private ComponentDemoDefinition ValidationDemo => new()
    {
        Demo = RenderValidation(),
        Code = """
private ValidationModel ValidationModel = new();

private class ValidationModel
{
    [Required(ErrorMessage = "Date is required")]
    public DateOnly? RequiredDate { get; set; }

    [Required(ErrorMessage = "Time is required")]
    public TimeOnly? RequiredTime { get; set; }

    [Required(ErrorMessage = "DateTime is required")]
    public DateTime? RequiredDateTime { get; set; }
}

<EditForm Model="ValidationModel" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />

    <BUIInputDateTime Label="Required Date"
                      Required
                      @bind-Value="ValidationModel.RequiredDate" />

    <BUIInputDateTime Label="Required Time"
                      Required
                      @bind-Value="ValidationModel.RequiredTime" />

    <BUIInputDateTime Label="Required DateTime"
                      Required
                      @bind-Value="ValidationModel.RequiredDateTime" />

    <BUIButton Text="Submit" Type="submit" />
</EditForm>
"""
    };

    private ComponentDemoDefinition PrefixSuffixDemo => new()
