"""
    };

    private ComponentDemoDefinition NumericTypesDemo => new()
    {
        Demo = RenderNumericTypes(),
        Code = """
<BUIInputNumber @bind-Value="_intValue"
                Label="Int32" />

<BUIInputNumber @bind-Value="_longValue"
                Label="Int64 (Long)" />

<BUIInputNumber @bind-Value="_floatValue"
                Label="Float"
                DecimalPlaces="3" />

<BUIInputNumber @bind-Value="_doubleValue"
                Label="Double"
                DecimalPlaces="4" />

<BUIInputNumber @bind-Value="_decimalValue"
                Label="Decimal"
                DecimalPlaces="2" />

<BUIInputNumber @bind-Value="_nullableInt"
                Label="Nullable Int"
                Placeholder="null" />
"""
    };

    private ComponentDemoDefinition ShoppingCartDemo => new()
    {
        Demo = RenderShoppingCart(),
        Code = """
<BUIInputNumber @bind-Value="_quantity"
                Label="Quantity"
                Min="1"
                Max="99"
                Size="SizeEnum.Small" />

<BUIInputNumber @bind-Value="_unitPrice"
                Label="Unit Price"
                PrefixText="$"
                DecimalPlaces="2"
                ReadOnly="true"
                Size="SizeEnum.Small" />
"""
    };

    private ComponentDemoDefinition TemperatureDemo => new()
    {
        Demo = RenderTemperature(),
        Code = """
<BUIInputNumber @bind-Value="_celsius"
                Label="Celsius"
                SuffixText="°C"
                DecimalPlaces="1"
                Step="0.5m"
                OnIncrement="@((decimal? _) => UpdateFahrenheit())"
                OnDecrement="@((decimal? _) => UpdateFahrenheit())" />

<BUIInputNumber @bind-Value="_fahrenheit"
                Label="Fahrenheit"
                SuffixText="°F"
                DecimalPlaces="1"
                ReadOnly="true" />
"""
    };

    private ComponentDemoDefinition TipCalculatorDemo => new()
    {
        Demo = RenderTipCalculator(),
        Code = """
<BUIInputNumber @bind-Value="_billAmount"
                Label="Bill Amount"
                PrefixText="$"
                DecimalPlaces="2"
                Min="0m"
                OnIncrement="@((decimal? _) => CalculateTip())"
                OnDecrement="@((decimal? _) => CalculateTip())" />

<BUIInputNumber @bind-Value="_tipPercent"
                Label="Tip %"
                SuffixText="%"
                Min="0"
