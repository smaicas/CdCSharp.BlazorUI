<BUIInputNumber @bind-Value="_noButtonsValue"
                Label="No Buttons"
                ShowStepButtons="false"
                HelperText="Keyboard arrows only" />
"""
    };

    private ComponentDemoDefinition StatesDemo => new()
    {
        Demo = RenderStates(),
        Code = """
<BUIInputNumber @bind-Value="_stateValue"
                Label="Disabled"
                Disabled="true" />

<BUIInputNumber @bind-Value="_stateValue"
                Label="Read Only"
                ReadOnly="true" />

<BUIInputNumber @bind-Value="_stateValue"
                Label="Required"
                Required="true" />
"""
    };

    private ComponentDemoDefinition LoadingStateDemo => new()
    {
        Demo = RenderLoadingState(),
        Code = """
<BUIInputNumber @bind-Value="_loadingValue"
                Label="Loading"
                IsLoading="true"
                LoadingIndicatorVariant="BUILoadingIndicatorVariant.Spinner" />
"""
    };

    private ComponentDemoDefinition CallbacksDemo => new()
    {
        Demo = RenderCallbacks(),
        Code = """
<BUIInputNumber @bind-Value="_callbackValue"
                Label="With Callbacks"
                OnIncrement="@HandleIncrement"
                OnDecrement="@HandleDecrement"
