    /* ===================== RENDER FRAGMENTS ===================== */

    private RenderFragment RenderBasicUsage() => __builder =>
    {
        <div class="demo-row">
            <BUIInputNumber @bind-Value="_basicInt"
                            Label="Integer Input"
                            Placeholder="Enter a number"
                            HelperText="Basic integer input" />

            <BUIInputNumber @bind-Value="_basicDecimal"
                            Label="Decimal Input"
                            Placeholder="Enter a decimal"
                            DecimalPlaces="2"
                            HelperText="Decimal with 2 places" />
        </div>;
    };

    private RenderFragment RenderVariants() => __builder =>
    {
        <div class="demo-row">
            <BUIInputNumber @bind-Value="_variantValue"
                            Variant="BUIInputVariant.Outlined"
                            Label="Outlined" />

            <BUIInputNumber @bind-Value="_variantValue"
                            Variant="BUIInputVariant.Filled"
                            Label="Filled" />

            <BUIInputNumber @bind-Value="_variantValue"
                            Variant="BUIInputVariant.Standard"
                            Label="Standard" />
