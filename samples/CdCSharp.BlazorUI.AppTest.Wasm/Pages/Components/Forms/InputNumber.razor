@page "/components/forms/input-number"

@using System.Globalization
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Core.Css

<PageTitle>Input Number - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>BUIInputNumber</h1>

    <p class="doc-intro">
        <strong>BUIInputNumber</strong> provides a highly customizable numeric input component
        with culture-aware formatting, step controls, prefix/suffix support, and validation.
        Supports multiple numeric types with fluid editing experience.
    </p>

    <!-- BASIC USAGE -->
    <section class="doc-section">
        <h2>Basic usage</h2>
        <ComponentDemo Definition="@BasicUsageDemo" />
        <p>Integer value: @_basicInt | Decimal value: @_basicDecimal</p>
    </section>

    <!-- VARIANTS -->
    <section class="doc-section">
        <h2>Variants</h2>
        <ComponentDemo Definition="@VariantsDemo" />
    </section>

    <!-- SIZES -->
    <section class="doc-section">
        <h2>Sizes</h2>
        <ComponentDemo Definition="@SizesDemo" />
    </section>

    <!-- MIN/MAX & STEP -->
    <section class="doc-section">
        <h2>Min/Max & Step</h2>
        <ComponentDemo Definition="@RangeDemo" />
        <p>Range value: @_rangeValue | Step value: @_stepValue</p>
    </section>

    <!-- PREFIX & SUFFIX TEXT -->
    <section class="doc-section">
        <h2>Prefix & Suffix (Text)</h2>
        <ComponentDemo Definition="@PrefixSuffixTextDemo" />
    </section>

    <!-- PREFIX & SUFFIX ICONS -->
    <section class="doc-section">
        <h2>Prefix & Suffix (Icons)</h2>
        <ComponentDemo Definition="@PrefixSuffixIconDemo" />
    </section>

    <!-- COMBINED PREFIX/SUFFIX -->
    <section class="doc-section">
        <h2>Combined Prefix/Suffix</h2>
        <ComponentDemo Definition="@CombinedPrefixSuffixDemo" />
    </section>

    <!-- CULTURE FORMATTING -->
    <section class="doc-section">
        <h2>Number Formatting & Culture</h2>
        <ComponentDemo Definition="@CultureFormattingDemo" />
        <div style="margin-top: 1rem; padding: 1rem; background: rgba(0,0,0,0.05); border-radius: 4px;">
            <h4>Try typing naturally!</h4>
            <p>Focus on any input and type numbers using the culture's format. The decimal separator will match the culture (. or ,). Thousand separators are added on blur for readability.</p>
        </div>
    </section>

    <!-- BUTTON PLACEMENT -->
    <section class="doc-section">
        <h2>Button placement</h2>
        <ComponentDemo Definition="@ButtonPlacementDemo" />
    </section>

    <!-- ADVANCED FEATURES -->
    <section class="doc-section">
        <h2>Advanced features</h2>
        <ComponentDemo Definition="@AdvancedFeaturesDemo" />
    </section>

    <!-- STATES -->
    <section class="doc-section">
        <h2>States</h2>
        <ComponentDemo Definition="@StatesDemo" />
    </section>

    <!-- LOADING STATE -->
    <section class="doc-section">
        <h2>Loading state</h2>
        <ComponentDemo Definition="@LoadingStateDemo" />
    </section>

    <!-- CALLBACKS -->
    <section class="doc-section">
        <h2>Callbacks</h2>
        <ComponentDemo Definition="@CallbacksDemo" />
        <div style="margin-top: 1rem; padding: 1rem; background: rgba(0,0,0,0.05); border-radius: 4px;">
            <p><strong>Last Action:</strong> @_lastAction</p>
            <p><strong>Current Value:</strong> @_callbackValue</p>
        </div>
    </section>

    <!-- NUMERIC TYPES -->
    <section class="doc-section">
        <h2>Different numeric types</h2>
        <ComponentDemo Definition="@NumericTypesDemo" />
    </section>

    <!-- REAL-WORLD EXAMPLES -->
    <section class="doc-section">
        <h2>Real-world examples</h2>

        <h3 style="margin-top: 2rem;">Shopping Cart</h3>
        <ComponentDemo Definition="@ShoppingCartDemo" />
        <p style="margin-top: 1rem;"><strong>Total: $@(((_quantity ?? 0) * (_unitPrice ?? 0)).ToString("F2"))</strong></p>

        <h3 style="margin-top: 2rem;">Temperature Converter</h3>
        <ComponentDemo Definition="@TemperatureDemo" />

        <h3 style="margin-top: 2rem;">Tip Calculator</h3>
        <ComponentDemo Definition="@TipCalculatorDemo" />
        <div style="margin-top: 1rem; padding: 1rem; background: var(--palette-primary); color: var(--palette-primarycontrast); border-radius: 4px;">
            <h4 style="margin: 0;">Total: $@_totalWithTip.ToString("F2")</h4>
        </div>
    </section>

    <!-- PROPERTIES -->
    <section class="doc-section">
        <h2>Properties</h2>
        <PropertyTable Properties="@Properties" />
    </section>
</div>

@code {
    private int? _basicInt = 42;
    private decimal? _basicDecimal = 3.14m;
    private int? _variantValue = 100;
    private int? _sizeValue = 50;
    private int? _rangeValue = 50;
    private decimal? _stepValue = 0.5m;
    private decimal? _priceValue = 99.99m;
    private int? _percentValue = 75;
    private decimal? _priceIconValue = 149.99m;
    private decimal? _weightValue = 68.5m;
    private decimal? _priceComboValue = 249.99m;
    private decimal? _tempComboValue = 22.5m;
    private decimal? _formattedValue = 123456.78m;
    private decimal? _germanValue = 1234.56m;
    private decimal? _spanishValue = 5678.90m;
    private decimal? _frenchValue = 9876.54m;
    private int? _buttonValue = 10;
    private int? _mouseWheelValue = 0;
    private int? _accelerationValue = 0;
    private int? _noButtonsValue = 0;
    private int? _stateValue = 100;
    private int? _loadingValue = 50;
    private int? _callbackValue = 0;
    private string _lastAction = "None";
    private int? _intValue = 42;
    private long? _longValue = 1234567890L;
    private float? _floatValue = 3.14159f;
    private double? _doubleValue = 2.71828;
    private decimal? _decimalValue = 123.45m;
    private int? _nullableInt = null;
    private int? _quantity = 1;
    private decimal? _unitPrice = 19.99m;
    private decimal? _celsius = 20m;
    private decimal? _fahrenheit = 68m;
    private decimal? _billAmount = 50m;
    private int? _tipPercent = 20;
    private decimal? _tipAmount = 10m;
    private decimal _totalWithTip = 60m;

    private readonly CultureInfo _usCulture = new("en-US");
    private readonly CultureInfo _germanCulture = new("de-DE");
    private readonly CultureInfo _spanishCulture = new("es-ES");
    private readonly CultureInfo _frenchCulture = new("fr-FR");

    /* ===================== DEMOS ===================== */

    private ComponentDemoDefinition BasicUsageDemo => new()
    {
        Demo = RenderBasicUsage(),
        Code = """
<BUIInputNumber @bind-Value="_basicInt"
                Label="Integer Input"
                Placeholder="Enter a number" />

<BUIInputNumber @bind-Value="_basicDecimal"
                Label="Decimal Input"
                Placeholder="Enter a decimal"
                DecimalPlaces="2" />
"""
    };

    private ComponentDemoDefinition VariantsDemo => new()
    {
        Demo = RenderVariants(),
        Code = """
<BUIInputNumber @bind-Value="_variantValue"
                Variant="BUIInputVariant.Outlined"
                Label="Outlined" />

<BUIInputNumber @bind-Value="_variantValue"
                Variant="BUIInputVariant.Filled"
                Label="Filled" />

<BUIInputNumber @bind-Value="_variantValue"
                Variant="BUIInputVariant.Standard"
                Label="Standard" />
"""
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """
<BUIInputNumber @bind-Value="_sizeValue"
                Size="SizeEnum.Small"
                Label="Small" />

<BUIInputNumber @bind-Value="_sizeValue"
                Size="SizeEnum.Medium"
                Label="Medium" />

<BUIInputNumber @bind-Value="_sizeValue"
                Size="SizeEnum.Large"
                Label="Large" />
"""
    };

    private ComponentDemoDefinition RangeDemo => new()
    {
        Demo = RenderRange(),
        Code = """
<BUIInputNumber @bind-Value="_rangeValue"
                Label="Range (0-100)"
                Min="0"
                Max="100"
                Step="5"
                HelperText="Step: 5, Min: 0, Max: 100" />

<BUIInputNumber @bind-Value="_stepValue"
                Label="Decimal Steps"
                Min="0m"
                Max="1m"
                Step="0.1m"
                DecimalPlaces="2"
                HelperText="Step: 0.1, Range: 0-1" />
"""
    };

    private ComponentDemoDefinition PrefixSuffixTextDemo => new()
    {
        Demo = RenderPrefixSuffixText(),
        Code = """
<BUIInputNumber @bind-Value="_priceValue"
                Label="Price"
                PrefixText="$"
                DecimalPlaces="2"
                Min="0m" />

<BUIInputNumber @bind-Value="_percentValue"
                Label="Percentage"
                SuffixText="%"
                Min="0"
                Max="100" />
"""
    };

    private ComponentDemoDefinition PrefixSuffixIconDemo => new()
    {
        Demo = RenderPrefixSuffixIcon(),
        Code = """
<BUIInputNumber @bind-Value="_priceIconValue"
                Label="Price"
                PrefixIcon="@BUIIcons.MaterialIconsOutlined.i_attach_money"
                DecimalPlaces="2"
                Min="0m" />

<BUIInputNumber @bind-Value="_weightValue"
                Label="Weight"
                SuffixIcon="@BUIIcons.MaterialIconsOutlined.i_fitness_center"
                DecimalPlaces="1"
                Step="0.5m" />
"""
    };

    private ComponentDemoDefinition CombinedPrefixSuffixDemo => new()
    {
        Demo = RenderCombinedPrefixSuffix(),
        Code = """
<BUIInputNumber @bind-Value="_priceComboValue"
                Label="Price (Icon + Text)"
                PrefixIcon="@BUIIcons.MaterialIconsOutlined.i_attach_money"
                PrefixText="USD"
                DecimalPlaces="2"
                Min="0m" />

<BUIInputNumber @bind-Value="_tempComboValue"
                Label="Temperature"
                SuffixIcon="@BUIIcons.MaterialIconsOutlined.i_thermostat"
                SuffixText="°C"
                DecimalPlaces="1" />
"""
    };

    private ComponentDemoDefinition CultureFormattingDemo => new()
    {
        Demo = RenderCultureFormatting(),
        Code = """
<BUIInputNumber @bind-Value="_formattedValue"
                Label="US Format (en-US)"
                UseThousandsSeparator="true"
                Culture="@_usCulture"
                DecimalPlaces="2"
                HelperText="Format: 1,234.56" />

<BUIInputNumber @bind-Value="_germanValue"
                Label="German Format (de-DE)"
                UseThousandsSeparator="true"
                Culture="@_germanCulture"
                DecimalPlaces="2"
                HelperText="Format: 1.234,56" />

<BUIInputNumber @bind-Value="_spanishValue"
                Label="Spanish Format (es-ES)"
                UseThousandsSeparator="true"
                Culture="@_spanishCulture"
                DecimalPlaces="2"
                HelperText="Format: 1.234,56" />

<BUIInputNumber @bind-Value="_frenchValue"
                Label="French Format (fr-FR)"
                UseThousandsSeparator="true"
                Culture="@_frenchCulture"
                DecimalPlaces="2"
                HelperText="Format: 1 234,56" />
"""
    };

    private ComponentDemoDefinition ButtonPlacementDemo => new()
    {
        Demo = RenderButtonPlacement(),
        Code = """
<BUIInputNumber @bind-Value="_buttonValue"
                Label="Buttons on Right (Default)"
                ButtonPlacement="StepButtonPlacement.Right" />

<BUIInputNumber @bind-Value="_buttonValue"
                Label="Buttons on Left"
                ButtonPlacement="StepButtonPlacement.Left" />
"""
    };

    private ComponentDemoDefinition AdvancedFeaturesDemo => new()
    {
        Demo = RenderAdvancedFeatures(),
        Code = """
<BUIInputNumber @bind-Value="_mouseWheelValue"
