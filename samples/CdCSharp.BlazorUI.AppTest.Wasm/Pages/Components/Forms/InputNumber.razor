    private Task HandleIncrement(int? value)
    {
        _lastAction = $"Incremented to {value}";
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task HandleDecrement(int? value)
    {
        _lastAction = $"Decremented to {value}";
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void UpdateFahrenheit()
    {
        if (_celsius.HasValue)
        {
            _fahrenheit = (_celsius * 9 / 5) + 32;
        }
    }

    private void CalculateTip()
    {
        if (_billAmount.HasValue && _tipPercent.HasValue)
        {
            _tipAmount = _billAmount * _tipPercent / 100;
            _totalWithTip = (_billAmount ?? 0) + (_tipAmount ?? 0);
        }
    }

    protected override void OnInitialized()
    {
        UpdateFahrenheit();
        CalculateTip();
    }

