    private List<LazyCategory> LazyCategories = new()
    {
        new LazyCategory("root1", "Category A", true),
        new LazyCategory("root2", "Category B", true),
        new LazyCategory("root3", "Category C (no children)", false)
    };

    public record Category(string Id, string Name, string? ParentId, List<Category>? Children, int ItemCount = 0);
    public record LazyCategory(string Id, string Name, bool HasChildren);

    private async Task<IEnumerable<LazyCategory>> LoadLazyChildren(LazyCategory parent)
    {
        await Task.Delay(800);

        return parent.Id switch
        {
            "root1" => new List<LazyCategory>
            {
                new LazyCategory("a1", "Sub A-1", true),
                new LazyCategory("a2", "Sub A-2", false),
                new LazyCategory("a3", "Sub A-3", false)
            },
            "root2" => new List<LazyCategory>
            {
                new LazyCategory("b1", "Sub B-1", false),
                new LazyCategory("b2", "Sub B-2", true)
            },
            "a1" => new List<LazyCategory>
            {
                new LazyCategory("a1-1", "Deep A-1-1", false),
                new LazyCategory("a1-2", "Deep A-1-2", false)
            },
            "b2" => new List<LazyCategory>
            {
                new LazyCategory("b2-1", "Deep B-2-1", false)
            },
            _ => Enumerable.Empty<LazyCategory>()
        };
    }

