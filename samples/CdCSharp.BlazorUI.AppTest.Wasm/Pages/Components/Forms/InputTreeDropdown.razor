    /* ===================== RENDER FRAGMENTS ===================== */

    private RenderFragment RenderBasicDeclarative() => __builder =>
    {
        <BUIInputTreeDropdown TValue="string" @bind-Value="_selectedBasicDeclarative" Placeholder="Select category">
            <BUITreeDropdownItem TValue="string" Value="@("electronics")" Text="Electronics">
                <BUITreeDropdownItem TValue="string" Value="@("phones")" Text="Phones" />
                <BUITreeDropdownItem TValue="string" Value="@("computers")" Text="Computers">
                    <BUITreeDropdownItem TValue="string" Value="@("laptops")" Text="Laptops" />
                    <BUITreeDropdownItem TValue="string" Value="@("desktops")" Text="Desktops" />
                </BUITreeDropdownItem>
            </BUITreeDropdownItem>
            <BUITreeDropdownItem TValue="string" Value="@("clothing")" Text="Clothing">
                <BUITreeDropdownItem TValue="string" Value="@("mens")" Text="Men's" />
                <BUITreeDropdownItem TValue="string" Value="@("womens")" Text="Women's" />
            </BUITreeDropdownItem>
        </BUIInputTreeDropdown>
    };

    private RenderFragment RenderBasicBinding() => __builder =>
    {
        <BUIInputTreeDropdown TValue="Category"
                              Items="Categories"
                              KeySelector="c => c.Id"
                              TextSelector="c => c.Name"
                              ChildrenSelector="c => c.Children"
                              @bind-Value="_selectedCategory"
                              Placeholder="Select category" />
    };

    private RenderFragment RenderLabelHelper() => __builder =>
    {
        <BUIInputTreeDropdown TValue="string"
                              @bind-Value="_selectedLabelHelper"
                              Label="Category"
                              HelperText="Select a product category"
                              Required="true"
                              Placeholder="Select...">
            <BUITreeDropdownItem TValue="string" Value="@("opt1")" Text="Option 1" />
            <BUITreeDropdownItem TValue="string" Value="@("opt2")" Text="Option 2" />
            <BUITreeDropdownItem TValue="string" Value="@("opt3")" Text="Option 3" />
        </BUIInputTreeDropdown>
    };

    private RenderFragment RenderMultipleDeclarative() => __builder =>
    {
        <BUIInputTreeDropdown TValue="string[]" @bind-Value="_selectedMultipleDeclarative" Placeholder="Select categories">
            <BUITreeDropdownItem TValue="string" Value="@("electronics")" Text="Electronics">
