@* File: Pages/Components/Forms/InputTreeDropdownPage.razor *@
@page "/components/forms/input-tree-dropdown"

@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Components.Forms
@using CdCSharp.BlazorUI.Components.Forms.Dropdown
@using CdCSharp.BlazorUI.Core.Search

<PageTitle>Tree Dropdown - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>BUIInputTreeDropdown</h1>

    <p class="doc-intro">
        <strong>BUIInputTreeDropdown</strong> is a hierarchical dropdown selector that displays items in a tree structure.
        It supports single and multiple selection, search filtering, lazy loading, keyboard navigation, and both declarative and data-bound modes.
    </p>

    <!-- BASIC USAGE (DECLARATIVE) -->
    <section class="doc-section">
        <h2>Basic usage (Declarative)</h2>
        <p>Define tree structure directly in markup:</p>
        <ComponentDemo Definition="@BasicDeclarativeDemo" />
        <p class="demo-result">Selected: <strong>@(_selectedBasicDeclarative ?? "None")</strong></p>
    </section>

    <!-- BASIC USAGE (DATA BINDING) -->
    <section class="doc-section">
        <h2>Basic usage (Data binding)</h2>
        <p>Bind to hierarchical data using selectors:</p>
        <ComponentDemo Definition="@BasicBindingDemo" />
        <p class="demo-result">Selected: <strong>@(_selectedCategory?.Name ?? "None")</strong></p>
    </section>

    <!-- WITH LABEL AND HELPER -->
    <section class="doc-section">
        <h2>Label and helper text</h2>
        <ComponentDemo Definition="@LabelHelperDemo" />
    </section>

    <!-- MULTIPLE SELECTION (DECLARATIVE) -->
    <section class="doc-section">
        <h2>Multiple selection (Declarative)</h2>
        <p>Select multiple items with checkboxes:</p>
        <ComponentDemo Definition="@MultipleDeclarativeDemo" />
        <p class="demo-result">Selected: <strong>@string.Join(", ", _selectedMultipleDeclarative ?? Array.Empty<string>())</strong></p>
    </section>

    <!-- MULTIPLE SELECTION (DATA BINDING) -->
    <section class="doc-section">
        <h2>Multiple selection (Data binding)</h2>
        <p>Multiple selection with data-bound items:</p>
        <ComponentDemo Definition="@MultipleBindingDemo" />
        <p class="demo-result">Selected: <strong>@string.Join(", ", _selectedMultipleCategories?.Select(c => c.Name) ?? Array.Empty<string>())</strong></p>
    </section>

    <!-- SEARCHABLE -->
    <section class="doc-section">
        <h2>Searchable</h2>
        <p>Enable search to filter tree items:</p>
        <ComponentDemo Definition="@SearchableDemo" />
        <p class="demo-result">Selected: <strong>@(_selectedSearchable?.Name ?? "None")</strong></p>
    </section>

    <!-- CUSTOM CONTENT (DECLARATIVE) -->
    <section class="doc-section">
        <h2>Custom content (Declarative)</h2>
        <p>Customize node content using ChildContent:</p>
        <ComponentDemo Definition="@CustomContentDeclarativeDemo" />
        <p class="demo-result">Selected: <strong>@(_selectedCustomDeclarative ?? "None")</strong></p>
    </section>

    <!-- NODE TEMPLATE (DATA BINDING) -->
    <section class="doc-section">
        <h2>Node template (Data binding)</h2>
        <p>Use NodeTemplate to customize node rendering:</p>
        <ComponentDemo Definition="@NodeTemplateDemo" />
        <p class="demo-result">Selected: <strong>@(_selectedNodeTemplate?.Name ?? "None")</strong></p>
    </section>

    <!-- INITIALLY EXPANDED -->
    <section class="doc-section">
        <h2>Initially expanded nodes</h2>
        <p>Expand nodes by default using InitiallyExpanded:</p>
        <ComponentDemo Definition="@InitiallyExpandedDemo" />
    </section>

    <!-- EXPAND TO SELECTION -->
    <section class="doc-section">
        <h2>Expand to selection</h2>
        <p>Automatically expand tree to show selected item:</p>
        <ComponentDemo Definition="@ExpandToSelectionDemo" />
        <p class="demo-result">Selected: <strong>@(_selectedExpandToSelection ?? "None")</strong></p>
    </section>

    <!-- DISABLED OPTIONS -->
    <section class="doc-section">
        <h2>Disabled options</h2>
        <p>Disable specific tree nodes:</p>
        <ComponentDemo Definition="@DisabledOptionsDemo" />
    </section>

    <!-- ICONS -->
    <section class="doc-section">
        <h2>With icons</h2>
        <p>Add icons to tree nodes:</p>
        <ComponentDemo Definition="@IconsDemo" />
    </section>

    <!-- LAZY LOADING -->
    <section class="doc-section">
        <h2>Lazy loading</h2>
        <p>Load children on demand using OnLoadChildren:</p>
        <ComponentDemo Definition="@LazyLoadingDemo" />
        <p class="demo-result">Selected: <strong>@(_selectedLazyLoading?.Name ?? "None")</strong></p>
    </section>

    <!-- SIZES -->
    <section class="doc-section">
        <h2>Sizes</h2>
        <p>Available sizes: Small, Medium (default), Large:</p>
        <ComponentDemo Definition="@SizesDemo" />
    </section>

    <!-- VARIANTS -->
    <section class="doc-section">
        <h2>Variants</h2>
        <p>Available variants: Outlined (default), Filled, Standard:</p>
        <ComponentDemo Definition="@VariantsDemo" />
    </section>

    <!-- PLACEMENT -->
    <section class="doc-section">
        <h2>Placement</h2>
        <p>Control menu placement: Auto (default), Top, Bottom:</p>
        <ComponentDemo Definition="@PlacementDemo" />
    </section>

    <!-- STATES -->
    <section class="doc-section">
        <h2>States</h2>
        <p>Component states: Disabled, Loading:</p>
        <ComponentDemo Definition="@StatesDemo" />
    </section>

    <!-- FULL WIDTH -->
    <section class="doc-section">
        <h2>Full width</h2>
        <p>Expand to fill container width:</p>
        <ComponentDemo Definition="@FullWidthDemo" />
    </section>
</div>

@code {
