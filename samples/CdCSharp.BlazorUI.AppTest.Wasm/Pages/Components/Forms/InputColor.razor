@page "/components/forms/input-color"

@using System.ComponentModel.DataAnnotations
@using CdCSharp.BlazorUI.Components.Forms
@using CdCSharp.BlazorUI.Core.Css
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared

<PageTitle>InputColor - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>BUIInputColor</h1>

    <p class="doc-intro">
        <strong>BUIInputColor</strong> is a color picker input component that allows users to
        select colors using a visual picker interface. It supports multiple display modes,
        output formats, and integrates seamlessly with forms and validation.
    </p>

    <!-- BASIC -->
    <section class="doc-section">
        <h2>Basic usage</h2>
        <ComponentDemo Definition="@BasicDemo" />
    </section>

    <!-- VARIANTS -->
    <section class="doc-section">
        <h2>Variants</h2>
        <ComponentDemo Definition="@VariantsDemo" />
    </section>

    <!-- DISPLAY MODES -->
    <section class="doc-section">
        <h2>Display modes</h2>
        <ComponentDemo Definition="@DisplayModesDemo" />
    </section>

    <!-- OUTPUT FORMATS -->
    <section class="doc-section">
        <h2>Output formats</h2>
        <ComponentDemo Definition="@OutputFormatsDemo" />
    </section>

    <!-- SIZES -->
    <section class="doc-section">
        <h2>Sizes</h2>
        <ComponentDemo Definition="@SizesDemo" />
    </section>

    <!-- DENSITY -->
    <section class="doc-section">
        <h2>Density</h2>
        <ComponentDemo Definition="@DensityDemo" />
    </section>

    <!-- CLEARABLE -->
    <section class="doc-section">
        <h2>Clearable</h2>
        <ComponentDemo Definition="@ClearableDemo" />
    </section>

    <!-- READONLY / DISABLED -->
    <section class="doc-section">
        <h2>ReadOnly & Disabled</h2>
        <ComponentDemo Definition="@StateDemo" />
    </section>

    <!-- VALIDATION -->
    <section class="doc-section">
        <h2>Validation</h2>
        <ComponentDemo Definition="@ValidationDemo" />
    </section>

    <!-- STANDALONE COLOR PICKER -->
    <section class="doc-section">
        <h2>Standalone Color Picker</h2>
        <ComponentDemo Definition="@StandaloneDemo" />
    </section>

    <!-- CURRENT VALUE -->
    <section class="doc-section">
        <h2>Current value</h2>
        <div class="demo-output-row">
            <div class="demo-color-preview" style="background-color: @(Model.Color?.ToString(ColorOutputFormats.Rgba) ?? "transparent");"></div>
            <pre class="demo-output">@(Model.Color?.ToString(ColorOutputFormats.HexA) ?? "(empty)")</pre>
        </div>
    </section>

    <!-- PROPERTIES INPUT COLOR -->
    <section class="doc-section">
        <h2>BUIInputColor Properties</h2>
        <PropertyTable Properties="@InputColorProperties" />
    </section>

    <!-- PROPERTIES COLOR PICKER -->
    <section class="doc-section">
        <h2>BUIColorPicker Properties</h2>
        <PropertyTable Properties="@ColorPickerProperties" />
    </section>
</div>

<style>
    .demo-output-row {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .demo-color-preview {
        width: 48px;
        height: 48px;
        border-radius: 8px;
        border: 1px solid rgba(0, 0, 0, 0.2);
        background-image: linear-gradient(45deg, #ccc 25%, transparent 25%), linear-gradient(-45deg, #ccc 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #ccc 75%), linear-gradient(-45deg, transparent 75%, #ccc 75%);
        background-size: 8px 8px;
        background-position: 0 0, 0 4px, 4px -4px, -4px 0;
    }

        .demo-color-preview > div {
            width: 100%;
            height: 100%;
            border-radius: 8px;
        }
</style>

@code {
    /* ===================== MODEL ===================== */

    private DemoModel Model = new()
    {
        Color = new CssColor("#3498dbff")
    };

    private class DemoModel
    {
        public CssColor? Color { get; set; }

        [Required(ErrorMessage = "Color is required")]
        public CssColor? ValidatedColor { get; set; }
    }

    /* ===================== DEMOS ===================== */

    private ComponentDemoDefinition BasicDemo => new()
    {
        Demo = RenderBasic(),
        Code = """
<BUIInputColor Label="Pick a color"
               @bind-Value="model.Color" />
"""
    };

    private ComponentDemoDefinition VariantsDemo => new()
    {
        Demo = RenderVariants(),
        Code = """
<BUIInputColor Label="Outlined"
               Variant="BUIInputColorVariant.Outlined"
               @bind-Value="model.Color" />

<BUIInputColor Label="Filled"
               Variant="BUIInputColorVariant.Filled"
               @bind-Value="model.Color" />

<BUIInputColor Label="Standard"
               Variant="BUIInputColorVariant.Standard"
               @bind-Value="model.Color" />
"""
    };

    private ComponentDemoDefinition DisplayModesDemo => new()
    {
        Demo = RenderDisplayModes(),
        Code = """
<BUIInputColor Label="Dropdown mode"
               DisplayMode="ColorPickerDisplayMode.Dropdown"
               @bind-Value="model.Color" />

<BUIInputColor Label="Modal mode"
               DisplayMode="ColorPickerDisplayMode.Modal"
               @bind-Value="model.Color" />
"""
    };

    private ComponentDemoDefinition OutputFormatsDemo => new()
    {
        Demo = RenderOutputFormats(),
        Code = """
<BUIInputColor Label="HEX format"
               OutputFormat="ColorPickerOutputFormat.Hex"
               @bind-Value="model.Color" />

<BUIInputColor Label="RGB format"
               OutputFormat="ColorPickerOutputFormat.Rgb"
               @bind-Value="model.Color" />

<BUIInputColor Label="HSV format"
               OutputFormat="ColorPickerOutputFormat.Hsv"
               @bind-Value="model.Color" />
"""
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """
<BUIInputColor Label="Small"
               Size="SizeEnum.Small"
               @bind-Value="model.Color" />

<BUIInputColor Label="Medium"
               Size="SizeEnum.Medium"
               @bind-Value="model.Color" />

<BUIInputColor Label="Large"
               Size="SizeEnum.Large"
               @bind-Value="model.Color" />
"""
    };

    private ComponentDemoDefinition DensityDemo => new()
    {
        Demo = RenderDensity(),
        Code = """
<BUIInputColor Label="Comfortable"
               Density="DensityEnum.Comfortable"
               @bind-Value="model.Color" />

<BUIInputColor Label="Standard"
               Density="DensityEnum.Standard"
               @bind-Value="model.Color" />

<BUIInputColor Label="Compact"
               Density="DensityEnum.Compact"
               @bind-Value="model.Color" />
"""
    };

    private ComponentDemoDefinition ClearableDemo => new()
    {
        Demo = RenderClearable(),
        Code = """
<BUIInputColor Label="Clearable"
               Clearable="true"
               @bind-Value="model.Color" />

<BUIInputColor Label="Not clearable"
               Clearable="false"
               @bind-Value="model.Color" />
"""
    };

    private ComponentDemoDefinition StateDemo => new()
    {
        Demo = RenderStates(),
        Code = """
<BUIInputColor Label="ReadOnly"
               ReadOnly
               @bind-Value="model.Color" />

<BUIInputColor Label="Disabled"
               Disabled
               @bind-Value="model.Color" />
"""
    };

    private ComponentDemoDefinition ValidationDemo => new()
    {
        Demo = RenderValidation(),
        Code = """
<EditForm Model="model">
    <DataAnnotationsValidator />

    <BUIInputColor Label="Required color"
                   Required
                   HelperText="Please select a color"
                   @bind-Value="model.ValidatedColor" />
</EditForm>
"""
    };

    private ComponentDemoDefinition StandaloneDemo => new()
    {
        Demo = RenderStandalone(),
        Code = """
<BUIColorPicker @bind-Value="model.Color"
                OutputFormat="ColorPickerOutputFormat.Hex"
                SelectionWidth="250"
                SelectionHeight="180" />
"""
    };

    /* ===================== RENDER FRAGMENTS ===================== */

    private RenderFragment RenderBasic() => __builder =>
    {
        <BUIInputColor Label="Pick a color"
                       @bind-Value="Model.Color" />
    };

    private RenderFragment RenderVariants() => __builder =>
    {
        <div class="demo-column">
            <BUIInputColor Label="Outlined"
                           Variant="BUIInputColorVariant.Outlined"
                           @bind-Value="Model.Color" />

            <BUIInputColor Label="Filled"
                           Variant="BUIInputColorVariant.Filled"
                           @bind-Value="Model.Color" />

            <BUIInputColor Label="Standard"
                           Variant="BUIInputColorVariant.Standard"
                           @bind-Value="Model.Color" />
        </div>
    };

    private RenderFragment RenderDisplayModes() => __builder =>
    {
        <div class="demo-column">
            <BUIInputColor Label="Dropdown mode"
                           DisplayMode="ColorPickerDisplayMode.Dropdown"
                           HelperText="Opens below the input"
                           @bind-Value="Model.Color" />

            <BUIInputColor Label="Modal mode"
                           DisplayMode="ColorPickerDisplayMode.Modal"
                           HelperText="Opens in a centered overlay"
                           @bind-Value="Model.Color" />
        </div>
    };

    private RenderFragment RenderOutputFormats() => __builder =>
    {
        <div class="demo-column">
            <BUIInputColor Label="HEX format"
                           OutputFormat="ColorPickerOutputFormat.Hex"
                           HelperText="Displays as #RRGGBBAA"
                           @bind-Value="Model.Color" />

            <BUIInputColor Label="RGB format"
                           OutputFormat="ColorPickerOutputFormat.Rgb"
                           HelperText="Displays as rgba(R,G,B,A)"
                           @bind-Value="Model.Color" />

            <BUIInputColor Label="HSV format"
                           OutputFormat="ColorPickerOutputFormat.Hsv"
                           HelperText="Picker shows H, S, V inputs"
                           @bind-Value="Model.Color" />
        </div>
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <div class="demo-column">
            <BUIInputColor Label="Small"
                           Size="SizeEnum.Small"
                           @bind-Value="Model.Color" />

            <BUIInputColor Label="Medium"
                           Size="SizeEnum.Medium"
                           @bind-Value="Model.Color" />

            <BUIInputColor Label="Large"
                           Size="SizeEnum.Large"
                           @bind-Value="Model.Color" />
        </div>
    };

    private RenderFragment RenderDensity() => __builder =>
    {
        <div class="demo-column">
            <BUIInputColor Label="Comfortable"
                           Density="DensityEnum.Comfortable"
                           @bind-Value="Model.Color" />

            <BUIInputColor Label="Standard"
                           Density="DensityEnum.Standard"
                           @bind-Value="Model.Color" />

            <BUIInputColor Label="Compact"
                           Density="DensityEnum.Compact"
                           @bind-Value="Model.Color" />
        </div>
    };

    private RenderFragment RenderClearable() => __builder =>
    {
        <div class="demo-column">
            <BUIInputColor Label="Clearable"
                           Clearable="true"
                           HelperText="Click X to clear"
                           @bind-Value="Model.Color" />

            <BUIInputColor Label="Not clearable"
                           Clearable="false"
                           HelperText="No clear button"
                           @bind-Value="Model.Color" />
        </div>
    };

    private RenderFragment RenderStates() => __builder =>
    {
        <div class="demo-column">
            <BUIInputColor Label="ReadOnly"
                           ReadOnly
                           @bind-Value="Model.Color" />

            <BUIInputColor Label="Disabled"
                           Disabled
                           @bind-Value="Model.Color" />
        </div>
    };

    private RenderFragment RenderValidation() => __builder =>
    {
        <EditForm Model="Model">
            <DataAnnotationsValidator />

            <BUIInputColor Label="Required color"
                           Required
                           HelperText="Please select a color"
                           @bind-Value="Model.ValidatedColor" />
        </EditForm>
    };

    private RenderFragment RenderStandalone() => __builder =>
    {
        <BUIColorPicker @bind-Value="Model.Color"
                        OutputFormat="ColorPickerOutputFormat.Hex"
                        SelectionWidth="250"
                        SelectionHeight="180" />
    };

    /* ===================== PROPERTIES ===================== */

    private List<PropertyDefinition> InputColorProperties = new()
    {
        new("Value", "CssColor?", "null", "Bound color value"),
        new("ValueChanged", "EventCallback<CssColor?>", "-", "Raised when the color changes"),
        new("Label", "string?", "null", "Input label"),
        new("Placeholder", "string?", "\"Select color...\"", "Placeholder text when no color selected"),
        new("HelperText", "string?", "null", "Helper text below the input"),
        new("Clearable", "bool", "false", "Shows a clear button when a color is selected"),
        new("DisplayMode", "ColorPickerDisplayMode", "Dropdown", "How the picker is displayed (Dropdown, Modal)"),
        new("OutputFormat", "ColorPickerOutputFormat", "Hex", "Color format in picker inputs (Hex, Rgb, Hsv)"),
        new("RevertText", "string", "\"Revert\"", "Text for the revert button"),
        new("SelectionWidth", "int", "200", "Width of the color selection area in pixels"),
        new("SelectionHeight", "int", "150", "Height of the color selection area in pixels"),
        new("Required", "bool", "false", "Marks the field as required"),
        new("ReadOnly", "bool", "false", "Makes the input read-only"),
        new("Disabled", "bool", "false", "Disables the input"),
        new("Size", "SizeEnum", "Medium", "Input size"),
        new("Density", "DensityEnum", "Standard", "Input density"),
        new("Variant", "BUIInputColorVariant", "Outlined", "Visual variant (Outlined, Filled, Standard)"),
        new("FullWidth", "bool", "false", "Makes the input full width"),
    };

    private List<PropertyDefinition> ColorPickerProperties = new()
    {
        new("Value", "CssColor?", "null", "Bound color value"),
        new("ValueChanged", "EventCallback<CssColor?>", "-", "Raised when the color changes"),
        new("OutputFormat", "ColorPickerOutputFormat", "Hex", "Color format in inputs (Hex, Rgb, Hsv)"),
        new("ShowActions", "bool", "true", "Shows the revert button"),
        new("RevertText", "string", "\"Revert\"", "Text for the revert button"),
        new("OnRevert", "EventCallback", "-", "Raised when revert is clicked"),
        new("SelectionWidth", "int", "200", "Width of the color selection area in pixels"),
        new("SelectionHeight", "int", "200", "Height of the color selection area in pixels"),
        new("Size", "SizeEnum", "Medium", "Component size"),
    };
}