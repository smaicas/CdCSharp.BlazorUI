@page "/demo/treemenu"

<PageTitle>Tree Menu - CdCSharp.BlazorUI</PageTitle>

<h1>BUITreeMenu</h1>

<h2>Basic Usage</h2>
<ComponentDemo Definition="@BasicUsageDemo" />

<h2>With Icons</h2>
<ComponentDemo Definition="@IconsDemo" />

<h2>Initially Expanded</h2>
<ComponentDemo Definition="@ExpandedDemo" />

<h2>Orientation</h2>
<ComponentDemo Definition="@OrientationDemo" />

<h2>Expand Mode</h2>
<ComponentDemo Definition="@ExpandModeDemo" />

<h2>Trigger</h2>
<ComponentDemo Definition="@TriggerDemo" />

<h2>Sizes</h2>
<ComponentDemo Definition="@SizesDemo" />

<h2>Collapsible</h2>
<ComponentDemo Definition="@CollapsibleDemo" />

<h2>With Navigation</h2>
<ComponentDemo Definition="@NavigationDemo" />

@code {
    private ComponentDemoDefinition BasicUsageDemo => new()
    {
        Demo = RenderBasicUsage(),
        Code = """ """
    };

    private RenderFragment RenderBasicUsage() => __builder =>
    {
        <BUITreeMenu TItem="object">
            <BUITreeMenuItem Text="Item 1" />
            <BUITreeMenuItem Text="Item 2">
                <ChildContent>
                    <BUITreeMenuItem Text="Sub Item 2.1" />
                    <BUITreeMenuItem Text="Sub Item 2.2" />
                </ChildContent>
            </BUITreeMenuItem>
            <BUITreeMenuItem Text="Item 3" />
        </BUITreeMenu>
    };

    private ComponentDemoDefinition IconsDemo => new()
    {
        Demo = RenderIcons(),
        Code = """ """
    };

    private RenderFragment RenderIcons() => __builder =>
    {
        <BUITreeMenu TItem="object">
            <BUITreeMenuItem Text="Dashboard" Icon="@BUIIcons.MaterialIconsRound.i_dashboard" />
            <BUITreeMenuItem Text="Products" Icon="@BUIIcons.MaterialIconsRound.i_shopping_cart">
                <ChildContent>
                    <BUITreeMenuItem Text="All Products" Icon="@BUIIcons.MaterialIconsRound.i_list" />
                    <BUITreeMenuItem Text="Categories" Icon="@BUIIcons.MaterialIconsRound.i_category" />
                </ChildContent>
            </BUITreeMenuItem>
            <BUITreeMenuItem Text="Settings" Icon="@BUIIcons.UI.Settings" />
        </BUITreeMenu>
    };

    private ComponentDemoDefinition ExpandedDemo => new()
    {
        Demo = RenderExpanded(),
        Code = """ """
    };

    private RenderFragment RenderExpanded() => __builder =>
    {
        <BUITreeMenu TItem="object">
            <BUITreeMenuItem Text="Item 1" />
            <BUITreeMenuItem Text="Item 2" InitiallyExpanded="true">
                <ChildContent>
                    <BUITreeMenuItem Text="Sub Item 2.1" />
                    <BUITreeMenuItem Text="Sub Item 2.2" InitiallyExpanded="true">
                        <ChildContent>
                            <BUITreeMenuItem Text="Sub Sub Item 2.2.1" />
                        </ChildContent>
                    </BUITreeMenuItem>
                </ChildContent>
            </BUITreeMenuItem>
        </BUITreeMenu>
    };

    private ComponentDemoDefinition OrientationDemo => new()
    {
        Demo = RenderOrientation(),
        Code = """ """
    };

    private RenderFragment RenderOrientation() => __builder =>
    {
        <BUIGrid Gap="2rem">
            <BUIGridItem>
                <h3>Vertical (Default)</h3>
                <BUITreeMenu TItem="object" Orientation="TreeMenuOrientation.Vertical">
                    <BUITreeMenuItem Text="Item 1" />
                    <BUITreeMenuItem Text="Item 2">
                        <ChildContent>
                            <BUITreeMenuItem Text="Sub Item 2.1" />
                        </ChildContent>
                    </BUITreeMenuItem>
                </BUITreeMenu>
            </BUIGridItem>
            <BUIGridItem>
                <h3>Horizontal</h3>
                <BUITreeMenu TItem="object" Orientation="TreeMenuOrientation.Horizontal">
                    <BUITreeMenuItem Text="Item 1" />
                    <BUITreeMenuItem Text="Item 2">
                        <ChildContent>
                            <BUITreeMenuItem Text="Sub Item 2.1" />
                        </ChildContent>
                    </BUITreeMenuItem>
                </BUITreeMenu>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition ExpandModeDemo => new()
    {
        Demo = RenderExpandMode(),
        Code = """ """
    };

    private RenderFragment RenderExpandMode() => __builder =>
    {
        <BUIGrid Gap="2rem">
            <BUIGridItem>
                <h3>Inline (Default)</h3>
                <BUITreeMenu TItem="object" ExpandMode="TreeMenuExpandMode.Inline">
                    <BUITreeMenuItem Text="Item 1" />
                    <BUITreeMenuItem Text="Item 2">
                        <ChildContent>
                            <BUITreeMenuItem Text="Sub Item 2.1" />
                        </ChildContent>
                    </BUITreeMenuItem>
                </BUITreeMenu>
            </BUIGridItem>
            <BUIGridItem>
                <h3>Flyout</h3>
                <BUITreeMenu TItem="object" ExpandMode="TreeMenuExpandMode.Flyout">
                    <BUITreeMenuItem Text="Item 1">
                        <ChildContent>
                            <BUITreeMenuItem Text="Sub Item 1.1" />
                        </ChildContent>
                    </BUITreeMenuItem>
                    <BUITreeMenuItem Text="Item 2">
                        <ChildContent>
                            <BUITreeMenuItem Text="Sub Item 2.1" />
                        </ChildContent>
                    </BUITreeMenuItem>
                </BUITreeMenu>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition TriggerDemo => new()
    {
        Demo = RenderTrigger(),
        Code = """ """
    };

    private RenderFragment RenderTrigger() => __builder =>
    {
        <BUIGrid Gap="2rem">
            <BUIGridItem>
                <h3>Click Trigger (Default)</h3>
                <BUITreeMenu TItem="object" Trigger="TreeMenuTrigger.Click">
                    <BUITreeMenuItem Text="Item 1">
                        <ChildContent>
                            <BUITreeMenuItem Text="Sub Item 1.1" />
                        </ChildContent>
                    </BUITreeMenuItem>
                </BUITreeMenu>
            </BUIGridItem>
            <BUIGridItem>
                <h3>Hover Trigger</h3>
                <BUITreeMenu TItem="object" Trigger="TreeMenuTrigger.Hover">
                    <BUITreeMenuItem Text="Item 1">
                        <ChildContent>
                            <BUITreeMenuItem Text="Sub Item 1.1" />
                        </ChildContent>
                    </BUITreeMenuItem>
                </BUITreeMenu>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """ """
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <BUIGrid Gap="2rem">
            <BUIGridItem>
                <h3>Small</h3>
                <BUITreeMenu TItem="object" Size="SizeEnum.Small">
                    <BUITreeMenuItem Text="Item 1" />
                    <BUITreeMenuItem Text="Item 2" />
                </BUITreeMenu>
            </BUIGridItem>
            <BUIGridItem>
                <h3>Medium (Default)</h3>
                <BUITreeMenu TItem="object" Size="SizeEnum.Medium">
                    <BUITreeMenuItem Text="Item 1" />
                    <BUITreeMenuItem Text="Item 2" />
                </BUITreeMenu>
            </BUIGridItem>
            <BUIGridItem>
                <h3>Large</h3>
                <BUITreeMenu TItem="object" Size="SizeEnum.Large">
                    <BUITreeMenuItem Text="Item 1" />
                    <BUITreeMenuItem Text="Item 2" />
                </BUITreeMenu>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition CollapsibleDemo => new()
    {
        Demo = RenderCollapsible(),
        Code = """ """
    };

    private RenderFragment RenderCollapsible() => __builder =>
    {
        <BUITreeMenu TItem="object" Collapsible="false">
            <BUITreeMenuItem Text="Item 1" InitiallyExpanded="true">
                <ChildContent>
                    <BUITreeMenuItem Text="Sub Item 1.1" />
                </ChildContent>
            </BUITreeMenuItem>
            <BUITreeMenuItem Text="Item 2" />
        </BUITreeMenu>
    };

    private ComponentDemoDefinition NavigationDemo => new()
    {
        Demo = RenderNavigation(),
        Code = """ """
    };

    private RenderFragment RenderNavigation() => __builder =>
    {
        <BUITreeMenu TItem="object">
            <BUITreeMenuItem Text="Home" Icon="@BUIIcons.UI.Home" Href="/" Match="NavLinkMatch.All" />
            <BUITreeMenuItem Text="Components" Icon="@BUIIcons.MaterialIconsRound.i_category">
                <ChildContent>
                    <BUITreeMenuItem Text="Forms" Href="/demo/checkbox" />
                    <BUITreeMenuItem Text="Generic" Href="/demo/button" />
                </ChildContent>
            </BUITreeMenuItem>
        </BUITreeMenu>
    };
}