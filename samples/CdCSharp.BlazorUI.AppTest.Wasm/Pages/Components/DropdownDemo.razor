@page "/demo/dropdown"

<PageTitle>Dropdown - CdCSharp.BlazorUI</PageTitle>

<h1>BUIInputDropdown</h1>

<h2>Basic Usage - Single Selection</h2>
<ComponentDemo Definition="@BasicUsageDemo" />

<h2>Multiple Selection</h2>
<ComponentDemo Definition="@MultipleSelectionDemo" />

<h2>With Label</h2>
<ComponentDemo Definition="@WithLabelDemo" />

<h2>Searchable</h2>
<ComponentDemo Definition="@SearchableDemo" />

<h2>With Select All</h2>
<ComponentDemo Definition="@SelectAllDemo" />

<h2>Variants</h2>
<ComponentDemo Definition="@VariantsDemo" />

<h2>Sizes</h2>
<ComponentDemo Definition="@SizesDemo" />

<h2>Placement</h2>
<ComponentDemo Definition="@PlacementDemo" />

<h2>Close on Select</h2>
<ComponentDemo Definition="@CloseOnSelectDemo" />

<h2>Disabled</h2>
<ComponentDemo Definition="@DisabledDemo" />

<h2>Loading State</h2>
<ComponentDemo Definition="@LoadingDemo" />

<h2>No Options Template</h2>
<ComponentDemo Definition="@NoOptionsDemo" />

<h2>Custom Option Content</h2>
<ComponentDemo Definition="@CustomOptionDemo" />

<h2>Density</h2>
<ComponentDemo Definition="@DensityDemo" />

<h2>With Helper Text</h2>
<ComponentDemo Definition="@HelperTextDemo" />

@code {
    private string? _singleValue;
    private List<string> _multipleValue = new();
    private string? _labelValue;
    private string? _searchableValue;
    private List<string> _selectAllValue = new();
    private string? _outlinedValue;
    private string? _filledValue;
    private string? _standardValue;
    private string? _smallValue;
    private string? _mediumValue;
    private string? _largeValue;
    private string? _topValue;
    private string? _bottomValue;
    private string? _closeValue;
    private string? _disabledValue = "Option 1";
    private string? _loadingValue;
    private string? _noOptionsValue;
    private string? _customOptionValue;
    private string? _compactValue;
    private string? _standardDensity;
    private string? _comfortableValue;
    private string? _helperValue;
    private CountryOption? _countryValue;

    private bool _isLoading = true;

    private List<string> _options = new() { "Option 1", "Option 2", "Option 3", "Option 4", "Option 5" };

    private ComponentDemoDefinition BasicUsageDemo => new()
    {
        Demo = RenderBasicUsage(),
        Code = """ """
    };

    private RenderFragment RenderBasicUsage() => __builder =>
    {
        <BUIInputDropdown @bind-Value="_singleValue" Placeholder="Select an option">
            @foreach (var option in _options)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>
    };

    private ComponentDemoDefinition MultipleSelectionDemo => new()
    {
        Demo = RenderMultipleSelection(),
        Code = """ """
    };

    private RenderFragment RenderMultipleSelection() => __builder =>
    {
        <BUIInputDropdown @bind-Value="_multipleValue" Placeholder="Select multiple options">
            @foreach (var option in _options)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>
    };

    private ComponentDemoDefinition WithLabelDemo => new()
    {
        Demo = RenderWithLabel(),
        Code = """ """
    };

    private RenderFragment RenderWithLabel() => __builder =>
    {
        <BUIInputDropdown @bind-Value="_countryValue"
                          Label="Country"
                          HelperText="Select your country"
                          Placeholder="Choose...">
            @foreach (var country in _countries)
            {
                <DropdownOption Value="@country" Text="@country.Name" />
            }
        </BUIInputDropdown>
    };

    private ComponentDemoDefinition SearchableDemo => new()
    {
        Demo = RenderSearchable(),
        Code = """ """
    };

    private RenderFragment RenderSearchable() => __builder =>
    {
        <BUIInputDropdown @bind-Value="_countryValue"
                          Label="Searchable Dropdown"
                          Searchable="true"
                          SearchPlaceholder="Type to search...">
            @foreach (var country in _countries)
            {
                <DropdownOption Value="@country" Text="@country.Name" />
            }
        </BUIInputDropdown>
    };

    private ComponentDemoDefinition SelectAllDemo => new()
    {
        Demo = RenderSelectAll(),
        Code = """ """
    };

    private RenderFragment RenderSelectAll() => __builder =>
    {
        <BUIInputDropdown @bind-Value="_selectAllValue"
                          Label="With Select All"
                          ShowSelectAll="true"
                          SelectAllText="Select All"
                          DeselectAllText="Deselect All">
            @foreach (var option in _options)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>
    };

    private ComponentDemoDefinition VariantsDemo => new()
    {
        Demo = RenderVariants(),
        Code = """ """
    };

    private RenderFragment RenderVariants() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUIInputDropdown @bind-Value="_outlinedValue"
                                  Label="Outlined"
                                  Variant="BUIInputVariant.Outlined">
                    @foreach (var option in _options)
                    {
                        <DropdownOption Value="@option" Text="@option" />
                    }
                </BUIInputDropdown>
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputDropdown @bind-Value="_filledValue"
                                  Label="Filled"
                                  Variant="BUIInputVariant.Filled">
                    @foreach (var option in _options)
                    {
                        <DropdownOption Value="@option" Text="@option" />
                    }
                </BUIInputDropdown>
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputDropdown @bind-Value="_standardValue"
                                  Label="Standard"
                                  Variant="BUIInputVariant.Standard">
                    @foreach (var option in _options)
                    {
                        <DropdownOption Value="@option" Text="@option" />
                    }
                </BUIInputDropdown>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """ """
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUIInputDropdown @bind-Value="_smallValue" Label="Small" Size="BUISize.Small">
                    @foreach (var option in _options)
                    {
                        <DropdownOption Value="@option" Text="@option" />
                    }
                </BUIInputDropdown>
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputDropdown @bind-Value="_mediumValue" Label="Medium (Default)" Size="BUISize.Medium">
                    @foreach (var option in _options)
                    {
                        <DropdownOption Value="@option" Text="@option" />
                    }
                </BUIInputDropdown>
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputDropdown @bind-Value="_largeValue" Label="Large" Size="BUISize.Large">
                    @foreach (var option in _options)
                    {
                        <DropdownOption Value="@option" Text="@option" />
                    }
                </BUIInputDropdown>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition PlacementDemo => new()
    {
        Demo = RenderPlacement(),
        Code = """ """
    };

    private RenderFragment RenderPlacement() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUIInputDropdown @bind-Value="_topValue"
                                  Label="Top Placement"
                                  Placement="DropdownPlacement.Top">
                    @foreach (var option in _options)
                    {
                        <DropdownOption Value="@option" Text="@option" />
                    }
                </BUIInputDropdown>
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputDropdown @bind-Value="_bottomValue"
                                  Label="Bottom Placement (Default)"
                                  Placement="DropdownPlacement.Bottom">
                    @foreach (var option in _options)
                    {
                        <DropdownOption Value="@option" Text="@option" />
                    }
                </BUIInputDropdown>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition CloseOnSelectDemo => new()
    {
        Demo = RenderCloseOnSelect(),
        Code = """ """
    };

    private RenderFragment RenderCloseOnSelect() => __builder =>
    {
        <BUIInputDropdown @bind-Value="_closeValue"
                          Label="Don't Close on Select"
                          CloseOnSelect="false">
            @foreach (var option in _options)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>
    };

    private ComponentDemoDefinition DisabledDemo => new()
    {
        Demo = RenderDisabled(),
        Code = """ """
    };

    private RenderFragment RenderDisabled() => __builder =>
    {
        <BUIInputDropdown @bind-Value="_disabledValue" Label="Disabled" Disabled="true">
            @foreach (var option in _options)
            {
                <DropdownOption Value="@option" Text="@option" />
            }
        </BUIInputDropdown>
    };

    private List<CountryOption> _countries = new()
    {
        new CountryOption { Code = "us", Name = "United States", Flag = "🇺🇸" },
        new CountryOption { Code = "uk", Name = "United Kingdom", Flag = "🇬🇧" },
        new CountryOption { Code = "de", Name = "Germany", Flag = "🇩🇪" },
        new CountryOption { Code = "fr", Name = "France", Flag = "🇫🇷" },
        new CountryOption { Code = "es", Name = "Spain", Flag = "🇪🇸" }
    };

    private ComponentDemoDefinition LoadingDemo => new()
    {
        Demo = RenderLoading(),
        Code = """ """
    };

    private RenderFragment RenderLoading() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUIButton Text="Toggle Loading" OnClick="@(() => _isLoading = !_isLoading)" />
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputDropdown TValue="string"
                                  @bind-Value="_loadingValue"
                                  Label="Loading State"
                                  IsLoading="_isLoading">
                    <DropdownOption Value="@("opt1")">Option 1</DropdownOption>
                    <DropdownOption Value="@("opt2")">Option 2</DropdownOption>
                    <DropdownOption Value="@("opt3")">Option 3</DropdownOption>
                </BUIInputDropdown>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition NoOptionsDemo => new()
    {
        Demo = RenderNoOptions(),
        Code = """ """
    };

    private RenderFragment RenderNoOptions() => __builder =>
    {
        <BUIInputDropdown TValue="string"
                          @bind-Value="_noOptionsValue"
                          Label="Empty Dropdown">
            <NoOptionsTemplate>
                <span>No items available</span>
            </NoOptionsTemplate>
        </BUIInputDropdown>
    };

    private ComponentDemoDefinition CustomOptionDemo => new()
    {
        Demo = RenderCustomOption(),
        Code = """ """
    };

    private RenderFragment RenderCustomOption() => __builder =>
    {
        <BUIInputDropdown @bind-Value="_countryValue"
                          Label="Select Country"
                          Placeholder="Choose a country...">
            @foreach (CountryOption country in _countries)
            {
                <DropdownOption Value="@country">
                    <span style="display: flex; align-items: center; gap: 0.5rem;">
                        <span style="font-size: 1.25rem;">@country.Flag</span>
                        <span>@country.Name</span>
                    </span>
                </DropdownOption>
            }
        </BUIInputDropdown>
    };

    private ComponentDemoDefinition DensityDemo => new()
    {
        Demo = RenderDensity(),
        Code = """ """
    };

    private RenderFragment RenderDensity() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem>
                <BUIInputDropdown TValue="string"
                                  @bind-Value="_compactValue"
                                  Label="Compact"
                                  Density="BUIDensity.Compact">
                    <DropdownOption Value="@("a")">Option A</DropdownOption>
                    <DropdownOption Value="@("b")">Option B</DropdownOption>
                </BUIInputDropdown>
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputDropdown TValue="string"
                                  @bind-Value="_standardDensity"
                                  Label="Standard"
                                  Density="BUIDensity.Standard">
                    <DropdownOption Value="@("a")">Option A</DropdownOption>
                    <DropdownOption Value="@("b")">Option B</DropdownOption>
                </BUIInputDropdown>
            </BUIGridItem>
            <BUIGridItem>
                <BUIInputDropdown TValue="string"
                                  @bind-Value="_comfortableValue"
                                  Label="Comfortable"
                                  Density="BUIDensity.Comfortable">
                    <DropdownOption Value="@("a")">Option A</DropdownOption>
                    <DropdownOption Value="@("b")">Option B</DropdownOption>
                </BUIInputDropdown>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition HelperTextDemo => new()
    {
        Demo = RenderHelperText(),
        Code = """ """
    };

    private RenderFragment RenderHelperText() => __builder =>
    {
        <BUIInputDropdown TValue="string"
                          @bind-Value="_helperValue"
                          Label="Select Option"
                          HelperText="Please select one option from the list"
                          Required="true">
            <DropdownOption Value="@("opt1")">Option 1</DropdownOption>
            <DropdownOption Value="@("opt2")">Option 2</DropdownOption>
            <DropdownOption Value="@("opt3")">Option 3</DropdownOption>
        </BUIInputDropdown>
    };

    private class CountryOption
    {
        public string Code { get; set; } = "";
        public string Name { get; set; } = "";
        public string Flag { get; set; } = "";
    }
}