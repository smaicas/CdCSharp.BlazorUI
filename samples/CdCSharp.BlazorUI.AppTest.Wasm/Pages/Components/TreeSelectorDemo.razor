@page "/demo/treeselector"

<PageTitle>Tree Selector - CdCSharp.BlazorUI</PageTitle>

<h1>BUITreeSelector</h1>

<h2>Basic Usage - Single Selection</h2>
<ComponentDemo Definition="@BasicUsageDemo" />

<h2>Multiple Selection</h2>
<ComponentDemo Definition="@MultipleSelectionDemo" />

<h2>With Checkboxes</h2>
<ComponentDemo Definition="@CheckboxesDemo" />

<h2>Initially Expanded</h2>
<ComponentDemo Definition="@ExpandedDemo" />

<h2>With Icons</h2>
<ComponentDemo Definition="@IconsDemo" />

<h2>Animated Expand</h2>
<ComponentDemo Definition="@AnimatedDemo" />

<h2>Sizes</h2>
<ComponentDemo Definition="@SizesDemo" />

<h2>Custom Icons</h2>
<ComponentDemo Definition="@CustomIconsDemo" />

@code {
    private HashSet<string> _selectedSingle = new();
    private HashSet<string> _selectedMultiple = new();
    private HashSet<string> _selectedCheckboxes = new();
    private HashSet<string> _selectedExpanded = new();
    private HashSet<string> _selectedIcons = new();
    private HashSet<string> _selectedAnimated = new();
    private HashSet<string> _selectedSmall = new();
    private HashSet<string> _selectedMedium = new();
    private HashSet<string> _selectedLarge = new();
    private HashSet<string> _selectedCustom = new();

    private ComponentDemoDefinition BasicUsageDemo => new()
    {
        Demo = RenderBasicUsage(),
        Code = """ """
    };

    private RenderFragment RenderBasicUsage() => __builder =>
    {
        <BUITreeSelector TItem="object"
                         SelectedKeys="_selectedSingle"
                         SelectedKeysChanged="@((keys) => _selectedSingle = keys)"
                         SelectionMode="TreeSelectionMode.Single">
            <BUITreeSelectorItem Text="Item 1" Key="1" />
            <BUITreeSelectorItem Text="Item 2" Key="2">
                <ChildContent>
                    <BUITreeSelectorItem Text="Sub Item 2.1" Key="2.1" />
                    <BUITreeSelectorItem Text="Sub Item 2.2" Key="2.2" />
                </ChildContent>
            </BUITreeSelectorItem>
            <BUITreeSelectorItem Text="Item 3" Key="3" />
        </BUITreeSelector>
    };

    private ComponentDemoDefinition MultipleSelectionDemo => new()
    {
        Demo = RenderMultipleSelection(),
        Code = """ """
    };

    private RenderFragment RenderMultipleSelection() => __builder =>
    {
        <BUITreeSelector TItem="object"
                         SelectedKeys="_selectedMultiple"
                         SelectedKeysChanged="@((keys) => _selectedMultiple = keys)"
                         SelectionMode="TreeSelectionMode.Multiple">
            <BUITreeSelectorItem Text="Item 1" Key="1" />
            <BUITreeSelectorItem Text="Item 2" Key="2">
                <ChildContent>
                    <BUITreeSelectorItem Text="Sub Item 2.1" Key="2.1" />
                    <BUITreeSelectorItem Text="Sub Item 2.2" Key="2.2" />
                </ChildContent>
            </BUITreeSelectorItem>
            <BUITreeSelectorItem Text="Item 3" Key="3" />
        </BUITreeSelector>
    };

    private ComponentDemoDefinition CheckboxesDemo => new()
    {
        Demo = RenderCheckboxes(),
        Code = """ """
    };

    private RenderFragment RenderCheckboxes() => __builder =>
    {
        <BUITreeSelector TItem="object"
                         SelectedKeys="_selectedCheckboxes"
                         SelectedKeysChanged="@((keys) => _selectedCheckboxes = keys)"
                         SelectionMode="TreeSelectionMode.Multiple"
                         ShowCheckboxes="true">
            <BUITreeSelectorItem Text="Documents" Key="docs">
                <ChildContent>
                    <BUITreeSelectorItem Text="Work" Key="work">
                        <ChildContent>
                            <BUITreeSelectorItem Text="Report.pdf" Key="report" />
                            <BUITreeSelectorItem Text="Presentation.pptx" Key="presentation" />
                        </ChildContent>
                    </BUITreeSelectorItem>
                    <BUITreeSelectorItem Text="Personal" Key="personal">
                        <ChildContent>
                            <BUITreeSelectorItem Text="Photo.jpg" Key="photo" />
                        </ChildContent>
                    </BUITreeSelectorItem>
                </ChildContent>
            </BUITreeSelectorItem>
        </BUITreeSelector>
    };

    private ComponentDemoDefinition ExpandedDemo => new()
    {
        Demo = RenderExpanded(),
        Code = """ """
    };

    private RenderFragment RenderExpanded() => __builder =>
    {
        <BUITreeSelector TItem="object"
                         SelectedKeys="_selectedExpanded"
                         SelectedKeysChanged="@((keys) => _selectedExpanded = keys)"
                         ExpandAll="true">
            <BUITreeSelectorItem Text="Level 1" Key="l1">
                <ChildContent>
                    <BUITreeSelectorItem Text="Level 2" Key="l2">
                        <ChildContent>
                            <BUITreeSelectorItem Text="Level 3" Key="l3" />
                        </ChildContent>
                    </BUITreeSelectorItem>
                </ChildContent>
            </BUITreeSelectorItem>
        </BUITreeSelector>
    };

    private ComponentDemoDefinition IconsDemo => new()
    {
        Demo = RenderIcons(),
        Code = """ """
    };

    private RenderFragment RenderIcons() => __builder =>
    {
        <BUITreeSelector TItem="object"
                         SelectedKeys="_selectedIcons"
                         SelectedKeysChanged="@((keys) => _selectedIcons = keys)">
            <BUITreeSelectorItem Text="Folder 1" Key="f1" Icon="@BUIIcons.UI.Folder">
                <ChildContent>
                    <BUITreeSelectorItem Text="File 1.1" Key="f1.1" Icon="@BUIIcons.UI.Description" />
                    <BUITreeSelectorItem Text="File 1.2" Key="f1.2" Icon="@BUIIcons.UI.Description" />
                </ChildContent>
            </BUITreeSelectorItem>
            <BUITreeSelectorItem Text="Folder 2" Key="f2" Icon="@BUIIcons.UI.Folder">
                <ChildContent>
                    <BUITreeSelectorItem Text="File 2.1" Key="f2.1" Icon="@BUIIcons.UI.Description" />
                </ChildContent>
            </BUITreeSelectorItem>
        </BUITreeSelector>
    };

    private ComponentDemoDefinition AnimatedDemo => new()
    {
        Demo = RenderAnimated(),
        Code = """ """
    };

    private RenderFragment RenderAnimated() => __builder =>
    {
        <BUITreeSelector TItem="object"
                         SelectedKeys="_selectedAnimated"
                         SelectedKeysChanged="@((keys) => _selectedAnimated = keys)"
                         AnimateExpand="true">
            <BUITreeSelectorItem Text="Item 1" Key="a1">
                <ChildContent>
                    <BUITreeSelectorItem Text="Sub Item 1.1" Key="a1.1" />
                    <BUITreeSelectorItem Text="Sub Item 1.2" Key="a1.2" />
                </ChildContent>
            </BUITreeSelectorItem>
            <BUITreeSelectorItem Text="Item 2" Key="a2">
                <ChildContent>
                    <BUITreeSelectorItem Text="Sub Item 2.1" Key="a2.1" />
                </ChildContent>
            </BUITreeSelectorItem>
        </BUITreeSelector>
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """ """
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <BUIGrid Gap="2rem">
            <BUIGridItem>
                <h3>Small</h3>
                <BUITreeSelector TItem="object"
                                 SelectedKeys="_selectedSmall"
                                 SelectedKeysChanged="@((keys) => _selectedSmall = keys)"
                                 Size="SizeEnum.Small">
                    <BUITreeSelectorItem Text="Item 1" Key="s1" />
                    <BUITreeSelectorItem Text="Item 2" Key="s2" />
                </BUITreeSelector>
            </BUIGridItem>
            <BUIGridItem>
                <h3>Medium (Default)</h3>
                <BUITreeSelector TItem="object"
                                 SelectedKeys="_selectedMedium"
                                 SelectedKeysChanged="@((keys) => _selectedMedium = keys)"
                                 Size="SizeEnum.Medium">
                    <BUITreeSelectorItem Text="Item 1" Key="m1" />
                    <BUITreeSelectorItem Text="Item 2" Key="m2" />
                </BUITreeSelector>
            </BUIGridItem>
            <BUIGridItem>
                <h3>Large</h3>
                <BUITreeSelector TItem="object"
                                 SelectedKeys="_selectedLarge"
                                 SelectedKeysChanged="@((keys) => _selectedLarge = keys)"
                                 Size="SizeEnum.Large">
                    <BUITreeSelectorItem Text="Item 1" Key="l1" />
                    <BUITreeSelectorItem Text="Item 2" Key="l2" />
                </BUITreeSelector>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition CustomIconsDemo => new()
    {
        Demo = RenderCustomIcons(),
        Code = """ """
    };

    private RenderFragment RenderCustomIcons() => __builder =>
    {
        <BUITreeSelector TItem="object"
                         SelectedKeys="_selectedCustom"
                         SelectedKeysChanged="@((keys) => _selectedCustom = keys)"
                         ExpandIcon="@BUIIcons.MaterialIconsRound.i_add_circle"
                         CollapseIcon="@BUIIcons.MaterialIconsRound.i_remove_circle">
            <BUITreeSelectorItem Text="Item 1" Key="c1">
                <ChildContent>
                    <BUITreeSelectorItem Text="Sub Item 1.1" Key="c1.1" />
                </ChildContent>
            </BUITreeSelectorItem>
        </BUITreeSelector>
    };
}