@page "/demo/datacards"

@using CdCSharp.BlazorUI.Components

<PageTitle>DataCards - CdCSharp.BlazorUI</PageTitle>

<h1>BUIDataCards</h1>

<h2>Basic Usage</h2>
<p>Simple card grid with automatic column layout.</p>
<ComponentDemo Definition="@BasicUsageDemo" />

<h2>Grid Layout</h2>
<p>Control columns count, gap, and minimum card width.</p>
<ComponentDemo Definition="@GridLayoutDemo" />

<h2>Responsive Grid</h2>
<p>Cards automatically adjust to available space using MinCardWidth.</p>
<ComponentDemo Definition="@ResponsiveGridDemo" />

<h2>Single Selection</h2>
<p>Radio button selection for single item.</p>
<ComponentDemo Definition="@SingleSelectionDemo" />

<h2>Multiple Selection</h2>
<p>Checkbox selection with select all functionality.</p>
<ComponentDemo Definition="@MultipleSelectionDemo" />

<h2>Sortable</h2>
<p>Dropdown to sort cards by any sortable column.</p>
<ComponentDemo Definition="@SortableDemo" />

<h2>Filterable</h2>
<p>Global text filter across filterable columns.</p>
<ComponentDemo Definition="@FilterableDemo" />

<h2>Pagination</h2>
<p>Paginated cards with page size selector.</p>
<ComponentDemo Definition="@PaginationDemo" />

<h2>Combined Features</h2>
<p>Sort + Filter + Pagination + Selection all together.</p>
<ComponentDemo Definition="@CombinedDemo" />

<h2>Card Click Handler</h2>
<p>Clickable cards with event callback.</p>
<ComponentDemo Definition="@CardClickDemo" />

<h2>Custom Card Template</h2>
<p>Completely custom card rendering.</p>
<ComponentDemo Definition="@CustomCardDemo" />

<h2>Card Header and Footer</h2>
<p>Custom header and footer templates for each card.</p>
<ComponentDemo Definition="@HeaderFooterDemo" />

<h2>Card Borders</h2>
<p>Add borders to cards using CardBorder parameter.</p>
<ComponentDemo Definition="@CardBordersDemo" />

<h2>Card Shadows</h2>
<p>Add elevation shadows to cards using CardShadow parameter.</p>
<ComponentDemo Definition="@CardShadowsDemo" />

<h2>Card Background</h2>
<p>Customize card background color using CardBackground parameter.</p>
<ComponentDemo Definition="@CardBackgroundDemo" />

<h2>Combined Card Styling</h2>
<p>Border + Shadow + Background together.</p>
<ComponentDemo Definition="@CombinedCardStylingDemo" />

<h2>Hoverable</h2>
<p>Highlight cards on hover.</p>
<ComponentDemo Definition="@HoverableDemo" />

<h2>Density Options</h2>
<p>Compact, Standard, and Comfortable spacing.</p>
<ComponentDemo Definition="@DensityDemo" />

<h2>Fixed Height with Scroll</h2>
<p>Container with fixed height and scrolling.</p>
<ComponentDemo Definition="@FixedHeightDemo" />

<h2>Empty State (Default)</h2>
<p>Default empty message when no data.</p>
<ComponentDemo Definition="@EmptyStateDemo" />

<h2>Empty State (Custom)</h2>
<p>Custom content for empty state.</p>
<ComponentDemo Definition="@CustomEmptyDemo" />

<h2>Loading State</h2>
<p>Display loading indicator while data is being fetched.</p>
<ComponentDemo Definition="@LoadingDemo" />

<h2>Events: OnSort</h2>
<p>Callback when sort changes.</p>
<ComponentDemo Definition="@OnSortDemo" />

<h2>Events: OnFilter</h2>
<p>Callback when filter changes.</p>
<ComponentDemo Definition="@OnFilterDemo" />

<h2>Events: OnPageChange</h2>
<p>Callback when page or page size changes.</p>
<ComponentDemo Definition="@OnPageChangeDemo" />

<h2>Programmatic Control</h2>
<p>Control cards via methods: SortBy, Filter, GoToPage.</p>
<ComponentDemo Definition="@ProgrammaticDemo" />

@code {
    private List<Person> _basicData = GenerateSampleData();
    private List<Person> _gridData = GenerateSampleData();
    private List<Person> _responsiveData = GenerateLargeDataset().Take(12).ToList();
    private List<Person> _singleSelectionData = GenerateSampleData();
    private List<Person> _multipleSelectionData = GenerateSampleData();
    private HashSet<Person> _singleSelected = new();
    private HashSet<Person> _multipleSelected = new();
    private List<Person> _sortableData = GenerateLargeDataset().Take(9).ToList();
    private List<Person> _filterableData = GenerateLargeDataset().Take(12).ToList();
    private List<Person> _paginationData = GenerateLargeDataset();
    private List<Person> _combinedData = GenerateLargeDataset();
    private HashSet<Person> _combinedSelected = new();
    private List<Person> _clickData = GenerateSampleData();
    private List<Person> _customCardData = GenerateSampleData();
    private List<Person> _headerFooterData = GenerateSampleData();
    private List<Person> _cardBordersData = GenerateSampleData();
    private List<Person> _cardShadowsData = GenerateSampleData();
    private List<Person> _cardBackgroundData = GenerateSampleData();
    private List<Person> _combinedCardStylingData = GenerateSampleData();
    private List<Person> _variantData = GenerateSampleData();
    private List<Person> _hoverableData = GenerateSampleData();
    private List<Person> _compactData = GenerateSampleData();
    private List<Person> _standardData = GenerateSampleData();
    private List<Person> _comfortableData = GenerateSampleData();
    private List<Person> _fixedHeightData = GenerateLargeDataset();
    private List<Person> _emptyData = new();
    private List<Person> _loadingData = GenerateSampleData();
    private bool _isLoading = true;
    private List<Person> _onSortData = GenerateSampleData();
    private List<Person> _onFilterData = GenerateLargeDataset().Take(9).ToList();
    private List<Person> _onPageData = GenerateLargeDataset();
    private List<Person> _programmaticData = GenerateLargeDataset();

    private string _lastClickedPerson = "None";
    private string _lastSortEvent = "None";
    private string _lastFilterEvent = "None";
    private string _lastPageEvent = "None";

    private BUIDataCards<Person>? _programmaticCards;

    #region Basic Usage
    private ComponentDemoDefinition BasicUsageDemo => new()
    {
        Demo = RenderBasicUsage(),
        Code = """ """
    };

    private RenderFragment RenderBasicUsage() => __builder =>
    {
        <BUIDataCards Items="_basicData">
            <Columns>
                <BUIDataColumn TItem="Person" Property="@(p => p.Id)" Header="ID" />
                <BUIDataColumn TItem="Person" Property="@(p => p.Name)" Header="Name" />
                <BUIDataColumn TItem="Person" Property="@(p => p.Email)" Header="Email" />
                <BUIDataColumn TItem="Person" Property="@(p => p.Age)" Header="Age" />
            </Columns>
        </BUIDataCards>
    };
    #endregion

    #region Grid Layout
    private ComponentDemoDefinition GridLayoutDemo => new()
    {
        Demo = RenderGridLayout(),
        Code = """ """
    };

    private RenderFragment RenderGridLayout() => __builder =>
    {
        <div>
            <h4>2 Columns, 2rem Gap</h4>
            <BUIDataCards Items="_gridData" ColumnsCount="2" Gap="2rem" MinCardWidth="">
                <Columns>
                    <BUIDataColumn TItem="Person" Property="@(p => p.Name)" Header="Name" />
                    <BUIDataColumn TItem="Person" Property="@(p => p.Email)" Header="Email" />
                </Columns>
            </BUIDataCards>

            <h4 style="margin-top: 2rem;">4 Columns, 0.5rem Gap</h4>
            <BUIDataCards Items="_gridData" ColumnsCount="4" Gap="0.5rem" MinCardWidth="">
                <Columns>
                    <BUIDataColumn TItem="Person" Property="@(p => p.Name)" Header="Name" />
                    <BUIDataColumn TItem="Person" Property="@(p => p.Email)" Header="Email" />
                </Columns>
            </BUIDataCards>
        </div>
    };
    #endregion

    #region Responsive Grid
    private ComponentDemoDefinition ResponsiveGridDemo => new()
    {
        Demo = RenderResponsiveGrid(),
        Code = """ """
    };

    private RenderFragment RenderResponsiveGrid() => __builder =>
    {
        <div>
            <p><strong>MinCardWidth="320px"</strong> - Cards will automatically wrap based on available space.</p>
            <BUIDataCards Items="_responsiveData" MinCardWidth="320px" Gap="1.5rem">
                <Columns>
                    <BUIDataColumn TItem="Person" Property="@(p => p.Id)" Header="ID" />
                    <BUIDataColumn TItem="Person" Property="@(p => p.Name)" Header="Name" />
                    <BUIDataColumn TItem="Person" Property="@(p => p.Email)" Header="Email" />
                    <BUIDataColumn TItem="Person" Property="@(p => p.Age)" Header="Age" />
                </Columns>
            </BUIDataCards>
        </div>
    };
    #endregion

    #region Single Selection
    private ComponentDemoDefinition SingleSelectionDemo => new()
    {
        Demo = RenderSingleSelection(),
        Code = """ """
    };

    private RenderFragment RenderSingleSelection() => __builder =>
    {
        <div>
            <p><strong>Selected:</strong> @(_singleSelected.FirstOrDefault()?.Name ?? "None")</p>
            <BUIDataCards TItem="Person"
                          Items="_singleSelectionData"
                          SelectionMode="SelectionMode.Single"
                          SelectedItems="_singleSelected"
                          SelectedItemsChanged="OnSingleSelectionChanged">
                <Columns>
                    <BUIDataColumn TItem="Person" Property="@(p => p.Id)" Header="ID" />
                    <BUIDataColumn TItem="Person" Property="@(p => p.Name)" Header="Name" />
                    <BUIDataColumn TItem="Person" Property="@(p => p.Email)" Header="Email" />
                </Columns>
            </BUIDataCards>
        </div>
    };

    private void OnSingleSelectionChanged(HashSet<Person> items)
    {
        _singleSelected = items;
        StateHasChanged();
    }
    #endregion

    #region Multiple Selection
    private ComponentDemoDefinition MultipleSelectionDemo => new()
    {
        Demo = RenderMultipleSelection(),
        Code = """ """
    };

    private RenderFragment RenderMultipleSelection() => __builder =>
    {
        <div>
            <p><strong>Selected count:</strong> @_multipleSelected.Count</p>
            <p><strong>Selected:</strong> @string.Join(", ", _multipleSelected.Select(p => p.Name))</p>
            <BUIDataCards TItem="Person"
                          Items="_multipleSelectionData"
                          SelectionMode="SelectionMode.Multiple"
                          SelectedItems="_multipleSelected"
                          SelectedItemsChanged="OnMultipleSelectionChanged">
                <Columns>
                    <BUIDataColumn TItem="Person" Property="@(p => p.Id)" Header="ID" />
                    <BUIDataColumn TItem="Person" Property="@(p => p.Name)" Header="Name" />
                    <BUIDataColumn TItem="Person" Property="@(p => p.Email)" Header="Email" />
                    <BUIDataColumn TItem="Person" Property="@(p => p.Age)" Header="Age" />
                </Columns>
            </BUIDataCards>
        </div>
    };

    private void OnMultipleSelectionChanged(HashSet<Person> items)
    {
        _multipleSelected = items;
        StateHasChanged();
    }
    #endregion

    #region Sortable
    private ComponentDemoDefinition SortableDemo => new()
    {
        Demo = RenderSortable(),
        Code = """ """
    };

    private RenderFragment RenderSortable() => __builder =>
    {
        <BUIDataCards Items="_sortableData" Sortable="true">
            <Columns>
                <BUIDataColumn TItem="Person" Property="@(p => p.Id)" Header="ID" Sortable="true" />
                <BUIDataColumn TItem="Person" Property="@(p => p.Name)" Header="Name" Sortable="true" />
                <BUIDataColumn TItem="Person" Property="@(p => p.Email)" Header="Email" Sortable="false" />
                <BUIDataColumn TItem="Person" Property="@(p => p.Age)" Header="Age" Sortable="true" />
            </Columns>
        </BUIDataCards>
    };
    #endregion

    #region Filterable
    private ComponentDemoDefinition FilterableDemo => new()
    {
        Demo = RenderFilterable(),
        Code = """ """
    };

    private RenderFragment RenderFilterable() => __builder =>
    {
        <BUIDataCards Items="_filterableData"
                      Filterable="true"
                      FilterPlaceholder="Type to search...">
            <Columns>
                <BUIDataColumn TItem="Person" Property="@(p => p.Id)" Header="ID" Filterable="true" />
                <BUIDataColumn TItem="Person" Property="@(p => p.Name)" Header="Name" Filterable="true" />
                <BUIDataColumn TItem="Person" Property="@(p => p.Email)" Header="Email" Filterable="true" />
                <BUIDataColumn TItem="Person" Property="@(p => p.Age)" Header="Age" Filterable="true" />
            </Columns>
        </BUIDataCards>
    };
    #endregion

    #region Pagination
    private ComponentDemoDefinition PaginationDemo => new()
    {
        Demo = RenderPagination(),
        Code = """ """
    };

    private RenderFragment RenderPagination() => __builder =>
    {
        <BUIDataCards Items="_paginationData"
                      PageSize="6"
                      ShowPageSizeSelector="true"
                      PageSizeOptions="@(new[] { 3, 6, 9, 12 })">
            <Columns>
                <BUIDataColumn TItem="Person" Property="@(p => p.Id)" Header="ID" />
                <BUIDataColumn TItem="Person" Property="@(p => p.Name)" Header="Name" />
                <BUIDataColumn TItem="Person" Property="@(p => p.Email)" Header="Email" />
                <BUIDataColumn TItem="Person" Property="@(p => p.Age)" Header="Age" />
            </Columns>
        </BUIDataCards>
    };
    #endregion

    #region Combined
    private ComponentDemoDefinition CombinedDemo => new()
    {
        Demo = RenderCombined(),
        Code = """ """
    };

    private RenderFragment RenderCombined() => __builder =>
    {
        <div>
            <p><strong>Selected:</strong> @_combinedSelected.Count items</p>
            <BUIDataCards TItem="Person"
                          Items="_combinedData"
                          Sortable="true"
                          Filterable="true"
                          FilterPlaceholder="Search..."
                          PageSize="6"
                          ShowPageSizeSelector="true"
                          PageSizeOptions="@(new[] { 3, 6, 9 })"
                          SelectionMode="SelectionMode.Multiple"
                          SelectedItems="_combinedSelected"
                          SelectedItemsChanged="OnCombinedSelectionChanged"
                          Hoverable="true">
                <Columns>
                    <BUIDataColumn TItem="Person" Property="@(p => p.Id)" Header="ID" Sortable="true" Filterable="true" />
                    <BUIDataColumn TItem="Person" Property="@(p => p.Name)" Header="Name" Sortable="true" Filterable="true" />
                    <BUIDataColumn TItem="Person" Property="@(p => p.Email)" Header="Email" Sortable="true" Filterable="true" />
                    <BUIDataColumn TItem="Person" Property="@(p => p.Age)" Header="Age" Sortable="true" Filterable="true" />
                </Columns>
            </BUIDataCards>
        </div>
    };

    private void OnCombinedSelectionChanged(HashSet<Person> items)
    {
        _combinedSelected = items;
        StateHasChanged();
    }
    #endregion

    #region Card Click
    private ComponentDemoDefinition CardClickDemo => new()
    {
        Demo = RenderCardClick(),
        Code = """ """
    };

    private RenderFragment RenderCardClick() => __builder =>
    {
        <div>
            <p><strong>Last clicked:</strong> @_lastClickedPerson</p>
            <BUIDataCards TItem="Person"
                          Items="_clickData"
                          OnRowClick="HandleCardClick"
                          Hoverable="true">
                <Columns>
                    <BUIDataColumn TItem="Person" Property="@(p => p.Id)" Header="ID" />
                    <BUIDataColumn TItem="Person" Property="@(p => p.Name)" Header="Name" />
                    <BUIDataColumn TItem="Person" Property="@(p => p.Email)" Header="Email" />
                </Columns>
            </BUIDataCards>
        </div>
    };

    private void HandleCardClick(Person person)
    {
        _lastClickedPerson = $"{person.Name} (ID: {person.Id}) at {DateTime.Now:HH:mm:ss}";
        StateHasChanged();
    }
    #endregion

    #region Custom Card Template
    private ComponentDemoDefinition CustomCardDemo => new()
    {
        Demo = RenderCustomCard(),
        Code = """ """
    };

    private RenderFragment RenderCustomCard() => __builder =>
    {
        <BUIDataCards Items="_customCardData" MinCardWidth="300px">
            <Columns>
                <BUIDataColumn TItem="Person" Property="@(p => p.Name)" Header="Name" Sortable="true" />
            </Columns>
            <CardTemplate Context="person">
                <div style="padding: 1.5rem; text-align: center;">
                    <div style="width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, var(--palette-primary) 0%, var(--palette-secondary) 100%); margin: 0 auto 1rem; display: flex; align-items: center; justify-content: center; font-size: 2rem; color: white;">
                        @person.Name[0]
                    </div>
                    <h3 style="margin: 0 0 0.5rem;">@person.Name</h3>
                    <p style="margin: 0; opacity: 0.7; font-size: 0.875rem;">@person.Email</p>
                    <div style="margin-top: 1rem; display: flex; gap: 0.5rem; justify-content: center;">
                        <span style="padding: 0.25rem 0.75rem; background: var(--palette-primary); color: var(--palette-primarycontrast); border-radius: 999px; font-size: 0.75rem;">
                            Age: @person.Age
                        </span>
                        <span style="padding: 0.25rem 0.75rem; background: var(--palette-surface); border: 1px solid var(--palette-border); border-radius: 999px; font-size: 0.75rem;">
                            ID: @person.Id
                        </span>
                    </div>
                </div>
            </CardTemplate>
        </BUIDataCards>
    };
    #endregion

    #region Header Footer Template
    private ComponentDemoDefinition HeaderFooterDemo => new()
    {
        Demo = RenderHeaderFooter(),
        Code = """ """
    };

    private RenderFragment RenderHeaderFooter() => __builder =>
    {
        <BUIDataCards Items="_headerFooterData" MinCardWidth="280px">
            <Columns>
                <BUIDataColumn TItem="Person" Property="@(p => p.Email)" Header="Email" />
                <BUIDataColumn TItem="Person" Property="@(p => p.Age)" Header="Age" />
            </Columns>
            <CardHeaderTemplate Context="person">
                <div style="display: flex; align-items: center; gap: 0.75rem;">
                    <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--palette-primary); display: flex; align-items: center; justify-content: center; color: white; font-weight: 600;">
                        @person.Name[0]
                    </div>
                    <div>
                        <strong>@person.Name</strong>
                        <div style="font-size: 0.75rem; opacity: 0.7;">Employee #@person.Id</div>
                    </div>
                </div>
            </CardHeaderTemplate>
            <CardFooterTemplate Context="person">
                <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                    <button class="bui-action-btn" @onclick:stopPropagation="true">Edit</button>
                    <button class="bui-action-btn" @onclick:stopPropagation="true">Delete</button>
                </div>
            </CardFooterTemplate>
        </BUIDataCards>
    };
    #endregion

