@page "/demo/tooltip"

@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Components

<PageTitle>Tooltips - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>BUITooltip</h1>

    <p class="doc-intro">
        <strong>BUITooltip</strong> displays contextual information when hovering, focusing,
        or clicking on an element. Supports rich content, multiple placements, configurable delays,
        auto-close, and interactive tooltips.
    </p>

    <section class="doc-section">
        <h2>Basic usage</h2>
        <ComponentDemo Definition="@BasicUsageDemo" />
    </section>

    <section class="doc-section">
        <h2>Placements</h2>
        <ComponentDemo Definition="@PlacementsDemo" />
    </section>

    <section class="doc-section">
        <h2>Triggers</h2>
        <ComponentDemo Definition="@TriggersDemo" />
    </section>

    <section class="doc-section">
        <h2>Click trigger</h2>
        <ComponentDemo Definition="@ClickTriggerDemo" />
    </section>

    <section class="doc-section">
        <h2>Auto close</h2>
        <ComponentDemo Definition="@AutoCloseDemo" />
    </section>

    <section class="doc-section">
        <h2>Delays</h2>
        <ComponentDemo Definition="@DelaysDemo" />
    </section>

    <section class="doc-section">
        <h2>Interactive</h2>
        <ComponentDemo Definition="@InteractiveDemo" />
    </section>

    <section class="doc-section">
        <h2>Arrow</h2>
        <ComponentDemo Definition="@ArrowDemo" />
    </section>

    <section class="doc-section">
        <h2>Max width</h2>
        <ComponentDemo Definition="@MaxWidthDemo" />
    </section>

    <section class="doc-section">
        <h2>Offset</h2>
        <ComponentDemo Definition="@OffsetDemo" />
    </section>

    <section class="doc-section">
        <h2>Rich content</h2>
        <ComponentDemo Definition="@RichContentDemo" />
    </section>

    <section class="doc-section">
        <h2>On various elements</h2>
        <ComponentDemo Definition="@VariousElementsDemo" />
    </section>

    <section class="doc-section">
        <h2>Permanent</h2>
        <ComponentDemo Definition="@PermanentDemo" />
    </section>
</div>

@code {

    [CascadingParameter] public BUIPalette Palette { get; set; } = default!;

    /* ===================== BASIC USAGE ===================== */

    private ComponentDemoDefinition BasicUsageDemo => new()
    {
        Demo = RenderBasicUsage(),
        Code = """ """
    };

    private RenderFragment RenderBasicUsage() => __builder =>
    {
        <BUITooltip Text="This is a basic tooltip">
            <BUIButton Text="Hover me" OnClick="@(() => { })" />
        </BUITooltip>
    };

    /* ===================== PLACEMENTS ===================== */

    private ComponentDemoDefinition PlacementsDemo => new()
    {
        Demo = RenderPlacements(),
        Code = """ """
    };

    private RenderFragment RenderPlacements() => __builder =>
    {
        <BUIGrid Gap="2rem">
            <BUIGridItem>
                <BUIGrid Direction="GridDirection.Row" Gap="1rem" JustifyContent="GridJustifyContent.Center">
                    <BUIGridItem Auto="true">
                        <BUITooltip Text="Top Start" Placement="TooltipPlacement.TopStart">
                            <BUIButton Text="TopStart" Size="BUISize.Small" OnClick="@(() => { })" />
                        </BUITooltip>
                    </BUIGridItem>
                    <BUIGridItem Auto="true">
                        <BUITooltip Text="Top" Placement="TooltipPlacement.Top">
                            <BUIButton Text="Top" Size="BUISize.Small" OnClick="@(() => { })" />
                        </BUITooltip>
                    </BUIGridItem>
                    <BUIGridItem Auto="true">
                        <BUITooltip Text="Top End" Placement="TooltipPlacement.TopEnd">
                            <BUIButton Text="TopEnd" Size="BUISize.Small" OnClick="@(() => { })" />
                        </BUITooltip>
                    </BUIGridItem>
                </BUIGrid>
            </BUIGridItem>
            <BUIGridItem>
                <BUIGrid Direction="GridDirection.Row" Gap="1rem" JustifyContent="GridJustifyContent.SpaceBetween">
                    <BUIGridItem Auto="true">
                        <BUIGrid Gap="1rem">
                            <BUIGridItem>
                                <BUITooltip Text="Left Start" Placement="TooltipPlacement.LeftStart">
                                    <BUIButton Text="LeftStart" Size="BUISize.Small" OnClick="@(() => { })" />
                                </BUITooltip>
                            </BUIGridItem>
                            <BUIGridItem>
                                <BUITooltip Text="Left" Placement="TooltipPlacement.Left">
                                    <BUIButton Text="Left" Size="BUISize.Small" OnClick="@(() => { })" />
                                </BUITooltip>
                            </BUIGridItem>
                            <BUIGridItem>
                                <BUITooltip Text="Left End" Placement="TooltipPlacement.LeftEnd">
                                    <BUIButton Text="LeftEnd" Size="BUISize.Small" OnClick="@(() => { })" />
                                </BUITooltip>
                            </BUIGridItem>
                        </BUIGrid>
                    </BUIGridItem>
                    <BUIGridItem Auto="true">
                        <BUIGrid Gap="1rem">
                            <BUIGridItem>
                                <BUITooltip Text="Right Start" Placement="TooltipPlacement.RightStart">
                                    <BUIButton Text="RightStart" Size="BUISize.Small" OnClick="@(() => { })" />
                                </BUITooltip>
                            </BUIGridItem>
                            <BUIGridItem>
                                <BUITooltip Text="Right" Placement="TooltipPlacement.Right">
                                    <BUIButton Text="Right" Size="BUISize.Small" OnClick="@(() => { })" />
                                </BUITooltip>
                            </BUIGridItem>
                            <BUIGridItem>
                                <BUITooltip Text="Right End" Placement="TooltipPlacement.RightEnd">
                                    <BUIButton Text="RightEnd" Size="BUISize.Small" OnClick="@(() => { })" />
                                </BUITooltip>
                            </BUIGridItem>
                        </BUIGrid>
                    </BUIGridItem>
                </BUIGrid>
            </BUIGridItem>
            <BUIGridItem>
                <BUIGrid Direction="GridDirection.Row" Gap="1rem" JustifyContent="GridJustifyContent.Center">
                    <BUIGridItem Auto="true">
                        <BUITooltip Text="Bottom Start" Placement="TooltipPlacement.BottomStart">
                            <BUIButton Text="BottomStart" Size="BUISize.Small" OnClick="@(() => { })" />
                        </BUITooltip>
                    </BUIGridItem>
                    <BUIGridItem Auto="true">
                        <BUITooltip Text="Bottom" Placement="TooltipPlacement.Bottom">
                            <BUIButton Text="Bottom" Size="BUISize.Small" OnClick="@(() => { })" />
                        </BUITooltip>
                    </BUIGridItem>
                    <BUIGridItem Auto="true">
                        <BUITooltip Text="Bottom End" Placement="TooltipPlacement.BottomEnd">
                            <BUIButton Text="BottomEnd" Size="BUISize.Small" OnClick="@(() => { })" />
                        </BUITooltip>
                    </BUIGridItem>
                </BUIGrid>
            </BUIGridItem>
        </BUIGrid>
    };

    /* ===================== TRIGGERS ===================== */

    private ComponentDemoDefinition TriggersDemo => new()
    {
        Demo = RenderTriggers(),
        Code = """ """
    };

    private RenderFragment RenderTriggers() => __builder =>
    {
        <BUIGrid Direction="GridDirection.Row" Gap="1rem">
            <BUIGridItem Auto="true">
                <BUITooltip Text="Hover trigger (default)" Trigger="TooltipTrigger.Hover">
                    <BUIButton Text="Hover" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="Focus trigger" Trigger="TooltipTrigger.Focus">
                    <BUIButton Text="Focus (tab)" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="Hover and focus trigger" Trigger="TooltipTrigger.HoverAndFocus">
                    <BUIButton Text="Hover or Focus" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="Click trigger" Trigger="TooltipTrigger.Click">
                    <BUIButton Text="Click" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
        </BUIGrid>
    };

    /* ===================== CLICK TRIGGER ===================== */

    private ComponentDemoDefinition ClickTriggerDemo => new()
    {
        Demo = RenderClickTrigger(),
        Code = """ """
    };

    private RenderFragment RenderClickTrigger() => __builder =>
    {
        <BUIGrid Direction="GridDirection.Row" Gap="1rem">
            <BUIGridItem Auto="true">
                <BUITooltip Text="Copied!" Trigger="TooltipTrigger.Click" AutoCloseAfterMs="2000">
                    <BUIButton Text="Copy to clipboard" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="Saved!" Trigger="TooltipTrigger.Click" AutoCloseAfterMs="1500">
                    <BUIButton Text="Save" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="Click again to close (no auto-close)" Trigger="TooltipTrigger.Click">
                    <BUIButton Text="Toggle" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
        </BUIGrid>
    };

    /* ===================== AUTO CLOSE ===================== */

    private ComponentDemoDefinition AutoCloseDemo => new()
    {
        Demo = RenderAutoClose(),
        Code = """ """
    };

    private RenderFragment RenderAutoClose() => __builder =>
    {
        <BUIGrid Direction="GridDirection.Row" Gap="1rem">
            <BUIGridItem Auto="true">
                <BUITooltip Text="I will close in 2 seconds" AutoCloseAfterMs="2000">
                    <BUIButton Text="Hover (2s auto-close)" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="I will close in 5 seconds" AutoCloseAfterMs="5000">
                    <BUIButton Text="Hover (5s auto-close)" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="Hover over me to pause auto-close" AutoCloseAfterMs="3000" Interactive="true">
                    <BUIButton Text="Interactive + auto-close" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
        </BUIGrid>
    };

    /* ===================== DELAYS ===================== */

    private ComponentDemoDefinition DelaysDemo => new()
    {
        Demo = RenderDelays(),
        Code = """ """
    };

    private RenderFragment RenderDelays() => __builder =>
    {
        <BUIGrid Direction="GridDirection.Row" Gap="1rem">
            <BUIGridItem Auto="true">
                <BUITooltip Text="Instant show" ShowDelay="0">
                    <BUIButton Text="No delay" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="Default delays (200ms show, 150ms leave)">
                    <BUIButton Text="Default" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="Slow show (500ms)" ShowDelay="500">
                    <BUIButton Text="Slow show" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="Long leave delay (500ms)" LeaveDelay="500">
                    <BUIButton Text="Long leave delay" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
        </BUIGrid>
    };

    /* ===================== INTERACTIVE ===================== */

    private ComponentDemoDefinition InteractiveDemo => new()
    {
        Demo = RenderInteractive(),
        Code = """ """
    };

    private RenderFragment RenderInteractive() => __builder =>
    {
        <BUIGrid Direction="GridDirection.Row" Gap="1rem">
            <BUIGridItem Auto="true">
                <BUITooltip Interactive="false" Text="Non-interactive: disappears when you move to tooltip">
                    <BUIButton Text="Non-interactive" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Interactive="true">
                    <ChildContent>
                        <BUIButton Text="Interactive" OnClick="@(() => { })" />
                    </ChildContent>
                    <TooltipContent>
                        <div>
                            <p style="margin: 0 0 0.5rem 0;">You can interact with this tooltip!</p>
                            <BUIButton Text="Click me" Size="BUISize.Small" OnClick="@(() => { })" />
                        </div>
                    </TooltipContent>
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Interactive="true">
                    <ChildContent>
                        <BUIButton Text="With link" OnClick="@(() => { })" />
                    </ChildContent>
                    <TooltipContent>
                        <div>
                            Click the link:
                            <a href="https://github.com" target="_blank">GitHub</a>
                        </div>
                    </TooltipContent>
                </BUITooltip>
            </BUIGridItem>
        </BUIGrid>
    };

    /* ===================== ARROW ===================== */

    private ComponentDemoDefinition ArrowDemo => new()
    {
        Demo = RenderArrow(),
        Code = """ """
    };

    private RenderFragment RenderArrow() => __builder =>
    {
        <BUIGrid Direction="GridDirection.Row" Gap="1rem">
            <BUIGridItem Auto="true">
                <BUITooltip Text="With arrow (default)" Arrow="true">
                    <BUIButton Text="With arrow" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="Without arrow" Arrow="false">
                    <BUIButton Text="No arrow" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
        </BUIGrid>
    };

    /* ===================== MAX WIDTH ===================== */

    private ComponentDemoDefinition MaxWidthDemo => new()
    {
        Demo = RenderMaxWidth(),
        Code = """ """
    };

    private RenderFragment RenderMaxWidth() => __builder =>
    {
        <BUIGrid Direction="GridDirection.Row" Gap="1rem">
            <BUIGridItem Auto="true">
                <BUITooltip Text="This is a tooltip with a narrow max width. It will wrap when content is too long." MaxWidth="150">
                    <BUIButton Text="150px" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="This tooltip has the default max width of 300px." MaxWidth="300">
                    <BUIButton Text="300px (default)" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="This tooltip has a wider max width of 500px. It can display more content in a single line before wrapping occurs." MaxWidth="500">
                    <BUIButton Text="500px" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
        </BUIGrid>
    };

    /* ===================== OFFSET ===================== */

    private ComponentDemoDefinition OffsetDemo => new()
    {
        Demo = RenderOffset(),
        Code = """ """
    };

    private RenderFragment RenderOffset() => __builder =>
    {
        <BUIGrid Direction="GridDirection.Row" Gap="1rem">
            <BUIGridItem Auto="true">
                <BUITooltip Text="Small offset (4px)" Offset="4">
                    <BUIButton Text="4px offset" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="Default offset (8px)" Offset="8">
                    <BUIButton Text="8px (default)" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="Large offset (20px)" Offset="20">
                    <BUIButton Text="20px offset" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
        </BUIGrid>
    };

    /* ===================== RICH CONTENT ===================== */

    private ComponentDemoDefinition RichContentDemo => new()
    {
        Demo = RenderRichContent(),
        Code = """ """
    };

    private RenderFragment RenderRichContent() => __builder =>
    {
        <BUIGrid Direction="GridDirection.Row" Gap="1rem">
            <BUIGridItem Auto="true">
                <BUITooltip>
                    <ChildContent>
                        <BUIButton Text="With icon" OnClick="@(() => { })" />
                    </ChildContent>
                    <TooltipContent>
                        <div style="text-align: center;">
                            <BUISvgIcon Icon="@BUIIcons.UI.Info" Color="@Palette.Primary" />
                            <p style="margin: 0.5rem 0 0 0; font-weight: bold;">Information</p>
                            <p style="margin: 0; font-size: 0.875rem;">This is a tooltip with rich content.</p>
                        </div>
                    </TooltipContent>
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip>
                    <ChildContent>
                        <BUIButton Text="With badge" OnClick="@(() => { })" />
                    </ChildContent>
                    <TooltipContent>
                        <div>
                            <p style="margin: 0 0 0.5rem 0;">Status:</p>
                            <BUIBadge Text="Active" BackgroundColor="@Palette.Success" Color="@Palette.SuccessContrast" />
                        </div>
                    </TooltipContent>
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Interactive="true">
                    <ChildContent>
                        <BUIButton Text="With list" OnClick="@(() => { })" />
                    </ChildContent>
                    <TooltipContent>
                        <div>
                            <strong>Keyboard Shortcuts:</strong>
                            <ul style="margin: 0.5rem 0 0 0; padding-left: 1.25rem;">
                                <li>Ctrl+S - Save</li>
                                <li>Ctrl+Z - Undo</li>
                                <li>Ctrl+Y - Redo</li>
                            </ul>
                        </div>
                    </TooltipContent>
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip>
                    <ChildContent>
                        <BUIButton Text="Formatted text" OnClick="@(() => { })" />
                    </ChildContent>
                    <TooltipContent>
                        <div>
                            <strong>Bold title</strong>
                            <p style="margin: 0.5rem 0 0 0;">
                                With <em>italic</em> and <u>underlined</u> text.
                            </p>
                        </div>
                    </TooltipContent>
                </BUITooltip>
            </BUIGridItem>
        </BUIGrid>
    };

    /* ===================== VARIOUS ELEMENTS ===================== */

    private ComponentDemoDefinition VariousElementsDemo => new()
    {
        Demo = RenderVariousElements(),
        Code = """ """
    };

    private RenderFragment RenderVariousElements() => __builder =>
    {
        <BUIGrid Direction="GridDirection.Row" Gap="2rem" AlignItems="GridAlignItems.Center">
            <BUIGridItem Auto="true">
                <BUITooltip Text="Tooltip on icon">
                    <BUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_help" Size="BUISize.Large" Color="@Palette.Primary" />
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="Tooltip on badge">
                    <BUIBadge Text="New" BackgroundColor="@Palette.Primary" Color="@Palette.PrimaryContrast" />
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="Tooltip on text">
                    <span style="text-decoration: underline dotted; cursor: help;">Hover this text</span>
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="This button is disabled because...">
                    <span>
                        <BUIButton Text="Disabled" Disabled="true" OnClick="@(() => { })" />
                    </span>
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="Tooltip on image">
                    <img src="https://via.placeholder.com/50" alt="Placeholder" style="border-radius: 4px;" />
                </BUITooltip>
            </BUIGridItem>
        </BUIGrid>
    };

    /* ===================== PERMANENT ===================== */

    private ComponentDemoDefinition PermanentDemo => new()
    {
        Demo = RenderPermanent(),
        Code = """ """
    };

    private RenderFragment RenderPermanent() => __builder =>
    {
        <BUIGrid Direction="GridDirection.Row" Gap="1rem">
            <BUIGridItem Auto="true">
                <BUITooltip Trigger="TooltipTrigger.Permanent" Placement="TooltipPlacement.Right">
                    <ChildContent>
                        <BUIButton Text="Permanent tooltip" OnClick="@(() => { })" />
                    </ChildContent>
                    <TooltipContent>
                        <strong>This tooltip stays visible until closed.</strong>
                    </TooltipContent>
                </BUITooltip>
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUITooltip Text="Permanent with auto-close" Trigger="TooltipTrigger.Permanent" AutoCloseAfterMs="5000" Placement="TooltipPlacement.Top">
                    <BUIButton Text="Permanent (5s auto-close)" OnClick="@(() => { })" />
                </BUITooltip>
            </BUIGridItem>
        </BUIGrid>
    };
}