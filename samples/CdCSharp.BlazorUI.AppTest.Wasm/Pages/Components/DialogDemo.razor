@page "/demo/dialog"
@using CdCSharp.BlazorUI.Components.Layout.Services
@inject IModalService ModalService

<PageTitle>Modal - CdCSharp.BlazorUI</PageTitle>

<h1>BUIDialog & BUIDrawer</h1>

<h2>Dialog - Basic Usage</h2>
<ComponentDemo Definition="@DialogBasicDemo" />

<h2>Dialog - With Title</h2>
<ComponentDemo Definition="@DialogTitleDemo" />

<h2>Dialog - Custom Header</h2>
<ComponentDemo Definition="@DialogCustomHeaderDemo" />

<h2>Dialog - With Footer</h2>
<ComponentDemo Definition="@DialogFooterDemo" />

<h2>Dialog - Min/Max Dimensions</h2>
<ComponentDemo Definition="@DialogDimensionsDemo" />

<h2>Dialog - Full Screen</h2>
<ComponentDemo Definition="@DialogFullScreenDemo" />

<h2>Scrollable Content</h2>
<ComponentDemo Definition="@ScrollableDemo" />

<h2>Dialog - Close Options</h2>
<ComponentDemo Definition="@DialogCloseOptionsDemo" />

<h2>Dialog - Programmatic (Service)</h2>
<ComponentDemo Definition="@DialogServiceDemo" />

<h2>Drawer - Basic Usage</h2>
<ComponentDemo Definition="@DrawerBasicDemo" />

<h2>Drawer - Positions</h2>
<ComponentDemo Definition="@DrawerPositionsDemo" />

<h2>Drawer - Custom Size</h2>
<ComponentDemo Definition="@DrawerSizeDemo" />

<h2>Drawer - With Header and Footer</h2>
<ComponentDemo Definition="@DrawerHeaderFooterDemo" />

<h2>Drawer - Programmatic (Service)</h2>
<ComponentDemo Definition="@DrawerServiceDemo" />

@code {
    [CascadingParameter] public BUIPalette Palette { get; set; } = default!;

    private bool _basicDialogOpen = false;
    private bool _titleDialogOpen = false;
    private bool _customHeaderDialogOpen = false;
    private bool _footerDialogOpen = false;
    private bool _dimensionsDialogOpen = false;
    private bool _fullScreenDialogOpen = false;
    private bool _closeOptionsDialogOpen = false;

    private bool _basicDrawerOpen = false;
    private bool _leftDrawerOpen = false;
    private bool _rightDrawerOpen = false;
    private bool _topDrawerOpen = false;
    private bool _bottomDrawerOpen = false;
    private bool _sizeDrawerOpen = false;
    private bool _headerFooterDrawerOpen = false;
    private bool _scrollableOpen = false;

    private ComponentDemoDefinition DialogBasicDemo => new()
    {
        Demo = RenderDialogBasic(),
        Code = """ """
    };

    private RenderFragment RenderDialogBasic() => __builder =>
    {
        <BUIButton Text="Open Basic Dialog" OnClick="@(() => _basicDialogOpen = true)" />

        <BUIDialog @bind-Open="_basicDialogOpen">
            <Content>
                <p>This is a basic dialog with default settings.</p>
                <p>Click the X button or press Escape to close.</p>
            </Content>
        </BUIDialog>
    };

    private ComponentDemoDefinition DialogTitleDemo => new()
    {
        Demo = RenderDialogTitle(),
        Code = """ """
    };

    private RenderFragment RenderDialogTitle() => __builder =>
    {
        <BUIButton Text="Open Dialog with Title" OnClick="@(() => _titleDialogOpen = true)" />

        <BUIDialog @bind-Open="_titleDialogOpen" Title="Dialog Title">
            <Content>
                <p>This dialog has a title in the header.</p>
            </Content>
        </BUIDialog>
    };

    private ComponentDemoDefinition DialogCustomHeaderDemo => new()
    {
        Demo = RenderDialogCustomHeader(),
        Code = """ """
    };

    private RenderFragment RenderDialogCustomHeader() => __builder =>
    {
        <BUIButton Text="Open Dialog with Custom Header" OnClick="@(() => _customHeaderDialogOpen = true)" />

        <BUIDialog @bind-Open="_customHeaderDialogOpen">
            <Header>
                <BUIGrid Direction="GridDirection.Row" AlignItems="GridAlignItems.Center" Gap="0.5rem">
                    <BUIGridItem Auto="true">
                        <BUISvgIcon Icon="@BUIIcons.UI.Info" Color="@Palette.Primary" />
                    </BUIGridItem>
                    <BUIGridItem>
                        <strong>Custom Header</strong>
                    </BUIGridItem>
                </BUIGrid>
            </Header>
            <Content>
                <p>This dialog uses a custom header with an icon.</p>
            </Content>
        </BUIDialog>
    };

    private ComponentDemoDefinition DialogFooterDemo => new()
    {
        Demo = RenderDialogFooter(),
        Code = """ """
    };

    private RenderFragment RenderDialogFooter() => __builder =>
    {
        <BUIButton Text="Open Dialog with Footer" OnClick="@(() => _footerDialogOpen = true)" />

        <BUIDialog @bind-Open="_footerDialogOpen" Title="Confirm Action">
            <Content>
                <p>Are you sure you want to proceed with this action?</p>
            </Content>
            <Footer>
                <BUIGrid Direction="GridDirection.Row" Gap="0.5rem" JustifyContent="GridJustifyContent.End">
                    <BUIGridItem Auto="true">
                        <BUIButton Text="Cancel" OnClick="@(() => _footerDialogOpen = false)" />
                    </BUIGridItem>
                    <BUIGridItem Auto="true">
                        <BUIButton Text="Confirm"
                                   BackgroundColor="@Palette.Primary"
                                   Color="@Palette.PrimaryContrast"
                                   OnClick="@(() => _footerDialogOpen = false)" />
                    </BUIGridItem>
                </BUIGrid>
            </Footer>
        </BUIDialog>
    };

    private ComponentDemoDefinition DialogDimensionsDemo => new()
    {
        Demo = RenderDialogDimensions(),
        Code = """ """
    };

    private RenderFragment RenderDialogDimensions() => __builder =>
    {
        <BUIButton Text="Open Dialog with Custom Dimensions" OnClick="@(() => _dimensionsDialogOpen = true)" />

        <BUIDialog @bind-Open="_dimensionsDialogOpen"
                   Title="Custom Dimensions"
                   MinWidth="400px"
                   MaxWidth="600px"
                   MinHeight="300px"
                   MaxHeight="500px">
            <Content>
                <p>This dialog has custom min/max width and height constraints.</p>
                <p>MinWidth: 400px, MaxWidth: 600px</p>
                <p>MinHeight: 300px, MaxHeight: 500px</p>
            </Content>
        </BUIDialog>
    };

    private ComponentDemoDefinition DialogFullScreenDemo => new()
    {
        Demo = RenderDialogFullScreen(),
        Code = """ """
    };

    private RenderFragment RenderDialogFullScreen() => __builder =>
    {
        <BUIButton Text="Open Full Screen Dialog" OnClick="@(() => _fullScreenDialogOpen = true)" />

        <BUIDialog @bind-Open="_fullScreenDialogOpen"
                   Title="Full Screen Dialog"
                   FullScreen="true">
            <Content>
                <p>This dialog takes up the entire screen.</p>
                <p>Useful for complex forms or detailed content.</p>
            </Content>
        </BUIDialog>
    };

    private ComponentDemoDefinition DialogCloseOptionsDemo => new()
    {
        Demo = RenderDialogCloseOptions(),
        Code = """ """
    };

    private RenderFragment RenderDialogCloseOptions() => __builder =>
    {
        <BUIButton Text="Open Dialog (Custom Close)" OnClick="@(() => _closeOptionsDialogOpen = true)" />

        <BUIDialog @bind-Open="_closeOptionsDialogOpen"
                   Title="Close Options"
                   Closable="false"
                   CloseOnOverlayClick="false"
                   CloseOnEscape="false">
            <Content>
                <p>This dialog has all automatic close options disabled:</p>
                <ul>
                    <li>No close button (Closable=false)</li>
                    <li>No close on overlay click</li>
                    <li>No close on Escape key</li>
                </ul>
                <p>You must use the button below to close it.</p>
            </Content>
            <Footer>
                <BUIButton Text="Close Manually"
                           BackgroundColor="@Palette.Primary"
                           Color="@Palette.PrimaryContrast"
                           OnClick="@(() => _closeOptionsDialogOpen = false)" />
            </Footer>
        </BUIDialog>
    };

    private ComponentDemoDefinition DialogServiceDemo => new()
    {
        Demo = RenderDialogService(),
        Code = """ """
    };

    private RenderFragment RenderDialogService() => __builder =>
    {
        <BUIGrid Direction="GridDirection.Row" Gap="1rem">
            <BUIGridItem Auto="true">
                <BUIButton Text="Show Dialog (Service)" OnClick="@ShowDialogAsync" />
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUIButton Text="Show Dialog with Result" OnClick="@ShowDialogWithResultAsync" />
            </BUIGridItem>
        </BUIGrid>
    };

    private async Task ShowDialogAsync()
    {
        await ModalService.ShowDialogAsync<SampleDialogContent>(
            new { Message = "This dialog was opened using IModalService!" },
            new DialogOptions
            {
                Title = "Service Dialog",
                MaxWidth = "500px"
            });
    }

    private async Task ShowDialogWithResultAsync()
    {
        bool? result = await ModalService.ShowDialogAsync<SampleConfirmDialog, bool?>(
            null,
            new DialogOptions
            {
                Title = "Confirm",
                MaxWidth = "400px"
            });
    }

    private ComponentDemoDefinition DrawerBasicDemo => new()
    {
        Demo = RenderDrawerBasic(),
        Code = """ """
    };

    private RenderFragment RenderDrawerBasic() => __builder =>
    {
        <BUIButton Text="Open Basic Drawer" OnClick="@(() => _basicDrawerOpen = true)" />

        <BUIDrawer @bind-Open="_basicDrawerOpen">
            <ChildContent>
                <p>This is a basic drawer with default settings.</p>
                <p>It opens from the left by default.</p>
            </ChildContent>
        </BUIDrawer>
    };

    private ComponentDemoDefinition DrawerPositionsDemo => new()
    {
        Demo = RenderDrawerPositions(),
        Code = """ """
    };

    private RenderFragment RenderDrawerPositions() => __builder =>
    {
        <BUIGrid Direction="GridDirection.Row" Gap="1rem">
            <BUIGridItem Auto="true">
                <BUIButton Text="Left" OnClick="@(() => _leftDrawerOpen = true)" />
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUIButton Text="Right" OnClick="@(() => _rightDrawerOpen = true)" />
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUIButton Text="Top" OnClick="@(() => _topDrawerOpen = true)" />
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUIButton Text="Bottom" OnClick="@(() => _bottomDrawerOpen = true)" />
            </BUIGridItem>
        </BUIGrid>

        <BUIDrawer @bind-Open="_leftDrawerOpen" Position="DrawerPosition.Left">
            <ChildContent>
                <h3>Left Drawer</h3>
                <p>This drawer slides in from the left.</p>
            </ChildContent>
        </BUIDrawer>

        <BUIDrawer @bind-Open="_rightDrawerOpen" Position="DrawerPosition.Right">
            <ChildContent>
                <h3>Right Drawer</h3>
                <p>This drawer slides in from the right.</p>
            </ChildContent>
        </BUIDrawer>

        <BUIDrawer @bind-Open="_topDrawerOpen" Position="DrawerPosition.Top">
            <ChildContent>
                <h3>Top Drawer</h3>
                <p>This drawer slides in from the top.</p>
            </ChildContent>
        </BUIDrawer>

        <BUIDrawer @bind-Open="_bottomDrawerOpen" Position="DrawerPosition.Bottom">
            <ChildContent>
                <h3>Bottom Drawer</h3>
                <p>This drawer slides in from the bottom.</p>
            </ChildContent>
        </BUIDrawer>
    };

    private ComponentDemoDefinition DrawerSizeDemo => new()
    {
        Demo = RenderDrawerSize(),
        Code = """ """
    };

    private RenderFragment RenderDrawerSize() => __builder =>
    {
        <BUIButton Text="Open Wide Drawer (500px)" OnClick="@(() => _sizeDrawerOpen = true)" />

        <BUIDrawer @bind-Open="_sizeDrawerOpen" Size="500px">
            <ChildContent>
                <h3>Custom Size Drawer</h3>
                <p>This drawer has a custom width of 500px.</p>
            </ChildContent>
        </BUIDrawer>
    };

    private ComponentDemoDefinition DrawerHeaderFooterDemo => new()
    {
        Demo = RenderDrawerHeaderFooter(),
        Code = """ """
    };

    private RenderFragment RenderDrawerHeaderFooter() => __builder =>
    {
        <BUIButton Text="Open Drawer with Header/Footer" OnClick="@(() => _headerFooterDrawerOpen = true)" />

        <BUIDrawer @bind-Open="_headerFooterDrawerOpen" Position="DrawerPosition.Right" Size="350px">
            <Header>
                <BUIGrid Direction="GridDirection.Row" AlignItems="GridAlignItems.Center" Gap="0.5rem">
                    <BUIGridItem Auto="true">
                        <BUISvgIcon Icon="@BUIIcons.UI.Settings" />
                    </BUIGridItem>
                    <BUIGridItem>
                        <strong>Settings</strong>
                    </BUIGridItem>
                </BUIGrid>
            </Header>
            <ChildContent>
                <p>This drawer has a custom header and footer.</p>
                <p>The content area is scrollable if needed.</p>
            </ChildContent>
            <Footer>
                <BUIGrid Direction="GridDirection.Row" Gap="0.5rem" JustifyContent="GridJustifyContent.End">
                    <BUIGridItem Auto="true">
                        <BUIButton Text="Cancel" OnClick="@(() => _headerFooterDrawerOpen = false)" />
                    </BUIGridItem>
                    <BUIGridItem Auto="true">
                        <BUIButton Text="Save"
                                   BackgroundColor="@Palette.Primary"
                                   Color="@Palette.PrimaryContrast"
                                   OnClick="@(() => _headerFooterDrawerOpen = false)" />
                    </BUIGridItem>
                </BUIGrid>
            </Footer>
        </BUIDrawer>
    };

    private ComponentDemoDefinition DrawerServiceDemo => new()
    {
        Demo = RenderDrawerService(),
        Code = """ """
    };

    private RenderFragment RenderDrawerService() => __builder =>
    {
        <BUIGrid Direction="GridDirection.Row" Gap="1rem">
            <BUIGridItem Auto="true">
                <BUIButton Text="Show Left Drawer (Service)" OnClick="@(() => ShowDrawerAsync(DrawerPosition.Left))" />
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <BUIButton Text="Show Right Drawer (Service)" OnClick="@(() => ShowDrawerAsync(DrawerPosition.Right))" />
            </BUIGridItem>
        </BUIGrid>
    };

    private async Task ShowDrawerAsync(DrawerPosition position)
    {
        await ModalService.ShowDrawerAsync<SampleDrawerContent>(
            new { Title = $"Drawer from {position}" },
            new DrawerOptions
            {
                Position = position,
                Size = "350px"
            });
    }

    private ComponentDemoDefinition ScrollableDemo => new()
    {
        Demo = RenderScrollable(),
        Code = """ """
    };

    private RenderFragment RenderScrollable() => __builder =>
    {
        <BUIButton Text="Open Scrollable Dialog" OnClick="@(() => _scrollableOpen = true)" />

        <BUIDialog @bind-Open="_scrollableOpen"
                   Title="Scrollable Content"
                   MaxHeight="400px"
                   Closable="true">
            <Content>
                @for (int i = 1; i <= 20; i++)
                {
                    <p>This is paragraph @i. When the content exceeds the max height, it becomes scrollable.</p>
                }
            </Content>
        </BUIDialog>
    };
}

@* Sample components for programmatic modals *@

@code {
    public class SampleDialogContent : ComponentBase, IModalContent
    {
        [Parameter] public string Message { get; set; } = "";
        [CascadingParameter] public ModalReference? ModalReference { get; set; }

        protected override void BuildRenderTree(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder builder)
        {
            builder.OpenElement(0, "div");
            builder.AddContent(1, Message);
            builder.CloseElement();
        }
    }

    public class SampleConfirmDialog : ComponentBase, IModalContent
    {
        [CascadingParameter] public ModalReference ModalReference { get; set; } = default!;

        protected override void BuildRenderTree(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder builder)
        {
            builder.OpenElement(0, "div");
            builder.OpenElement(1, "p");
            builder.AddContent(2, "Do you want to proceed?");
            builder.CloseElement();
            builder.OpenComponent<BUIButton>(3);
            builder.AddAttribute(4, "Text", "Yes");
            builder.AddAttribute(5, "OnClick", EventCallback.Factory.Create<MouseEventArgs>(this, () => ModalReference.CloseAsync<bool>(true)));
            builder.CloseComponent();
            builder.OpenComponent<BUIButton>(6);
            builder.AddAttribute(7, "Text", "No");
            builder.AddAttribute(8, "OnClick", EventCallback.Factory.Create<MouseEventArgs>(this, () => ModalReference.CloseAsync<bool>(false)));
            builder.CloseComponent();
            builder.CloseElement();
        }
    }

    public class SampleDrawerContent : ComponentBase, IModalContent
    {
        [Parameter] public string Title { get; set; } = "";
        [CascadingParameter] public ModalReference ModalReference { get; set; } = default!;

        protected override void BuildRenderTree(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder builder)
        {
            builder.OpenElement(0, "div");
            builder.OpenElement(1, "h3");
            builder.AddContent(2, Title);
            builder.CloseElement();
            builder.OpenElement(3, "p");
            builder.AddContent(4, "This drawer was opened using IModalService.");
            builder.CloseElement();
            builder.OpenComponent<BUIButton>(5);
            builder.AddAttribute(6, "Text", "Close");
            builder.AddAttribute(7, "OnClick", EventCallback.Factory.Create<MouseEventArgs>(this, () => ModalReference.CloseAsync()));
            builder.CloseComponent();
            builder.CloseElement();
        }
    }
}