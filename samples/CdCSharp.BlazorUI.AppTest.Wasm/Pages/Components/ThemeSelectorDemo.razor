@page "/demo/themeselector"

<PageTitle>Theme Selector - CdCSharp.BlazorUI</PageTitle>

<h1>BUIThemeSelector</h1>

<h2>Basic Usage</h2>
<ComponentDemo Definition="@BasicUsageDemo" />

<h2>With Custom Themes</h2>
<ComponentDemo Definition="@CustomThemesDemo" />

<h2>Show Icon</h2>
<ComponentDemo Definition="@ShowIconDemo" />

<h2>Custom Icon Map</h2>
<ComponentDemo Definition="@IconMapDemo" />

@code {
    private ComponentDemoDefinition BasicUsageDemo => new()
    {
        Demo = RenderBasicUsage(),
        Code = """ """
    };

    private RenderFragment RenderBasicUsage() => __builder =>
    {
        <BUIThemeSelector />
    };

    private ComponentDemoDefinition CustomThemesDemo => new()
    {
        Demo = RenderCustomThemes(),
        Code = """ """
    };

    private RenderFragment RenderCustomThemes() => __builder =>
    {
        <BUIThemeSelector AvailableThemes="@(new[] { "light", "dark", "auto" })" />
    };

    private ComponentDemoDefinition ShowIconDemo => new()
    {
        Demo = RenderShowIcon(),
        Code = """ """
    };

    private RenderFragment RenderShowIcon() => __builder =>
    {
        <BUIGrid Gap="1rem" Direction="GridDirection.Row">
            <BUIGridItem Auto="true">
                <p>With Icon (default):</p>
                <BUIThemeSelector ShowIcon="true" />
            </BUIGridItem>
            <BUIGridItem Auto="true">
                <p>Without Icon:</p>
                <BUIThemeSelector ShowIcon="false" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition IconMapDemo => new()
    {
        Demo = RenderIconMap(),
        Code = """ """
    };

    private RenderFragment RenderIconMap() => __builder =>
    {
        <BUIThemeSelector IconMap="@_customIconMap" />
    };

    private readonly Dictionary<string, string> _customIconMap = new()
    {
        { "light", BUIIcons.MaterialIconsOutlined.i_wb_sunny },
        { "dark", BUIIcons.MaterialIconsOutlined.i_nights_stay }
    };
}