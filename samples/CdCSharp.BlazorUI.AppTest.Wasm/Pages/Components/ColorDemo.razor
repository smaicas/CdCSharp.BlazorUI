@page "/demo/color"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared

<PageTitle>Color Picker - CdCSharp.BlazorUI</PageTitle>

<h1>BUIInputColor</h1>

<h2>Basic Usage</h2>
<ComponentDemo Definition="@BasicUsageDemo" />

<h2>With Label and Helper Text</h2>
<ComponentDemo Definition="@WithLabelDemo" />

<h2>Variants</h2>
<ComponentDemo Definition="@VariantsDemo" />

<h2>Display Modes</h2>
<ComponentDemo Definition="@DisplayModesDemo" />

<h2>Output Formats</h2>
<ComponentDemo Definition="@OutputFormatsDemo" />

<h2>Editable Input</h2>
<ComponentDemo Definition="@EditableInputDemo" />

<h2>With Copy Button</h2>
<ComponentDemo Definition="@CopyButtonDemo" />

<h2>Clearable (Reverts to Initial Value)</h2>
<ComponentDemo Definition="@ClearableDemo" />

<h2>Sizes</h2>
<ComponentDemo Definition="@SizesDemo" />

<h2>With Prefix and Suffix</h2>
<ComponentDemo Definition="@PrefixSuffixDemo" />

<h2>Custom Picker Size</h2>
<ComponentDemo Definition="@CustomPickerSizeDemo" />

<h2>Required and Validation</h2>
<ComponentDemo Definition="@ValidationDemo" />

<h2>Disabled and ReadOnly</h2>
<ComponentDemo Definition="@DisabledReadOnlyDemo" />

<h2>Combined Features</h2>
<ComponentDemo Definition="@CombinedDemo" />

@code {
    private CssColor? _basicValue;
    private CssColor? _labelValue = BUIColor.DarkRed.Default;
    private CssColor? _outlinedValue = BUIColor.Blue.Default;
    private CssColor? _filledValue = BUIColor.Green.Default;
    private CssColor? _standardValue = BUIColor.Purple.Default;
    private CssColor? _modalValue = BUIColor.Orange.Default;
    private CssColor? _dropdownValue = BUIColor.Teal.Default;
    private CssColor? _hexValue = new CssColor("#8ab4f8");
    private CssColor? _rgbValue = new CssColor(138, 180, 248, 1);
    private CssColor? _editableValue = BUIColor.DarkRed.Default;
    private CssColor? _copyValue = BUIColor.Indigo.Default;
    private CssColor? _clearableValue = BUIColor.Cyan.Default;
    private CssColor? _clearableInitial = BUIColor.Cyan.Default;
    private CssColor? _smallValue = BUIColor.Pink.Default;
    private CssColor? _mediumValue = BUIColor.Lime.Default;
    private CssColor? _largeValue = BUIColor.Aquamarine.Default;
    private CssColor? _prefixValue = BUIColor.MediumPurple.Default;
    private CssColor? _customPickerValue = BUIColor.LightBlue.Default;
    private CssColor? _requiredValue;
    private CssColor? _disabledValue = BUIColor.Gray.Default;
    private CssColor? _readOnlyValue = BUIColor.Brown.Default;
    private CssColor? _combinedValue = BUIColor.DarkOrange.Default;

    private ComponentDemoDefinition BasicUsageDemo => new()
    {
        Demo = RenderBasicUsage(),
        Code = """ """
    };

    private RenderFragment RenderBasicUsage() => __builder =>
    {
        <BUIInputColor @bind-Value="_basicValue" />
        <p style="margin-top: 0.5rem;">Selected: @(_basicValue?.ToString() ?? "None")</p>
    };

    private ComponentDemoDefinition WithLabelDemo => new()
    {
        Demo = RenderWithLabel(),
        Code = """ """
    };

    private RenderFragment RenderWithLabel() => __builder =>
    {
        <BUIInputColor @bind-Value="_labelValue"
                       Label="Brand Color"
                       HelperText="Select your brand's primary color"
                       Placeholder="#000000" />
    };

    private ComponentDemoDefinition VariantsDemo => new()
    {
        Demo = RenderVariants(),
        Code = """ """
    };

    private RenderFragment RenderVariants() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem Xs="12" Md="4">
                <BUIInputColor @bind-Value="_outlinedValue" Variant="BUIInputVariant.Outlined" Label="Outlined" />
            </BUIGridItem>
            <BUIGridItem Xs="12" Md="4">
                <BUIInputColor @bind-Value="_filledValue" Variant="BUIInputVariant.Filled" Label="Filled" />
            </BUIGridItem>
            <BUIGridItem Xs="12" Md="4">
                <BUIInputColor @bind-Value="_standardValue" Variant="BUIInputVariant.Standard" Label="Standard" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition DisplayModesDemo => new()
    {
        Demo = RenderDisplayModes(),
        Code = """ """
    };

    private RenderFragment RenderDisplayModes() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem Xs="12" Md="6">
                <BUIInputColor @bind-Value="_dropdownValue"
                               Label="Dropdown (Default)"
                               DisplayMode="ColorPickerDisplayMode.Dropdown" />
            </BUIGridItem>
            <BUIGridItem Xs="12" Md="6">
                <BUIInputColor @bind-Value="_modalValue"
                               Label="Modal"
                               DisplayMode="ColorPickerDisplayMode.Modal" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition OutputFormatsDemo => new()
    {
        Demo = RenderOutputFormats(),
        Code = """ """
    };

    private RenderFragment RenderOutputFormats() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem Xs="12" Md="6">
                <BUIInputColor @bind-Value="_hexValue"
                               Label="HEX Format"
                               OutputFormat="ColorPickerOutputFormat.Hex" />
                <p style="margin-top: 0.25rem; font-size: 0.875rem;">Value: @_hexValue?.ToString(ColorOutputFormats.HexA)</p>
            </BUIGridItem>
            <BUIGridItem Xs="12" Md="6">
                <BUIInputColor @bind-Value="_rgbValue"
                               Label="RGB Format"
                               OutputFormat="ColorPickerOutputFormat.Rgb" />
                <p style="margin-top: 0.25rem; font-size: 0.875rem;">Value: @_rgbValue?.ToString(ColorOutputFormats.Rgba)</p>
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition EditableInputDemo => new()
    {
        Demo = RenderEditableInput(),
        Code = """ """
    };

    private RenderFragment RenderEditableInput() => __builder =>
    {
        <BUIInputColor @bind-Value="_editableValue"
                       Label="Type a Color"
                       InputEditable="true"
                       HelperText="Try typing #FF0000 or rgb(255,0,0)" />
        <p style="margin-top: 0.25rem; font-size: 0.875rem;">Current value: @(_editableValue?.ToString() ?? "None")</p>
    };

    private ComponentDemoDefinition CopyButtonDemo => new()
    {
        Demo = RenderCopyButton(),
        Code = """ """
    };

    private RenderFragment RenderCopyButton() => __builder =>
    {
        <BUIInputColor @bind-Value="_copyValue"
                       Label="With Copy Button"
                       ShowCopyButton="true"
                       HelperText="Click the copy icon to copy the color value" />
    };

    private ComponentDemoDefinition ClearableDemo => new()
    {
        Demo = RenderClearable(),
        Code = """ """
    };

    private RenderFragment RenderClearable() => __builder =>
    {
        <BUIInputColor @bind-Value="_clearableValue"
                       Label="Clearable"
                       Clearable="true"
                       HelperText="Initial value was Cyan - Clear reverts to it" />
        <p style="margin-top: 0.25rem; font-size: 0.875rem;">
            Current: @(_clearableValue?.ToString() ?? "None") | Initial: @(_clearableInitial?.ToString() ?? "None")
        </p>
    };

    private ComponentDemoDefinition SizesDemo => new()
    {
        Demo = RenderSizes(),
        Code = """ """
    };

    private RenderFragment RenderSizes() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem Xs="12" Md="4">
                <BUIInputColor @bind-Value="_smallValue" Label="Small" Size="SizeEnum.Small" />
            </BUIGridItem>
            <BUIGridItem Xs="12" Md="4">
                <BUIInputColor @bind-Value="_mediumValue" Label="Medium (Default)" Size="SizeEnum.Medium" />
            </BUIGridItem>
            <BUIGridItem Xs="12" Md="4">
                <BUIInputColor @bind-Value="_largeValue" Label="Large" Size="SizeEnum.Large" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition PrefixSuffixDemo => new()
    {
        Demo = RenderPrefixSuffix(),
        Code = """ """
    };

    private RenderFragment RenderPrefixSuffix() => __builder =>
    {
        <BUIInputColor @bind-Value="_prefixValue"
                       Label="With Prefix Icon"
                       PrefixIcon="@BUIIcons.MaterialIconsOutlined.i_palette" />
    };

    private ComponentDemoDefinition CustomPickerSizeDemo => new()
    {
        Demo = RenderCustomPickerSize(),
        Code = """ """
    };

    private RenderFragment RenderCustomPickerSize() => __builder =>
    {
        <BUIInputColor @bind-Value="_customPickerValue"
                       Label="Large Picker"
                       SelectionWidth="300"
                       SelectionHeight="200"
                       HelperText="Custom picker size: 300x200" />
    };

    private ComponentDemoDefinition ValidationDemo => new()
    {
        Demo = RenderValidation(),
        Code = """ """
    };

    private RenderFragment RenderValidation() => __builder =>
    {
        <BUIInputColor @bind-Value="_requiredValue"
                       Label="Required Color"
                       Required="true"
                       HelperText="This field is required" />
    };

    private ComponentDemoDefinition DisabledReadOnlyDemo => new()
    {
        Demo = RenderDisabledReadOnly(),
        Code = """  """
    };

    private RenderFragment RenderDisabledReadOnly() => __builder =>
    {
        <BUIGrid Gap="1rem">
            <BUIGridItem Xs="12" Md="6">
                <BUIInputColor @bind-Value="_disabledValue" Label="Disabled" Disabled="true" />
            </BUIGridItem>
            <BUIGridItem Xs="12" Md="6">
                <BUIInputColor @bind-Value="_readOnlyValue" Label="Read Only" ReadOnly="true" InputEditable="false" />
            </BUIGridItem>
        </BUIGrid>
    };

    private ComponentDemoDefinition CombinedDemo => new()
    {
        Demo = RenderCombined(),
        Code = """ """
    };

    private RenderFragment RenderCombined() => __builder =>
    {
        <BUIInputColor @bind-Value="_combinedValue"
                       Label="Full Featured"
                       Variant="BUIInputVariant.Outlined"
                       Size="SizeEnum.Medium"
                       DisplayMode="ColorPickerDisplayMode.Dropdown"
                       OutputFormat="ColorPickerOutputFormat.Hex"
                       InputEditable="true"
                       ShowCopyButton="true"
                       Clearable="true"
                       PrefixIcon="@BUIIcons.MaterialIconsOutlined.i_palette"
                       HelperText="All features enabled"
                       SelectionWidth="250"
                       SelectionHeight="180" />
        <p style="margin-top: 0.5rem;">Selected: @(_combinedValue?.ToString() ?? "None")</p>
    };
}