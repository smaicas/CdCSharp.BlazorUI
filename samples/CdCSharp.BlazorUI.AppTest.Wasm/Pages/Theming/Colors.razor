@page "/theming/colors"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using System.Reflection
@using CdCSharp.BlazorUI.Core.Css

<PageTitle>Colors - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>Colors</h1>
    <p class="doc-intro">
        The color system provides a comprehensive set of colors with automatic variants for lighter and darker shades.
        Colors adapt to the current theme and support transparency.
    </p>

    <div class="doc-section">
        <h2>Theme Palette Colors</h2>
        <p>These colors are defined by the current theme and change automatically when switching themes:</p>

        <div class="palette-grid">
            @foreach (var paletteColor in UIColorPalette)
            {
                <div class="palette-item">
                    <h4>@paletteColor.Key</h4>
                    <div class="palette-swatch" style="@($"background: {paletteColor.Value}; color: {paletteColor.Value.GetBestContrast()}")">
                        @paletteColor.Key
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="doc-section">
        <h2>UIColor Full Palette</h2>
        <p>This section shows all predefined colors in <code>UIColor</code> with their Lighten/Darken variants.</p>

        <div class="palette-grid">
            @foreach (var colorClass in UIColorColorClasses)
            {
                <div class="palette-color-block">
                    <h4>@colorClass.Name</h4>
                    <div class="color-variants">
                        @foreach (var prop in colorClass.Properties)
                        {
                            <div class="variant-item">
                                <BUIButton Text="@prop.Name"
                                          BackgroundColor="@(prop.Value)"
                                          Color="@(prop.Value.GetBestContrast())" />
                                <code>@($"UIColor.{colorClass.Name}.{prop.Name}")</code>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="doc-section">
        <h2>Using Colors</h2>

        <ComponentDemo Code="@usingColorsCode">
            <Demo>
                <div class="demo-row">
                    <BUIButton Text="Theme Primary" BackgroundColor="@(new CssColor("var(--palette-primary)", true))" TextColor="@(new CssColor("var(--palette-primary)", true).GetBestContrast())" />
                    <BUIButton Text="UIColor Blue" BackgroundColor="@BUIColor.Blue.Default" TextColor="@BUIColor.Blue.Default.GetBestContrast()" />
                    <BUIButton Text="Custom Color" BackgroundColor="@(new CssColor("#FF5722"))" TextColor="@(new CssColor("#FF5722").GetBestContrast())" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Creating Custom Colors</h2>

        <CodeBlock Code="@customColorsCode" Language="csharp" Title="Custom Colors" />
    </div>
</div>

@code {
    private string usingColorsCode = @"// Using theme palette colors
<BUIButton Text=""Theme Primary"" BackgroundColor=""@(new CssColor(""var(--palette-primary)"", true))"" TextColor=""@(new CssColor(""var(--palette-primary)"", true).GetBestContrast())"" />

// Using UIColor constants
<BUIButton Text=""UIColor Blue"" BackgroundColor=""@UIColor.Blue.Default"" TextColor=""@UIColor.Blue.Default.GetBestContrast()"" />

// Using custom hex color
<BUIButton Text=""Custom Color"" BackgroundColor=""@(new CssColor(""#FF5722""))"" TextColor=""@(new CssColor(""#FF5722"").GetBestContrast())"" />";

    private string customColorsCode = @"// Create from hex
CssColor customColor1 = new CssColor(""#FF5722"");

// Create from RGB
CssColor customColor2 = new CssColor(255, 87, 34);

// Create from RGBA with transparency
CssColor customColor3 = new CssColor(255, 87, 34, 0.5);

// Use CSS variables
CssColor themeColor = new CssColor(""var(--palette-primary)"", true);";

    // Representa una clase de UIColor con sus propiedades CssColor
    private record UIColorClass(string Name, List<(string Name, CssColor Value)> Properties);

    private List<UIColorClass> UIColorColorClasses { get; set; } = new();
    private Dictionary<string, CssColor> UIColorPalette { get; set; } = new();

    protected override void OnInitialized()
    {
        // Obtener todas las clases internas públicas estáticas de UIColor
        var innerTypes = typeof(BUIColor).GetNestedTypes(BindingFlags.Public | BindingFlags.Static);

        foreach (var type in innerTypes)
        {
            // Para Palette, guardamos en un diccionario
            if (type.Name == "Palette")
            {
                var paletteProps = type.GetProperties(BindingFlags.Public | BindingFlags.Static)
                                       .Where(p => p.PropertyType == typeof(CssColor))
                                       .ToDictionary(p => p.Name, p => (CssColor)p.GetValue(null)!);

                UIColorPalette = paletteProps;
            }
            else
            {
                var props = type.GetProperties(BindingFlags.Public | BindingFlags.Static)
                                .Where(p => p.PropertyType == typeof(CssColor))
                                .Select(p => (p.Name, (CssColor)p.GetValue(null)!))
                                .ToList();

                UIColorColorClasses.Add(new UIColorClass(type.Name, props));
            }
        }
    }
}
