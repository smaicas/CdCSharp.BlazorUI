</style>

@code {
    private record ColorFamily(string Name, List<(string Name, CssColor Value)> Variants);

    private Dictionary<string, CssColor> PaletteColors = new();
    private List<ColorFamily> AllColorFamilies = new();
    private List<ColorFamily> SelectedColorFamilies = new();

    protected override void OnInitialized()
    {
        LoadColors();
    }

    private void LoadColors()
    {
        Type[] innerTypes = typeof(BUIColor).GetNestedTypes(BindingFlags.Public | BindingFlags.Static);

        foreach (Type type in innerTypes)
        {
            if (type.Name == "Palette")
            {
                PaletteColors = type.GetProperties(BindingFlags.Public | BindingFlags.Static)
                    .Where(p => p.PropertyType == typeof(CssColor))
                    .ToDictionary(p => p.Name, p => (CssColor)p.GetValue(null)!);
            }
            else
            {
                List<(string, CssColor)> variants = type.GetProperties(BindingFlags.Public | BindingFlags.Static)
                    .Where(p => p.PropertyType == typeof(CssColor))
                    .Select(p => (p.Name, (CssColor)p.GetValue(null)!))
                    .ToList();

                AllColorFamilies.Add(new ColorFamily(type.Name, variants));
            }
        }

        string[] selectedNames = { "Blue", "Red", "Green", "Purple", "Orange" };
        SelectedColorFamilies = AllColorFamilies
            .Where(f => selectedNames.Contains(f.Name))
            .ToList();
    }

    /* ===================== DEMOS ===================== */

    private ComponentDemoDefinition CreatingColorsDemo => new()
    {
        Demo = RenderCreatingColors(),
        Code = """
// From HEX
CssColor hex = new CssColor("#3B82F6");

// From RGB integers
CssColor rgb = new CssColor(59, 130, 246);

// From RGBA with alpha (0.0 - 1.0)
CssColor rgba = new CssColor(59, 130, 246, 0.5);

// From CSS variable
CssColor cssVar = new CssColor("var(--palette-primary)", isCssVariable: true);

// From HSL
CssColor hsl = new CssColor(h: 217, s: 0.91, l: 0.60, a: 1.0);
"""
    };

    private ComponentDemoDefinition HexFormatsDemo => new()
    {
        Demo = RenderHexFormats(),
        Code = """
<BUIButton Text="#RGB" BackgroundColor="@(new CssColor("#F00"))" />
<BUIButton Text="#RGBA" BackgroundColor="@(new CssColor("#F008"))" />
<BUIButton Text="#RRGGBB" BackgroundColor="@(new CssColor("#FF5722"))" />
<BUIButton Text="#RRGGBBAA" BackgroundColor="@(new CssColor("#FF572280"))" />
"""
    };

    private ComponentDemoDefinition RgbFormatsDemo => new()
    {
        Demo = RenderRgbFormats(),
        Code = """
// Integer RGB
<BUIButton Text="RGB" BackgroundColor="@(new CssColor(76, 175, 80))" />

// With double alpha (0.0 - 1.0)
<BUIButton Text="RGBA 0.7" BackgroundColor="@(new CssColor(76, 175, 80, 0.7))" />

// With integer alpha (0 - 255)
<BUIButton Text="RGBA 128" BackgroundColor="@(new CssColor(76, 175, 80, 128))" />

// From string
<BUIButton Text="rgb()" BackgroundColor="@(new CssColor("rgb(76, 175, 80)"))" />
<BUIButton Text="rgba()" BackgroundColor="@(new CssColor("rgba(76, 175, 80, 0.5)"))" />
"""
    };

    private ComponentDemoDefinition CssVariablesDemo => new()
    {
        Demo = RenderCssVariables(),
        Code = """
// Theme-aware colors that change with light/dark mode
<BUIButton Text="Primary"
           BackgroundColor="@(new CssColor("var(--palette-primary)", true))" />

<BUIButton Text="Secondary"
           BackgroundColor="@(new CssColor("var(--palette-secondary)", true))" />

// Or use BUIColor.Palette directly
<BUIButton Text="Success" BackgroundColor="BUIColor.Palette.Success" />
<BUIButton Text="Error" BackgroundColor="BUIColor.Palette.Error" />
"""
    };

    private ComponentDemoDefinition AlphaDemo => new()
    {
        Demo = RenderAlpha(),
        Code = """
CssColor baseColor = BUIColor.Blue.Default;

<BUIButton Text="100%" BackgroundColor="@baseColor" />
<BUIButton Text="75%" BackgroundColor="@baseColor.SetAlpha(0.75)" />
<BUIButton Text="50%" BackgroundColor="@baseColor.SetAlpha(0.5)" />
<BUIButton Text="25%" BackgroundColor="@baseColor.SetAlpha(0.25)" />
"""
    };

    private ComponentDemoDefinition LightenDarkenDemo => new()
    {
        Demo = RenderLightenDarken(),
        Code = """
CssColor baseColor = BUIColor.Blue.Default;

// Darken
<BUIButton Text="Darken 0.2" BackgroundColor="@baseColor.ColorDarken(0.2)" />
<BUIButton Text="Darken 0.1" BackgroundColor="@baseColor.ColorDarken(0.1)" />

// Original
<BUIButton Text="Default" BackgroundColor="@baseColor" />

// Lighten
<BUIButton Text="Lighten 0.1" BackgroundColor="@baseColor.ColorLighten(0.1)" />
<BUIButton Text="Lighten 0.2" BackgroundColor="@baseColor.ColorLighten(0.2)" />
"""
    };

    private ComponentDemoDefinition ContrastDemo => new()
    {
        Demo = RenderContrast(),
        Code = """
// GetBestContrast() returns black or white for optimal readability
CssColor yellow = BUIColor.Yellow.Default;
CssColor navy = BUIColor.Navy.Default;

<BUIButton Text="Yellow (dark text)"
           BackgroundColor="@yellow"
           Color="@yellow.GetBestContrast()" />

<BUIButton Text="Navy (light text)"
           BackgroundColor="@navy"
           Color="@navy.GetBestContrast()" />
"""
    };

    private ComponentDemoDefinition PaletteDemo => new()
    {
        Demo = RenderPalette(),
        Code = """
// Theme palette colors adapt to light/dark mode
<BUIButton Text="Primary" BackgroundColor="BUIColor.Palette.Primary"
           Color="BUIColor.Palette.PrimaryContrast" />

<BUIButton Text="Secondary" BackgroundColor="BUIColor.Palette.Secondary"
           Color="BUIColor.Palette.SecondaryContrast" />

<BUIButton Text="Success" BackgroundColor="BUIColor.Palette.Success"
           Color="BUIColor.Palette.SuccessContrast" />

<BUIButton Text="Error" BackgroundColor="BUIColor.Palette.Error"
           Color="BUIColor.Palette.ErrorContrast" />
"""
    };

    private ComponentDemoDefinition PredefinedColorsDemo => new()
    {
        Demo = RenderPredefinedColors(),
        Code = """
// Access colors via BUIColor.[ColorName].[Variant]
<BUIButton Text="Blue" BackgroundColor="BUIColor.Blue.Default" />
<BUIButton Text="Red Darken2" BackgroundColor="BUIColor.Red.Darken2" />
<BUIButton Text="Green Lighten1" BackgroundColor="BUIColor.Green.Lighten1" />
<BUIButton Text="Purple" BackgroundColor="BUIColor.Purple.Default" />
<BUIButton Text="Orange Darken1" BackgroundColor="BUIColor.Orange.Darken1" />
"""
    };

    private ComponentDemoDefinition OutputFormatsDemo => new()
    {
        Demo = RenderOutputFormats(),
        Code = """
CssColor color = new CssColor(59, 130, 246, 0.8);

color.ToString(ColorOutputFormats.Hex);      // "#3b82f6"
color.ToString(ColorOutputFormats.HexA);     // "#3b82f6cc"
color.ToString(ColorOutputFormats.Rgb);      // "rgb(59,130,246)"
color.ToString(ColorOutputFormats.Rgba);     // "rgba(59,130,246,0.8)"
color.ToString(ColorOutputFormats.ColorElements); // "59,130,246"
"""
    };

    /* ===================== RENDER FRAGMENTS ===================== */

    private RenderFragment RenderCreatingColors() => __builder =>
    {
        <div class="demo-row">
            <BUIButton Text="HEX" BackgroundColor="@(new CssColor("#3B82F6"))"
                       Color="@(new CssColor("#3B82F6").GetBestContrast())" />
            <BUIButton Text="RGB" BackgroundColor="@(new CssColor(59, 130, 246, 255))"
                       Color="@(new CssColor(59, 130, 246, 255).GetBestContrast())" />
            <BUIButton Text="RGBA" BackgroundColor="@(new CssColor(59, 130, 246, 0.7))"
                       Color="@(new CssColor(59, 130, 246, 255).GetBestContrast())" />
            <BUIButton Text="CSS Var" BackgroundColor="@(new CssColor("var(--palette-primary)", true))"
                       Color="@(new CssColor("var(--palette-primarycontrast)", true))" />
        </div>
    };

    private RenderFragment RenderHexFormats() => __builder =>
    {
        <div class="demo-row">
            <BUIButton Text="#RGB" BackgroundColor="@(new CssColor("#F00"))"
                       Color="@(new CssColor("#F00").GetBestContrast())" />
            <BUIButton Text="#RGBA" BackgroundColor="@(new CssColor("#F008"))"
                       Color="@(new CssColor("#F00").GetBestContrast())" />
            <BUIButton Text="#RRGGBB" BackgroundColor="@(new CssColor("#FF5722"))"
                       Color="@(new CssColor("#FF5722").GetBestContrast())" />
            <BUIButton Text="#RRGGBBAA" BackgroundColor="@(new CssColor("#FF572280"))"
                       Color="@(new CssColor("#FF5722").GetBestContrast())" />
        </div>
    };

    private RenderFragment RenderRgbFormats() => __builder =>
    {
        <div class="demo-row">
            <BUIButton Text="RGB int" BackgroundColor="@(new CssColor(76, 175, 80, 1))"
                       Color="@(new CssColor(76, 175, 80, 1).GetBestContrast())" />
            <BUIButton Text="RGBA 0.7" BackgroundColor="@(new CssColor(76, 175, 80, 0.7))"
                       Color="@(new CssColor(76, 175, 80, 1).GetBestContrast())" />
            <BUIButton Text="rgb()" BackgroundColor="@(new CssColor("rgb(76, 175, 80)"))"
                       Color="@(new CssColor("rgb(76, 175, 80)").GetBestContrast())" />
            <BUIButton Text="rgba()" BackgroundColor="@(new CssColor("rgba(76, 175, 80, 0.5)"))"
                       Color="@(new CssColor("rgb(76, 175, 80)").GetBestContrast())" />
        </div>
    };

    private RenderFragment RenderCssVariables() => __builder =>
    {
        <div class="demo-row">
            <BUIButton Text="Primary"
                       BackgroundColor="@(new CssColor("var(--palette-primary)", true))"
                       Color="@(new CssColor("var(--palette-primarycontrast)", true))" />
            <BUIButton Text="Secondary"
                       BackgroundColor="@(new CssColor("var(--palette-secondary)", true))"
                       Color="@(new CssColor("var(--palette-secondarycontrast)", true))" />
            <BUIButton Text="Success"
                       BackgroundColor="BUIColor.Palette.Success"
                       Color="BUIColor.Palette.SuccessContrast" />
            <BUIButton Text="Error"
                       BackgroundColor="BUIColor.Palette.Error"
                       Color="BUIColor.Palette.ErrorContrast" />
        </div>
    };

    private RenderFragment RenderAlpha() => __builder =>
    {
        CssColor baseColor = BUIColor.Blue.Default;
        <div class="demo-row">
            <BUIButton Text="100%" BackgroundColor="@baseColor"
                       Color="@baseColor.GetBestContrast()" />
            <BUIButton Text="75%" BackgroundColor="@baseColor.SetAlpha(0.75)"
                       Color="@baseColor.GetBestContrast()" />
            <BUIButton Text="50%" BackgroundColor="@baseColor.SetAlpha(0.5)"
                       Color="@baseColor.GetBestContrast()" />
            <BUIButton Text="25%" BackgroundColor="@baseColor.SetAlpha(0.25)"
                       Color="@baseColor.GetBestContrast()" />
        </div>
    };

    private RenderFragment RenderLightenDarken() => __builder =>
    {
        CssColor baseColor = BUIColor.Blue.Default;
        <div class="demo-row">
            <BUIButton Text="Darken 0.2" BackgroundColor="@baseColor.ColorDarken(0.2)"
                       Color="@baseColor.ColorDarken(0.2).GetBestContrast()" />
            <BUIButton Text="Darken 0.1" BackgroundColor="@baseColor.ColorDarken(0.1)"
                       Color="@baseColor.ColorDarken(0.1).GetBestContrast()" />
            <BUIButton Text="Default" BackgroundColor="@baseColor"
                       Color="@baseColor.GetBestContrast()" />
            <BUIButton Text="Lighten 0.1" BackgroundColor="@baseColor.ColorLighten(0.1)"
                       Color="@baseColor.ColorLighten(0.1).GetBestContrast()" />
            <BUIButton Text="Lighten 0.2" BackgroundColor="@baseColor.ColorLighten(0.2)"
                       Color="@baseColor.ColorLighten(0.2).GetBestContrast()" />
        </div>
    };

    private RenderFragment RenderContrast() => __builder =>
    {
        CssColor yellow = BUIColor.Yellow.Default;
        CssColor navy = BUIColor.Navy.Default;
        CssColor lime = BUIColor.Lime.Default;
        CssColor darkSlateGray = BUIColor.DarkSlateGray.Default;

        <div class="demo-row">
            <BUIButton Text="Yellow" BackgroundColor="@yellow"
                       Color="@yellow.GetBestContrast()" />
            <BUIButton Text="Navy" BackgroundColor="@navy"
                       Color="@navy.GetBestContrast()" />
            <BUIButton Text="Lime" BackgroundColor="@lime"
                       Color="@lime.GetBestContrast()" />
            <BUIButton Text="DarkSlateGray" BackgroundColor="@darkSlateGray"
                       Color="@darkSlateGray.GetBestContrast()" />
        </div>
    };

    private RenderFragment RenderPalette() => __builder =>
    {
        <div class="demo-row">
            <BUIButton Text="Primary" BackgroundColor="BUIColor.Palette.Primary"
                       Color="BUIColor.Palette.PrimaryContrast" />
            <BUIButton Text="Secondary" BackgroundColor="BUIColor.Palette.Secondary"
                       Color="BUIColor.Palette.SecondaryContrast" />
            <BUIButton Text="Success" BackgroundColor="BUIColor.Palette.Success"
                       Color="BUIColor.Palette.SuccessContrast" />
            <BUIButton Text="Warning" BackgroundColor="BUIColor.Palette.Warning"
                       Color="BUIColor.Palette.WarningContrast" />
            <BUIButton Text="Error" BackgroundColor="BUIColor.Palette.Error"
                       Color="BUIColor.Palette.ErrorContrast" />
        </div>
    };

    private RenderFragment RenderPredefinedColors() => __builder =>
    {
        <div class="demo-row">
            <BUIButton Text="Blue" BackgroundColor="BUIColor.Blue.Default"
                       Color="BUIColor.Blue.Default.GetBestContrast()" />
            <BUIButton Text="Red Darken2" BackgroundColor="BUIColor.Red.Darken2"
                       Color="BUIColor.Red.Darken2.GetBestContrast()" />
            <BUIButton Text="Green Lighten1" BackgroundColor="BUIColor.Green.Lighten1"
                       Color="BUIColor.Green.Lighten1.GetBestContrast()" />
            <BUIButton Text="Purple" BackgroundColor="BUIColor.Purple.Default"
                       Color="BUIColor.Purple.Default.GetBestContrast()" />
            <BUIButton Text="Orange Darken1" BackgroundColor="BUIColor.Orange.Darken1"
                       Color="BUIColor.Orange.Darken1.GetBestContrast()" />
        </div>
    };

    private CssColor _outputColor = new CssColor(59, 130, 246, 0.8);

    private RenderFragment RenderOutputFormats() => __builder =>
    {
        <div class="demo-column" style="gap: 0.5rem; font-family: monospace;">
            <div><strong>Hex:</strong> @_outputColor.ToString(ColorOutputFormats.Hex)</div>
            <div><strong>HexA:</strong> @_outputColor.ToString(ColorOutputFormats.HexA)</div>
            <div><strong>Rgb:</strong> @_outputColor.ToString(ColorOutputFormats.Rgb)</div>
            <div><strong>Rgba:</strong> @_outputColor.ToString(ColorOutputFormats.Rgba)</div>
            <div><strong>ColorElements:</strong> @_outputColor.ToString(ColorOutputFormats.ColorElements)</div>
        </div>
    };

    /* ===================== PROPERTIES ===================== */

    private List<PropertyDefinition> ConstructorProperties = new()
    {
        new("CssColor(string)", "-", "-", "From HEX (#RGB, #RRGGBB, #RRGGBBAA) or rgb()/rgba()"),
        new("CssColor(string, bool)", "-", "-", "From CSS variable when second param is true"),
        new("CssColor(int r, int g, int b)", "-", "-", "From RGB integers (0-255)"),
        new("CssColor(int r, int g, int b, double a)", "-", "-", "From RGBA with alpha (0.0-1.0)"),
        new("CssColor(int r, int g, int b, int a)", "-", "-", "From RGBA with alpha (0-255)"),
        new("CssColor(byte r, byte g, byte b, byte a)", "-", "-", "From RGBA bytes"),
        new("CssColor(double h, double s, double l, double a)", "-", "-", "From HSLA values"),
    };

    private List<PropertyDefinition> MethodProperties = new()
    {
        new("SetAlpha(double)", "CssColor", "-", "Returns new color with specified alpha (0.0-1.0)"),
        new("SetAlpha(int)", "CssColor", "-", "Returns new color with specified alpha (0-255)"),
        new("ColorLighten(double)", "CssColor", "-", "Returns lighter color by amount"),
        new("ColorDarken(double)", "CssColor", "-", "Returns darker color by amount"),
        new("ChangeLightness(double)", "CssColor", "-", "Modify luminosity (+/-)"),
        new("GetBestContrast()", "CssColor", "-", "Returns black or white for best readability"),
        new("GetRelativeLuminance()", "double", "-", "Returns WCAG luminance (0-1)"),
        new("ToString(ColorOutputFormats)", "string", "-", "Convert to specified format"),
    };

    private List<PropertyDefinition> FormatProperties = new()
    {
        new("Hex", "ColorOutputFormats", "-", "#rrggbb"),
        new("HexA", "ColorOutputFormats", "-", "#rrggbbaa"),
        new("Rgb", "ColorOutputFormats", "-", "rgb(r,g,b)"),
        new("Rgba", "ColorOutputFormats", "-", "rgba(r,g,b,a)"),
        new("ColorElements", "ColorOutputFormats", "-", "r,g,b"),
    };
}