@page "/theming/colors"

@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Core.Css
@using System.Reflection

<PageTitle>Colors - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>Colors</h1>

    <p class="doc-intro">
        <strong>CssColor</strong> is a comprehensive color system that supports multiple input formats
        (HEX, RGB, RGBA, HSL), CSS variables, automatic contrast calculation, and color manipulation.
        The <strong>BUIColor</strong> class provides a full palette of predefined colors with
        Lighten/Darken variants.
    </p>

    <!-- CREATING COLORS -->
    <section class="doc-section">
        <h2>Creating colors</h2>
        <p>CssColor accepts multiple input formats:</p>
        <ComponentDemo Definition="@CreatingColorsDemo" />
    </section>

    <!-- HEX FORMATS -->
    <section class="doc-section">
        <h2>HEX formats</h2>
        <p>Supports 3, 4, 6, and 8 character hex codes:</p>
        <ComponentDemo Definition="@HexFormatsDemo" />
    </section>

    <!-- RGB/RGBA -->
    <section class="doc-section">
        <h2>RGB and RGBA</h2>
        <ComponentDemo Definition="@RgbFormatsDemo" />
    </section>

    <!-- CSS VARIABLES -->
    <section class="doc-section">
        <h2>CSS variables</h2>
        <p>Use theme-aware CSS variables that adapt to light/dark modes:</p>
        <ComponentDemo Definition="@CssVariablesDemo" />
    </section>

    <!-- ALPHA MANIPULATION -->
    <section class="doc-section">
        <h2>Alpha manipulation</h2>
        <p>Modify transparency using <code>SetAlpha()</code>:</p>
        <ComponentDemo Definition="@AlphaDemo" />
    </section>

    <!-- LIGHTEN/DARKEN -->
    <section class="doc-section">
        <h2>Lighten and Darken</h2>
        <p>Modify color luminosity:</p>
        <ComponentDemo Definition="@LightenDarkenDemo" />
    </section>

    <!-- BEST CONTRAST -->
    <section class="doc-section">
        <h2>Automatic contrast</h2>
        <p><code>GetBestContrast()</code> returns black or white based on WCAG luminance calculation:</p>
        <ComponentDemo Definition="@ContrastDemo" />
    </section>

    <!-- THEME PALETTE -->
    <section class="doc-section">
        <h2>Theme palette</h2>
        <p>Access theme colors via <code>BUIColor.Palette</code>. These adapt to the current theme:</p>
        <ComponentDemo Definition="@PaletteDemo" />

        <div class="palette-grid">
            @foreach (KeyValuePair<string, CssColor> color in PaletteColors)
            {
                <div class="palette-swatch" style="background: @color.Value; color: @color.Value.GetBestContrast()">
                    <span class="palette-name">@color.Key</span>
                    <code>BUIColor.Palette.@color.Key</code>
                </div>
            }
        </div>
    </section>

    <!-- PREDEFINED COLORS -->
    <section class="doc-section">
        <h2>Predefined colors</h2>
        <p>Access any color with variants via <code>BUIColor.[ColorName].[Variant]</code>:</p>
        <ComponentDemo Definition="@PredefinedColorsDemo" />
    </section>

    <!-- COLOR VARIANTS -->
    <section class="doc-section">
        <h2>Color variants</h2>
        <p>Each color includes Default, Lighten1-3, and Darken1-3 variants:</p>

        <div class="color-families">
            @foreach (ColorFamily family in SelectedColorFamilies)
            {
                <div class="color-family">
                    <h4>@family.Name</h4>
                    <div class="color-variants">
                        @foreach ((string Name, CssColor Value) variant in family.Variants)
                        {
                            <div class="color-variant"
                                 style="background: @variant.Value; color: @variant.Value.GetBestContrast()">
                                <span>@variant.Name</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- OUTPUT FORMATS -->
    <section class="doc-section">
        <h2>Output formats</h2>
        <p>Convert colors to different string formats:</p>
        <ComponentDemo Definition="@OutputFormatsDemo" />
    </section>

    <!-- FULL COLOR REFERENCE -->
    <section class="doc-section">
        <h2>Full color reference</h2>
        <p>All available colors in BUIColor:</p>

        <div class="color-reference">
            @foreach (ColorFamily family in AllColorFamilies)
            {
                <details class="color-family-details">
                    <summary>
                        <span class="color-preview" style="background: @family.Variants.First(v => v.Name == "Default").Value"></span>
                        @family.Name
                    </summary>
                    <div class="color-variants-list">
                        @foreach ((string Name, CssColor Value) variant in family.Variants)
                        {
                            <div class="color-variant-item">
                                <span class="color-swatch" style="background: @variant.Value"></span>
                                <code>BUIColor.@family.Name.@variant.Name</code>
                                <span class="color-value">@variant.Value.ToString(ColorOutputFormats.Hex)</span>
                            </div>
                        }
                    </div>
                </details>
            }
        </div>
    </section>

    <!-- API REFERENCE -->
    <section class="doc-section">
        <h2>CssColor constructors</h2>
        <PropertyTable Properties="@ConstructorProperties" />
    </section>

    <section class="doc-section">
        <h2>CssColor methods</h2>
        <PropertyTable Properties="@MethodProperties" />
    </section>

    <section class="doc-section">
        <h2>Output formats</h2>
        <PropertyTable Properties="@FormatProperties" />
    </section>
</div>

<style>
    .palette-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1rem;
        margin-top: 1rem;
    }

    .palette-swatch {
        padding: 1rem;
        border-radius: 8px;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .palette-name {
        font-weight: 600;
    }

    .palette-swatch code {
        font-size: 0.75rem;
        opacity: 0.8;
    }

    .color-families {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        margin-top: 1rem;
    }

    .color-family h4 {
        margin-bottom: 0.5rem;
    }

    .color-variants {
        display: flex;
        gap: 0.25rem;
        flex-wrap: wrap;
    }

    .color-variant {
        padding: 0.5rem 0.75rem;
        border-radius: 4px;
        font-size: 0.75rem;
        min-width: 80px;
        text-align: center;
    }

    .color-reference {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-top: 1rem;
    }

    .color-family-details {
        border: 1px solid rgba(128, 128, 128, 0.2);
        border-radius: 8px;
        overflow: hidden;
    }

        .color-family-details summary {
            padding: 0.75rem 1rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-weight: 500;
        }

            .color-family-details summary:hover {
                background: rgba(128, 128, 128, 0.1);
            }

    .color-preview {
        width: 24px;
        height: 24px;
        border-radius: 4px;
        flex-shrink: 0;
    }

    .color-variants-list {
        padding: 0.5rem 1rem 1rem;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 0.5rem;
    }

    .color-variant-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0;
    }

