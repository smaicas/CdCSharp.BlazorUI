@page "/features/density"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared

<PageTitle>Density - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>Density System</h1>
    <p class="doc-intro">
        The density system allows you to adjust the spacing and size of components to match different 
        use cases and user preferences. Choose from Comfortable, Standard, or Compact densities.
    </p>

    <div class="doc-section">
        <h2>Density Levels</h2>
        
        <div class="density-comparison">
            <div class="density-example">
                <h4>Comfortable</h4>
                <p>More spacing, touch-friendly, better for mobile or accessibility.</p>
                <div class="density-demo">
                    <BUIButton Text="Comfortable Button" Density="DensityEnum.Comfortable" />
                    <div class="density-card ui-density-comfortable">
                        <h5>Card Content</h5>
                        <p>This card has comfortable spacing.</p>
                    </div>
                </div>
            </div>
            
            <div class="density-example">
                <h4>Standard</h4>
                <p>Default spacing, balanced for most use cases.</p>
                <div class="density-demo">
                    <BUIButton Text="Standard Button" Density="DensityEnum.Standard" />
                    <div class="density-card ui-density-standard">
                        <h5>Card Content</h5>
                        <p>This card has standard spacing.</p>
                    </div>
                </div>
            </div>
            
            <div class="density-example">
                <h4>Compact</h4>
                <p>Less spacing, more content visible, good for data-dense interfaces.</p>
                <div class="density-demo">
                    <BUIButton Text="Compact Button" Density="DensityEnum.Compact" />
                    <div class="density-card ui-density-compact">
                        <h5>Card Content</h5>
                        <p>This card has compact spacing.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="doc-section">
        <h2>Component Comparison</h2>
        <ComponentDemo Code="@componentComparisonCode">
            <Demo>
                <div class="component-grid">
                    <div>
                        <h5>Comfortable</h5>
                        <BUIButton Text="Action" Density="DensityEnum.Comfortable" />
                        <BUIButton Text="Action" Density="DensityEnum.Comfortable" LeadingIcon="@BUIIcons.MaterialIconsRound.i_save" />
                    </div>
                    <div>
                        <h5>Standard</h5>
                        <BUIButton Text="Action" Density="DensityEnum.Standard" />
                        <BUIButton Text="Action" Density="DensityEnum.Standard" LeadingIcon="@BUIIcons.MaterialIconsRound.i_save" />
                    </div>
                    <div>
                        <h5>Compact</h5>
                        <BUIButton Text="Action" Density="DensityEnum.Compact" />
                        <BUIButton Text="Action" Density="DensityEnum.Compact" LeadingIcon="@BUIIcons.MaterialIconsRound.i_save" />
                    </div>
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Use Case Guidelines</h2>
        
        <div class="use-cases">
            <div class="use-case">
                <h4>When to Use Comfortable</h4>
                <ul>
                    <li>Touch interfaces (tablets, mobile)</li>
                    <li>Accessibility-focused applications</li>
                    <li>Onboarding or learning interfaces</li>
                    <li>Content with fewer interactive elements</li>
                </ul>
            </div>
            
            <div class="use-case">
                <h4>When to Use Standard</h4>
                <ul>
                    <li>General desktop applications</li>
                    <li>Mixed content types</li>
                    <li>Default choice for most scenarios</li>
                    <li>Responsive designs that adapt</li>
                </ul>
            </div>
            
            <div class="use-case">
                <h4>When to Use Compact</h4>
                <ul>
                    <li>Data tables and grids</li>
                    <li>Professional/enterprise applications</li>
                    <li>Information-dense interfaces</li>
                    <li>Power user interfaces</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="doc-section">
        <h2>Global Density Settings</h2>
        <p>You can set a default density for your entire application:</p>
        
        <CodeBlock Code="@globalDensityCode" Language="csharp" Title="Global Configuration" />
    </div>

    <div class="doc-section">
        <h2>CSS Classes</h2>
        <p>Apply density directly to any element using CSS classes:</p>
        
        <CodeBlock Code="@cssClassesCode" Language="html" Title="Density Classes" />
    </div>

    <div class="doc-section">
        <h2>Responsive Density</h2>
        <p>Adjust density based on screen size for optimal user experience:</p>
        
        <CodeBlock Code="@responsiveDensityCode" Language="css" Title="Responsive Density" />
    </div>

    <div class="doc-section">
        <h2>Combining with Other Features</h2>
        <ComponentDemo Code="@combinedFeaturesCode">
            <Demo>
                <div class="feature-combination">
                    <BUIButton Text="Compact + Elevated" 
                             Density="DensityEnum.Compact" 
                             Elevation="4" />
                    
                    <BUIButton Text="Comfortable + Transition" 
                             Density="DensityEnum.Comfortable" 
                             Transitions="@BUITransitionPresets.HoverScale" />
                    
                    <BUIButton Text="Compact + Full Width" 
                             Density="DensityEnum.Compact" 
                             FullWidth="true" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>
</div>

@code {
    private string componentComparisonCode = @"<!-- Different density levels -->
<BUIButton Text=""Action"" Density=""DensityEnum.Comfortable"" />
<BUIButton Text=""Action"" Density=""DensityEnum.Standard"" />
<BUIButton Text=""Action"" Density=""DensityEnum.Compact"" />";

    private string globalDensityCode = @"// In your App.razor or MainLayout
<CascadingValue Value=""@DensityEnum.Compact"" Name=""DefaultDensity"">
    @Body
</CascadingValue>

// Or configure in services
builder.Services.AddBlazorUI(options =>
{
    options.DefaultDensity = DensityEnum.Compact;
});";

    private string cssClassesCode = @"<!-- Apply density with CSS classes -->
<div class=""ui-density-comfortable"">
    More spacious content
</div>

<div class=""ui-density-standard"">
    Default spacing
</div>

<div class=""ui-density-compact"">
    Condensed content
</div>";

    private string responsiveDensityCode = @"/* Mobile: Use comfortable density */
@media (max-width: 768px) {
    .responsive-component {
        @apply ui-density-comfortable;
    }
}

/* Tablet: Use standard density */
@media (min-width: 769px) and (max-width: 1024px) {
    .responsive-component {
        @apply ui-density-standard;
    }
}

/* Desktop: Use compact density */
@media (min-width: 1025px) {
    .responsive-component {
        @apply ui-density-compact;
    }
}";

    private string combinedFeaturesCode = @"<BUIButton Text=""Compact + Elevated"" 
         Density=""DensityEnum.Compact"" 
         Elevation=""4"" />

<BUIButton Text=""Comfortable + Transition"" 
         Density=""DensityEnum.Comfortable"" 
         Transitions=""@BUITransitionPresets.HoverScale"" />

<BUIButton Text=""Compact + Full Width"" 
         Density=""DensityEnum.Compact"" 
         FullWidth=""true"" />";
}