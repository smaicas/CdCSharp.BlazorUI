@page "/features/borders"

@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Core.Abstractions.Behaviors.Design

<PageTitle>Borders - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>Borders</h1>

    <p class="doc-intro">
        The border system provides a flexible way to add borders to components with support for
        different styles, widths, colors, and corner radius.
    </p>

    <!-- PRESETS -->
    <section class="doc-section">
        <h2>Border presets</h2>
        <ComponentDemo Definition="@BorderPresetsDemo" />
    </section>

    <!-- RADIUS -->
    <section class="doc-section">
        <h2>Border radius</h2>
        <ComponentDemo Definition="@BorderRadiusDemo" />
    </section>

    <!-- STYLES -->
    <section class="doc-section">
        <h2>Border styles</h2>
        <ComponentDemo Definition="@BorderStylesDemo" />
    </section>

    <!-- INDIVIDUAL -->
    <section class="doc-section">
        <h2>Individual borders</h2>
        <ComponentDemo Definition="@IndividualBordersDemo" />
    </section>

    <!-- CUSTOM -->
    <section class="doc-section">
        <h2>Custom borders</h2>
        <ComponentDemo Definition="@CustomBordersDemo" />
    </section>

    <!-- PROPERTIES -->
    <section class="doc-section">
        <h2>BorderStyle properties</h2>
        <PropertyTable Properties="@Properties" />
    </section>
</div>

@code {
    /* ===================== CUSTOM BORDERS ===================== */

    private BorderStyle _customBorder =
    BorderStyle.Create()
        .All("3px", BorderStyleType.Solid, BUIColor.Purple.Default);


    private BorderStyle _customBorderWithRadius =
    BorderStyle.Create()
        .All("2px", BorderStyleType.Solid, BUIColor.Blue.Default)
        .Radius(16);

    /* ===================== DEMOS ===================== */

    private ComponentDemoDefinition BorderPresetsDemo => new()
    {
        Demo = RenderBorderPresets(),
        Code = """
<BUIButton Text="Default" Border="@BUIBorderPresets.Default" />
<BUIButton Text="Subtle" Border="@BUIBorderPresets.Subtle" />
<BUIButton Text="Strong" Border="@BUIBorderPresets.Strong" />
<BUIButton Text="Primary" Border="@BUIBorderPresets.Primary" />
<BUIButton Text="Error" Border="@BUIBorderPresets.Error" />
<BUIButton Text="Success" Border="@BUIBorderPresets.Success" />
"""
    };

    private ComponentDemoDefinition BorderRadiusDemo => new()
    {
        Demo = RenderBorderRadius(),
        Code = """
<BUIButton Text="Square" Border="@BUIBorderPresets.Default" />
<BUIButton Text="Rounded" Border="@BUIBorderPresets.Rounded" />
<BUIButton Text="Large Rounded" Border="@BUIBorderPresets.RoundedLarge" />
<BUIButton Text="Pill" Border="@BUIBorderPresets.Pill" />
"""
    };

    private ComponentDemoDefinition BorderStylesDemo => new()
    {
        Demo = RenderBorderStyles(),
        Code = """
<BUIButton Text="Solid" Border="@BUIBorderPresets.Default" />
<BUIButton Text="Dashed" Border="@BUIBorderPresets.Dashed" />
<BUIButton Text="Dotted" Border="@BUIBorderPresets.Dotted" />
<BUIButton Text="Double" Border="@BUIBorderPresets.Double" />
"""
    };

    private ComponentDemoDefinition IndividualBordersDemo => new()
    {
        Demo = RenderIndividualBorders(),
        Code = """
<BUIButton Text="Top Only" BorderTop="@BUIBorderPresets.Primary" />
<BUIButton Text="Bottom Only" BorderBottom="@BUIBorderPresets.Primary" />
<BUIButton Text="Left & Right"
           BorderLeft="@BUIBorderPresets.Primary"
           BorderRight="@BUIBorderPresets.Primary" />
"""
    };

    private ComponentDemoDefinition CustomBordersDemo => new()
    {
        Demo = RenderCustomBorders(),
        Code = """
// Custom border
private BorderStyle _customBorder =
    new("3px", BorderStyleType.Solid, BUIColor.Purple.Default);

// Custom border with radius
private BorderStyle _customBorderWithRadius =
    new BorderStyle("2px", BorderStyleType.Solid, BUIColor.Blue.Default)
        .WithRadius(16);

<BUIButton Text="Custom Style" Border="@_customBorder" />
<BUIButton Text="Custom with Radius" Border="@_customBorderWithRadius" />
"""
    };

    /* ===================== RENDER FRAGMENTS ===================== */

    private RenderFragment RenderBorderPresets() => __builder =>
    {
        <div class="border-examples">
            <BUIButton Text="Default" Border="@BUIBorderPresets.Default" />
            <BUIButton Text="Subtle" Border="@BUIBorderPresets.Subtle" />
            <BUIButton Text="Strong" Border="@BUIBorderPresets.Strong" />
            <BUIButton Text="Primary" Border="@BUIBorderPresets.Primary" />
            <BUIButton Text="Error" Border="@BUIBorderPresets.Error" />
            <BUIButton Text="Success" Border="@BUIBorderPresets.Success" />
        </div>
        ;
    };

    private RenderFragment RenderBorderRadius() => __builder =>
    {
        <div class="border-examples">
            <BUIButton Text="Square" Border="@BUIBorderPresets.Default" />
            <BUIButton Text="Rounded" Border="@BUIBorderPresets.Rounded" />
            <BUIButton Text="Large Rounded" Border="@BUIBorderPresets.RoundedLarge" />
            <BUIButton Text="Pill" Border="@BUIBorderPresets.Pill" />
        </div>
        ;
    };

    private RenderFragment RenderBorderStyles() => __builder =>
    {
        <div class="border-examples">
            <BUIButton Text="Solid" Border="@BUIBorderPresets.Default" />
            <BUIButton Text="Dashed" Border="@BUIBorderPresets.Dashed" />
            <BUIButton Text="Dotted" Border="@BUIBorderPresets.Dotted" />
            <BUIButton Text="Double" Border="@BUIBorderPresets.Double" />
        </div>
        ;
    };

    private RenderFragment RenderIndividualBorders() => __builder =>
    {
        <div class="border-examples">
            <BUIButton Text="Top Only" BorderTop="@BUIBorderPresets.Primary" />
            <BUIButton Text="Bottom Only" BorderBottom="@BUIBorderPresets.Primary" />
            <BUIButton Text="Left & Right"
                       BorderLeft="@BUIBorderPresets.Primary"
                       BorderRight="@BUIBorderPresets.Primary" />
        </div>
        ;
    };

    private RenderFragment RenderCustomBorders() => __builder =>
    {
        <div class="border-examples">
            <BUIButton Text="Custom Style" Border="@_customBorder" />
            <BUIButton Text="Custom with Radius" Border="@_customBorderWithRadius" />
        </div>
        ;
    };

    /* ===================== PROPERTIES ===================== */

    private List<PropertyDefinition> Properties = new()
    {
        new("Width", "string", "-", "Border width (e.g. 1px, 2px)"),
        new("Style", "BorderStyleType", "-", "Line style (Solid, Dashed, Dotted, etc.)"),
        new("Color", "CssColor", "-", "Border color"),
        new("Radius", "int?", "null", "Corner radius in pixels"),
    };
}
