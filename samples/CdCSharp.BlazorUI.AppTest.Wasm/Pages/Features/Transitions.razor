    private ComponentDemoDefinition CustomBuilderDemo => new()
    {
        Demo = RenderCustomBuilder(),
        Code = """
@code {
    private BUITransitions CustomTransition => BUITransitionPresets.Create()
        .OnHover().Scale(1.08f, options =>
        {
            options.Duration = TimeSpan.FromMilliseconds(250);
            options.Easing = easing => easing.CubicBezier()
                .WithControlPoints(0.34, 1.56, 0.64, 1).Build();
        })
        .And()
        .OnHover().Shadow("0 15px 35px rgba(0,0,0,0.25)")
        .And()
        .OnHover().Glow("rgba(99, 102, 241, 0.5)")
        .And()
        .OnActive().Scale(0.96f, options =>
        {
            options.Duration = TimeSpan.FromMilliseconds(80);
        })
        .And()
        .OnFocus().Shadow("0 0 0 4px rgba(99, 102, 241, 0.3)")
        .Build();
}

<BUIButton Text="Fully Custom" Transitions="CustomTransition" />
"""
    };

