@page "/features/transitions"

@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Core.Abstractions.Behaviors.Transitions
@using CdCSharp.BlazorUI.Core.Css

<PageTitle>Transitions - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>Transitions</h1>

    <p class="doc-intro">
        <strong>BUITransitions</strong> is a powerful, fluent API for defining visual transitions
        on components. It supports multiple triggers (hover, focus, active, disabled),
        various effects (scale, shadow, glow, blur, etc.), custom easings, and can be combined
        to create sophisticated animations.
    </p>

    <!-- BASIC PRESETS -->
    <section class="doc-section">
        <h2>Basic presets</h2>
        <p>Use <code>BUITransitionPresets</code> for common transition patterns.</p>
        <ComponentDemo Definition="@BasicPresetsDemo" />
    </section>

    <!-- SCALE -->
    <section class="doc-section">
        <h2>Scale</h2>
        <ComponentDemo Definition="@ScaleDemo" />
    </section>

    <!-- SHADOW -->
    <section class="doc-section">
        <h2>Shadow</h2>
        <ComponentDemo Definition="@ShadowDemo" />
    </section>

    <!-- LIFT -->
    <section class="doc-section">
        <h2>Lift (translate + shadow)</h2>
        <ComponentDemo Definition="@LiftDemo" />
    </section>

    <!-- GLOW -->
    <section class="doc-section">
        <h2>Glow</h2>
        <ComponentDemo Definition="@GlowDemo" />
    </section>

    <!-- FADE -->
    <section class="doc-section">
        <h2>Fade</h2>
        <ComponentDemo Definition="@FadeDemo" />
    </section>

    <!-- ROTATE -->
    <section class="doc-section">
        <h2>Rotate</h2>
        <ComponentDemo Definition="@RotateDemo" />
    </section>

    <!-- BLUR -->
    <section class="doc-section">
        <h2>Blur effects</h2>
        <ComponentDemo Definition="@BlurDemo" />
    </section>

    <!-- MULTIPLE TRIGGERS -->
    <section class="doc-section">
        <h2>Multiple triggers</h2>
        <p>Combine different effects for hover, focus, and active states.</p>
        <ComponentDemo Definition="@MultipleTriggersDemo" />
    </section>

    <!-- COMBINED EFFECTS -->
    <section class="doc-section">
        <h2>Combined effects</h2>
        <p>Chain multiple effects on the same trigger using <code>.And()</code>.</p>
        <ComponentDemo Definition="@CombinedEffectsDemo" />
    </section>

    <!-- CUSTOM DURATION -->
    <section class="doc-section">
        <h2>Custom duration</h2>
        <ComponentDemo Definition="@CustomDurationDemo" />
    </section>

    <!-- CUSTOM EASING -->
    <section class="doc-section">
        <h2>Custom easing</h2>
        <p>Use predefined easings or create custom cubic-bezier curves.</p>
        <ComponentDemo Definition="@CustomEasingDemo" />
    </section>

    <!-- MATERIAL DESIGN -->
    <section class="doc-section">
        <h2>Material Design easings</h2>
        <ComponentDemo Definition="@MaterialEasingDemo" />
    </section>

    <!-- ELASTIC & BOUNCE -->
    <section class="doc-section">
        <h2>Elastic & Bounce</h2>
        <ComponentDemo Definition="@ElasticBounceDemo" />
    </section>

    <!-- PREMIUM PRESETS -->
    <section class="doc-section">
        <h2>Premium presets</h2>
        <p>Complex, polished transitions for production use.</p>
        <ComponentDemo Definition="@PremiumPresetsDemo" />
    </section>

    <!-- MODERN EFFECTS -->
    <section class="doc-section">
        <h2>Modern effects</h2>
        <ComponentDemo Definition="@ModernEffectsDemo" />
    </section>

    <!-- DISABLED STATE -->
    <section class="doc-section">
        <h2>Disabled state transitions</h2>
        <ComponentDemo Definition="@DisabledStateDemo" />
    </section>

    <!-- CUSTOM BUILDER -->
    <section class="doc-section">
        <h2>Custom builder</h2>
        <p>Create fully custom transitions with the fluent API.</p>
        <ComponentDemo Definition="@CustomBuilderDemo" />
    </section>

    <!-- API REFERENCE -->
    <section class="doc-section">
        <h2>Transition presets</h2>
        <PropertyTable Properties="@PresetProperties" />
    </section>

    <section class="doc-section">
        <h2>Builder methods</h2>
        <PropertyTable Properties="@BuilderMethods" />
    </section>

    <section class="doc-section">
        <h2>Easing presets</h2>
        <PropertyTable Properties="@EasingPresets" />
    </section>
</div>

