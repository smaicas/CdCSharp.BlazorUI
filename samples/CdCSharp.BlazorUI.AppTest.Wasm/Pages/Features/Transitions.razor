@page "/features/transitions"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Core.Abstractions.Behaviors.Transitions

<PageTitle>Transitions - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>Transitions</h1>
    <p class="doc-intro">
        The transitions system provides smooth animations for component interactions,
        with presets for common effects and a builder API for custom animations.
    </p>

    <div class="doc-section">
        <h2>Transition Presets</h2>
        <p>Ready-to-use transition effects:</p>

        <div class="transition-grid">
            <div class="transition-demo">
                <h4>Hover Scale</h4>
                <BUIButton Text="Hover Me" Transitions="@BUITransitionPresets.HoverScale" />
            </div>

            <div class="transition-demo">
                <h4>Hover Lift</h4>
                <BUIButton Text="Hover Me" Transitions="@BUITransitionPresets.HoverLift" Elevation="2" />
            </div>

            <div class="transition-demo">
                <h4>Hover Glow</h4>
                <BUIButton Text="Hover Me" Transitions="@BUITransitionPresets.HoverGlow" />
            </div>

            <div class="transition-demo">
                <h4>Focus Ring</h4>
                <BUIButton Text="Tab to Focus" Transitions="@BUITransitionPresets.FocusRing" />
            </div>
        </div>
    </div>

    <div class="doc-section">
        <h2>Material Design Effects</h2>

        <ComponentDemo Code="@materialEffectsCode">
            <Demo>
                <div class="transition-grid">
                    <BUIButton Text="Material Button" Transitions="@BUITransitionPresets.MaterialButton" />
                    <BUIButton Text="Card Hover" Transitions="@BUITransitionPresets.CardHover" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Custom Transitions</h2>
        <p>Create custom transitions using the builder API:</p>

        <ComponentDemo Code="@customTransitionCode">
            <Demo>
                <BUIButton Text="Custom Effect" Transitions="@_customTransition" />
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Combined Effects</h2>

        <ComponentDemo Code="@combinedEffectsCode">
            <Demo>
                <div class="transition-grid">
                    <BUIButton Text="Interactive" Transitions="@BUITransitionPresets.Interactive" />
                    <BUIButton Text="Premium" Transitions="@BUITransitionPresets.PremiumButton" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Available Presets</h2>

        <div class="preset-list">
            <div class="preset-item">
                <code>HoverScale</code>
                <p>Scales element on hover</p>
            </div>
            <div class="preset-item">
                <code>HoverLift</code>
                <p>Lifts element with shadow</p>
            </div>
            <div class="preset-item">
                <code>HoverGlow</code>
                <p>Adds glow effect</p>
            </div>
            <div class="preset-item">
                <code>HoverFade</code>
                <p>Fades opacity on hover</p>
            </div>
            <div class="preset-item">
                <code>FocusRing</code>
                <p>Shows focus ring</p>
            </div>
            <div class="preset-item">
                <code>MaterialButton</code>
                <p>Material Design button effect</p>
            </div>
            <div class="preset-item">
                <code>CardHover</code>
                <p>Card elevation on hover</p>
            </div>
            <div class="preset-item">
                <code>Interactive</code>
                <p>Combined hover, focus, and active states</p>
            </div>
        </div>
    </div>
</div>

@code {
    private BUITransitions _customTransition = BUITransitionPresets.Create()
        .OnHover()
            .Scale(1.1f, options =>
            {
                options.Duration = TimeSpan.FromMilliseconds(400);
                options.Easing = easing => easing.CubicBezier().MaterialStandard();
            })
            .Shadow("0 10px 20px rgba(139, 92, 246, 0.3)")
        .Build();

    private string materialEffectsCode = @"<BUIButton Text=""Material Button"" Transitions=""@BUITransitionPresets.MaterialButton"" />
<BUIButton Text=""Card Hover"" Transitions=""@BUITransitionPresets.CardHover"" />";

    private string customTransitionCode = @"private BUITransitions _customTransition = BUITransitionPresets.Create()
    .OnHover()
        .Scale(1.1f, options => {
            options.Duration = TimeSpan.FromMilliseconds(400);
            options.Easing = easing => easing.CubicBezier().MaterialStandard();
        })
        .Shadow(""0 10px 20px rgba(139, 92, 246, 0.3)"")
    .Build();

<BUIButton Text=""Custom Effect"" Transitions=""@_customTransition"" />";

    private string combinedEffectsCode = @"<BUIButton Text=""Interactive"" Transitions=""@BUITransitionPresets.Interactive"" />
<BUIButton Text=""Premium"" Transitions=""@BUITransitionPresets.PremiumButton"" />";
}
