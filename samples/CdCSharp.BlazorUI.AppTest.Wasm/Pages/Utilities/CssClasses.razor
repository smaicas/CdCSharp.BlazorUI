@page "/utilities/css-classes"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared

<PageTitle>CSS Classes - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>CSS Classes Reference</h1>
    <p class="doc-intro">
        A comprehensive list of all CSS utility classes available in CdCSharp.BlazorUI. 
        These classes can be applied directly to elements for quick styling.
    </p>

    <div class="doc-section">
        <h2>Size Classes</h2>
        <div class="class-grid">
            <div class="class-item">
                <code>.bui-size-small</code>
                <p>Small size variant</p>
                <div class="example ui-size-small">Small Text</div>
            </div>
            
            <div class="class-item">
                <code>.bui-size-medium</code>
                <p>Medium size variant (default)</p>
                <div class="example ui-size-medium">Medium Text</div>
            </div>
            
            <div class="class-item">
                <code>.bui-size-large</code>
                <p>Large size variant</p>
                <div class="example ui-size-large">Large Text</div>
            </div>
        </div>
    </div>

    <div class="doc-section">
        <h2>Density Classes</h2>
        <div class="class-grid">
            <div class="class-item">
                <code>.bui-density-comfortable</code>
                <p>Extra spacing for touch interfaces</p>
                <div class="example-box ui-density-comfortable">Comfortable</div>
            </div>
            
            <div class="class-item">
                <code>.bui-density-standard</code>
                <p>Standard spacing (default)</p>
                <div class="example-box ui-density-standard">Standard</div>
            </div>
            
            <div class="class-item">
                <code>.bui-density-compact</code>
                <p>Reduced spacing for dense layouts</p>
                <div class="example-box ui-density-compact">Compact</div>
            </div>
        </div>
    </div>

    <div class="doc-section">
        <h2>Elevation Classes</h2>
        <p>Classes from <code>.bui-elevation-0</code> to <code>.bui-elevation-24</code></p>
        
        <div class="elevation-examples">
            @for (int i = 0; i <= 24; i += 4)
            {
                <div class="elevation-example ui-elevation-@i">
                    <code>.bui-elevation-@i</code>
                </div>
            }
        </div>
    </div>

    <div class="doc-section">
        <h2>Transition Classes</h2>
        
        <h3>Base Classes</h3>
        <div class="class-list">
            <div class="class-entry">
                <code>.bui-has-transitions</code>
                <p>Enables transitions on an element</p>
            </div>
        </div>

        <h3>Hover Transitions</h3>
        <div class="transition-grid">
            <div class="transition-item ui-has-transitions ui-transition-hover-scale">
                <code>.bui-transition-hover-scale</code>
                <p>Scale on hover</p>
            </div>
            
            <div class="transition-item ui-has-transitions ui-transition-hover-rotate">
                <code>.bui-transition-hover-rotate</code>
                <p>Rotate on hover</p>
            </div>
            
            <div class="transition-item ui-has-transitions ui-transition-hover-fade">
                <code>.bui-transition-hover-fade</code>
                <p>Fade on hover</p>
            </div>
            
            <div class="transition-item ui-has-transitions ui-transition-hover-shadow">
                <code>.bui-transition-hover-shadow</code>
                <p>Shadow on hover</p>
            </div>
        </div>

        <h3>Combined Effects</h3>
        <div class="transition-grid">
            <div class="transition-item ui-has-transitions ui-transition-hover-lift">
                <code>.bui-transition-hover-lift</code>
                <p>Lift effect (translate + shadow)</p>
            </div>
            
            <div class="transition-item ui-has-transitions ui-transition-hover-glow">
                <code>.bui-transition-hover-glow</code>
                <p>Glow effect (scale + shadow)</p>
            </div>
        </div>
    </div>

    <div class="doc-section">
        <h2>State Classes</h2>
        <div class="class-list">
            <div class="class-entry">
                <code>.bui-full-width</code>
                <p>Makes element take full width of container</p>
            </div>
            
            <div class="class-entry">
                <code>.bui-loading</code>
                <p>Indicates loading state</p>
            </div>
            
            <div class="class-entry">
                <code>.bui-has-ripple</code>
                <p>Enables ripple effect on click</p>
            </div>
        </div>
    </div>

    <div class="doc-section">
        <h2>Component-Specific Classes</h2>
        
        <h3>Button Classes</h3>
        <div class="class-list">
            <div class="class-entry">
                <code>.bui-button</code>
                <p>Base button class</p>
            </div>
            
            <div class="class-entry">
                <code>.bui-button__text</code>
                <p>Button text element</p>
            </div>
            
            <div class="class-entry">
                <code>.bui-button--default</code>
                <p>Default button variant</p>
            </div>
        </div>

        <h3>Icon Classes</h3>
        <div class="class-list">
            <div class="class-entry">
                <code>.bui-svg-icon</code>
                <p>SVG icon wrapper</p>
            </div>
        </div>

        <h3>Theme Switch Classes</h3>
        <div class="class-list">
            <div class="class-entry">
                <code>.bui-theme-switch</code>
                <p>Theme switch component</p>
            </div>
            
            <div class="class-entry">
                <code>.bui-theme-switch--default</code>
                <p>Default variant</p>
            </div>
            
            <div class="class-entry">
                <code>.bui-theme-switch--sunmoon</code>
                <p>Sun/Moon icon variant</p>
            </div>
        </div>
    </div>

    <div class="doc-section">
        <h2>CSS Variables</h2>
        <p>These CSS variables can be used in custom styles:</p>
        
        <h3>Transition Variables</h3>
        <CodeBlock Code="@transitionVariablesCode" Language="css" Title="Transition Variables" />
        
        <h3>Component Variables</h3>
        <CodeBlock Code="@componentVariablesCode" Language="css" Title="Component Variables" />
    </div>

    <div class="doc-section">
        <h2>Usage Examples</h2>
        <CodeBlock Code="@usageExamplesCode" Language="html" Title="Combining Classes" />
    </div>
</div>

@code {
    private string transitionVariablesCode = @"/* Duration and timing */
--ui-transition-duration: 200ms;
--ui-transition-easing: ease-in-out;
--ui-transition-delay: 0ms;

/* Hover state variables */
--ui-transition-hover-scale: 1.05;
--ui-transition-hover-rotate: 5deg;
--ui-transition-hover-opacity: 0.8;
--ui-transition-hover-shadow: 0 4px 8px rgba(0,0,0,0.15);

/* Focus state variables */
--ui-transition-focus-scale: 1.05;
--ui-transition-focus-shadow: 0 0 0 3px rgba(59,130,246,0.3);

/* Active state variables */
--ui-transition-active-scale: 0.98;";

    private string componentVariablesCode = @"/* Ripple effect */
--ui-ripple-color: rgba(0,0,0,0.2);
--ui-ripple-duration: 600ms;

/* Button specific */
--ui-button-hover-background: var(--palette-primary-light);
--ui-button-active-background: var(--palette-primary-dark);

/* Loading indicator */
--ui-loading-color: var(--palette-primary);
--ui-loading-size: 1em;";

    private string usageExamplesCode = @"<!-- Button with multiple utilities -->
<button class=""ui-button ui-size-large ui-elevation-4 ui-has-transitions ui-transition-hover-lift"">
    Elevated Large Button
</button>

<!-- Card with density and elevation -->
<div class=""ui-density-comfortable ui-elevation-2"">
    <h3>Card Title</h3>
    <p>Card content with comfortable spacing and slight elevation.</p>
</div>

<!-- Full width element with ripple -->
<div class=""ui-full-width ui-has-ripple"">
    Click for ripple effect across full width
</div>

<!-- Combining transitions -->
<div class=""ui-has-transitions ui-transition-hover-scale ui-transition-hover-shadow"">
    Hover for combined scale and shadow effect
</div>";
}
