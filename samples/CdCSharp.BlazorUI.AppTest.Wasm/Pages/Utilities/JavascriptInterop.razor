@page "/utilities/javascript-interop"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared

<PageTitle>JavaScript Interop - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>JavaScript Interop</h1>
    <p class="doc-intro">
        CdCSharp.BlazorUI uses JavaScript interop for enhanced functionality like theme management, 
        ripple effects, and behavior attachments. This page documents the interop services and patterns.
    </p>

    <div class="doc-section">
        <h2>Architecture Overview</h2>
        <p>The library uses a modular approach to JavaScript interop:</p>
        
        <div class="architecture-diagram">
            <div class="arch-layer">
                <h4>C# Services</h4>
                <p>IThemeJsInterop, IBehaviorJsInterop</p>
            </div>
            <div class="arch-arrow">↓</div>
            <div class="arch-layer">
                <h4>Module Loading</h4>
                <p>Lazy-loaded ES modules</p>
            </div>
            <div class="arch-arrow">↓</div>
            <div class="arch-layer">
                <h4>JavaScript Modules</h4>
                <p>theme.js, behavior.js, ripple.js</p>
            </div>
        </div>
    </div>

    <div class="doc-section">
        <h2>Theme JavaScript Interop</h2>
        <p>The theme interop manages theme switching and persistence:</p>
        
        <CodeBlock Code="@themeInteropCode" Language="csharp" Title="IThemeJsInterop Usage" />
        
        <h3>Available Methods</h3>
        <div class="method-list">
            <div class="method">
                <code>InitializeAsync(string theme)</code>
                <p>Initializes the theme system with the specified theme ("light", "dark", or "auto")</p>
            </div>
            
            <div class="method">
                <code>SetThemeAsync(string theme)</code>
                <p>Changes the current theme</p>
            </div>
            
            <div class="method">
                <code>GetThemeAsync()</code>
                <p>Returns the current theme name</p>
            </div>
            
            <div class="method">
                <code>DisposeAsync()</code>
