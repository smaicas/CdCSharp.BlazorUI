            </div>
        </div>
    </div>

    <div class="doc-section">
        <h2>Behavior JavaScript Interop</h2>
        <p>The behavior interop attaches dynamic behaviors like ripple effects:</p>
        
        <CodeBlock Code="@behaviorInteropCode" Language="csharp" Title="IBehaviorJsInterop Usage" />
        
        <h3>Behavior Configuration</h3>
        <CodeBlock Code="@behaviorConfigCode" Language="csharp" Title="BehaviorConfiguration" />
    </div>

    <div class="doc-section">
        <h2>Module Loading Pattern</h2>
        <p>All JavaScript modules are loaded lazily to optimize performance:</p>
        
        <CodeBlock Code="@moduleLoadingCode" Language="csharp" Title="Module Loading Example" />
    </div>

    <div class="doc-section">
        <h2>Creating Custom Interop Services</h2>
        <p>Follow this pattern to create your own JavaScript interop:</p>
        
        <CodeBlock Code="@customInteropCode" Language="csharp" Title="Custom Interop Service" />
        
        <p>JavaScript module example:</p>
        <CodeBlock Code="@customJsModuleCode" Language="javascript" Title="custom.js" />
    </div>

    <div class="doc-section">
        <h2>Best Practices</h2>
        
        <div class="practice-cards">
            <div class="practice-card">
                <h4>1. Use Lazy Loading</h4>
                <p>Load JavaScript modules only when needed to improve initial load time.</p>
            </div>
            
            <div class="practice-card">
                <h4>2. Implement IAsyncDisposable</h4>
                <p>Always clean up event listeners and resources in JavaScript.</p>
            </div>
            
            <div class="practice-card">
                <h4>3. Handle Errors Gracefully</h4>
                <p>JavaScript calls can fail; always use try-catch blocks.</p>
            </div>
            
            <div class="practice-card">
                <h4>4. Minimize Interop Calls</h4>
                <p>Batch operations when possible to reduce overhead.</p>
            </div>
        </div>
    </div>

    <div class="doc-section">
        <h2>JavaScript Module Structure</h2>
        <p>The library's JavaScript modules follow this structure:</p>
        
        <CodeBlock Code="@jsStructureCode" Language="text" Title="Module Structure" />
    </div>

    <div class="doc-section">
        <h2>Debugging Tips</h2>
        <ul>
            <li>Use browser DevTools to inspect JavaScript module loading</li>
            <li>Check the Network tab to verify modules are loaded lazily</li>
            <li>Use console.log in JavaScript modules for debugging</li>
            <li>Enable detailed errors in Blazor for better error messages</li>
            <li>Test with both prerendering enabled and disabled</li>
        </ul>
    </div>

    <div class="doc-note doc-note--warning">
        <strong>Important:</strong> Always dispose of JavaScript interop services properly to prevent memory leaks, 
        especially when dealing with event listeners or DOM observers.
    </div>
</div>

@code {
    private string themeInteropCode = @"@inject IThemeJsInterop ThemeInterop

// Initialize theme on component load
protected override async Task OnAfterRenderAsync(bool firstRender)
{
    if (firstRender)
    {
        await ThemeInterop.InitializeAsync(""dark"");
    }
}

// Change theme programmatically
private async Task ToggleTheme()
{
    var currentTheme = await ThemeInterop.GetThemeAsync();
    var newTheme = currentTheme == ""light"" ? ""dark"" : ""light"";
    await ThemeInterop.SetThemeAsync(newTheme);
}

// Clean up on disposal
public async ValueTask DisposeAsync()
{
    await ThemeInterop.DisposeAsync();
}";

    private string behaviorInteropCode = @"@inject IBehaviorJsInterop BehaviorInterop

// Attach ripple behavior to an element
protected override async Task OnAfterRenderAsync(bool firstRender)
{
    if (firstRender && !DisableRipple)
    {
        var config = new BehaviorConfiguration
        {
            Behaviors = new[] { ""ripple"" },
            Options = new Dictionary<string, object>
            {
                [""ripple""] = new
                {
                    color = RippleColor?.ToString(),
                    duration = RippleDuration
                }
            }
        };

        await BehaviorInterop.AttachBehaviorsAsync(_elementRef, config);
    }
}";

    private string behaviorConfigCode = @"public class BehaviorConfiguration
{
    public string[] Behaviors { get; set; } = Array.Empty<string>();
    public Dictionary<string, object> Options { get; set; } = new();
}

// Available behaviors:
// - ""ripple"": Material design ripple effect
// - ""tooltip"": Tooltip on hover
// - ""focus-trap"": Trap focus within element
// - ""click-outside"": Detect clicks outside element";

    private string moduleLoadingCode = @"public abstract class ModuleJsInteropBase : IAsyncDisposable
{
    private readonly Lazy<Task<IJSObjectReference>> _moduleTask;
    protected readonly IJSRuntime JsRuntime;
    protected IJSObjectReference? Module;

    protected ModuleJsInteropBase(IJSRuntime jsRuntime, string modulePath)
    {
        JsRuntime = jsRuntime;
        _moduleTask = new(() => LoadModule(modulePath));
    }

    private async Task<IJSObjectReference> LoadModule(string modulePath)
    {
        Module = await JsRuntime.InvokeAsync<IJSObjectReference>(
            ""import"", modulePath);
        return Module;
    }

    protected async Task<IJSObjectReference> GetModule()
    {
        return await _moduleTask.Value;
    }

    public async ValueTask DisposeAsync()
    {
        if (Module != null)
        {
            await Module.DisposeAsync();
        }
    }
}";

    private string customInteropCode = @"public interface IMyCustomJsInterop : IAsyncDisposable
{
    Task<string> DoSomethingAsync(string input);
}

public class MyCustomJsInterop : ModuleJsInteropBase, IMyCustomJsInterop
{
    public MyCustomJsInterop(IJSRuntime jsRuntime) 
        : base(jsRuntime, ""/js/custom.min.js"")
    {
    }

    public async Task<string> DoSomethingAsync(string input)
    {
        var module = await GetModule();
        return await module.InvokeAsync<string>(""doSomething"", input);
    }
}

// Register in Program.cs
builder.Services.AddScoped<IMyCustomJsInterop, MyCustomJsInterop>();";

    private string customJsModuleCode = @"// custom.js
export function doSomething(input) {
    console.log('Processing:', input);
    
    // Your custom logic here
    const result = processInput(input);
    
    return result;
}

// Clean up function (optional)
export function dispose() {
    // Remove event listeners, clear timers, etc.
    console.log('Cleaning up custom module');
}

// Module initialization (optional)
export function initialize() {
    console.log('Custom module initialized');
}";

    private string jsStructureCode = @"wwwroot/
└── js/
    ├── Types/
    │   ├── Behaviors/
    │   │   ├── behavior.js
    │   │   └── ripple.js
    │   └── Theme/
    │       └── theme.js
    ├── main.js          # Entry point
    └── *.min.js         # Compiled/minified versions";
}