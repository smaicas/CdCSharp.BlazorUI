<BUITreeMenu TItem="object" Size="BUISize.Medium">
    <BUITreeMenuItem Text="Home"
                     Icon="@BUIIcons.MaterialIconsRound.i_home"
                     Href="/"
                     Match="NavLinkMatch.All" />

    <BUITreeMenuItem Text="Forms"
                     Icon="@BUIIcons.MaterialIconsOutlined.i_edit_note"
                     InitiallyExpanded="true">
        <ChildContent>
            <BUITreeMenuItem Text="Checkbox" Href="/demo/checkbox" />
            <BUITreeMenuItem Text="Color Picker" Href="/demo/color" />
            <BUITreeMenuItem Text="DateTime" Href="/demo/datetime" />
            <BUITreeMenuItem Text="Dropdown" Href="/demo/dropdown" />
            <BUITreeMenuItem Text="Number" Href="/demo/number" />
            <BUITreeMenuItem Text="Radio" Href="/demo/radio" />
            <BUITreeMenuItem Text="Switch" Href="/demo/switch" />
            <BUITreeMenuItem Text="Text" Href="/demo/text" />
            <BUITreeMenuItem Text="TextArea" Href="/demo/textarea" />
        </ChildContent>
    </BUITreeMenuItem>

    <BUITreeMenuItem Text="Generic"
                     Icon="@BUIIcons.MaterialIconsOutlined.i_widgets"
                     InitiallyExpanded="true">
        <ChildContent>
            <BUITreeMenuItem Text="Badge" Href="/demo/badge" />
            <BUITreeMenuItem Text="Button" Href="/demo/button" />
            <BUITreeMenuItem Text="DataGrid" Href="/demo/datagrid" />
            <BUITreeMenuItem Text="DataCards" Href="/demo/datacards" />
            <BUITreeMenuItem Text="Loading" Href="/demo/loading" />
            <BUITreeMenuItem Text="Svg Icon" Href="/demo/svgicon" />
            <BUITreeMenuItem Text="Switch" Href="/demo/genericswitch" />
        </ChildContent>
    </BUITreeMenuItem>

    <BUITreeMenuItem Text="Layout"
                     Icon="@BUIIcons.MaterialIconsOutlined.i_dashboard"
                     InitiallyExpanded="true">
        <ChildContent>
            <BUITreeMenuItem Text="Card" Href="/demo/card" />
            <BUITreeMenuItem Text="Grid" Href="/demo/grid" />
            <BUITreeMenuItem Text="Modal" Href="/demo/dialog" />
            <BUITreeMenuItem Text="Toast" Href="/demo/toast" />
            <BUITreeMenuItem Text="Theme Selector" Href="/demo/themeselector" />
            <BUITreeMenuItem Text="Culture Selector" Href="/demo/cultureselector" />
            <BUITreeMenuItem Text="Theme Generator" Href="/theme-generator" />
        </ChildContent>
    </BUITreeMenuItem>

    <BUITreeMenuItem Text="Tree"
                     Icon="@BUIIcons.MaterialIconsOutlined.i_account_tree"
                     InitiallyExpanded="true">
        <ChildContent>
            <BUITreeMenuItem Text="Tree Menu" Href="/demo/treemenu" />
            <BUITreeMenuItem Text="Tree Selector" Href="/demo/treeselector" />
        </ChildContent>
    </BUITreeMenuItem>

    <BUITreeMenuItem Text="Utils"
                     Icon="@BUIIcons.MaterialIconsOutlined.i_build"
                     InitiallyExpanded="true">
        <ChildContent>
            <BUITreeMenuItem Text="Tooltip" Href="/demo/tooltip" />
            <BUITreeMenuItem Text="DatePicker" Href="/demo/datepicker" />
            <BUITreeMenuItem Text="TimePicker" Href="/demo/timepicker" />
        </ChildContent>
    </BUITreeMenuItem>
</BUITreeMenu>

