@using CdCSharp.BlazorUI.Components

@namespace CdCSharp.BlazorUI.Components.Diagnostics

@implements IDisposable

@inject IBUIPerformanceService PerformanceService

<div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
    <h3 style="margin: 0;">BUI Performance Monitor</h3>
    <BUIButton TrackPerformanceEnabled="false" Text="Reset" Size="BUISize.Small" OnClick="@(() => PerformanceService.Reset())" />
</div>

<BUIDataGrid Items="_metrics" Sortable="true" TrackPerformanceEnabled="false">
    <Columns>
        <BUIDataColumn TItem="BUIComponentMetrics" Property="@(m => m.ComponentType)"
                       Sortable="true">
            <HeaderTemplate>
                <BUITooltip Text="Nombre del tipo de componente Blazor" Placement="TooltipPlacement.Bottom" Trigger="TooltipTrigger.Click"
                            TrackPerformanceEnabled="false">
                    Component
                </BUITooltip>
            </HeaderTemplate>
        </BUIDataColumn>

        <BUIDataColumn TItem="BUIComponentMetrics" Property="@(m => m.RenderCount)"
                       Align="ColumnAlign.Right" Width="90px" Sortable="true">
            <HeaderTemplate>
                <BUITooltip Text="Número de veces que BuildRenderTree ha sido invocado desde que se inició la sesión o el último reset."
                            Placement="TooltipPlacement.Bottom" Trigger="TooltipTrigger.Click" TrackPerformanceEnabled="false">
                    Renders
                </BUITooltip>
            </HeaderTemplate>
        </BUIDataColumn>

        <BUIDataColumn TItem="BUIComponentMetrics" Property="@(m => m.InitTimeMs)"
                       Align="ColumnAlign.Right" Width="100px" Sortable="true">
            <HeaderTemplate>
                <BUITooltip Text="Tiempo total desde OnInitialized hasta el primer OnAfterRenderAsync. Refleja el coste real de crear la instancia incluyendo JS interop inicial."
                            Placement="TooltipPlacement.Bottom" Trigger="TooltipTrigger.Click" TrackPerformanceEnabled="false">
                    Init (ms)
                </BUITooltip>
            </HeaderTemplate>
            <Template>
                <span style="color: @GetTimeColor(context.InitTimeMs)">
                    @context.InitTimeMs.ToString("F3")
                </span>
            </Template>
        </BUIDataColumn>

        <BUIDataColumn TItem="BUIComponentMetrics" Align="ColumnAlign.Right" Width="130px"
                       Sortable="true" Property="@(m => m.AverageRenderTreeBuildTimeMs)">
            <HeaderTemplate>
                <BUITooltip Text="Media de tiempo empleado en BuildRenderTree sobre todos los renders. Un valor alto aquí suele indicar lógica compleja en el árbol de render."
                            Placement="TooltipPlacement.Bottom" Trigger="TooltipTrigger.Click" TrackPerformanceEnabled="false">
                    Avg Render (ms)
                </BUITooltip>
            </HeaderTemplate>
            <Template>
                <span style="color: @GetTimeColor(context.AverageRenderTreeBuildTimeMs)">
                    @context.AverageRenderTreeBuildTimeMs.ToString("F3")
                </span>
            </Template>
        </BUIDataColumn>

        <BUIDataColumn TItem="BUIComponentMetrics" Property="@(m => m.LastRenderTreeBuildTimeMs)"
                       Align="ColumnAlign.Right" Width="130px" Sortable="true">
            <HeaderTemplate>
                <BUITooltip Text="Tiempo del último BuildRenderTree registrado. Útil para detectar renders puntuales costosos tras interacciones."
                            Placement="TooltipPlacement.Bottom" Trigger="TooltipTrigger.Click" TrackPerformanceEnabled="false">
                    Last Render (ms)
                </BUITooltip>
            </HeaderTemplate>
            <Template>
                <span style="color: @GetTimeColor(context.LastRenderTreeBuildTimeMs)">
                    @context.LastRenderTreeBuildTimeMs.ToString("F3")
                </span>
            </Template>
        </BUIDataColumn>

        <BUIDataColumn TItem="BUIComponentMetrics" Property="@(m => m.ParametersSetCount)"
                       Align="ColumnAlign.Right" Width="110px" Sortable="true">
            <HeaderTemplate>
                <BUITooltip Text="Cuántas veces OnParametersSet fue llamado. Si este número crece mucho más rápido que Renders, el componente padre está re-renderizando innecesariamente."
                            Placement="TooltipPlacement.Bottom" Trigger="TooltipTrigger.Click" TrackPerformanceEnabled="false">
                    ParamsSet #
                </BUITooltip>
            </HeaderTemplate>
        </BUIDataColumn>

        <BUIDataColumn TItem="BUIComponentMetrics" Align="ColumnAlign.Right" Width="130px"
                       Sortable="true" Property="@(m => m.AverageParametersSetTimeMs)">
            <HeaderTemplate>
                <BUITooltip Text="Media de tiempo empleado en OnParametersSet. Incluye el coste de BuildStyles y la resolución de atributos adicionales."
                            Placement="TooltipPlacement.Bottom" Trigger="TooltipTrigger.Click" TrackPerformanceEnabled="false">
                    Avg Params (ms)
                </BUITooltip>
            </HeaderTemplate>
            <Template>
                <span style="color: @GetTimeColor(context.AverageParametersSetTimeMs)">
                    @context.AverageParametersSetTimeMs.ToString("F3")
                </span>
            </Template>
        </BUIDataColumn>

    </Columns>
</BUIDataGrid>

@code {
    private List<BUIComponentMetrics> _metrics = [];
    private const int DebounceDelayMs = 500;

    protected override void OnInitialized()
    {
        PerformanceService.MetricsUpdated += OnMetricsUpdated;
        RefreshMetrics();
    }

    private CancellationTokenSource? _debounceCts;

    private async void OnMetricsUpdated()
    {
        _debounceCts?.Cancel();
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;

        try
        {
            await Task.Delay(DebounceDelayMs, token); // agrupa ráfagas de renders
            RefreshMetrics();
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException) { }
    }

    public void Dispose()
    {
        _debounceCts?.Cancel();
        PerformanceService.MetricsUpdated -= OnMetricsUpdated;
    }

    private void RefreshMetrics() =>
        _metrics = PerformanceService.GetAll().ToList();

    // Verde < 1ms · Naranja 1-5ms · Rojo > 5ms
    private static string GetTimeColor(double ms) => ms switch
    {
        > 5.0 => "var(--bui-color-danger)",
        > 1.0 => "var(--bui-color-warning)",
        _ => "var(--bui-color-success)"
    };
}