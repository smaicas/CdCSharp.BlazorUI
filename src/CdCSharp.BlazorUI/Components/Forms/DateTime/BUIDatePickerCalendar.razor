@using System.Globalization

@namespace CdCSharp.BlazorUI.Components.Forms

@code {
    [Parameter] public DateTime ViewDate { get; set; }
    [Parameter] public DateTime? SelectedDate { get; set; }
    [Parameter] public DateTime? MinDate { get; set; }
    [Parameter] public DateTime? MaxDate { get; set; }
    [Parameter] public List<DateTime>? DisabledDates { get; set; }
    [Parameter] public DayOfWeek FirstDayOfWeek { get; set; } = DayOfWeek.Monday;
    [Parameter] public CultureInfo Culture { get; set; } = CultureInfo.CurrentCulture;
    [Parameter] public EventCallback<DateTime> OnDateSelected { get; set; }
    [Parameter] public SizeEnum Size { get; set; }
    [Parameter] public DensityEnum Density { get; set; }

    private List<List<DateTime?>> GetCalendarDays()
    {
        var firstDayOfMonth = new DateTime(ViewDate.Year, ViewDate.Month, 1);
        var lastDayOfMonth = firstDayOfMonth.AddMonths(1).AddDays(-1);

        // Calculate start date (previous month days)
        int daysFromPrevMonth = ((int)firstDayOfMonth.DayOfWeek - (int)FirstDayOfWeek + 7) % 7;
        var startDate = firstDayOfMonth.AddDays(-daysFromPrevMonth);

        var weeks = new List<List<DateTime?>>();
        var currentDate = startDate;

        while (currentDate <= lastDayOfMonth || weeks.Count < 6)
        {
            var week = new List<DateTime?>();
            for (int i = 0; i < 7; i++)
            {
                week.Add(currentDate);
                currentDate = currentDate.AddDays(1);
            }
            weeks.Add(week);
        }

        return weeks;
    }

    private bool IsDateDisabled(DateTime date)
    {
        if (MinDate.HasValue && date < MinDate.Value) return true;
        if (MaxDate.HasValue && date > MaxDate.Value) return true;
        if (DisabledDates?.Contains(date.Date) == true) return true;
        return false;
    }

    private bool IsToday(DateTime date) => date.Date == DateTime.Today;
    private bool IsSelected(DateTime date) => SelectedDate?.Date == date.Date;
    private bool IsCurrentMonth(DateTime date) => date.Month == ViewDate.Month;

    private string GetDayClasses(DateTime date)
    {
        var classes = new List<string> { "bui-calendar__day" };

        if (!IsCurrentMonth(date)) classes.Add("bui-calendar__day--other-month");
        if (IsToday(date)) classes.Add("bui-calendar__day--today");
        if (IsSelected(date)) classes.Add("bui-calendar__day--selected");
        if (IsDateDisabled(date)) classes.Add("bui-calendar__day--disabled");

        return string.Join(" ", classes);
    }

    private async Task HandleDateClick(DateTime date)
    {
        if (!IsDateDisabled(date))
        {
            await OnDateSelected.InvokeAsync(date);
        }
    }
}

<div class="bui-calendar" data-bui-size="@Size.ToString().ToLowerInvariant()" data-bui-density="@Density.ToString().ToLowerInvariant()">
    <div class="bui-calendar__weekdays">
        @for (int i = 0; i < 7; i++)
        {
            var dayOfWeek = (DayOfWeek)(((int)FirstDayOfWeek + i) % 7);
            <div class="bui-calendar__weekday">
                @Culture.DateTimeFormat.GetAbbreviatedDayName(dayOfWeek)
            </div>
        }
    </div>

    <div class="bui-calendar__days">
        @foreach (var week in GetCalendarDays())
        {
            @foreach (var day in week)
            {
                if (day.HasValue)
                {
                    <button class="@GetDayClasses(day.Value)"
                            @onclick="() => HandleDateClick(day.Value)"
                            disabled="@IsDateDisabled(day.Value)"
                            type="button">
                        @day.Value.Day
                    </button>
                }
            }
        }
    </div>
</div>