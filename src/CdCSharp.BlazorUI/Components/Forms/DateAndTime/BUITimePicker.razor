@namespace CdCSharp.BlazorUI.Components.Forms
@using System.Globalization

<div class="timepicker">
    <button type="button"
            class="timepicker-format-btn"
            @onclick="ToggleFormat">
        @(Format == "24" ? "24h" : "12h")
    </button>

    <div class="timepicker-spinners">
        <div class="timepicker-spinner">
            <button type="button" class="timepicker-spin-btn" @onclick="IncrementHour">▲</button>
            <input type="text"
                   class="timepicker-input"
                   value="@DisplayHour.ToString("00")"
                   @onchange="OnHourInput"
                   @onfocus="OnInputFocus"
                   maxlength="2" />
            <button type="button" class="timepicker-spin-btn" @onclick="DecrementHour">▼</button>
        </div>

        <span class="timepicker-separator">:</span>

        <div class="timepicker-spinner">
            <button type="button" class="timepicker-spin-btn" @onclick="IncrementMinute">▲</button>
            <input type="text"
                   class="timepicker-input"
                   value="@Minute.ToString("00")"
                   @onchange="OnMinuteInput"
                   @onfocus="OnInputFocus"
                   maxlength="2" />
            <button type="button" class="timepicker-spin-btn" @onclick="DecrementMinute">▼</button>
        </div>
    </div>

    @if (Format == "12")
    {
        <button type="button"
                class="timepicker-ampm-btn"
                @onclick="ToggleAmPm">
            @AmPm
        </button>
    }
</div>

@code {
    [Parameter] public TimeOnly? Value { get; set; }
    [Parameter] public EventCallback<TimeOnly?> ValueChanged { get; set; }

    private int Hour;
    private int Minute;
    private string Format = "24";
    private string AmPm = "AM";

    private int DisplayHour
    {
        get
        {
            if (Format == "24") return Hour;
            int h = Hour % 12;
            return h == 0 ? 12 : h;
        }
    }

    protected override void OnInitialized()
    {
        Format = CultureInfo.CurrentCulture.DateTimeFormat.ShortTimePattern.Contains("tt")
            ? "12"
            : "24";
    }

    protected override void OnParametersSet()
    {
        if (Value.HasValue)
        {
            Hour = Value.Value.Hour;
            Minute = Value.Value.Minute;
            AmPm = Hour >= 12 ? "PM" : "AM";
        }
    }

    private async Task UpdateValue()
    {
        TimeOnly t = new(Hour, Minute);
        await ValueChanged.InvokeAsync(t);
    }

    private void OnInputFocus(FocusEventArgs e)
    {
    }

    private void OnHourInput(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out int h)) return;

        if (Format == "24")
        {
            Hour = Math.Clamp(h, 0, 23);
        }
        else
        {
            h = Math.Clamp(h, 1, 12);
            Hour = AmPm == "PM" ? (h % 12) + 12 : h % 12;
        }
        _ = UpdateValue();
    }

    private void OnMinuteInput(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out int m)) return;

        Minute = Math.Clamp(m, 0, 59);
        _ = UpdateValue();
    }

    private void ToggleFormat()
    {
        Format = Format == "24" ? "12" : "24";
        if (Format == "12")
        {
            AmPm = Hour >= 12 ? "PM" : "AM";
        }
    }

    private void ToggleAmPm()
    {
        if (AmPm == "AM")
        {
            AmPm = "PM";
            if (Hour < 12) Hour += 12;
        }
        else
        {
            AmPm = "AM";
            if (Hour >= 12) Hour -= 12;
        }
        _ = UpdateValue();
    }

    private void IncrementHour()
    {
        if (Format == "24")
        {
            Hour = (Hour + 1) % 24;
        }
        else
        {
            int display = DisplayHour;
            display = display % 12 + 1;
            Hour = AmPm == "PM" ? (display % 12) + 12 : display % 12;
        }
        _ = UpdateValue();
    }

    private void DecrementHour()
    {
        if (Format == "24")
        {
            Hour = (Hour + 23) % 24;
        }
        else
        {
            int display = DisplayHour;
            display = display == 1 ? 12 : display - 1;
            Hour = AmPm == "PM" ? (display % 12) + 12 : display % 12;
        }
        _ = UpdateValue();
    }

    private void IncrementMinute()
    {
        Minute = (Minute + 1) % 60;
        _ = UpdateValue();
    }

    private void DecrementMinute()
    {
        Minute = (Minute + 59) % 60;
        _ = UpdateValue();
    }
}

<style>
    .timepicker {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-family: system-ui, -apple-system, sans-serif;
        user-select: none;
    }

    .timepicker-format-btn {
        padding: 0.5rem 0.75rem;
        border: 1px solid #ddd;
        border-radius: 6px;
        background: #f8f8f8;
        cursor: pointer;
        font-size: 0.875rem;
        font-weight: 500;
        color: #666;
        transition: all 0.15s ease;
    }

        .timepicker-format-btn:hover {
            background: #f0f0f0;
            border-color: #ccc;
        }

    .timepicker-spinners {
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    .timepicker-spinner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
    }

    .timepicker-spin-btn {
        width: 40px;
        height: 28px;
        border: 1px solid #ddd;
        border-radius: 4px;
        background: #fff;
        cursor: pointer;
        font-size: 0.75rem;
        color: #666;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.15s ease;
    }

        .timepicker-spin-btn:hover {
            background: #f0f0f0;
            border-color: #ccc;
        }

        .timepicker-spin-btn:active {
            background: #e0e0e0;
        }

    .timepicker-input {
        width: 48px;
        font-size: 1.5rem;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
        text-align: center;
        padding: 0.25rem;
        border: 1px solid transparent;
        border-radius: 4px;
        background: transparent;
        transition: all 0.15s ease;
    }

        .timepicker-input:hover {
            border-color: #ddd;
        }

        .timepicker-input:focus {
            outline: none;
            border-color: #0078ff;
            background: #fff;
        }

    .timepicker-separator {
        font-size: 1.5rem;
        font-weight: 600;
        color: #333;
        padding-bottom: 0.25rem;
    }

    .timepicker-ampm-btn {
        padding: 0.75rem 1rem;
        border: 1px solid #0078ff;
        border-radius: 6px;
        background: #0078ff;
        cursor: pointer;
        font-size: 1rem;
        font-weight: 600;
        color: #fff;
        transition: all 0.15s ease;
    }

        .timepicker-ampm-btn:hover {
            background: #0066dd;
        }

        .timepicker-ampm-btn:active {
            background: #0055cc;
        }
</style>