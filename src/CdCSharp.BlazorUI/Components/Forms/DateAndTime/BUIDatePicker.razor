@using System.Globalization
@namespace CdCSharp.BlazorUI.Components.Forms

<div class="datepicker">
    <div class="datepicker-nav">
        <div class="datepicker-nav-year">
            <button type="button" class="datepicker-btn" @onclick="PrevYear">«</button>
            <span class="datepicker-year">@CurrentMonth.Year</span>
            <button type="button" class="datepicker-btn" @onclick="NextYear">»</button>
        </div>
        <div class="datepicker-nav-month">
            <button type="button" class="datepicker-btn" @onclick="PrevMonth">‹</button>
            <span class="datepicker-month">@CurrentMonth.ToString("MMMM", CultureInfo.CurrentCulture)</span>
            <button type="button" class="datepicker-btn" @onclick="NextMonth">›</button>
        </div>
    </div>

    <div class="datepicker-weekdays">
        @foreach (string d in WeekDays)
        {
            <span>@d</span>
        }
    </div>

    <div class="datepicker-days">
        @foreach (DayCell day in Days)
        {
            <button type="button"
                    class="datepicker-day @(day.IsSelected ? "selected" : "") @(day.IsToday ? "today" : "") @(!day.IsCurrentMonth ? "other-month" : "")"
                    @onclick="() => SelectDate(day.Date)">
                @day.Date.Day
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public DateOnly? Value { get; set; }
    [Parameter] public EventCallback<DateOnly?> ValueChanged { get; set; }

    private DateTime CurrentMonth = DateTime.Today;
    private DateOnly SelectedDate = DateOnly.FromDateTime(DateTime.Today);

    protected override void OnParametersSet()
    {
        if (Value.HasValue)
        {
            SelectedDate = Value.Value;
            CurrentMonth = new DateTime(Value.Value.Year, Value.Value.Month, 1);
        }
    }

    private void PrevYear() => CurrentMonth = CurrentMonth.AddYears(-1);
    private void NextYear() => CurrentMonth = CurrentMonth.AddYears(1);
    private void PrevMonth() => CurrentMonth = CurrentMonth.AddMonths(-1);
    private void NextMonth() => CurrentMonth = CurrentMonth.AddMonths(1);

    private async Task SelectDate(DateTime date)
    {
        SelectedDate = DateOnly.FromDateTime(date);
        CurrentMonth = new DateTime(date.Year, date.Month, 1);
        await ValueChanged.InvokeAsync(SelectedDate);
    }

    private IEnumerable<string> WeekDays => CultureInfo.CurrentCulture.DateTimeFormat.AbbreviatedDayNames;

    private IEnumerable<DayCell> Days
    {
        get
        {
            DateTime firstOfMonth = new(CurrentMonth.Year, CurrentMonth.Month, 1);
            DateTime start = firstOfMonth.AddDays(-(int)firstOfMonth.DayOfWeek);

            return Enumerable.Range(0, 42).Select(i =>
            {
                DateTime d = start.AddDays(i);
                return new DayCell
                {
                    Date = d,
                    IsCurrentMonth = d.Month == CurrentMonth.Month,
                    IsSelected = SelectedDate.DayNumber == DateOnly.FromDateTime(d).DayNumber,
                    IsToday = d.Date == DateTime.Today
                };
            });
        }
    }

    private sealed class DayCell
    {
        public DateTime Date { get; set; }
        public bool IsCurrentMonth { get; set; }
        public bool IsSelected { get; set; }
        public bool IsToday { get; set; }
    }
}

<style>
    .datepicker {
        font-family: system-ui, -apple-system, sans-serif;
        user-select: none;
    }

    .datepicker-nav {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .datepicker-nav-year,
    .datepicker-nav-month {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .datepicker-year,
    .datepicker-month {
        font-weight: 600;
        font-size: 1rem;
        min-width: 120px;
        text-align: center;
    }

    .datepicker-btn {
        width: 32px;
        height: 32px;
        border: 1px solid #ddd;
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        font-size: 1rem;
        color: #333;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.15s ease;
    }

        .datepicker-btn:hover {
            background: #f0f0f0;
            border-color: #ccc;
        }

        .datepicker-btn:active {
            background: #e0e0e0;
        }

    .datepicker-weekdays {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 2px;
        margin-bottom: 0.5rem;
    }

        .datepicker-weekdays span {
            text-align: center;
            font-size: 0.75rem;
            font-weight: 600;
            color: #666;
            padding: 0.25rem;
        }

    .datepicker-days {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 2px;
    }

    .datepicker-day {
        width: 36px;
        height: 36px;
        border: none;
        border-radius: 50%;
        background: transparent;
        cursor: pointer;
        font-size: 0.875rem;
        color: #333;
        transition: all 0.15s ease;
    }

        .datepicker-day:hover:not(.selected) {
            background: #f0f0f0;
        }

        .datepicker-day.other-month {
            color: #ccc;
        }

        .datepicker-day.today {
            box-shadow: inset 0 0 0 1px #0078ff;
        }

        .datepicker-day.selected {
            background: #0078ff;
            color: #fff;
        }

            .datepicker-day.selected.today {
                box-shadow: none;
            }
</style>