@using System.Globalization
@using CdCSharp.BlazorUI.Components.Utils
@using CdCSharp.BlazorUI.Core.Abstractions.Behaviors.State

@namespace CdCSharp.BlazorUI.Components.Forms

@typeparam TValue
@inherits InputBase<TValue>
@implements IHasReadOnly

<div class="idt-wrapper">
    <BUIDateTimePattern @bind-Text="@CurrentValueAsString"
                        Format="@Format"
                        DefaultText="@DefaultText"
                        Editable="@(IsReadOnly == false)"
                        IsValidFunction="ValidateFinalValue" />

    <button type="button"
            class="idt-btn"
            @onclick="TogglePicker"
            disabled="@IsReadOnly">
        📅
    </button>
</div>

@if (IsOpen)
{
    <div class="picker-overlay" @onclick="ClosePicker">
        <div class="picker-modal" @onclick:stopPropagation>
            @if (ShowDate)
            {
                <BUIDatePicker Value="DateValue"
                               ValueChanged="OnDateChanged" />
            }
            @if (ShowTime)
            {
                <BUITimePicker Value="TimeValue"
                               ValueChanged="OnTimeChanged" />
            }
        </div>
    </div>
}

@code {
    private bool IsOpen;
    private bool ShowDate;
    private bool ShowTime;

    private DateOnly DateValue { get; set; } = DateOnly.FromDateTime(DateTime.Today);
    private TimeOnly TimeValue { get; set; } = TimeOnly.MinValue;

    [Parameter] public bool ReadOnly { get; set; }
    public bool IsReadOnly => ReadOnly;

    // -------------------------
    // Computed state
    // -------------------------

    private string Format => GetCultureFormatString();
    private string DefaultText => GetDefaultText();

    // -------------------------
    // Lifecycle
    // -------------------------

    protected override void OnInitialized()
    {
        var t = Nullable.GetUnderlyingType(typeof(TValue)) ?? typeof(TValue);

        ShowDate = t == typeof(DateOnly)
                || t == typeof(DateTime)
                || t == typeof(DateTimeOffset);

        ShowTime = t == typeof(TimeOnly)
                || t == typeof(DateTime)
                || t == typeof(DateTimeOffset);
    }

    protected override void OnParametersSet()
    {
        if (CurrentValue == null) return;

        var t = Nullable.GetUnderlyingType(typeof(TValue)) ?? typeof(TValue);

        if (t == typeof(DateOnly))
            DateValue = (DateOnly)(object)CurrentValue!;
        else if (t == typeof(TimeOnly))
            TimeValue = (TimeOnly)(object)CurrentValue!;
        else if (t == typeof(DateTime))
        {
            var dt = (DateTime)(object)CurrentValue!;
            DateValue = DateOnly.FromDateTime(dt);
            TimeValue = TimeOnly.FromDateTime(dt);
        }
        else if (t == typeof(DateTimeOffset))
        {
            var dto = (DateTimeOffset)(object)CurrentValue!;
            DateValue = DateOnly.FromDateTime(dto.DateTime);
            TimeValue = TimeOnly.FromDateTime(dto.DateTime);
        }
    }

    // -------------------------
    // Validation
    // -------------------------

    private bool ValidateFinalValue(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return true;

        var t = Nullable.GetUnderlyingType(typeof(TValue)) ?? typeof(TValue);

        return t switch
        {
            Type x when x == typeof(DateOnly)
                => DateOnly.TryParseExact(text, Format, CultureInfo.CurrentCulture, DateTimeStyles.None, out _),

            Type x when x == typeof(TimeOnly)
                => TimeOnly.TryParseExact(text, Format, CultureInfo.CurrentCulture, DateTimeStyles.None, out _),

            Type x when x == typeof(DateTime)
                => DateTime.TryParseExact(text, Format, CultureInfo.CurrentCulture, DateTimeStyles.None, out _),

            Type x when x == typeof(DateTimeOffset)
                => DateTimeOffset.TryParseExact(text, Format, CultureInfo.CurrentCulture, DateTimeStyles.None, out _),

            _ => false
        };
    }

    // -------------------------
    // Picker sync
    // -------------------------

    private async Task OnDateChanged(DateOnly? value)
    {
        if (value.HasValue)
            DateValue = value.Value;

        await UpdateCurrentValue();
    }

    private async Task OnTimeChanged(TimeOnly? value)
    {
        if (value.HasValue)
            TimeValue = value.Value;

        await UpdateCurrentValue();
    }

    private async Task UpdateCurrentValue()
    {
        var t = Nullable.GetUnderlyingType(typeof(TValue)) ?? typeof(TValue);

        object newValue = t switch
        {
            Type x when x == typeof(DateOnly) => DateValue,
            Type x when x == typeof(TimeOnly) => TimeValue,
            Type x when x == typeof(DateTime) => DateValue.ToDateTime(TimeValue),
            Type x when x == typeof(DateTimeOffset)
                => new DateTimeOffset(DateValue.ToDateTime(TimeValue)),
            _ => throw new InvalidOperationException()
        };

        CurrentValue = (TValue)newValue;
        await Task.CompletedTask;
    }

    // -------------------------
    // Formatting
    // -------------------------

    protected override string? FormatValueAsString(TValue? value)
    {
        if (value == null) return string.Empty;

        var t = Nullable.GetUnderlyingType(typeof(TValue)) ?? typeof(TValue);

        return t switch
        {
            Type x when x == typeof(DateOnly)
                => ((DateOnly)(object)value).ToString(Format, CultureInfo.CurrentCulture),

            Type x when x == typeof(TimeOnly)
                => ((TimeOnly)(object)value).ToString(Format, CultureInfo.CurrentCulture),

            Type x when x == typeof(DateTime)
                => ((DateTime)(object)value).ToString(Format, CultureInfo.CurrentCulture),

            Type x when x == typeof(DateTimeOffset)
                => ((DateTimeOffset)(object)value).ToString(Format, CultureInfo.CurrentCulture),

            _ => value.ToString()
        };
    }

    protected override bool TryParseValueFromString(
        string? value,
        out TValue result,
        out string? validationErrorMessage)
    {
        result = default!;
        validationErrorMessage = null;

        if (string.IsNullOrWhiteSpace(value))
        {
            if (Nullable.GetUnderlyingType(typeof(TValue)) != null)
                return true;

            validationErrorMessage = "El valor es requerido.";
            return false;
        }

        try
        {
            var type = Nullable.GetUnderlyingType(typeof(TValue)) ?? typeof(TValue);

            object parsed = type switch
            {
                Type x when x == typeof(DateOnly)
                    => DateOnly.ParseExact(value, Format, CultureInfo.CurrentCulture),

                Type x when x == typeof(TimeOnly)
                    => TimeOnly.ParseExact(value, Format, CultureInfo.CurrentCulture),

                Type x when x == typeof(DateTime)
                    => DateTime.ParseExact(value, Format, CultureInfo.CurrentCulture),

                Type x when x == typeof(DateTimeOffset)
                    => DateTimeOffset.ParseExact(value, Format, CultureInfo.CurrentCulture),

                _ => throw new InvalidOperationException()
            };

            result = (TValue)parsed;
            return true;
        }
        catch
        {
            validationErrorMessage =
                $"El valor '{value}' no coincide con el formato esperado ({Format}).";
            return false;
        }
    }

    // -------------------------
    // UI helpers
    // -------------------------

    private void TogglePicker() => IsOpen = !IsOpen;
    private void ClosePicker() => IsOpen = false;

    private string GetCultureFormatString()
    {
        var dtfi = CultureInfo.CurrentCulture.DateTimeFormat;
        var t = Nullable.GetUnderlyingType(typeof(TValue)) ?? typeof(TValue);

        return t switch
        {
            Type x when x == typeof(DateOnly) => dtfi.ShortDatePattern,
            Type x when x == typeof(TimeOnly) => dtfi.ShortTimePattern,
            Type x when x == typeof(DateTime) || x == typeof(DateTimeOffset)
                => $"{dtfi.ShortDatePattern} {dtfi.ShortTimePattern}",
            _ => string.Empty
        };
    }

    private string GetDefaultText()
    {
        var now = DateTime.Now;
        var t = Nullable.GetUnderlyingType(typeof(TValue)) ?? typeof(TValue);

        return t switch
        {
            Type x when x == typeof(DateOnly)
                => DateOnly.FromDateTime(now).ToString(Format, CultureInfo.CurrentCulture),

            Type x when x == typeof(TimeOnly)
                => TimeOnly.FromDateTime(now).ToString(Format, CultureInfo.CurrentCulture),

            Type x when x == typeof(DateTime)
                => now.ToString(Format, CultureInfo.CurrentCulture),

            Type x when x == typeof(DateTimeOffset)
                => DateTimeOffset.Now.ToString(Format, CultureInfo.CurrentCulture),

            _ => string.Empty
        };
    }
}
