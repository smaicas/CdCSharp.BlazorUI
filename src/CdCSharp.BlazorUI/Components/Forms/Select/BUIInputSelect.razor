@using CdCSharp.BlazorUI.Core.Abstractions.Behaviors.Design
@using CdCSharp.BlazorUI.Core.Abstractions.Behaviors.State
@using CdCSharp.BlazorUI.Core.Css
@using Microsoft.AspNetCore.Components.Forms
@using System.Collections
@using System.Globalization

@namespace CdCSharp.BlazorUI.Components.Forms

@typeparam TValue

@inherits BUIInputComponentBase<TValue, BUIInputSelect<TValue>, BUIInputSelectVariant>
@implements IHasSize
@implements IHasFullWidth
@implements IHasLoading
@implements IHasDensity
@implements IHasElevation
@implements IHasBorder

@{
    base.BuildRenderTree(__builder);
}

@code {
    private string _inputId = $"bui-select-{Guid.NewGuid():N}";
    private string _helperTextId = $"bui-helper-{Guid.NewGuid():N}";
    private bool _isOpen = false;
    private bool _isMultiple;

    // IHasSize
    [Parameter] public SizeEnum Size { get; set; } = SizeEnum.Medium;

    // IHasFullWidth
    [Parameter] public bool FullWidth { get; set; }

    // IHasLoading
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public BUILoadingIndicatorVariant? LoadingIndicatorVariant { get; set; }

    // IHasDensity
    [Parameter] public DensityEnum Density { get; set; } = DensityEnum.Standard;

    // IHasElevation
    [Parameter] public int? Elevation { get; set; }
    [Parameter] public CssColor? ElevationColor { get; set; }

    // IHasBorder
    [Parameter] public BorderStyle? Border { get; set; }
    [Parameter] public BorderStyle? BorderTop { get; set; }
    [Parameter] public BorderStyle? BorderRight { get; set; }
    [Parameter] public BorderStyle? BorderBottom { get; set; }
    [Parameter] public BorderStyle? BorderLeft { get; set; }

    // Select specific parameters
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public List<SelectOption<TValue>>? Options { get; set; }
    [Parameter] public Func<TValue?, string>? DisplayFunc { get; set; }

    public override BUIInputSelectVariant DefaultVariant => BUIInputSelectVariant.Outlined;

    public BUIInputSelect()
    {
        var type = typeof(TValue);
        _isMultiple = type.IsArray || (typeof(IEnumerable).IsAssignableFrom(type) && type != typeof(string));
    }

    protected override IReadOnlyDictionary<BUIInputSelectVariant, Func<BUIInputSelect<TValue>, RenderFragment>> BuiltInTemplates { get; } =
        new Dictionary<BUIInputSelectVariant, Func<BUIInputSelect<TValue>, RenderFragment>>
        {
            [BUIInputSelectVariant.Outlined] = i => i.RenderOutlined(),
            [BUIInputSelectVariant.Filled] = i => i.RenderFilled(),
            [BUIInputSelectVariant.Standard] = i => i.RenderStandard()
        };

    protected override bool TryParseValueFromString(string? value, out TValue result, out string validationErrorMessage)
    {
        validationErrorMessage = string.Empty;
        return BindConverter.TryConvertTo<TValue>(value, CultureInfo.CurrentCulture, out result);
    }

    private string GetDisplayValue()
    {
        if (CurrentValue == null) return string.Empty;

        // Caso Múltiple: Iteramos sobre la colección y buscamos los labels
        if (_isMultiple && CurrentValue is IEnumerable collection)
        {
            var labels = new List<string>();
            foreach (var item in collection)
            {
                var option = Options?.FirstOrDefault(o =>
                {
                    // Si TValue es una colección (ej string[]), comparamos el item con el valor de la opción
                    // Nota: Aquí se asume que las opciones contienen elementos del tipo interno de la colección
                    return Equals(o.Value, item);
                });
                labels.Add(option?.Label ?? item?.ToString() ?? string.Empty);
            }
            return labels.Any() ? string.Join(", ", labels) : string.Empty;
        }

        // Caso Simple (Existente)
        if (DisplayFunc != null) return DisplayFunc(CurrentValue);

        var opt = Options?.FirstOrDefault(o => EqualityComparer<TValue>.Default.Equals(o.Value, CurrentValue));
        return opt?.Label ?? CurrentValue.ToString() ?? string.Empty;
    }

    private void HandleToggleDropdown()
    {
        if (IsDisabled || IsLoading) return;
        _isOpen = !_isOpen;
    }

    private void HandleSelectOption(object? clickedValue)
    {
        if (IsDisabled) return;

        if (_isMultiple)
        {
            // Lógica de Toggle para múltiples valores
            var currentList = new List<object>();
            if (CurrentValue is IEnumerable collection)
            {
                foreach (var item in collection) currentList.Add(item!);
            }

            if (currentList.Contains(clickedValue!))
                currentList.Remove(clickedValue!);
            else
                currentList.Add(clickedValue!);

            // Convertimos la lista de vuelta al tipo TValue (Array o List) usando BindConverter
            if (BindConverter.TryConvertTo<TValue>(currentList.ToArray(), CultureInfo.CurrentCulture, out var result))
            {
                CurrentValue = result;
            }
        }
        else
        {
            // Selección simple
            CurrentValue = (TValue)clickedValue!;
            _isOpen = false;
        }
    }

    private bool IsOptionSelected(object? optionValue)
    {
        if (CurrentValue == null) return false;
        if (_isMultiple && CurrentValue is IEnumerable collection)
        {
            foreach (var item in collection)
            {
                if (Equals(item, optionValue)) return true;
            }
            return false;
        }
        return EqualityComparer<TValue>.Default.Equals((TValue)optionValue!, CurrentValue);
    }

    private RenderFragment RenderOutlined() => RenderSelect();
    private RenderFragment RenderFilled() => RenderSelect();
    private RenderFragment RenderStandard() => RenderSelect();

    private RenderFragment RenderSelect() => __builder =>
    {
        <bui-component @attributes="ComputedAttributes" data-bui-multiple="@_isMultiple">
            @if (!string.IsNullOrWhiteSpace(Label))
            {
                <label for="@_inputId" class="bui-input__label">
                    @Label
                    @if (Required)
                    {
                        <span class="bui-input__required">*</span>
                    }
                </label>
            }

            <div class="bui-select__container @(_isOpen ? "bui-select__container--open" : "")">
                <div class="bui-select__trigger" @onclick="() => { if (!IsDisabled && !IsLoading) _isOpen = !_isOpen; }">
                    <span class="bui-select__value @(string.IsNullOrEmpty(GetDisplayValue()) ? "bui-select__placeholder" : "")">
                        @(string.IsNullOrEmpty(GetDisplayValue()) ? Placeholder : GetDisplayValue())
                    </span>
                    <span class="bui-select__arrow">
                        <BUISvgIcon Icon="@(_isOpen? BUIIcons.MaterialIconsOutlined.i_arrow_drop_up : BUIIcons.MaterialIconsOutlined.i_arrow_drop_down)" Size="Size" />
                    </span>
                </div>

                @if (_isOpen && Options != null)
                {
                    <div class="bui-select__dropdown">
                        @foreach (var option in Options)
                        {
                            var isSelected = IsOptionSelected(option.Value);
                            <div class="bui-select__option @(isSelected ? "bui-select__option--selected" : "")"
                                 @onclick="() => HandleSelectOption(option.Value)">

                                @if (_isMultiple)
                                {
                                    <BUISvgIcon Size="Size"
                                                Icon="@(isSelected ? BUIIcons.MaterialIconsRound.i_check_box : BUIIcons.MaterialIconsRound.i_check_box_outline_blank)"
                                                Class="bui-select__option-icon" />
                                }

                                <span class="bui-select__option-label">@option.Label</span>
                            </div>
                        }
                    </div>
                }
            </div>
            @* ... (HelperText y ValidationMessage) *@
        </bui-component>
    };

    public class SelectOption<T>
    {
        public T? Value { get; set; }
        public string Label { get; set; } = string.Empty;
        public bool Disabled { get; set; }
    }
}