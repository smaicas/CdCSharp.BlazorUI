@* File: Components/Forms/TreeDropdown/BUITreeDropdownItem.razor *@
@namespace CdCSharp.BlazorUI.Components.Forms

@typeparam TValue

@if (Registry != null && ChildContent != null)
{
    <CascadingValue Value="@_resolvedKey" Name="TreeDropdownParentKey">
        @ChildContent
    </CascadingValue>

}

@code {
    private bool _registered;
    private string _resolvedKey = string.Empty;

    [CascadingParameter(Name = "TreeDropdownRegistry")]
    internal ITreeDropdownItemRegistry? Registry { get; set; }

    [CascadingParameter(Name = "TreeDropdownParentKey")]
    internal string? ParentKey { get; set; }

    [Parameter] public string? Key { get; set; }
    [Parameter] public TValue? Value { get; set; }
    [Parameter] public string? Text { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool InitiallyExpanded { get; set; }
    [Parameter] public RenderFragment? NodeContent { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    protected override void OnInitialized()
    {
        _resolvedKey = Key ?? $"tree-dropdown-item-{Guid.NewGuid():N}";
    }

    protected override void OnParametersSet()
    {
        if (Registry != null && !_registered)
        {
            ValidateValueType();

            TreeDropdownItemRegistration registration = new()
            {
                Key = _resolvedKey,
                Text = Text,
                Icon = Icon,
                IsDisabled = Disabled,
                InitiallyExpanded = InitiallyExpanded,
                Value = Value,
                NodeContent = NodeContent,
                ParentKey = ParentKey
            };

            Registry.Register(registration);
            _registered = true;
        }
    }

    private void ValidateValueType()
    {
        if (Registry == null) return;

        Type itemValueType = typeof(TValue);
        Type expectedType = Registry.ValueType;

        if (!expectedType.IsAssignableFrom(itemValueType))
        {
            throw new InvalidOperationException(
                $"BUITreeDropdownItem<{itemValueType.Name}> is not compatible with the dropdown's value type. " +
                $"Expected element type: {expectedType.Name}.");
        }
    }
}