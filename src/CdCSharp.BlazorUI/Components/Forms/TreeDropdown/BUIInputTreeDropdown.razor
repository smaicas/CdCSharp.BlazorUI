@* File: Components/Forms/TreeDropdown/BUIInputTreeDropdown.razor *@
@using CdCSharp.BlazorUI.Components.Forms.Dropdown
@using CdCSharp.BlazorUI.Components.Forms.Dropdown.JsInterop
@using CdCSharp.BlazorUI.Core.Abstractions.Behaviors.Design
@using CdCSharp.BlazorUI.Core.Abstractions.Behaviors.Families
@using CdCSharp.BlazorUI.Core.Abstractions.Behaviors.State
@using CdCSharp.BlazorUI.Core.Abstractions.Components
@using CdCSharp.BlazorUI.Core.Css
@using CdCSharp.BlazorUI.Core.Search
@using CdCSharp.BlazorUI.Core.Utilities

@namespace CdCSharp.BlazorUI.Components.Forms

@typeparam TValue

@inherits BUIInputComponentBase<TValue>
@implements IHasSize
@implements IHasFullWidth
@implements IHasLoading
@implements IHasDensity
@implements IHasElevation
@implements IHasBorder
@implements IDropdownJsCallback

@implements IInputFamilyComponent

@{
    base.BuildRenderTree(__builder);
}

<bui-component @attributes="ComputedAttributes"
               data-bui-placement="@GetEffectivePlacement().ToString().ToLowerInvariant()"
               data-bui-input-dropdown-open="@_isOpen">

    @if (_isDeclarativeMode)
    {
        <CascadingValue Value="@((ITreeDropdownItemRegistry)_registry)" Name="TreeDropdownRegistry">
            @ChildContent
        </CascadingValue>
    }

    <div class="bui-stack-column">
        @if (!string.IsNullOrWhiteSpace(Label))
        {
            <label for="@_componentId" class="bui-input__label">
                @Label
                @if (Required)
                {
                    <span class="bui-input__required">*</span>
                }
            </label>
        }

        @if (_structureBuilt)
        {
            <div class="bui-input__wrapper">
                <button id="@_componentId"
                        type="button"
                        class="bui-input__field"
                        @ref="_triggerElement"
                        @onclick="ToggleDropdownAsync"
                        disabled="@(IsDisabled || IsLoading)"
                        aria-expanded="@(_isOpen ? "true" : "false")"
                        aria-haspopup="tree">

                    <span class="bui-dropdown__value @(string.IsNullOrEmpty(GetDisplayValue()) ? "bui-dropdown__placeholder" : "")">
                        @(string.IsNullOrEmpty(GetDisplayValue()) ? Placeholder : GetDisplayValue())
                    </span>

                    <span class="bui-dropdown__arrow">
                        <BUISvgIcon Icon="@(_isOpen? BUIIcons.UI.ChevronUp : BUIIcons.UI.ChevronDown)" Size="Size" />
                    </span>

                    @if (IsLoading && LoadingIndicatorVariant != null)
                    {
                        <div class="bui-input__loading">
                            <BUILoadingIndicator Variant="@LoadingIndicatorVariant" Size="Size" />
                        </div>
                    }
                </button>

                @if (_isOpen)
                {
                    <div class="bui-dropdown__overlay" @onclick="CloseAsync" @onclick:stopPropagation="true"></div>

                    <div class="bui-dropdown__menu bui-tree-dropdown__menu"
                         @ref="_menuElement"
                         role="tree"
                         aria-multiselectable="@_typeResolver.IsMultiple">

                        @if (Searchable)
                        {
                            <div class="bui-dropdown__search">
                                <input type="text"
                                       class="bui-dropdown__search-input"
                                       placeholder="@SearchPlaceholder"
                                       value="@_searchText"
                                       @oninput="OnSearchInput"
                                       @onclick:stopPropagation="true" />
                            </div>
                        }

                        @if (_typeResolver.IsMultiple && ShowSelectAll && _flatNodes.Count > 0)
                        {
                            <div class="bui-dropdown__select-all">
                                <button type="button"
                                        class="bui-dropdown__select-all-button"
                                        @onclick="SelectAll"
                                        @onclick:stopPropagation="true">
                                    @SelectAllText
                                </button>
                                <button type="button"
                                        class="bui-dropdown__select-all-button"
                                        @onclick="DeselectAll"
                                        @onclick:stopPropagation="true">
                                    @DeselectAllText
                                </button>
                            </div>
                        }

                        <div class="bui-dropdown__items bui-tree-dropdown__items" style="max-height: @(MaxHeight)px;">
                            @if (string.IsNullOrWhiteSpace(_searchText))
                            {
                                @foreach (TreeDropdownNode<TValue> node in _rootNodes)
                                {
                                    @RenderNode(node)
                                }
                            }
                            else
                            {
                                @foreach (TreeDropdownNode<TValue> node in GetFilteredNodes())
                                {
                                    @RenderFlatNode(node)
                                }
                            }

                            @if (GetVisibleNodeCount() == 0)
                            {
                                <div class="bui-dropdown__no-options">
                                    @(string.IsNullOrWhiteSpace(_searchText) ? NoOptionsText : NoResultsText)
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }

        @if (IsError && EditContext != null && ValueExpression != null)
        {
            <div class="bui-input__validation">
                <ValidationMessage For="ValueExpression" />
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(HelperText))
        {
            <div class="bui-input__helper-text">
                @HelperText
            </div>
        }
    </div>
</bui-component>

@code {
    private readonly string _componentId = $"bui-tree-dropdown-{Guid.NewGuid():N}";
    private readonly SelectionTypeResolver _typeResolver;
    private TreeDropdownItemRegistry _registry = null!;
    private List<TreeDropdownNode<TValue>> _rootNodes = [];
    private List<TreeDropdownNode<TValue>> _flatNodes = [];
    private Dictionary<string, TreeDropdownNode<TValue>> _nodeMap = [];
    private HashSet<string> _expandedKeys = [];
    private HashSet<string> _loadingKeys = [];
    private ElementReference _triggerElement;
    private ElementReference _menuElement;
    private DropdownCallbacksRelay? _callbacksRelay;
    private bool _jsInitialized;
    private bool _isDeclarativeMode;
    private bool _structureBuilt;
    private bool _isOpen;
    private string _searchText = string.Empty;
    private DropdownPlacement _computedPlacement;

    [Inject] private IDropdownJsInterop JsInterop { get; set; } = default!;

    // IHasSize
    [Parameter] public SizeEnum Size { get; set; } = SizeEnum.Medium;

    // IHasFullWidth
    [Parameter] public bool FullWidth { get; set; }

    // IHasLoading
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public BUILoadingIndicatorVariant? LoadingIndicatorVariant { get; set; }

    // IHasDensity
    [Parameter] public DensityEnum Density { get; set; } = DensityEnum.Standard;

    // IHasElevation
    [Parameter] public int? Elevation { get; set; }
    [Parameter] public CssColor? ElevationColor { get; set; }

    // IHasBorder
    [Parameter] public BorderStyle? Border { get; set; }
    [Parameter] public BorderStyle? BorderTop { get; set; }
    [Parameter] public BorderStyle? BorderRight { get; set; }
    [Parameter] public BorderStyle? BorderBottom { get; set; }
    [Parameter] public BorderStyle? BorderLeft { get; set; }

    // Content (declarative mode)
    [Parameter] public RenderFragment? ChildContent { get; set; }

    // Appearance
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? HelperText { get; set; }

    // Tree Data (binding mode)
    [Parameter] public IEnumerable<TValue>? Items { get; set; }
    [Parameter] public Func<TValue, string>? KeySelector { get; set; }
    [Parameter] public Func<TValue, string>? TextSelector { get; set; }
    [Parameter] public Func<TValue, string>? IconSelector { get; set; }
    [Parameter] public Func<TValue, IEnumerable<TValue>?>? ChildrenSelector { get; set; }
    [Parameter] public Func<TValue, bool>? HasChildrenSelector { get; set; }
    [Parameter] public Func<TValue, bool>? DisabledSelector { get; set; }
    [Parameter] public Func<TValue, Task<IEnumerable<TValue>>>? OnLoadChildren { get; set; }
    [Parameter] public RenderFragment<TreeDropdownNode<TValue>>? NodeTemplate { get; set; }

    // Behavior
    [Parameter] public bool CloseOnSelect { get; set; } = true;
    [Parameter] public DropdownPlacement Placement { get; set; } = DropdownPlacement.Auto;
    [Parameter] public int MaxHeight { get; set; } = 300;
    [Parameter] public bool ExpandToSelection { get; set; } = true;
    [Parameter] public bool ExpandAllOnOpen { get; set; }

    // Search
    [Parameter] public bool Searchable { get; set; }
    [Parameter] public string SearchPlaceholder { get; set; } = "Search...";
    [Parameter] public SearchMode SearchMode { get; set; } = SearchMode.Smart;

    // Multiple selection
    [Parameter] public bool ShowSelectAll { get; set; } = true;
    [Parameter] public string SelectAllText { get; set; } = "Select All";
    [Parameter] public string DeselectAllText { get; set; } = "Deselect All";

    // Text
    [Parameter] public string NoOptionsText { get; set; } = "No options available";
    [Parameter] public string NoResultsText { get; set; } = "No results found";
    [Parameter] public string PathSeparator { get; set; } = " › ";

    // Icons
    [Parameter] public string ExpandIcon { get; set; } = BUIIcons.UI.ChevronRight;
    [Parameter] public string CollapseIcon { get; set; } = BUIIcons.UI.ChevronDown;

    // Events
    [Parameter] public EventCallback<TreeDropdownNode<TValue>> OnNodeClick { get; set; }

    public BUIInputTreeDropdown()
    {
        _typeResolver = new SelectionTypeResolver(typeof(TValue));
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        _registry = new TreeDropdownItemRegistry(_typeResolver.ElementType);
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        _isDeclarativeMode = ChildContent != null && Items == null;

        if (!_isDeclarativeMode && Items != null)
        {
            BuildTreeFromItems();
            _structureBuilt = true;
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);

        if (firstRender && _isDeclarativeMode && !_structureBuilt)
        {
            BuildTreeFromRegistrations();
            _structureBuilt = true;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (_isOpen && !_jsInitialized)
        {
            _callbacksRelay ??= new DropdownCallbacksRelay(this);
            await JsInterop.InitializeAsync(_triggerElement, _menuElement, _callbacksRelay.DotNetReference, _componentId);
            _jsInitialized = true;

            if (Placement == DropdownPlacement.Auto)
            {
                await ComputePlacementAsync();
            }

            if (Searchable)
            {
                await JsInterop.FocusSearchInputAsync(_componentId);
            }
        }
    }

    private void BuildTreeFromItems()
    {
        _rootNodes.Clear();
        _flatNodes.Clear();
        _nodeMap.Clear();

        if (Items == null) return;

        foreach (TValue item in Items)
        {
            TreeDropdownNode<TValue> node = BuildNodeFromItem(item, null, 0);
            _rootNodes.Add(node);
        }
    }

    private TreeDropdownNode<TValue> BuildNodeFromItem(TValue item, TreeDropdownNode<TValue>? parent, int depth)
    {
        string key = KeySelector?.Invoke(item) ?? item?.GetHashCode().ToString() ?? Guid.NewGuid().ToString();
        string text = TextSelector?.Invoke(item) ?? item?.ToString() ?? key;
        string? icon = IconSelector?.Invoke(item);
        bool isDisabled = DisabledSelector?.Invoke(item) ?? false;
        IEnumerable<TValue>? children = ChildrenSelector?.Invoke(item);
        bool hasChildren = HasChildrenSelector?.Invoke(item) ?? children?.Any() ?? false;

        TreeDropdownNode<TValue> node = new()
        {
            Key = key,
            Item = item,
            Text = text,
            Icon = icon,
            IsDisabled = isDisabled,
            HasChildren = hasChildren,
            Depth = depth,
            Parent = parent
        };

        _nodeMap[key] = node;
        _flatNodes.Add(node);

        if (children != null)
        {
            foreach (TValue child in children)
            {
                TreeDropdownNode<TValue> childNode = BuildNodeFromItem(child, node, depth + 1);
                node.Children.Add(childNode);
            }
        }

        return node;
    }

    private void BuildTreeFromRegistrations()
    {
        _rootNodes.Clear();
        _flatNodes.Clear();
        _nodeMap.Clear();

        IReadOnlyList<TreeDropdownItemRegistration> registrations = _registry.GetRegistrations();
        _registry.Clear();

        Dictionary<string, List<TreeDropdownItemRegistration>> childrenByParent = new();

        foreach (TreeDropdownItemRegistration reg in registrations)
        {
            string parentKey = reg.ParentKey ?? string.Empty;

            if (!childrenByParent.ContainsKey(parentKey))
            {
                childrenByParent[parentKey] = new List<TreeDropdownItemRegistration>();
            }
            childrenByParent[parentKey].Add(reg);
        }

        if (childrenByParent.TryGetValue(string.Empty, out List<TreeDropdownItemRegistration>? roots))
        {
            foreach (TreeDropdownItemRegistration reg in roots)
            {
                TreeDropdownNode<TValue> node = BuildNodeFromRegistration(reg, null, 0, childrenByParent);
                _rootNodes.Add(node);
            }
        }
    }

    private TreeDropdownNode<TValue> BuildNodeFromRegistration(
        TreeDropdownItemRegistration reg,
        TreeDropdownNode<TValue>? parent,
        int depth,
        Dictionary<string, List<TreeDropdownItemRegistration>> childrenByParent)
    {
        bool hasChildren = childrenByParent.ContainsKey(reg.Key);

        TreeDropdownNode<TValue> node = new()
        {
            Key = reg.Key,
            Item = reg.Value != null ? (TValue)reg.Value : default,
            Text = reg.Text ?? reg.Value?.ToString() ?? reg.Key,
            Icon = reg.Icon,
            IsDisabled = reg.IsDisabled,
            HasChildren = hasChildren,
            Depth = depth,
            Parent = parent,
            CustomContent = reg.NodeContent
        };

        _nodeMap[reg.Key] = node;
        _flatNodes.Add(node);

        if (reg.InitiallyExpanded)
        {
            _expandedKeys.Add(reg.Key);
        }

        if (childrenByParent.TryGetValue(reg.Key, out List<TreeDropdownItemRegistration>? children))
        {
            foreach (TreeDropdownItemRegistration childReg in children)
            {
                TreeDropdownNode<TValue> childNode = BuildNodeFromRegistration(childReg, node, depth + 1, childrenByParent);
                node.Children.Add(childNode);
            }
        }

        return node;
    }

    private async Task ComputePlacementAsync()
    {
        DropdownPosition position = await JsInterop.GetPositionAsync(_componentId);
        double spaceBelow = position.ViewportHeight - position.TriggerTop - position.TriggerHeight;
        double spaceAbove = position.TriggerTop;

        _computedPlacement = spaceBelow >= MaxHeight || spaceBelow >= spaceAbove
            ? DropdownPlacement.Bottom
            : DropdownPlacement.Top;

        StateHasChanged();
    }

    private DropdownPlacement GetEffectivePlacement()
    {
        return Placement == DropdownPlacement.Auto ? _computedPlacement : Placement;
    }

    private string GetDisplayValue()
    {
        if (CurrentValue == null) return string.Empty;

        List<object> selectedValues = _typeResolver.ExtractValues(CurrentValue).ToList();
        if (selectedValues.Count == 0) return string.Empty;

        if (_typeResolver.IsMultiple)
        {
            return $"{selectedValues.Count} selected";
        }

        TreeDropdownNode<TValue>? node = FindNodeByValue(selectedValues[0]);
        if (node == null) return selectedValues[0]?.ToString() ?? string.Empty;

        return GetNodePath(node);
    }

    private string GetNodePath(TreeDropdownNode<TValue> node)
    {
        List<string> parts = [];
        TreeDropdownNode<TValue>? current = node;

        while (current != null)
        {
            parts.Insert(0, current.Text);
            current = current.Parent;
        }

        return string.Join(PathSeparator, parts);
    }

    private TreeDropdownNode<TValue>? FindNodeByValue(object? value)
    {
        if (value == null) return null;
        return _flatNodes.FirstOrDefault(n => _typeResolver.ValuesEqual(n.Item, value));
    }

    private bool IsNodeSelected(TreeDropdownNode<TValue> node)
    {
        return _typeResolver.ContainsValue(CurrentValue, node.Item);
    }

    private bool IsNodeExpanded(string key) => _expandedKeys.Contains(key);
    private bool IsNodeLoading(string key) => _loadingKeys.Contains(key);

    private int GetVisibleNodeCount()
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return _flatNodes.Count;
        }
        return GetFilteredNodes().Count();
    }

    private IEnumerable<TreeDropdownNode<TValue>> GetFilteredNodes()
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return _flatNodes;
        }

        return SearchAlgorithms
            .Search(_flatNodes, _searchText, n => n.Text, SearchMode)
            .Select(r => r.Item);
    }

    private RenderFragment RenderNode(TreeDropdownNode<TValue> node) => __builder =>
    {
        bool isSelected = IsNodeSelected(node);
        bool isExpanded = IsNodeExpanded(node.Key);
        bool isLoading = IsNodeLoading(node.Key);

        <div class="bui-tree-dropdown__node @(node.IsDisabled ? "bui-tree-dropdown__node--disabled" : "") @(isSelected ? "bui-tree-dropdown__node--selected" : "")"
             data-depth="@node.Depth"
             data-key="@node.Key">

            <div class="bui-dropdown__option bui-tree-dropdown__node-content"
                 style="padding-left: calc(@(node.Depth) * var(--bui-tree-dropdown-indent, 1.25rem))"
                 role="treeitem"
                 aria-selected="@isSelected"
                 @onclick="() => HandleNodeClickAsync(node)"
                 @onclick:stopPropagation="true">

                @if (node.HasChildren)
                {
                    <button type="button"
                            class="bui-tree-dropdown__expander"
                            @onclick="() => ToggleExpandAsync(node)"
                            @onclick:stopPropagation="true"
                            disabled="@node.IsDisabled">
                        @if (isLoading)
                        {
                            <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Size="Size" />
                        }
                        else
                        {
                            <BUISvgIcon Icon="@(isExpanded? CollapseIcon : ExpandIcon)" Size="Size" />
                        }
                    </button>
                }
                else
                {
                    <span class="bui-tree-dropdown__expander-placeholder"></span>
                }

                @if (_typeResolver.IsMultiple)
                {
                    <span class="bui-dropdown__checkbox">
                        <BUISvgIcon Icon="@(isSelected? BUIIcons.MaterialIconsRound.i_check_box : BUIIcons.MaterialIconsRound.i_check_box_outline_blank)"
                                    Size="@Size" />
                    </span>
                }

                <span class="bui-dropdown__option-content bui-tree-dropdown__node-label">
                    @if (_isDeclarativeMode && node.CustomContent != null)
                    {
                        @node.CustomContent
                    }
                    else if (!_isDeclarativeMode && NodeTemplate != null)
                    {
                        @NodeTemplate(node)
                    }
                    else
                    {
                        @if (!string.IsNullOrEmpty(node.Icon))
                        {
                            <BUISvgIcon Icon="@node.Icon" Size="Size" class="bui-tree-dropdown__node-icon" />
                        }
                        <span class="bui-tree-dropdown__node-text">@node.Text</span>
                    }
                </span>
            </div>

            @if (node.HasChildren && isExpanded)
            {
                <div class="bui-tree-dropdown__children">
                    @foreach (TreeDropdownNode<TValue> child in node.Children)
                    {
                        @RenderNode(child)
                    }
                </div>
            }
        </div>
    };

    private RenderFragment RenderFlatNode(TreeDropdownNode<TValue> node) => __builder =>
    {
        bool isSelected = IsNodeSelected(node);

        <div class="bui-dropdown__option bui-tree-dropdown__node--flat @(node.IsDisabled ? "bui-dropdown__option--disabled" : "") @(isSelected ? "bui-dropdown__option--selected" : "")"
             data-key="@node.Key"
             role="treeitem"
             aria-selected="@isSelected"
             @onclick="() => HandleNodeClickAsync(node)"
             @onclick:stopPropagation="true">

            @if (_typeResolver.IsMultiple)
            {
                <span class="bui-dropdown__checkbox">
                    <BUISvgIcon Icon="@(isSelected? BUIIcons.MaterialIconsRound.i_check_box : BUIIcons.MaterialIconsRound.i_check_box_outline_blank)"
                                Size="@Size" />
                </span>
            }

            <span class="bui-dropdown__option-content bui-tree-dropdown__node-label">
                @if (!string.IsNullOrEmpty(node.Icon))
                {
                    <BUISvgIcon Icon="@node.Icon" Size="Size" class="bui-tree-dropdown__node-icon" />
                }
                <span class="bui-tree-dropdown__node-text">@GetNodePath(node)</span>
            </span>
        </div>
    };

    private async Task ToggleDropdownAsync()
    {
        if (IsDisabled || IsLoading) return;

        if (_isOpen)
        {
            await CloseAsync();
        }
        else
        {
            await OpenAsync();
        }
    }

    private Task OpenAsync()
    {
        _isOpen = true;
        _searchText = string.Empty;
        _computedPlacement = Placement == DropdownPlacement.Auto ? DropdownPlacement.Bottom : Placement;

        if (ExpandToSelection)
        {
            ExpandToSelectedNodes();
        }

        if (ExpandAllOnOpen)
        {
            ExpandAllNodes();
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task CloseAsync()
    {
        if (!_isOpen) return;

        _isOpen = false;
        _jsInitialized = false;

        if (_callbacksRelay != null)
        {
            await JsInterop.DisposeAsync(_componentId);
        }

        StateHasChanged();
    }

    private void ExpandToSelectedNodes()
    {
        List<object> selectedValues = _typeResolver.ExtractValues(CurrentValue).ToList();

        foreach (object value in selectedValues)
        {
            TreeDropdownNode<TValue>? node = FindNodeByValue(value);
            if (node != null)
            {
                ExpandParents(node);
            }
        }
    }

    private void ExpandParents(TreeDropdownNode<TValue> node)
    {
        TreeDropdownNode<TValue>? parent = node.Parent;
        while (parent != null)
        {
            _expandedKeys.Add(parent.Key);
            parent = parent.Parent;
        }
    }

    private void ExpandAllNodes()
    {
        foreach (TreeDropdownNode<TValue> node in _flatNodes.Where(n => n.HasChildren))
        {
            _expandedKeys.Add(node.Key);
        }
    }

    private async Task ToggleExpandAsync(TreeDropdownNode<TValue> node)
    {
        if (IsNodeExpanded(node.Key))
        {
            _expandedKeys.Remove(node.Key);
        }
        else
        {
            if (OnLoadChildren != null && node.Children.Count == 0 && node.HasChildren && node.Item != null)
            {
                await LoadChildrenAsync(node);
            }
            _expandedKeys.Add(node.Key);
        }
        StateHasChanged();
    }

    private async Task LoadChildrenAsync(TreeDropdownNode<TValue> node)
    {
        if (OnLoadChildren == null || node.Item == null) return;

        _loadingKeys.Add(node.Key);
        StateHasChanged();

        try
        {
            IEnumerable<TValue> children = await OnLoadChildren(node.Item);

            node.Children.Clear();
            foreach (TValue child in children)
            {
                TreeDropdownNode<TValue> childNode = BuildNodeFromItem(child, node, node.Depth + 1);
                node.Children.Add(childNode);
            }

            node.HasChildren = node.Children.Count > 0;
        }
        finally
        {
            _loadingKeys.Remove(node.Key);
            StateHasChanged();
        }
    }

    private async Task HandleNodeClickAsync(TreeDropdownNode<TValue> node)
    {
        if (node.IsDisabled) return;

        await OnNodeClick.InvokeAsync(node);

        if (_typeResolver.IsMultiple)
        {
            List<object> currentValues = _typeResolver.ExtractValues(CurrentValue).ToList();

            if (currentValues.Any(v => _typeResolver.ValuesEqual(v, node.Item)))
            {
                currentValues.RemoveAll(v => _typeResolver.ValuesEqual(v, node.Item));
            }
            else if (node.Item != null)
            {
                currentValues.Add(node.Item);
            }

            CurrentValue = _typeResolver.CreateValue<TValue>(currentValues);
        }
        else
        {
            CurrentValue = _typeResolver.CreateValue<TValue>(node.Item != null ? [node.Item] : []);

            if (CloseOnSelect)
            {
                await CloseAsync();
            }
        }
    }

    private void SelectAll()
    {
        if (!_typeResolver.IsMultiple || IsDisabled) return;

        List<object> allValues = GetFilteredNodes()
            .Where(n => !n.IsDisabled && n.Item != null)
            .Select(n => (object)n.Item!)
            .ToList();

        CurrentValue = _typeResolver.CreateValue<TValue>(allValues);
    }

    private void DeselectAll()
    {
        if (!_typeResolver.IsMultiple || IsDisabled) return;
        CurrentValue = _typeResolver.CreateValue<TValue>([]);
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString() ?? string.Empty;
        StateHasChanged();
    }

    // IDropdownJsCallback implementation
    Task IDropdownJsCallback.OnClickOutside() => CloseAsync();

    async Task IDropdownJsCallback.OnKeyDown(string key, bool shiftKey, bool ctrlKey)
    {
        switch (key)
        {
            case "Escape":
                await CloseAsync();
                break;

            case "ArrowDown":
                if (!_isOpen)
                {
                    await OpenAsync();
                }
                break;

            case "Tab":
                await CloseAsync();
                break;
        }
    }

    async Task<DropdownPosition> IDropdownJsCallback.OnRequestPosition()
    {
        return await JsInterop.GetPositionAsync(_componentId);
    }

    protected override bool TryParseValueFromString(string? value, out TValue result, out string validationErrorMessage)
    {
        validationErrorMessage = string.Empty;
        result = default!;
        return true;
    }

    public override async ValueTask DisposeAsync()
    {
        if (_jsInitialized)
        {
            await JsInterop.DisposeAsync(_componentId);
        }

        _callbacksRelay?.Dispose();

        await base.DisposeAsync();
    }
}