@* @using CdCSharp.BlazorUI.Components.Forms.Abstractions
@using Microsoft.AspNetCore.Components.Forms
@typeparam TValue

@inherits UIInputComponentBase<TValue>

<div class="ui-input-number">
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <label for="@_inputId" class="ui-input__label">
            @Label
            @if (Required)
            {
                <span class="ui-input__required">*</span>
            }
        </label>
    }

    <div class="ui-input__container ui-input-number__container">
        @if (ShowSteppers)
        {
            <button type="button"
                    class="ui-input-number__stepper ui-input-number__stepper--down"
                    @onclick="StepDown"
                    disabled="@(IsDisabled || IsAtMin)">
                <span>−</span>
            </button>
        }

        <input @ref="_inputElement"
               @attributes="ComputedAttributes"
               type="number"
               id="@_inputId"
               value="@CurrentValueAsString"
               @onchange="HandleChange"
               step="@Step"
               min="@Min"
               max="@Max" />

        @if (ShowSteppers)
        {
            <button type="button"
                    class="ui-input-number__stepper ui-input-number__stepper--up"
                    @onclick="StepUp"
                    disabled="@(IsDisabled || IsAtMax)">
                <span>+</span>
            </button>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(HelperText))
    {
        <div class="ui-input__helper-text">
            @HelperText
        </div>
    }
</div>

@code {
    private ElementReference _inputElement;
    private string _inputId = $"ui-input-number-{Guid.NewGuid():N}";

    [Parameter] public bool ShowSteppers { get; set; } = true;
    [Parameter] public string? Step { get; set; }
    [Parameter] public string? Min { get; set; }
    [Parameter] public string? Max { get; set; }

    private bool IsAtMin => Min != null && CurrentValue?.ToString() == Min;
    private bool IsAtMax => Max != null && CurrentValue?.ToString() == Max;

    private async Task HandleChange(ChangeEventArgs e)
    {
        CurrentValueAsString = e.Value?.ToString() ?? string.Empty;
    }

    private async Task StepUp()
    {
        // Implementation depends on TValue
        await IncrementValue();
    }

    private async Task StepDown()
    {
        // Implementation depends on TValue
        await DecrementValue();
    }

    private Task IncrementValue()
    {
        // Logic to increment based on TValue and Step
        return Task.CompletedTask;
    }

    private Task DecrementValue()
    {
        // Logic to decrement based on TValue and Step
        return Task.CompletedTask;
    }

    public ElementReference GetRootElement() => _inputElement;
} *@