@using CdCSharp.BlazorUI.Components.Utils
@using CdCSharp.BlazorUI.SyntaxHighlight

@namespace CdCSharp.BlazorUI.Components

@inherits BUIComponentBase
@implements IHasSize

@inject IClipboardJsInterop Clipboard

<bui-component @attributes="ComputedAttributes">
    <div class="bui-code-block__header">
        <span class="bui-code-block__title">
            @(Title ?? Language.ToString().ToUpperInvariant())
        </span>

        <button class="bui-code-block__copy"
                @onclick="CopyAsync"
                disabled="@_copied">
            @(_copied ? "✓ Copied" : "Copy")
        </button>
    </div>

    <div class="bui-code-block__content">
        @HighlightedCode
    </div>
</bui-component>

@code {
    [Parameter, EditorRequired] public string Code { get; set; } = string.Empty;
    [Parameter] public SyntaxHighlightLanguage Language { get; set; } = SyntaxHighlightLanguage.CSharp;
    [Parameter] public string? Title { get; set; }

    [Parameter] public SizeEnum Size { get; set; } = SizeEnum.Medium;

    private bool _copied;
    private Highlighter _highlighter = new Highlighter();

    private MarkupString HighlightedCode
    {
        get
        {
            if (Code == null) return (MarkupString)string.Empty;

            try
            {
                string result = _highlighter.Highlight(Language.ToString(), NormalizeIndentation(Code));
                return (MarkupString)result;
            }
            catch
            {
                return (MarkupString)System.Web.HttpUtility.HtmlEncode(NormalizeIndentation(Code));
            }
        }
    }

    private async Task CopyAsync()
    {
        await Clipboard.CopyTextAsync(NormalizeIndentation(Code));
        _copied = true;

        await Task.Delay(1500);
        _copied = false;
        StateHasChanged();
    }

    private static string NormalizeIndentation(string code)
    {
        if (string.IsNullOrWhiteSpace(code)) return string.Empty;

        string[] lines = code.Split('\n');

        int minIndent = lines
            .Where(l => !string.IsNullOrWhiteSpace(l))
            .Select(l => l.TakeWhile(char.IsWhiteSpace).Count())
            .DefaultIfEmpty(0)
            .Min();

        return string.Join(
            "\n",
            lines.Select(l => l.Length >= minIndent ? l[minIndent..] : l)
        ).Trim();
    }
}