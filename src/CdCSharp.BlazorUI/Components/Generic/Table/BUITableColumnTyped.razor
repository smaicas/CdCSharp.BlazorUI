@namespace CdCSharp.BlazorUI.Components
@typeparam TItem
@typeparam TValue
@inherits BUITableColumnBase<TItem, TValue>

@{
    base.BuildRenderTree(__builder);
}

@code {
    protected override TableColumnRegistration<TItem> CreateRegistration() => new()
    {
        Header = Header,
        ValueSelector = CompiledSelector,
        Template = Template,
        Format = Format,
        Align = Align,
        Width = Width,
        HeaderClass = HeaderClass,
        CellClass = CellClass,
        Visible = Visible
    };
}