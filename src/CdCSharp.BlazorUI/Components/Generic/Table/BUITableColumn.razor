@namespace CdCSharp.BlazorUI.Components
@typeparam TItem
@inherits BUITableColumnBase<TItem>

@{
    base.BuildRenderTree(__builder);
}

@code {
    protected override TableColumnRegistration<TItem> CreateRegistration() => new()
    {
        Header = Header,
        ValueSelector = null, // Non-generic column has no value selector
        Template = Template,
        Format = null,
        Align = Align,
        Width = Width,
        HeaderClass = HeaderClass,
        CellClass = CellClass,
        Visible = Visible
    };
}