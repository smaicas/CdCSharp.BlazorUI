@using CdCSharp.BlazorUI.Core.Abstractions.Components
@using Microsoft.AspNetCore.Components.Web.Virtualization

@namespace CdCSharp.BlazorUI.Components
@attribute [GenerateComponentInfo]

@typeparam TItem
@inherits BUIDataCollectionBase<TItem, BUIDataGrid<TItem>, DataGridVariant>

@{
    base.BuildRenderTree(__builder);
}

<CascadingValue Value="@((IDataColumnRegistry<TItem>)ColumnRegistry)" Name="DataColumnRegistry">
    @Columns
</CascadingValue>

<bui-component @attributes="ComputedAttributes">
    @if (ColumnsBuilt)
    {
        @if (Filterable || ShowPageSizeSelector)
        {
            <div class="bui-dc__toolbar">
                @if (Filterable)
                {
                    <div class="bui-dc__filter">
                        <_BUIInText Value="@State.FilterText"
                                    Placeholder="@FilterPlaceholder"
                                    AriaLabel="@FilterPlaceholder"
                                    UpdateOnInput="true"
                                    OnInput="HandleFilterInputChange" />
                        @if (!string.IsNullOrEmpty(State.FilterText))
                        {
                            <_BUIBtn Icon="@BUIIcons.UI.Close"
                                     AriaLabel="Clear filter"
                                     OnClick="ClearFilterClicked" />
                        }
                    </div>
                }

                <div class="bui-dc__toolbar-spacer"></div>

                @if (SelectionMode != SelectionMode.None && State.SelectedItems.Any())
                {
                    <div class="bui-dc__selection-info">
                        <span>@State.SelectedItems.Count selected</span>
                        <_BUIBtn OnClick="ClearSelectionClicked">
                            Clear
                        </_BUIBtn>
                    </div>
                }

                @if (ShowPageSizeSelector)
                {
                    <div class="bui-dc__page-size">
                        <label>Show</label>
                        <_BUIInSelect Value="@State.PageSize.ToString()"
                                      AriaLabel="Items per page"
                                      ValueChanged="HandlePageSizeSelectChange">
                            @foreach (int size in PageSizeOptions)
                            {
                                <option value="@size">@size</option>
                            }
                        </_BUIInSelect>
                    </div>
                }
            </div>
        }

        @if (Loading && LoadingContent != null)
        {
            <div class="bui-dc__loading">
                @LoadingContent
            </div>
        }
        else
        {
            <div class="bui-datagrid__container" style="@GetContainerStyle()">
                <table class="bui-datagrid__table" role="grid" aria-rowcount="@FilteredItems.Count">
                    <thead class="bui-datagrid__header">
                        <tr role="row">
                            @if (SelectionMode != SelectionMode.None)
                            {
                                <th class="bui-datagrid__header-cell bui-datagrid__select-cell" role="columnheader" scope="col">
                                    @if (SelectionMode == SelectionMode.Multiple)
                                    {
                                        <_BUIBtn Icon="@GetSelectAllIcon()"
                                                 Size="SizeEnum.Small"
                                                 AriaLabel="@(IsAllSelected() ? "Deselect all" : "Select all")"
                                                 OnClick="HandleSelectAllClick" />
                                    }
                                </th>
                            }
                            @foreach (DataColumnRegistration<TItem> col in VisibleColumns)
                            {
                                <th class="bui-datagrid__header-cell @GetAlignClass(col.Align, "bui-datagrid__cell") @col.HeaderClass"
                                    style="@(col.Width != null ? $"width: {col.Width}" : null)"
                                    role="columnheader"
                                    scope="col"
                                    aria-sort="@GetAriaSort(col)">
                                    @if (col.Sortable && Sortable)
                                    {
                                        <button type="button"
                                                class="bui-datagrid__sort-btn"
                                                @onclick="() => HandleSort(col)">
                                            <span>@col.Header</span>
                                            <span class="bui-datagrid__sort-icon" aria-hidden="true">
                                                @if (State.SortColumn == col.Header)
                                                {
                                                    @if (State.SortDirection == SortDirection.Ascending)
                                                    {
                                                        <BUISvgIcon Icon="@BUIIcons.UI.ArrowUpward" Size="SizeEnum.Small" />
                                                    }
                                                    else if (State.SortDirection == SortDirection.Descending)
                                                    {
                                                        <BUISvgIcon Icon="@BUIIcons.UI.ArrowDownward" Size="SizeEnum.Small" />
                                                    }
                                                }
                                            </span>
                                        </button>
                                    }
                                    else
                                    {
                                        @col.Header
                                    }
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (EnableVirtualization && !string.IsNullOrEmpty(Height))
                        {
                            <Virtualize Items="@IndexedItems" Context="indexed">
                                @RenderRow(indexed.Item, indexed.Index)
                            </Virtualize>
                        }
                        else if (ProcessedItems.Any())
                        {
                            int rowIndex = 0;
                            @foreach (TItem item in ProcessedItems)
                            {
                                @RenderRow(item, rowIndex)
                                rowIndex++;
                            }
                        }
                        else
                        {
                            <tr class="bui-datagrid__empty-row" role="row">
                                <td colspan="@(VisibleColumns.Count + (SelectionMode != SelectionMode.None ? 1 : 0))"
                                    class="bui-datagrid__empty-cell">
                                    @if (EmptyContent != null)
                                    {
                                        @EmptyContent
                                    }
                                    else
                                    {
                                        <div class="bui-dc__empty">
                                            <span class="bui-dc__empty-icon">📋</span>
                                            <p class="bui-dc__empty-text">No data available</p>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>

                    @if (FooterTemplate != null)
                    {
                        <tfoot class="bui-datagrid__footer">
                            @FooterTemplate
                        </tfoot>
                    }
                </table>
            </div>
        }

        @if (PageSize.HasValue && FilteredItems.Any())
        {
            <_BUIPagination CurrentPage="@State.CurrentPage"
                            TotalPages="@TotalPages"
                            TotalItems="@FilteredItems.Count"
                            PageSize="@State.PageSize"
                            OnPageChange="ChangePage" />
        }
    }
</bui-component>

@code {
    [Parameter] public bool FixedHeader { get; set; }
    [Parameter] public RenderFragment<TItem>? RowTemplate { get; set; }
    [Parameter] public RenderFragment? FooterTemplate { get; set; }

    [Parameter] public BorderStyle? CellBorder { get; set; }
    [Parameter] public BorderStyle? RowBorder { get; set; }

    public override DataGridVariant DefaultVariant => DataGridVariant.Default;

    protected override IReadOnlyDictionary<DataGridVariant, Func<BUIDataGrid<TItem>, RenderFragment>> BuiltInTemplates { get; } =
        new Dictionary<DataGridVariant, Func<BUIDataGrid<TItem>, RenderFragment>>();

    private List<(TItem Item, int Index)> IndexedItems =>
        ProcessedItems.Select((item, i) => (item, i)).ToList();

    public override void BuildComponentCssVariables(Dictionary<string, string> cssVariables)
    {
        base.BuildComponentCssVariables(cssVariables);

        if (CellBorder != null)
        {
            BorderCssValues values = CellBorder.GetCssValues();
            if (values.All != null)
                cssVariables[FeatureDefinitions.InlineVariables.DcCellBorder] = values.All;
            if (values.Top != null)
                cssVariables[FeatureDefinitions.InlineVariables.DcCellBorderTop] = values.Top;
            if (values.Right != null)
                cssVariables[FeatureDefinitions.InlineVariables.DcCellBorderRight] = values.Right;
            if (values.Bottom != null)
                cssVariables[FeatureDefinitions.InlineVariables.DcCellBorderBottom] = values.Bottom;
            if (values.Left != null)
                cssVariables[FeatureDefinitions.InlineVariables.DcCellBorderLeft] = values.Left;
        }

        if (RowBorder != null)
        {
            BorderCssValues values = RowBorder.GetCssValues();
            if (values.All != null)
                cssVariables[FeatureDefinitions.InlineVariables.DcRowBorder] = values.All;
            if (values.Top != null)
                cssVariables[FeatureDefinitions.InlineVariables.DcRowBorderTop] = values.Top;
            if (values.Right != null)
                cssVariables[FeatureDefinitions.InlineVariables.DcRowBorderRight] = values.Right;
            if (values.Bottom != null)
                cssVariables[FeatureDefinitions.InlineVariables.DcRowBorderBottom] = values.Bottom;
            if (values.Left != null)
                cssVariables[FeatureDefinitions.InlineVariables.DcRowBorderLeft] = values.Left;
        }
    }

    private RenderFragment RenderRow(TItem item, int index) => __builder =>
    {
        bool isSelected = State.IsSelected(item);
        string? patternStyle = GetItemPatternStyle(index);

        string rowClasses = $"bui-datagrid__row {(isSelected ? "bui-datagrid__row--selected" : "")} {(IsInteractiveRow ? "bui-datagrid__row--interactive" : "")}";

        <tr @key="item"
            class="@rowClasses"
            style="@patternStyle"
            role="row"
            tabindex="@(IsInteractiveRow ? 0 : -1)"
            @onclick="() => HandleRowClick(item)"
            @onkeydown="e => HandleRowKeyDown(e, item)"
            @onkeydown:preventDefault="PreventRowKeyDown">

            @if (SelectionMode != SelectionMode.None)
            {
                <td class="bui-datagrid__select-cell" role="gridcell">
                    <_BUICheckMark Checked="@isSelected"
                                   Mode="@(SelectionMode == SelectionMode.Single ? _BUICheckMark.CheckMarkMode.Radio : _BUICheckMark.CheckMarkMode.Checkbox)"
                                   Size="@Size" />
                </td>
            }

            @if (RowTemplate != null)
            {
                @RowTemplate(item)
            }
            else
            {
                @foreach (DataColumnRegistration<TItem> col in VisibleColumns)
                {
                    <td class="bui-datagrid__cell @GetAlignClass(col.Align, "bui-datagrid__cell") @col.CellClass"
                        role="gridcell">
                        @if (col.Template != null)
                        {
                            @col.Template(item)
                        }
                        else if (col.ValueSelector != null)
                        {
                            @FormatValue(col.ValueSelector(item), col.Format)
                        }
                    </td>
                }
            }
        </tr>
    };

    private string GetContainerStyle()
    {
        if (EnableVirtualization && !string.IsNullOrEmpty(Height))
            return $"max-height: {Height}; overflow-y: auto;";

        if (FixedHeader && !string.IsNullOrEmpty(Height))
            return $"max-height: {Height}; overflow-y: auto;";

        return string.Empty;
    }

    private string GetSelectAllIcon()
    {
        if (!ProcessedItems.Any())
            return BUIIcons.MaterialIconsRound.i_check_box_outline_blank;

        if (IsAllSelected())
            return BUIIcons.MaterialIconsRound.i_check_box;

        if (State.SelectedItems.Any())
            return BUIIcons.MaterialIconsOutlined.i_indeterminate_check_box;

        return BUIIcons.MaterialIconsRound.i_check_box_outline_blank;
    }

    private async Task HandleSelectAllClick(MouseEventArgs e)
    {
        if (IsAllSelected())
            State.ClearSelection();
        else
            State.SelectAll(ProcessedItems);

        await NotifySelectionChanged();
    }
}