@using CdCSharp.BlazorUI.Core.Abstractions.Components
@using Microsoft.AspNetCore.Components.Web.Virtualization

@namespace CdCSharp.BlazorUI.Components

@typeparam TItem
@inherits BUIDataCollectionBase<TItem, BUIDataCards<TItem>, DataCardsVariant>

@{
    base.BuildRenderTree(__builder);
}

<CascadingValue Value="@((IDataColumnRegistry<TItem>)ColumnRegistry)" Name="DataColumnRegistry">
    @Columns
</CascadingValue>

<bui-component @attributes="ComputedAttributes">
    @if (ColumnsBuilt)
    {
        @if (Filterable || ShowPageSizeSelector || (Sortable && SortableColumns.Any()))
        {
            <div class="bui-dc__toolbar">
                @if (Filterable)
                {
                    <div class="bui-dc__filter">
                        <_BUIInText Value="@State.FilterText"
                                    Placeholder="@FilterPlaceholder"
                                    AriaLabel="@FilterPlaceholder"
                                    UpdateOnInput="true"
                                    OnInput="HandleFilterInputChange" />
                        @if (!string.IsNullOrEmpty(State.FilterText))
                        {
                            <_BUIBtn Icon="@BUIIcons.UI.Close"
                                     AriaLabel="Clear filter"
                                     OnClick="ClearFilterClicked" />
                        }
                    </div>
                }

                <div class="bui-dc__toolbar-spacer"></div>

                @if (SelectionMode != SelectionMode.None && State.SelectedItems.Any())
                {
                    <div class="bui-dc__selection-info">
                        <span>@State.SelectedItems.Count selected</span>
                        <_BUIBtn OnClick="ClearSelectionClicked">
                            Clear
                        </_BUIBtn>
                    </div>
                }

                @if (Sortable && SortableColumns.Any())
                {
                    <div class="bui-datacards__sort">
                        <label>Sort by</label>
                        <_BUIInSelect Value="@State.SortColumn"
                                      AriaLabel="Sort by column"
                                      ValueChanged="HandleSortSelectChange">
                            <option value="">None</option>
                            @foreach (DataColumnRegistration<TItem> col in SortableColumns)
                            {
                                <option value="@col.Header">@col.Header</option>
                            }
                        </_BUIInSelect>
                        @if (!string.IsNullOrEmpty(State.SortColumn))
                        {
                            <_BUIBtn Icon="@(State.SortDirection == SortDirection.Ascending ? BUIIcons.UI.ArrowUpward : BUIIcons.UI.ArrowDownward)"
                                     AriaLabel="Toggle sort direction"
                                     OnClick="ToggleSortDirectionClicked" />
                        }
                    </div>
                }

                @if (ShowPageSizeSelector)
                {
                    <div class="bui-dc__page-size">
                        <label>Show</label>
                        <_BUIInSelect Value="@State.PageSize.ToString()"
                                      AriaLabel="Items per page"
                                      ValueChanged="HandlePageSizeSelectChange">
                            @foreach (int size in PageSizeOptions)
                            {
                                <option value="@size">@size</option>
                            }
                        </_BUIInSelect>
                    </div>
                }
            </div>
        }

        @if (Loading && LoadingContent != null)
        {
            <div class="bui-dc__loading">
                @LoadingContent
            </div>
        }
        else if (ProcessedItems.Any())
        {
            <div class="bui-datacards__grid"
                 style="@GetGridStyle()"
                 role="list">
                @if (EnableVirtualization && !string.IsNullOrEmpty(Height))
                {
                    <Virtualize Items="@ProcessedItems" Context="item">
                        @RenderCard(item)
                    </Virtualize>
                }
                else
                {
                    @foreach (TItem item in ProcessedItems)
                    {
                        @RenderCard(item)
                    }
                }
            </div>
        }
        else
        {
            @if (EmptyContent != null)
            {
                @EmptyContent
            }
            else
            {
                <div class="bui-dc__empty">
                    <span class="bui-dc__empty-icon">📋</span>
                    <p class="bui-dc__empty-text">No data available</p>
                </div>
            }
        }

        @if (PageSize.HasValue && FilteredItems.Any())
        {
            <_BUIPagination CurrentPage="@State.CurrentPage"
                            TotalPages="@TotalPages"
                            TotalItems="@FilteredItems.Count"
                            PageSize="@State.PageSize"
                            OnPageChange="ChangePage" />
        }
    }
</bui-component>

@code {
    [Parameter] public int ColumnsCount { get; set; } = 3;
    [Parameter] public string Gap { get; set; } = "1rem";
    [Parameter] public string? MinCardWidth { get; set; } = "280px";
    [Parameter] public RenderFragment<TItem>? CardTemplate { get; set; }
    [Parameter] public RenderFragment<TItem>? CardHeaderTemplate { get; set; }
    [Parameter] public RenderFragment<TItem>? CardFooterTemplate { get; set; }

    public override DataCardsVariant DefaultVariant => DataCardsVariant.Default;

    protected override IReadOnlyDictionary<DataCardsVariant, Func<BUIDataCards<TItem>, RenderFragment>> BuiltInTemplates { get; } =
        new Dictionary<DataCardsVariant, Func<BUIDataCards<TItem>, RenderFragment>>();

    private IEnumerable<DataColumnRegistration<TItem>> SortableColumns =>
        RegisteredColumns.Where(c => c.Sortable && c.ValueSelector != null);

    private RenderFragment RenderCard(TItem item) => __builder =>
    {
        bool isSelected = State.IsSelected(item);

        <article class="bui-datacards__card @(isSelected ? "bui-datacards__card--selected" : "") @(IsInteractiveRow ? "bui-datacards__card--interactive" : "")"
                 role="@(SelectionMode != SelectionMode.None ? "option" : null)"
                 aria-selected="@(SelectionMode != SelectionMode.None ? isSelected.ToString().ToLowerInvariant() : null)"
                 tabindex="@(IsInteractiveRow ? 0 : -1)"
                 @onclick="() => HandleRowClick(item)"
                 @onkeydown="e => HandleRowKeyDown(e, item)"
                 @onkeydown:preventDefault="PreventRowKeyDown">

            @if (SelectionMode != SelectionMode.None)
            {
                <div class="bui-datacards__card-select">
                    <_BUICheckMark Checked="@isSelected"
                                   Mode="@(SelectionMode == SelectionMode.Single ? _BUICheckMark.CheckMarkMode.Radio : _BUICheckMark.CheckMarkMode.Checkbox)"
                                   Size="SizeEnum.Small" />
                </div>
            }

            @if (CardTemplate != null)
            {
                @CardTemplate(item)
            }
            else
            {
                @if (CardHeaderTemplate != null)
                {
                    <header class="bui-datacards__card-header">
                        @CardHeaderTemplate(item)
                    </header>
                }

                <div class="bui-datacards__card-body">
                    @foreach (DataColumnRegistration<TItem> col in RegisteredColumns.Where(c => c.Visible))
                    {
                        <div class="bui-datacards__field">
                            <span class="bui-datacards__field-label">@col.Header</span>
                            <span class="bui-datacards__field-value">
                                @if (col.Template != null)
                                {
                                    @col.Template(item)
                                }
                                else if (col.ValueSelector != null)
                                {
                                    @FormatValue(col.ValueSelector(item), col.Format)
                                }
                            </span>
                        </div>
                    }
                </div>

                @if (CardFooterTemplate != null)
                {
                    <footer class="bui-datacards__card-footer">
                        @CardFooterTemplate(item)
                    </footer>
                }
            }
        </article>
    };

    private string GetGridStyle()
    {
        List<string> styles = [$"gap: {Gap}"];

        if (!string.IsNullOrEmpty(MinCardWidth))
        {
            styles.Add($"grid-template-columns: repeat(auto-fill, minmax({MinCardWidth}, 1fr))");
        }
        else
        {
            styles.Add($"grid-template-columns: repeat({ColumnsCount}, 1fr)");
        }

        if (!string.IsNullOrEmpty(Height))
        {
            styles.Add($"max-height: {Height}");
            styles.Add("overflow-y: auto");
        }

        return string.Join("; ", styles);
    }

    private async Task HandleSortChange(ChangeEventArgs e)
    {
        string? columnName = e.Value?.ToString();

        if (string.IsNullOrEmpty(columnName))
        {
            State.SortColumn = null;
            State.SortDirection = SortDirection.None;
        }
        else
        {
            State.SortColumn = columnName;
            if (State.SortDirection == SortDirection.None)
            {
                State.SortDirection = SortDirection.Ascending;
            }
        }

        State.ResetPagination();
        ProcessData();

        if (OnSort.HasDelegate && !string.IsNullOrEmpty(State.SortColumn))
        {
            await OnSort.InvokeAsync(new DataCollectionSortEventArgs
            {
                ColumnName = State.SortColumn,
                Direction = State.SortDirection
            });
        }
    }

    private void ToggleSortDirection()
    {
        State.SortDirection = State.SortDirection == SortDirection.Ascending
            ? SortDirection.Descending
            : SortDirection.Ascending;
        ProcessData();
    }

    private async Task HandleFilterInputChange(string? value)
    {
        await HandleFilterChange(new ChangeEventArgs { Value = value });
    }

    private async Task ClearFilterClicked(MouseEventArgs e) => ClearFilter();
    private async Task ClearSelectionClicked(MouseEventArgs e) => ClearSelection();
    private async Task ToggleSortDirectionClicked(MouseEventArgs e) => ToggleSortDirection();

    private async Task HandleSortSelectChange(string? value)
    {
        await HandleSortChange(new ChangeEventArgs { Value = value });
    }

    private async Task HandlePageSizeSelectChange(string? value)
    {
        if (int.TryParse(value, out int size))
        {
            await HandlePageSizeChange(new ChangeEventArgs { Value = size });
        }
    }
}