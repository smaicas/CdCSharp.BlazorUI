@namespace CdCSharp.BlazorUI.Components
@inherits BUIVariantComponentBase<BUILoadingIndicator, BUILoadingIndicatorVariant>
@implements IHasSize
@implements IHasColor
@{
    base.BuildRenderTree(__builder);
}
@code {
    [Parameter] public string? Color { get; set; }

    // IHasSize
    [Parameter] public SizeEnum Size { get; set; } = SizeEnum.Medium;

    /* ========= Variant ========= */
    public override BUILoadingIndicatorVariant DefaultVariant => BUILoadingIndicatorVariant.Spinner;

    protected override Dictionary<BUILoadingIndicatorVariant, Func<BUILoadingIndicator, RenderFragment>> BuiltInTemplates { get; } = new()
    {
        [BUILoadingIndicatorVariant.Spinner] = i => i.RenderSpinner(),
        [BUILoadingIndicatorVariant.CircularProgress] = i => i.RenderCircularProgress(),
        [BUILoadingIndicatorVariant.Ring] = i => i.RenderRing(),
        [BUILoadingIndicatorVariant.Dots] = i => i.RenderDots(),
        [BUILoadingIndicatorVariant.Bars] = i => i.RenderBars(),
        [BUILoadingIndicatorVariant.LinearIndeterminate] = i => i.RenderLinear(),
    };

    /* ========= Render Methods ========= */

    private RenderFragment RenderSpinner() => __builder =>
    {
        <bui-component @attributes="ComputedAttributes">
            <svg viewBox="0 0 50 50">
                <circle cx="25" cy="25" r="20"></circle>
            </svg>
        </bui-component>
    };

    private RenderFragment RenderCircularProgress() => __builder =>
    {
        <bui-component @attributes="ComputedAttributes">
            <svg viewBox="0 0 50 50">
                <circle cx="25" cy="25" r="20"></circle>
            </svg>
        </bui-component>
    };

    private RenderFragment RenderRing() => __builder =>
    {
        <bui-component @attributes="ComputedAttributes">
            <svg viewBox="0 0 50 50">
                <circle cx="25" cy="25" r="20"></circle>
            </svg>
        </bui-component>
    };

    private RenderFragment RenderDots() => __builder =>
    {
        <bui-component @attributes="ComputedAttributes">
            <svg viewBox="0 0 40 10">
                <circle cx="5" cy="5" r="4"></circle>
                <circle cx="20" cy="5" r="4"></circle>
                <circle cx="35" cy="5" r="4"></circle>
            </svg>
        </bui-component>
    };

    private RenderFragment RenderBars() => __builder =>
    {
        <bui-component @attributes="ComputedAttributes">
            <svg viewBox="0 0 24 30">
                <rect x="0" y="0" width="4" height="30" rx="2"></rect>
                <rect x="10" y="0" width="4" height="30" rx="2"></rect>
                <rect x="20" y="0" width="4" height="30" rx="2"></rect>
            </svg>
        </bui-component>
    };

    private RenderFragment RenderLinear() => __builder =>
    {
        <bui-component @attributes="ComputedAttributes">
            <div class="bui-loading-linear bui-loading-linear--primary"></div>
            <div class="bui-loading-linear bui-loading-linear--secondary"></div>
        </bui-component>
    };
}