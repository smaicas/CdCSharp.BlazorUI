@using CdCSharp.BlazorUI.Core.Abstractions.Behaviors.Design
@using CdCSharp.BlazorUI.Core.Css

@namespace CdCSharp.BlazorUI.Components

@typeparam TItem
@inherits BUIComponentBase
@implements ITreeContext<TItem>
@implements ITreeNodeRegistry
@implements IHasSize

@{
    base.BuildRenderTree(__builder);
}

<bui-component @attributes="@ComputedAttributes">
    @if (_isDeclarativeMode)
    {
        <CascadingValue Value="@((ITreeNodeRegistry)this)" IsFixed="true">
            @ChildContent
        </CascadingValue>

        @if (_declarativeNodesBuilt)
        {
            @RenderNodes(_rootNodes)
        }
    }
    else
    {
        @RenderNodes(_rootNodes)
    }
</bui-component>

@code {
    private readonly Dictionary<string, TreeNodeState<TItem>> _nodeMap = [];
    private readonly HashSet<string> _loadingNodes = [];
    private readonly HashSet<string> _expandedKeysInternal = [];
    private List<TreeNodeState<TItem>> _rootNodes = [];
    private bool _isDeclarativeMode;
    private bool _declarativeNodesBuilt;
    private TreeNodeCache<TItem>? _cacheInternal;

    // === Data-bound Mode ===
    [Parameter] public IEnumerable<TItem>? Items { get; set; }
    [Parameter] public Func<TItem, IEnumerable<TItem>?>? ChildrenSelector { get; set; }
    [Parameter] public Func<TItem, bool>? HasChildrenSelector { get; set; }
    [Parameter] public Func<TItem, string>? KeySelector { get; set; }
    [Parameter] public RenderFragment<ITreeNode<TItem>>? NodeTemplate { get; set; }
    [Parameter] public Func<TItem, Task<IEnumerable<TItem>>>? OnLoadChildren { get; set; }
    [Parameter] public TreeNodeCache<TItem>? Cache { get; set; }

    // === Declarative Mode ===
    [Parameter] public RenderFragment? ChildContent { get; set; }

    // === Common ===
    [Parameter] public HashSet<string>? ExpandedKeys { get; set; }
    [Parameter] public EventCallback<HashSet<string>> ExpandedKeysChanged { get; set; }
    [Parameter] public bool ExpandAll { get; set; }

    // === Events ===
    [Parameter] public EventCallback<TreeNodeEventArgs<TItem>> OnNodeClick { get; set; }
    [Parameter] public EventCallback<TreeNodeEventArgs<TItem>> OnNodeExpand { get; set; }
    [Parameter] public EventCallback<TreeNodeEventArgs<TItem>> OnNodeCollapse { get; set; }

    // === Appearance ===
    [Parameter] public SizeEnum Size { get; set; } = SizeEnum.Medium;
    [Parameter] public string ExpandIcon { get; set; } = BUIIcons.UI.ChevronRight;
    [Parameter] public string CollapseIcon { get; set; } = BUIIcons.UI.ChevronDown;
    [Parameter] public bool ShowLines { get; set; }
    [Parameter] public bool AnimateExpand { get; set; } = true;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        ValidateMode();

        _cacheInternal = Cache ?? new TreeNodeCache<TItem>();

        if (ExpandedKeys != null)
        {
            _expandedKeysInternal.Clear();
            foreach (string key in ExpandedKeys)
            {
                _expandedKeysInternal.Add(key);
            }
        }

        if (!_isDeclarativeMode && Items != null)
        {
            BuildDataBoundNodes();
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && _isDeclarativeMode && !_declarativeNodesBuilt)
        {
            BuildDeclarativeNodes();
            _declarativeNodesBuilt = true;
            StateHasChanged();
        }
    }

    private void ValidateMode()
    {
        bool hasDeclarative = ChildContent != null;
        bool hasDataBound = Items != null;

        if (hasDeclarative && hasDataBound)
        {
            throw new InvalidOperationException(
                "BUITree cannot use both declarative (ChildContent) and data-bound (Items) modes simultaneously. " +
                "Use either BUITreeNode children OR the Items parameter, not both.");
        }

        _isDeclarativeMode = hasDeclarative;
    }

    private void BuildDataBoundNodes()
    {
        _nodeMap.Clear();
        _rootNodes.Clear();

        if (Items == null) return;

        foreach (TItem item in Items)
        {
            TreeNodeState<TItem> node = BuildNodeFromItem(item, null, 0);
            _rootNodes.Add(node);
        }
    }

    private TreeNodeState<TItem> BuildNodeFromItem(TItem item, TreeNodeState<TItem>? parent, int depth)
    {
        string key = KeySelector?.Invoke(item) ?? $"item-{Guid.NewGuid():N}";

        IEnumerable<TItem>? children = ChildrenSelector?.Invoke(item);
        bool hasChildren = HasChildrenSelector?.Invoke(item) ?? children?.Any() ?? false;

        TreeNodeState<TItem> node = new()
        {
            Key = key,
            Item = item,
            HasChildren = hasChildren,
            Depth = depth,
            Parent = parent
        };

        _nodeMap[key] = node;

        if (ExpandAll && hasChildren)
        {
            _expandedKeysInternal.Add(key);
        }

        if (children != null)
        {
            foreach (TItem child in children)
            {
                TreeNodeState<TItem> childNode = BuildNodeFromItem(child, node, depth + 1);
                node.ChildrenInternal.Add(childNode);
            }
        }

        return node;
    }

    private readonly List<TreeNodeRegistration> _pendingRegistrations = [];

    void ITreeNodeRegistry.RegisterNode(TreeNodeRegistration registration)
    {
        _pendingRegistrations.Add(registration);
    }

    private void BuildDeclarativeNodes()
    {
        _nodeMap.Clear();
        _rootNodes.Clear();

        Dictionary<string, List<TreeNodeRegistration>> childrenByParent = [];

        foreach (TreeNodeRegistration reg in _pendingRegistrations)
        {
            string parentKey = reg.ParentKey ?? string.Empty;
            if (!childrenByParent.ContainsKey(parentKey))
            {
                childrenByParent[parentKey] = [];
            }
            childrenByParent[parentKey].Add(reg);
        }

        if (childrenByParent.TryGetValue(string.Empty, out List<TreeNodeRegistration>? roots))
        {
            foreach (TreeNodeRegistration reg in roots)
            {
                TreeNodeState<TItem> node = BuildNodeFromRegistration(reg, null, 0, childrenByParent);
                _rootNodes.Add(node);
            }
        }

        _pendingRegistrations.Clear();
    }

    private TreeNodeState<TItem> BuildNodeFromRegistration(
        TreeNodeRegistration reg,
        TreeNodeState<TItem>? parent,
        int depth,
        Dictionary<string, List<TreeNodeRegistration>> childrenByParent)
    {
        bool hasChildren = childrenByParent.ContainsKey(reg.Key);

        TreeNodeState<TItem> node = new()
        {
            Key = reg.Key,
            Text = reg.Text,
            Icon = reg.Icon,
            Disabled = reg.Disabled,
            HasChildren = hasChildren,
            Depth = depth,
            Parent = parent,
            CustomContent = reg.NodeContent,
            AdditionalData = reg.Data
        };

        _nodeMap[reg.Key] = node;

        if (reg.InitiallyExpanded || ExpandAll)
        {
            _expandedKeysInternal.Add(reg.Key);
        }

        if (childrenByParent.TryGetValue(reg.Key, out List<TreeNodeRegistration>? children))
        {
            foreach (TreeNodeRegistration childReg in children)
            {
                TreeNodeState<TItem> childNode = BuildNodeFromRegistration(childReg, node, depth + 1, childrenByParent);
                node.ChildrenInternal.Add(childNode);
            }
        }

        return node;
    }

    private RenderFragment RenderNodes(IEnumerable<TreeNodeState<TItem>> nodes) => __builder =>
    {
        <div class="bui-tree__nodes" role="tree">
            @foreach (TreeNodeState<TItem> node in nodes)
            {
                @RenderNode(node)
            }
        </div>
    };

    private RenderFragment RenderNode(TreeNodeState<TItem> node) => __builder =>
    {
        bool isExpanded = IsExpanded(node.Key);
        bool isLoading = IsLoading(node.Key);
        bool hasVisibleChildren = node.HasChildren && node.ChildrenInternal.Count > 0;

        <div class="bui-tree__node @(node.Disabled ? "bui-tree__node--disabled" : "")"
             role="treeitem"
             aria-expanded="@(node.HasChildren? isExpanded.ToString().ToLowerInvariant() : null)"
             aria-disabled="@node.Disabled.ToString().ToLowerInvariant()"
             data-depth="@node.Depth"
             data-key="@node.Key">

            <div class="bui-tree__node-content"
                 style="padding-left: calc(@(node.Depth) * var(--bui-tree-indent, 1.5rem))"
                 @onclick="() => HandleNodeClickAsync(node)"
                 @onclick:stopPropagation="true">

                @if (node.HasChildren)
                {
                    <button type="button"
                            class="bui-tree__expander @(isExpanded ? "bui-tree__expander--expanded" : "")"
                            @onclick="() => ToggleExpandAsync(node)"
                            @onclick:stopPropagation="true"
                            disabled="@node.Disabled"
                            aria-label="@(isExpanded ? "Collapse" : "Expand")">
                        @if (isLoading)
                        {
                            <BUILoadingIndicator Variant="BUILoadingIndicatorVariant.Spinner" Size="Size" />
                        }
                        else
                        {
                            <BUISvgIcon Icon="@(isExpanded? CollapseIcon : ExpandIcon)" Size="Size" />
                        }
                    </button>
                }
                else
                {
                    <span class="bui-tree__expander-placeholder"></span>
                }

                <div class="bui-tree__node-label">
                    @if (_isDeclarativeMode)
                    {
                        @RenderDeclarativeContent(node)
                    }
                    else if (NodeTemplate != null)
                    {
                        @NodeTemplate(node)
                    }
                    else
                    {
                        @RenderDefaultContent(node)
                    }
                </div>
            </div>

            @if (node.HasChildren && isExpanded)
            {
                <div class="bui-tree__children @(AnimateExpand ? "bui-tree__children--animated" : "")"
                     role="group">
                    @foreach (TreeNodeState<TItem> child in node.ChildrenInternal)
                    {
                        @RenderNode(child)
                    }
                </div>
            }
        </div>
    };

    private RenderFragment RenderDeclarativeContent(TreeNodeState<TItem> node) => __builder =>
    {
        if (node.CustomContent != null)
        {
            @node.CustomContent
        }
        else
        {
            @RenderDefaultContent(node)
        }
    };

    private RenderFragment RenderDefaultContent(TreeNodeState<TItem> node) => __builder =>
    {
        @if (!string.IsNullOrEmpty(node.Icon))
        {
            <BUISvgIcon Icon="@node.Icon" Size="Size" class="bui-tree__node-icon" />
        }
        <span class="bui-tree__node-text">@(node.Text ?? node.Item?.ToString() ?? node.Key)</span>
    };

    // === ITreeContext Implementation ===

    public bool IsExpanded(string key) => _expandedKeysInternal.Contains(key);

    public bool IsLoading(string key) => _loadingNodes.Contains(key);

    public async Task ToggleExpandAsync(ITreeNode<TItem> node)
    {
        if (IsExpanded(node.Key))
        {
            await CollapseAsync(node.Key);
        }
        else
        {
            await ExpandAsync(node.Key);
        }
    }

    public async Task ExpandAsync(string key)
    {
        if (!_nodeMap.TryGetValue(key, out TreeNodeState<TItem>? node)) return;
        if (!node.HasChildren || _expandedKeysInternal.Contains(key)) return;

        if (OnLoadChildren != null && node.ChildrenInternal.Count == 0)
        {
            await LoadChildrenAsync(node);
        }

        _expandedKeysInternal.Add(key);
        await NotifyExpandedKeysChangedAsync();
        await OnNodeExpand.InvokeAsync(CreateEventArgs(node, true));
        StateHasChanged();
    }

    public async Task CollapseAsync(string key)
    {
        if (!_nodeMap.TryGetValue(key, out TreeNodeState<TItem>? node)) return;
        if (!_expandedKeysInternal.Contains(key)) return;

        _expandedKeysInternal.Remove(key);
        await NotifyExpandedKeysChangedAsync();
        await OnNodeCollapse.InvokeAsync(CreateEventArgs(node, false));
        StateHasChanged();
    }

    private async Task LoadChildrenAsync(TreeNodeState<TItem> node)
    {
        if (OnLoadChildren == null || node.Item == null) return;

        _loadingNodes.Add(node.Key);
        StateHasChanged();

        try
        {
            IEnumerable<TItem> children;

            if (_cacheInternal!.TryGet(node.Key, out IEnumerable<TItem>? cached) && cached != null)
            {
                children = cached;
            }
            else
            {
                children = await OnLoadChildren(node.Item);
                _cacheInternal.Set(node.Key, children);
            }

            node.ChildrenInternal.Clear();
            foreach (TItem child in children)
            {
                TreeNodeState<TItem> childNode = BuildNodeFromItem(child, node, node.Depth + 1);
                node.ChildrenInternal.Add(childNode);
            }
            node.HasChildren = node.ChildrenInternal.Count > 0;
        }
        finally
        {
            _loadingNodes.Remove(node.Key);
            StateHasChanged();
        }
    }

    private async Task HandleNodeClickAsync(TreeNodeState<TItem> node)
    {
        if (node.Disabled) return;
        await OnNodeClick.InvokeAsync(CreateEventArgs(node, IsExpanded(node.Key)));
    }

    private TreeNodeEventArgs<TItem> CreateEventArgs(TreeNodeState<TItem> node, bool isExpanded) => new()
    {
        Node = node,
        Key = node.Key,
        Item = node.Item,
        Depth = node.Depth,
        IsExpanded = isExpanded
    };

    private async Task NotifyExpandedKeysChangedAsync()
    {
        if (ExpandedKeysChanged.HasDelegate)
        {
            await ExpandedKeysChanged.InvokeAsync(new HashSet<string>(_expandedKeysInternal));
        }
    }

    // === Public Methods ===

    public void ExpandAllNodes()
    {
        foreach (TreeNodeState<TItem> node in _nodeMap.Values.Where(n => n.HasChildren))
        {
            _expandedKeysInternal.Add(node.Key);
        }
        StateHasChanged();
    }

    public void CollapseAllNodes()
    {
        _expandedKeysInternal.Clear();
        StateHasChanged();
    }

    public void InvalidateCache(string? key = null)
    {
        if (key != null)
        {
            _cacheInternal?.Invalidate(key);
        }
        else
        {
            _cacheInternal?.InvalidateAll();
        }
    }

    public ITreeNode<TItem>? GetNode(string key)
    {
        return _nodeMap.TryGetValue(key, out TreeNodeState<TItem>? node) ? node : null;
    }
}