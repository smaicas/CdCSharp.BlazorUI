@namespace CdCSharp.BlazorUI.Components
@attribute [GenerateComponentInfo]
@inherits BUITreeNodeBase<TreeSelectionNodeRegistration>

@{
    base.BuildRenderTree(__builder);
}

@code {
    protected override string GenerateDefaultKey()
        => $"selection-item-{Guid.NewGuid():N}";

    protected override TreeSelectionNodeRegistration CreateRegistration() => new()
    {
        Key = ResolvedKey,
        Text = Text,
        Icon = Icon,
        IsDisabled = Disabled,
        InitiallyExpanded = InitiallyExpanded,
        Data = Data,
        NodeContent = NodeContent,
        ParentKey = ParentNodeKey
    };
}