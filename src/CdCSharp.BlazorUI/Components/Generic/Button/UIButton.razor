@using CdCSharp.BlazorUI.Components.Abstractions
@using CdCSharp.BlazorUI.Components.Features.Behaviors
@using CdCSharp.BlazorUI.Components.Features.Common
@using CdCSharp.BlazorUI.Components.Features.Loading
@using CdCSharp.BlazorUI.Components.Features.Transitions
@using CdCSharp.BlazorUI.Components.Generic.Svg
@using CdCSharp.BlazorUI.Core.Css
@using CdCSharp.BlazorUI.Core.Theming
@using CdCSharp.BlazorUI.Css
@using CdCSharp.BlazorUI.Media.Icons


@inherits UIVariantComponentBase<UIButton, UIButtonVariant>
@implements IHasTransitions
@implements IHasSize
@implements IHasFullWidth
@implements IHasLoading
@implements IHasElevation
@implements IHasRipple
@implements IHasDensity
@implements IHasBorder

@{
    base.BuildRenderTree(__builder);
}

@code {

    /* ========= Public API ========= */

    [Parameter] public string? Text { get; set; }
    [Parameter] public string? LeadingIcon { get; set; }
    [Parameter] public string? TrailingIcon { get; set; }
    [Parameter] public CssColor? BackgroundColor { get; set; }
    [Parameter] public CssColor? Color { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }

    // IHasTransitions
    [Parameter] public UITransitions? Transitions { get; set; }

    // IHasSize
    [Parameter] public SizeEnum Size { get; set; } = SizeEnum.Medium;

    // IHasFullWidth
    [Parameter] public bool FullWidth { get; set; }

    // IHasLoading
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public UILoadingIndicatorVariant? LoadingIndicatorVariant { get; set; }

    // IHasElevation
    private int _elevation;
    [Parameter]
    public int? Elevation { get; set; }

    // IHasRipple
    [Parameter] public bool DisableRipple { get; set; }
    [Parameter] public CssColor? RippleColor { get; set; }
    [Parameter] public int? RippleDuration { get; set; }

    // IHasDensity
    [Parameter] public DensityEnum Density { get; set; } = DensityEnum.Standard;

    // IHasBorder
    [Parameter] public BorderStyle? Border { get; set; }
    [Parameter] public BorderStyle? BorderTop { get; set; }
    [Parameter] public BorderStyle? BorderRight { get; set; }
    [Parameter] public BorderStyle? BorderBottom { get; set; }
    [Parameter] public BorderStyle? BorderLeft { get; set; }

    /* ========= Variant ========= */

    protected override UIButtonVariant DefaultVariant => UIButtonVariant.Default;

    protected override Dictionary<UIButtonVariant, Func<UIButton, RenderFragment>> BuiltInTemplates { get; } = new()
    {
        [UIButtonVariant.Default] = b => b.RenderDefault(),
    };

    /* ========= Private state ========= */

    private bool IsDisabled => Disabled || IsLoading;
    private ElementReference _buttonElement;

    // IHasRipple implementation (from IJsBehavior)
    public ElementReference GetRootElement() => _buttonElement;

    /* ========= Render ========= */

    private RenderFragment RenderDefault() => __builder =>
    {
        <button @ref="_buttonElement"
                @attributes="AdditionalAttributes"
                type="button"
                disabled="@IsDisabled"
                @onclick="HandleClick">

            @if (IsLoading && LoadingIndicatorVariant != null)
            {
                <UILoadingIndicator Variant="@LoadingIndicatorVariant"
                                    Size="Size"
                                    Color="@Color" />
            }
            else if (LeadingIcon != null)
            {
                <UISvgIcon Icon="@LeadingIcon" Size="@Size" />
            }

            @if (!string.IsNullOrWhiteSpace(Text))
            {
                <span class="@CssClassesReference.UIButton__Text">@Text</span>
            }

            @if (TrailingIcon != null && !IsLoading)
            {
                <UISvgIcon Icon="@TrailingIcon" Size="@Size" />
            }

        </button>
    };

    /* ========= Event Handlers ========= */

    private async Task HandleClick(MouseEventArgs args)
    {
        if (!IsDisabled)
        {
            await OnClick.InvokeAsync(args);
        }
    }

    /* ========= Styling ========= */

    public override IEnumerable<string> GetAdditionalCssClasses()
    {
        yield return CssClassesReference.UIButton;
        yield return CssClassesReference.Variant(CssClassesReference.UIButton, Variant ?? DefaultVariant);
        if (Text == null)
        {
            yield return CssClassesReference.Specific(CssClassesReference.UIButton, "icon-only");
        }
    }

    override public Dictionary<string, string> GetAdditionalInlineStyles()
    {
        Dictionary<string, string> styles = new();

        if (BackgroundColor != null)
        {
            styles.TryAdd("background-color", BackgroundColor.ToString(ColorOutputFormats.Rgba));
        }
        if (Color != null)
        {
            styles.TryAdd("color", Color.ToString(ColorOutputFormats.Rgba));
        }

        return styles;
    }
}