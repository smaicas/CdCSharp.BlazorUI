@namespace CdCSharp.BlazorUI.Components
@attribute [GenerateComponentInfo]
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inherits BUIVariantComponentBase<BUITabs, BUITabsVariant>
@implements IHasSize

@{
    base.BuildRenderTree(__builder);
}

@code {
    /* ========= Public API ========= */
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public string? ActiveTab { get; set; }

    [Parameter] public EventCallback<string?> ActiveTabChanged { get; set; }

    [Parameter] public bool FullWidth { get; set; }

    // IHasSize
    [Parameter] public BUISize Size { get; set; } = BUISize.Medium;

    /* ========= Variant ========= */
    public override BUITabsVariant DefaultVariant => BUITabsVariant.Underline;

    protected override Dictionary<BUITabsVariant, Func<BUITabs, RenderFragment>> BuiltInTemplates { get; } = new()
    {
        [BUITabsVariant.Underline] = t => t.RenderDefault(),
        [BUITabsVariant.Pills] = t => t.RenderDefault(),
        [BUITabsVariant.Enclosed] = t => t.RenderDefault(),
    };

    /* ========= Private state ========= */
    private readonly List<BUITab> _tabs = new();
    private readonly object _tabsLock = new();
    private readonly Dictionary<string, ElementReference> _tabRefs = new();
    private string? _pendingFocusTabId;

    /* ========= Internal API for BUITab ========= */
    internal void RegisterTab(BUITab tab)
    {
        if (IsDisposed) return;

        bool added;
        lock (_tabsLock)
        {
            if (_tabs.Contains(tab)) return;
            _tabs.Add(tab);
            added = true;
            if (string.IsNullOrEmpty(ActiveTab) && _tabs.Count == 1)
            {
                ActiveTab = tab.Id;
            }
        }

        if (added)
        {
            _ = InvokeAsync(StateHasChanged);
        }
    }

    internal void UnregisterTab(BUITab tab)
    {
        if (IsDisposed) return;

        bool removed;
        lock (_tabsLock)
        {
            removed = _tabs.Remove(tab);
        }

        if (removed)
        {
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private List<BUITab> SnapshotTabs()
    {
        lock (_tabsLock)
        {
            return new List<BUITab>(_tabs);
        }
    }

    public override async ValueTask DisposeAsync()
    {
        IsDisposed = true;
        lock (_tabsLock)
        {
            _tabs.Clear();
        }
        _tabRefs.Clear();
        await base.DisposeAsync();
    }

    internal bool IsActiveTab(string? tabId) => ActiveTab == tabId;

    /* ========= Render ========= */
    private RenderFragment RenderDefault() => __builder =>
    {
        List<BUITab> tabs = SnapshotTabs();
        <CascadingValue Value="this">
            <bui-component @attributes="@ComputedAttributes">
                <div class="bui-tabs__header" role="tablist">
                    @foreach (BUITab tab in tabs)
                    {
                        string tabId = tab.Id ?? string.Empty;
                        bool isActive = tab.Id == ActiveTab;
                        <button type="button"
                                role="tab"
                                id="@($"bui-tab-{tabId}")"
                                class="bui-tabs__tab"
                                data-bui-active="@(isActive.ToString().ToLowerInvariant())"
                                aria-selected="@(isActive ? "true" : "false")"
                                aria-controls="@($"bui-tabpanel-{tabId}")"
                                tabindex="@(isActive ? 0 : -1)"
                                disabled="@tab.Disabled"
                                @ref="_tabRefs[tabId]"
                                @onclick="() => SelectTab(tab.Id)"
                                @onkeydown="e => HandleKeyDown(e, tabs, tab.Id)">
                            @if (tab.Icon != null)
                            {
                                <span class="bui-tabs__tab-icon">@tab.Icon</span>
                            }
                            <span class="bui-tabs__tab-label">@tab.Label</span>
                        </button>
                    }
                </div>
                <div class="bui-tabs__content"
                     role="tabpanel"
                     id="@($"bui-tabpanel-{ActiveTab}")"
                     aria-labelledby="@($"bui-tab-{ActiveTab}")"
                     tabindex="0">
                    @ChildContent
                </div>
            </bui-component>
        </CascadingValue>
    };

    /* ========= Event Handlers ========= */
    private async Task SelectTab(string? tabId)
    {
        if (ActiveTab != tabId)
        {
            ActiveTab = tabId;
            await ActiveTabChanged.InvokeAsync(tabId);
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e, List<BUITab> tabs, string? currentId)
    {
        if (tabs.Count == 0) return;

        int currentIndex = tabs.FindIndex(t => t.Id == currentId);
        int targetIndex = -1;

        switch (e.Key)
        {
            case "ArrowRight":
                targetIndex = FindNextEnabled(tabs, currentIndex, 1);
                break;
            case "ArrowLeft":
                targetIndex = FindNextEnabled(tabs, currentIndex, -1);
                break;
            case "Home":
                targetIndex = FindFirstEnabled(tabs, 0, 1);
                break;
            case "End":
                targetIndex = FindFirstEnabled(tabs, tabs.Count - 1, -1);
                break;
            default:
                return;
        }

        if (targetIndex < 0 || targetIndex == currentIndex) return;

        string? targetId = tabs[targetIndex].Id;
        _pendingFocusTabId = targetId;
        await SelectTab(targetId);
    }

    private static int FindNextEnabled(List<BUITab> tabs, int start, int step)
    {
        if (tabs.Count == 0) return -1;
        int count = tabs.Count;
        for (int i = 1; i <= count; i++)
        {
            int idx = ((start + step * i) % count + count) % count;
            if (!tabs[idx].Disabled) return idx;
        }
        return -1;
    }

    private static int FindFirstEnabled(List<BUITab> tabs, int start, int step)
    {
        for (int i = start; i >= 0 && i < tabs.Count; i += step)
        {
            if (!tabs[i].Disabled) return i;
        }
        return -1;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (_pendingFocusTabId != null &&
            _tabRefs.TryGetValue(_pendingFocusTabId, out ElementReference er))
        {
            _pendingFocusTabId = null;
            try
            {
                await er.FocusAsync();
            }
            catch (JSDisconnectedException)
            {
            }
            catch (InvalidOperationException)
            {
            }
        }
    }

    /* ========= Component Attributes ========= */
    public override void BuildComponentDataAttributes(Dictionary<string, object> attributes)
    {
        if (FullWidth)
        {
            attributes[FeatureDefinitions.DataAttributes.FullWidth] = "true";
        }
    }
}