@typeparam TValue

@namespace CdCSharp.BlazorUI.Components.Forms

@inherits BUIComponentBase
@implements IHasSize
@implements IHasDensity
@implements IHasDisabled

<bui-component @attributes="ComputedAttributes">
    <label class="bui-switch" @onclick="HandleClick" @onclick:preventDefault="true">
        <input type="checkbox"
               id="@InputId"
               checked="@IsChecked"
               disabled="@IsDisabled"
               aria-checked="@IsChecked"
               aria-describedby="@AriaDescribedBy"
               class="bui-switch__input" />

        <span class="bui-switch__track" aria-hidden="true">
            <span class="bui-switch__thumb">
                @if (!string.IsNullOrWhiteSpace(IconInactive) || !string.IsNullOrWhiteSpace(IconActive))
                {
                    @if (IsChecked)
                    {
                        <BUISvgIcon Size="SizeEnum.Small" Icon="@IconActive" class="bui-switch__icon" />
                    }
                    else
                    {
                        <BUISvgIcon Size="SizeEnum.Small" Icon="@IconInactive" class="bui-switch__icon" />
                    }
                }
            </span>
        </span>

        @if (!string.IsNullOrWhiteSpace(Label))
        {
            <span class="bui-switch__label">@Label</span>
        }
    </label>

</bui-component>

@code {
    private string _generatedInputId = $"bui-switch-{Guid.NewGuid():N}";

    /* ===== Design ===== */

    [Parameter] public SizeEnum Size { get; set; } = SizeEnum.Medium;
    [Parameter] public DensityEnum Density { get; set; } = DensityEnum.Standard;

    /* ===== State ===== */

    [Parameter] public bool Disabled { get; set; }
    public bool IsDisabled => Disabled;

    /* ===== Accesibility ===== */
    [Parameter] public string AriaDescribedBy { get; set; } = string.Empty;

    /* ===== Switch behavior ===== */

    /// <summary>
    /// Current value of the switch
    /// </summary>
    [Parameter] public TValue? Value { get; set; }

    /// <summary>
    /// Callback when value changes
    /// </summary>
    [Parameter] public EventCallback<TValue?> ValueChanged { get; set; }

    /// <summary>
    /// Value when switch is in "off" state (unchecked)
    /// </summary>
    [Parameter, EditorRequired]
    public TValue OptionInactive { get; set; } = default!;

    /// <summary>
    /// Value when switch is in "on" state (checked)
    /// </summary>
    [Parameter, EditorRequired]
    public TValue OptionActive { get; set; } = default!;

    /* ===== Content ===== */

    /// <summary>
    /// Label text displayed next to the switch
    /// </summary>
    [Parameter] public string? Label { get; set; }

    /// <summary>
    /// Icon shown when switch is unchecked (Option1)
    /// </summary>
    [Parameter] public string? IconInactive { get; set; }

    /// <summary>
    /// Icon shown when switch is checked (Option2)
    /// </summary>
    [Parameter] public string? IconActive { get; set; }

    /// <summary>
    /// Track background color when unchecked
    /// </summary>
    [Parameter] public string? TrackColorInactive { get; set; }

    /// <summary>
    /// Track background color when checked
    /// </summary>
    [Parameter] public string? TrackColorActive { get; set; }

    /// <summary>
    /// Thumb background color when unchecked
    /// </summary>
    [Parameter] public string? ThumbBackgroundColorInactive { get; set; }

    /// <summary>
    /// Thumb background color when checked
    /// </summary>
    [Parameter] public string? ThumbBackgroundColorActive { get; set; }

    /// <summary>
    /// Thumb color when unchecked
    /// </summary>
    [Parameter] public string? ThumbColorInactive { get; set; }

    /// <summary>
    /// Thumb color when checked
    /// </summary>
    [Parameter] public string? ThumbColorActive { get; set; }

    /// <summary>
    /// Optional custom input ID. If not provided, one will be generated.
    /// </summary>
    [Parameter] public string? InputId { get; set; }

    /// <summary>
    /// Computed input ID (custom or generated)
    /// </summary>
    private string ActualInputId => InputId ?? _generatedInputId;

    /// <summary>
    /// Whether the switch is currently checked (Value == Option2)
    /// </summary>
    protected bool IsChecked =>
        EqualityComparer<TValue>.Default.Equals(Value, OptionActive);

    private async Task HandleClick(MouseEventArgs e)
    {
        if (IsDisabled)
            return;

        TValue newValue =
            EqualityComparer<TValue>.Default.Equals(Value, OptionInactive)
                ? OptionActive
                : OptionInactive;

        Value = newValue;
        await ValueChanged.InvokeAsync(newValue);
    }

    public override void BuildComponentDataAttributes(Dictionary<string, object> dataAttributes)
    {
        base.BuildComponentDataAttributes(dataAttributes);
        dataAttributes["data-checked"] = IsChecked.ToString().ToLowerInvariant();
    }

    public override void BuildComponentCssVariables(Dictionary<string, string> cssVariables)
    {
        base.BuildComponentCssVariables(cssVariables);

        if (!string.IsNullOrWhiteSpace(TrackColorInactive)) { cssVariables["--track-inline-inactive-bg"] = TrackColorInactive; }
        if (!string.IsNullOrWhiteSpace(TrackColorActive)) { cssVariables["--track-inline-active-bg"] = TrackColorActive; }

        if (!string.IsNullOrWhiteSpace(ThumbBackgroundColorInactive)) { cssVariables["--thumb-inline-inactive-bg"] = ThumbBackgroundColorInactive; }
        if (!string.IsNullOrWhiteSpace(ThumbBackgroundColorActive)) { cssVariables["--thumb-inline-active-bg"] = ThumbBackgroundColorActive; }

        if (!string.IsNullOrWhiteSpace(ThumbColorInactive)) { cssVariables["--thumb-inline-inactive-color"] = ThumbColorInactive; }
        if (!string.IsNullOrWhiteSpace(ThumbColorActive)) { cssVariables["--thumb-inline-active-color"] = ThumbColorActive; }
    }
}