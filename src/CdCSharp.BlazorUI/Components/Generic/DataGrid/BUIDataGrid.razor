@using CdCSharp.BlazorUI.Core.Abstractions.Components
@using Microsoft.AspNetCore.Components.Web.Virtualization

@namespace CdCSharp.BlazorUI.Components

@typeparam TItem
@inherits BUIComponentBase
@implements IHasDensity

<CascadingValue Value="@((IDataGridColumnRegistry<TItem>)_columnRegistry)" Name="DataGridColumnRegistry">
    @Columns
</CascadingValue>

<bui-component @attributes="ComputedAttributes">
    @if (_columnsBuilt)
    {
        @if (Filterable || ShowPageSizeSelector)
        {
            <div class="bui-datagrid__toolbar">
                @if (Filterable)
                {
                    <div class="bui-datagrid__filter">
                        <input type="text"
                               class="bui-simple-input bui-datagrid__filter-input"
                               placeholder="@FilterPlaceholder"
                               value="@_state.FilterText"
                               @oninput="HandleFilterChange" />
                        @if (!string.IsNullOrEmpty(_state.FilterText))
                        {
                            <button type="button"
                                    class="bui-icon-btn bui-icon-btn--sm bui-datagrid__filter-clear"
                                    @onclick="ClearFilter"
                                    aria-label="Clear filter">
                                <BUISvgIcon Icon="@BUIIcons.MaterialIconsSharp.i_close" Size="SizeEnum.Small" />
                            </button>
                        }
                    </div>
                }

                <div class="bui-datagrid__toolbar-spacer"></div>

                @if (SelectionMode == SelectionMode.Multiple && _state.SelectedItems.Count > 0)
                {
                    <div class="bui-datagrid__selection-info">
                        @_state.SelectedItems.Count selected
                        <button type="button"
                                class="bui-action-btn"
                                @onclick="ClearSelection">
                            Clear
                        </button>
                    </div>
                }

                @if (ShowPageSizeSelector && PageSize.HasValue)
                {
                    <div class="bui-datagrid__page-size">
                        <label>
                            Rows per page:
                            <select class="bui-simple-select"
                                    value="@_state.PageSize"
                                    @onchange="HandlePageSizeChange">
                                @foreach (int size in PageSizeOptions)
                                {
                                    <option value="@size">@size</option>
                                }
                            </select>
                        </label>
                    </div>
                }
            </div>
        }

        <div class="bui-datagrid__table-container" style="@GetContainerStyle()">
            <table class="bui-datagrid__table" role="grid" aria-label="@AriaLabel">
                @if (!string.IsNullOrEmpty(Caption))
                {
                    <caption>@Caption</caption>
                }

                <thead class="bui-datagrid__header">
                    <tr role="row">
                        @if (SelectionMode != SelectionMode.None)
                        {
                            <th class="bui-datagrid__select-cell"
                                role="columnheader">
                                @if (SelectionMode == SelectionMode.Multiple)
                                {
                                    <input type="checkbox"
                                           tabindex="0"
                                           class="bui-datagrid__checkbox"
                                           checked="@IsAllSelected()"
                                           @onchange="HandleSelectAll"
                                           aria-label="Select all rows" />
                                }
                            </th>
                        }

                        @foreach (DataGridColumnRegistration<TItem> col in _columns.Where(c => c.Visible))
                        {
                            <th class="bui-datagrid__header-cell @GetAlignClass(col.Align) @col.HeaderClass"
                                style="@(col.Width != null ? $"width: {col.Width}" : null)"
                                role="columnheader"
                                aria-sort="@GetAriaSort(col)">
                                @if (col.Sortable)
                                {
                                    <button type="button"
                                            class="bui-datagrid__sort-btn"
                                            @onclick="() => HandleSort(col)">
                                        <span class="bui-datagrid__header-content">
                                            @col.Header
                                            @if (_state.SortColumn == col.Header)
                                            {
                                                <span class="bui-datagrid__sort-icon">
                                                    <BUISvgIcon Icon="@(_state.SortDirection == SortDirection.Ascending ? BUIIcons.UI.ChevronUp : BUIIcons.UI.ChevronDown)"
                                                                Size="SizeEnum.Small" />
                                                </span>
                                            }
                                        </span>
                                    </button>
                                }
                                else
                                {
                                    <span class="bui-datagrid__header-content">@col.Header</span>
                                }
                            </th>
                        }
                    </tr>
                </thead>

                <tbody>
                    @if (EnableVirtualization)
                    {
                        <Virtualize Items="@_processedItems" Context="item">
                            @RenderRow(item)
                        </Virtualize>
                    }
                    else if (_processedItems.Any())
                    {
                        @foreach (TItem item in _processedItems)
                        {
                            @RenderRow(item)
                        }
                    }
                    else
                    {
                        <tr class="bui-datagrid__empty-row" role="row">
                            <td colspan="@(_columns.Count(c => c.Visible) + (SelectionMode != SelectionMode.None ? 1 : 0))"
                                class="bui-datagrid__empty-cell">
                                @if (EmptyContent != null)
                                {
                                    @EmptyContent
                                }
                                else
                                {
                                    <div class="bui-datagrid__empty-state">
                                        <span class="bui-datagrid__empty-icon">📋</span>
                                        <p class="bui-datagrid__empty-text">No data available</p>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>

                @if (FooterTemplate != null)
                {
                    <tfoot class="bui-datagrid__footer">
                        @FooterTemplate
                    </tfoot>
                }
            </table>
        </div>

        @if (PageSize.HasValue && _filteredItems.Any())
        {
            <div class="bui-datagrid__pagination">
                <div class="bui-datagrid__pagination-info">
                    Showing @_paginationStart to @_paginationEnd of @_filteredItems.Count
                </div>

                <div class="bui-datagrid__pagination-controls">
                    <button type="button"
                            class="bui-action-btn"
                            disabled="@(_state.CurrentPage == 1)"
                            @onclick="() => ChangePage(_state.CurrentPage - 1)"
                            aria-label="Previous page">
                        <BUISvgIcon Icon="@BUIIcons.UI.ChevronLeft" Size="SizeEnum.Small" />
                    </button>

                    @foreach (int currentPage in GetVisiblePages())
                    {
                        <button type="button"
                                class="bui-action-btn @(_state.CurrentPage == currentPage ? "bui-action-btn--active" : "")"
                                @onclick="() => ChangePage(currentPage)"
                                aria-label="@($"Page {currentPage}")"
                                aria-current="@(_state.CurrentPage == currentPage ? "page" : null)">
                            @currentPage
                        </button>
                    }

                    <button type="button"
                            class="bui-action-btn"
                            disabled="@(_state.CurrentPage == _totalPages)"
                            @onclick="() => ChangePage(_state.CurrentPage + 1)"
                            aria-label="Next page">
                        <BUISvgIcon Icon="@BUIIcons.UI.ChevronRight" Size="SizeEnum.Small" />
                    </button>
                </div>
            </div>
        }
    }
</bui-component>

@code {
    private readonly DataGridColumnRegistry<TItem> _columnRegistry = new();
    private readonly DataGridState<TItem> _state = new();
    private List<DataGridColumnRegistration<TItem>> _columns = [];
    private List<TItem> _filteredItems = [];
    private List<TItem> _processedItems = [];
    private bool _columnsBuilt;
    private bool _preventRowKeyDown;
    private bool _preventSelectAllKeyDown;
    private int _totalPages;
    private int _paginationStart;
    private int _paginationEnd;

    [Parameter] public RenderFragment? Columns { get; set; }
    [Parameter] public IEnumerable<TItem>? Items { get; set; }

    [Parameter] public TableVariant? Variant { get; set; }
    [Parameter] public TableVariant? VariantXs { get; set; }
    [Parameter] public TableVariant? VariantSm { get; set; }
    [Parameter] public TableVariant? VariantMd { get; set; }
    [Parameter] public TableVariant? VariantLg { get; set; }
    [Parameter] public TableVariant? VariantXl { get; set; }
    [Parameter] public DensityEnum Density { get; set; } = DensityEnum.Standard;
    [Parameter] public bool Hoverable { get; set; } = true;

    [Parameter] public SelectionMode SelectionMode { get; set; } = SelectionMode.None;
    [Parameter] public HashSet<TItem>? SelectedItems { get; set; }
    [Parameter] public EventCallback<HashSet<TItem>> SelectedItemsChanged { get; set; }

    [Parameter] public bool Sortable { get; set; }
    [Parameter] public string? DefaultSortColumn { get; set; }
    [Parameter] public SortDirection? DefaultSortDirection { get; set; }

    [Parameter] public bool Filterable { get; set; }
    [Parameter] public string FilterPlaceholder { get; set; } = "Search...";
    [Parameter] public Func<TItem, string, bool>? CustomFilter { get; set; }

    [Parameter] public int? PageSize { get; set; }
    [Parameter] public bool ShowPageSizeSelector { get; set; } = true;
    [Parameter] public int[] PageSizeOptions { get; set; } = [10, 20, 50, 100];

    [Parameter] public bool EnableVirtualization { get; set; }

    [Parameter] public RenderFragment? FooterTemplate { get; set; }
    [Parameter] public RenderFragment? EmptyContent { get; set; }
    [Parameter] public RenderFragment<TItem>? RowTemplate { get; set; }

    [Parameter] public EventCallback<TItem> OnRowClick { get; set; }
    [Parameter] public EventCallback<DataGridSortEventArgs> OnSort { get; set; }
    [Parameter] public EventCallback<DataGridFilterEventArgs> OnFilter { get; set; }
    [Parameter] public EventCallback<DataGridPageChangeEventArgs> OnPageChange { get; set; }

    [Parameter] public string? AriaLabel { get; set; }
    [Parameter] public string? Caption { get; set; }

    [Parameter] public string Height { get; set; } = "400px";
    [Parameter] public bool FixedHeader { get; set; }

    private bool IsInteractiveRow => SelectionMode != SelectionMode.None || OnRowClick.HasDelegate;

    public override void BuildComponentDataAttributes(Dictionary<string, object> dataAttributes)
    {
        dataAttributes["data-bui-selection-mode"] = SelectionMode.ToString().ToLowerInvariant();

        if (Hoverable)
            dataAttributes["data-bui-hoverable"] = "true";

        if (VariantXs is not null)
            dataAttributes["data-bui-variant-xs"] = VariantXs.Value.ToString().ToLowerInvariant();

        if (VariantSm is not null)
            dataAttributes["data-bui-variant-sm"] = VariantSm.Value.ToString().ToLowerInvariant();

        if (VariantMd is not null)
            dataAttributes["data-bui-variant-md"] = VariantMd.Value.ToString().ToLowerInvariant();

        if (VariantLg is not null)
            dataAttributes["data-bui-variant-lg"] = VariantLg.Value.ToString().ToLowerInvariant();

        if (VariantXl is not null)
            dataAttributes["data-bui-variant-xl"] = VariantXl.Value.ToString().ToLowerInvariant();
    }

    protected override void OnInitialized()
    {
        if (PageSize.HasValue)
        {
            _state.PageSize = PageSize.Value;
        }

        if (!string.IsNullOrEmpty(DefaultSortColumn))
        {
            _state.SortColumn = DefaultSortColumn;
            _state.SortDirection = DefaultSortDirection ?? SortDirection.Ascending;
        }
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (SelectedItems != null)
        {
            _state.ClearSelection();
            foreach (TItem item in SelectedItems)
            {
                _state.SelectItem(item, SelectionMode.Multiple);
            }
        }

        ProcessData();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);

        if (firstRender && Columns != null && !_columnsBuilt)
        {
            _columns = _columnRegistry.Columns.ToList();
            _columnRegistry.Clear();
            _columnsBuilt = true;
            ProcessData();
            StateHasChanged();
        }
    }

    private void ProcessData()
    {
        if (!_columnsBuilt || Items == null)
        {
            _filteredItems = [];
            _processedItems = [];
            return;
        }

        _filteredItems = ApplyFilter(Items).ToList();
        IEnumerable<TItem> sorted = ApplySort(_filteredItems);
        CalculatePaginationInfo();
        _processedItems = ApplyPagination(sorted).ToList();
    }

    private IEnumerable<TItem> ApplyFilter(IEnumerable<TItem> items)
    {
        if (string.IsNullOrWhiteSpace(_state.FilterText))
            return items;

        if (CustomFilter != null)
        {
            return items.Where(item => CustomFilter(item, _state.FilterText));
        }

        string searchText = _state.FilterText.ToLowerInvariant();
        List<DataGridColumnRegistration<TItem>> filterableColumns = _columns
            .Where(c => c.Filterable && c.ValueSelector != null)
            .ToList();

        if (!filterableColumns.Any())
        {
            filterableColumns = _columns.Where(c => c.ValueSelector != null).ToList();
        }

        return items.Where(item =>
            filterableColumns.Any(col =>
            {
                object? value = col.ValueSelector?.Invoke(item);
                return value?.ToString()?.ToLowerInvariant().Contains(searchText) ?? false;
            }));
    }

    private IEnumerable<TItem> ApplySort(IEnumerable<TItem> items)
    {
        if (string.IsNullOrEmpty(_state.SortColumn))
            return items;

        DataGridColumnRegistration<TItem>? column = _columns.FirstOrDefault(c => c.Header == _state.SortColumn);
        if (column?.ValueSelector == null)
            return items;

        if (column.CustomComparer != null)
        {
            List<TItem> list = items.ToList();
            Comparison<TItem> comparison = _state.SortDirection == SortDirection.Ascending
                ? new Comparison<TItem>(column.CustomComparer)
                : (x, y) => column.CustomComparer(y, x);
            list.Sort(comparison);
            return list;
        }

        IOrderedEnumerable<TItem> sorted = _state.SortDirection == SortDirection.Ascending
            ? items.OrderBy(item => column.ValueSelector(item))
            : items.OrderByDescending(item => column.ValueSelector(item));

        return sorted;
    }

    private IEnumerable<TItem> ApplyPagination(IEnumerable<TItem> items)
    {
        if (!PageSize.HasValue)
            return items;

        int skip = (_state.CurrentPage - 1) * _state.PageSize;
        return items.Skip(skip).Take(_state.PageSize);
    }

    private void CalculatePaginationInfo()
    {
        if (!PageSize.HasValue || !_filteredItems.Any())
        {
            _totalPages = 0;
            _paginationStart = 0;
            _paginationEnd = 0;
            return;
        }

        _totalPages = (int)Math.Ceiling(_filteredItems.Count / (double)_state.PageSize);

        if (_state.CurrentPage > _totalPages)
        {
            _state.CurrentPage = _totalPages > 0 ? _totalPages : 1;
        }

        _paginationStart = (_state.CurrentPage - 1) * _state.PageSize + 1;
        _paginationEnd = Math.Min(_state.CurrentPage * _state.PageSize, _filteredItems.Count);
    }

    private RenderFragment RenderRow(TItem item) => __builder =>
    {
        bool isSelected = _state.IsSelected(item);
        bool isInteractive = IsInteractiveRow;

        <tr class="bui-datagrid__row @(isSelected ? "bui-datagrid__row--selected" : "") @(isInteractive ? "bui-datagrid__row--interactive" : "")"
            role="row"
            tabindex="@(isInteractive ? 0 : -1)"
            @onclick="() => HandleRowClick(item)"
            @onkeydown="e => HandleRowKeyDown(e, item)"
            @onkeydown:preventDefault="_preventRowKeyDown">

            @if (SelectionMode != SelectionMode.None)
            {
                <td class="bui-datagrid__select-cell" role="gridcell" @onclick:stopPropagation="true">
                    <input type="@(SelectionMode == SelectionMode.Single ? "radio" : "checkbox")"
                           class="bui-datagrid__checkbox"
                           checked="@isSelected"
                           tabindex="-1"
                           @onchange="() => HandleSelectRow(item)"
                           aria-label="@($"Select row")" />
                </td>
            }

            @if (RowTemplate != null)
            {
                @RowTemplate(item)
            }
            else
            {
                @foreach (DataGridColumnRegistration<TItem> col in _columns.Where(c => c.Visible))
                {
                    <td class="bui-datagrid__cell @GetAlignClass(col.Align) @col.CellClass" role="gridcell">
                        @if (col.Template != null)
                        {
                            @col.Template(item)
                        }
                        else if (col.ValueSelector != null)
                        {
                            @FormatValue(col.ValueSelector(item), col.Format)
                        }
                    </td>
                }
            }
        </tr>
    };

    private async Task HandleRowKeyDown(KeyboardEventArgs e, TItem item)
    {
        _preventRowKeyDown = false;

        if (e.Key == "Enter" || e.Key == " ")
        {
            _preventRowKeyDown = true;

            if (SelectionMode != SelectionMode.None)
            {
                await HandleSelectRow(item);
            }
            else if (OnRowClick.HasDelegate)
            {
                await HandleRowClick(item);
            }
        }
    }

    private string? GetAriaSort(DataGridColumnRegistration<TItem> col)
    {
        if (!col.Sortable || _state.SortColumn != col.Header)
            return null;

        return _state.SortDirection == SortDirection.Ascending ? "ascending" : "descending";
    }

    private async Task HandleSort(DataGridColumnRegistration<TItem> column)
    {
        if (!column.Sortable || string.IsNullOrEmpty(column.Header))
            return;

        _state.ToggleSort(column.Header);
        _state.ResetPagination();
        ProcessData();

        if (OnSort.HasDelegate)
        {
            await OnSort.InvokeAsync(new DataGridSortEventArgs
            {
                ColumnName = column.Header,
                Direction = _state.SortDirection
            });
        }
    }

    private async Task HandleFilterChange(ChangeEventArgs e)
    {
        _state.FilterText = e.Value?.ToString() ?? string.Empty;
        _state.ResetPagination();
        ProcessData();

        if (OnFilter.HasDelegate)
        {
            await OnFilter.InvokeAsync(new DataGridFilterEventArgs
            {
                FilterText = _state.FilterText
            });
        }
    }

    private void ClearFilter()
    {
        _state.FilterText = string.Empty;
        _state.ResetPagination();
        ProcessData();
    }

    private async Task HandleSelectRow(TItem item)
    {
        _state.SelectItem(item, SelectionMode);
        await NotifySelectionChanged();
    }

    private async Task HandleSelectAll(ChangeEventArgs e)
    {
        if (e.Value is bool isChecked && isChecked)
        {
            _state.SelectAll(_processedItems);
        }
        else
        {
            _state.ClearSelection();
        }

        await NotifySelectionChanged();
    }

    private async Task ClearSelection()
    {
        _state.ClearSelection();
        await NotifySelectionChanged();
    }

    private bool IsAllSelected()
    {
        return _processedItems.Any() && _processedItems.All(_state.IsSelected);
    }

    private async Task NotifySelectionChanged()
    {
        if (SelectedItemsChanged.HasDelegate)
        {
            await SelectedItemsChanged.InvokeAsync(new HashSet<TItem>(_state.SelectedItems));
        }
    }

    private async Task HandleRowClick(TItem item)
    {
        if (OnRowClick.HasDelegate)
        {
            await OnRowClick.InvokeAsync(item);
        }
    }

    private async Task ChangePage(int page)
    {
        if (page < 1 || page > _totalPages)
            return;

        _state.CurrentPage = page;
        ProcessData();

        if (OnPageChange.HasDelegate)
        {
            await OnPageChange.InvokeAsync(new DataGridPageChangeEventArgs
            {
                Page = page,
                PageSize = _state.PageSize
            });
        }
    }

    private async Task HandlePageSizeChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int newSize))
        {
            _state.PageSize = newSize;
            _state.ResetPagination();
            ProcessData();

            if (OnPageChange.HasDelegate)
            {
                await OnPageChange.InvokeAsync(new DataGridPageChangeEventArgs
                {
                    Page = _state.CurrentPage,
                    PageSize = newSize
                });
            }
        }
    }

    private IEnumerable<int> GetVisiblePages()
    {
        const int maxVisible = 5;
        int start = Math.Max(1, _state.CurrentPage - maxVisible / 2);
        int end = Math.Min(_totalPages, start + maxVisible - 1);

        if (end - start + 1 < maxVisible)
        {
            start = Math.Max(1, end - maxVisible + 1);
        }

        return Enumerable.Range(start, end - start + 1);
    }

    private static string GetAlignClass(TableColumnAlign align) => align switch
    {
        TableColumnAlign.Center => "bui-datagrid__cell--center",
        TableColumnAlign.Right => "bui-datagrid__cell--right",
        _ => string.Empty
    };

    private static string FormatValue(object? value, string? format)
    {
        if (value == null) return string.Empty;

        if (!string.IsNullOrEmpty(format) && value is IFormattable formattable)
        {
            return formattable.ToString(format, null);
        }

        return value.ToString() ?? string.Empty;
    }

    private string GetContainerStyle()
    {
        if (EnableVirtualization && !string.IsNullOrEmpty(Height))
        {
            return $"max-height: {Height}; overflow-y: auto;";
        }
        else if (FixedHeader && !string.IsNullOrEmpty(Height))
        {
            return $"max-height: {Height}; overflow-y: auto;";
        }
        return string.Empty;
    }

    public void SortBy(string columnName, SortDirection direction)
    {
        _state.SortColumn = columnName;
        _state.SortDirection = direction;
        ProcessData();
        StateHasChanged();
    }

    public void Filter(string filterText)
    {
        _state.FilterText = filterText;
        _state.ResetPagination();
        ProcessData();
        StateHasChanged();
    }

    public void GoToPage(int page)
    {
        if (page >= 1 && page <= _totalPages)
        {
            _state.CurrentPage = page;
            ProcessData();
            StateHasChanged();
        }
    }

    public IReadOnlySet<TItem> GetSelectedItems() => _state.SelectedItems;
}