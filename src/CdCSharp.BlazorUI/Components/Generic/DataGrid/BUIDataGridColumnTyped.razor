@namespace CdCSharp.BlazorUI.Components
@typeparam TItem
@typeparam TValue
@inherits BUIDataGridColumnBase<TItem, TValue>

@{
    base.BuildRenderTree(__builder);
}

@code {
    protected override DataGridColumnRegistration<TItem> CreateRegistration() => new()
    {
        Header = Header,
        ValueSelector = CompiledSelector,
        Template = Template,
        Format = Format,
        Align = Align,
        Width = Width,
        HeaderClass = HeaderClass,
        CellClass = CellClass,
        Visible = Visible,
        Sortable = Sortable,
        Filterable = Filterable,
        CustomComparer = CustomComparer,
        CustomFilter = CustomFilter
    };
}