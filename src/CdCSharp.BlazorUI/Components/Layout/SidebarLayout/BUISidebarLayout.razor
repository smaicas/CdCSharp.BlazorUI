@namespace CdCSharp.BlazorUI.Components.Layout

@inherits BUIComponentBase

<bui-component @attributes="ComputedAttributes"
               data-bui-sidebar-side="@SidebarSide.ToString().ToLowerInvariant()"
               data-bui-sidebar-open="@_sidebarOpen.ToString().ToLowerInvariant()"
               data-bui-sticky-header="@StickyHeader.ToString().ToLowerInvariant()"
               data-bui-sticky-sidebar="@StickySidebar.ToString().ToLowerInvariant()">

    <header class="bui-sidebar-layout__header">
        @if (ShowToggle)
        {
            <button type="button"
                    class="bui-sidebar-layout__toggle"
                    aria-label="Toggle navigation"
                    aria-expanded="@_sidebarOpen.ToString().ToLowerInvariant()"
                    @onclick="ToggleSidebar">
                <span class="bui-sidebar-layout__toggle-bar"></span>
                <span class="bui-sidebar-layout__toggle-bar"></span>
                <span class="bui-sidebar-layout__toggle-bar"></span>
            </button>
        }
        @if (Header != null)
        {
            <div class="bui-sidebar-layout__header-content">
                @Header
            </div>
        }
    </header>

    <div class="bui-sidebar-layout__body">
        <aside class="bui-sidebar-layout__sidebar">
            <div class="bui-sidebar-layout__sidebar-inner">
                @Sidebar
            </div>
        </aside>

        @if (_sidebarOpen)
        {
            <div class="bui-sidebar-layout__scrim" @onclick="CloseSidebar" aria-hidden="true"></div>
        }

        <main class="bui-sidebar-layout__main">
            @ChildContent
        </main>
    </div>
</bui-component>

@code {
    private bool _sidebarOpen;

    [Parameter] public RenderFragment? Header { get; set; }
    [Parameter] public RenderFragment? Sidebar { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public string? SidebarWidth { get; set; }
    [Parameter] public string? HeaderHeight { get; set; }
    [Parameter] public string? CollapseBreakpoint { get; set; }
    [Parameter] public string? ContentMaxWidth { get; set; }

    [Parameter] public SidebarSide SidebarSide { get; set; } = SidebarSide.Start;
    [Parameter] public bool StickyHeader { get; set; } = true;
    [Parameter] public bool StickySidebar { get; set; } = true;
    [Parameter] public bool ShowToggle { get; set; } = true;

    [Parameter]
    public bool SidebarOpen
    {
        get => _sidebarOpen;
        set => _sidebarOpen = value;
    }

    [Parameter] public EventCallback<bool> SidebarOpenChanged { get; set; }

    private async Task ToggleSidebar()
    {
        _sidebarOpen = !_sidebarOpen;
        if (SidebarOpenChanged.HasDelegate)
            await SidebarOpenChanged.InvokeAsync(_sidebarOpen);
    }

    private async Task CloseSidebar()
    {
        if (!_sidebarOpen) return;
        _sidebarOpen = false;
        if (SidebarOpenChanged.HasDelegate)
            await SidebarOpenChanged.InvokeAsync(_sidebarOpen);
    }

    public override void BuildComponentCssVariables(Dictionary<string, string> cssVariables)
    {
        if (SidebarWidth != null)
            cssVariables["--bui-inline-sidebar-width"] = SidebarWidth;
        if (HeaderHeight != null)
            cssVariables["--bui-inline-header-height"] = HeaderHeight;
        if (CollapseBreakpoint != null)
            cssVariables["--bui-inline-collapse-breakpoint"] = CollapseBreakpoint;
        if (ContentMaxWidth != null)
            cssVariables["--bui-inline-content-max-width"] = ContentMaxWidth;
    }
}
