@namespace CdCSharp.BlazorUI.Components.Layout

@inherits BUIComponentBase

<bui-component @attributes="ComputedAttributes"
               data-bui-sticky-header="@StickyHeader.ToString().ToLowerInvariant()"
               data-bui-sticky-nav="@StickyNav.ToString().ToLowerInvariant()"
               data-bui-nav-open="@_navOpen.ToString().ToLowerInvariant()">

    <header class="bui-stacked-layout__header">
        @if (ShowToggle && Nav != null)
        {
            <button type="button"
                    class="bui-stacked-layout__toggle"
                    aria-label="Toggle navigation"
                    aria-expanded="@_navOpen.ToString().ToLowerInvariant()"
                    @onclick="ToggleNav">
                <span class="bui-stacked-layout__toggle-bar"></span>
                <span class="bui-stacked-layout__toggle-bar"></span>
                <span class="bui-stacked-layout__toggle-bar"></span>
            </button>
        }
        @if (Header != null)
        {
            <div class="bui-stacked-layout__header-content">
                @Header
            </div>
        }
    </header>

    @if (Nav != null)
    {
        <nav class="bui-stacked-layout__nav">
            <div class="bui-stacked-layout__nav-inner">
                @Nav
            </div>
        </nav>
    }

    <main class="bui-stacked-layout__main">
        <div class="bui-stacked-layout__main-inner">
            @ChildContent
        </div>
    </main>
</bui-component>

@code {
    private bool _navOpen;

    [Parameter] public RenderFragment? Header { get; set; }
    [Parameter] public RenderFragment? Nav { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public string? HeaderHeight { get; set; }
    [Parameter] public string? NavMinColumnWidth { get; set; }
    [Parameter] public string? NavGap { get; set; }
    [Parameter] public string? ContentMaxWidth { get; set; }

    [Parameter] public int? NavColumns { get; set; }
    [Parameter] public bool StickyHeader { get; set; } = true;
    [Parameter] public bool StickyNav { get; set; } = false;
    [Parameter] public bool ShowToggle { get; set; } = true;

    [Parameter]
    public bool NavOpen
    {
        get => _navOpen;
        set => _navOpen = value;
    }

    [Parameter] public EventCallback<bool> NavOpenChanged { get; set; }

    private async Task ToggleNav()
    {
        _navOpen = !_navOpen;
        if (NavOpenChanged.HasDelegate)
            await NavOpenChanged.InvokeAsync(_navOpen);
    }

    public override void BuildComponentCssVariables(Dictionary<string, string> cssVariables)
    {
        if (HeaderHeight != null)
            cssVariables[FeatureDefinitions.InlineVariables.LayoutHeaderHeight] = HeaderHeight;
        if (NavMinColumnWidth != null)
            cssVariables[FeatureDefinitions.InlineVariables.LayoutNavColMin] = NavMinColumnWidth;
        if (NavGap != null)
            cssVariables[FeatureDefinitions.InlineVariables.LayoutNavGap] = NavGap;
        if (ContentMaxWidth != null)
            cssVariables[FeatureDefinitions.InlineVariables.LayoutContentMaxWidth] = ContentMaxWidth;
        if (NavColumns.HasValue)
            cssVariables[FeatureDefinitions.InlineVariables.LayoutNavColumns] = NavColumns.Value.ToString();
    }
}
