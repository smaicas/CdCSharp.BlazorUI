@namespace CdCSharp.BlazorUI.Components.Layout
@using CdCSharp.BlazorUI.Components.Layout.TreeMenu
@using CdCSharp.BlazorUI.Core.Abstractions.Behaviors.Design
@using CdCSharp.BlazorUI.Core.Components.Tree
@using Microsoft.AspNetCore.Components.Routing
@inherits TreeComponentBase<TreeMenuItem>
@implements IHasSize
@implements IDisposable
@inject NavigationManager NavigationManager

@{
    base.BuildRenderTree(__builder);
}

<bui-component @attributes="@ComputedAttributes">
    @if (IsDeclarativeMode)
    {
        <CascadingValue Value="@((ITreeRegistry)Engine)" IsFixed="true">
            @ChildContent
        </CascadingValue>
    }

    @if (DeclarativeNodesBuilt || !IsDeclarativeMode)
    {
        <nav class="bui-tree-menu__nav" role="menubar" aria-orientation="@Orientation.ToString().ToLowerInvariant()">
            @foreach (var item in Engine.RootNodes)
            {
                @RenderNode(item)
            }
        </nav>
    }
</bui-component>

@code {
    private string _currentUri = string.Empty;

    [Parameter] public TreeMenuOrientation Orientation { get; set; } = TreeMenuOrientation.Vertical;
    [Parameter] public TreeMenuTrigger Trigger { get; set; } = TreeMenuTrigger.Click;
    [Parameter] public TreeMenuExpandMode ExpandMode { get; set; } = TreeMenuExpandMode.Inline;
    [Parameter] public SizeEnum Size { get; set; } = SizeEnum.Medium;
    [Parameter] public bool Collapsible { get; set; } = true;
    [Parameter] public EventCallback<string> OnNavigate { get; set; }

    public override void BuildComponentDataAttributes(Dictionary<string, object> dataAttributes)
    {
        dataAttributes["data-bui-orientation"] = Orientation.ToString().ToLowerInvariant();
        dataAttributes["data-bui-trigger"] = Trigger.ToString().ToLowerInvariant();
        dataAttributes["data-bui-expand-mode"] = ExpandMode.ToString().ToLowerInvariant();
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        _currentUri = NavigationManager.Uri;
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _currentUri = e.Location;

        if (ExpandMode == TreeMenuExpandMode.Flyout)
        {
            Engine.CollapseAll();
        }

        StateHasChanged();
    }

    protected override RenderFragment RenderNode(TreeNodeState<TreeMenuItem> item) => __builder =>
    {
        var isExpanded = Engine.IsExpanded(item.Key);
        var isActive = IsActive(item.Item?.Href);
        var hasChildren = item.HasChildren;
        var isFlyout = ExpandMode == TreeMenuExpandMode.Flyout;
        var isHoverTrigger = Trigger == TreeMenuTrigger.Hover;

        <div class="bui-tree-menu__item @GetItemClasses(item, isActive, isExpanded)"
             role="none"
             data-depth="@item.Depth"
             @onmouseenter="@(isHoverTrigger && hasChildren ? () => Engine.ExpandAsync(item.Key) : null)"
             @onmouseleave="@(isHoverTrigger && hasChildren && isFlyout ? () => Engine.CollapseAsync(item.Key) : null)">

            @if (!string.IsNullOrEmpty(item.Item?.Href) && !hasChildren)
            {
                <a class="bui-tree-menu__link"
                   href="@item.Item.Href"
                   target="@item.Item.Target"
                   role="menuitem"
                   aria-disabled="@item.Disabled.ToString().ToLowerInvariant()"
                   @onclick="() => HandleNodeInteractionAsync(item)"
                   @onclick:preventDefault="@item.Disabled">
                    @RenderItemContent(item, hasChildren, isExpanded)
                </a>
            }
            else
            {
                <button type="button"
                        class="bui-tree-menu__button"
                        role="menuitem"
                        aria-haspopup="@(hasChildren ? "true" : null)"
                        aria-expanded="@(hasChildren? isExpanded.ToString().ToLowerInvariant() : null)"
                        aria-disabled="@item.Disabled.ToString().ToLowerInvariant()"
                        disabled="@item.Disabled"
                        @onclick="() => HandleNodeInteractionAsync(item)">
                    @RenderItemContent(item, hasChildren, isExpanded)
                </button>
            }

            @if (hasChildren && isExpanded)
            {
                <div class="bui-tree-menu__submenu @(isFlyout ? "bui-tree-menu__submenu--flyout" : "bui-tree-menu__submenu--inline")"
                     role="menu">
                    @foreach (var child in item.ChildrenInternal)
                    {
                        @RenderNode(child)
                    }
                </div>
            }
        </div>
    };

    private RenderFragment RenderItemContent(TreeNodeState<TreeMenuItem> item, bool hasChildren, bool isExpanded) => __builder =>
    {
        @if (item.CustomContent != null)
        {
            @item.CustomContent
        }
        else
        {
            @if (!string.IsNullOrEmpty(item.Icon))
            {
                <BUISvgIcon Icon="@item.Icon" Size="Size" class="bui-tree-menu__icon" />
            }
            <span class="bui-tree-menu__text">@item.Text</span>
        }

        @if (hasChildren)
        {
            <span class="bui-tree-menu__arrow @(isExpanded ? "bui-tree-menu__arrow--expanded" : "")">
                <BUISvgIcon Icon="@GetExpandIcon()" Size="Size" />
            </span>
        }
    };

    protected override async Task HandleNodeInteractionAsync(TreeNodeState<TreeMenuItem> item)
    {
        if (item.Disabled) return;

        // Invoke custom OnClick if provided
        if (item.Item?.OnClick.HasDelegate == true)
        {
            await item.Item.OnClick.InvokeAsync();
        }

        // Handle expansion/collapse
        if (item.HasChildren)
        {
            if (!Collapsible && Engine.IsExpanded(item.Key))
            {
                // Don't collapse if not collapsible
                return;
            }

            // For inline non-collapsible mode, collapse others first
            if (!Collapsible && ExpandMode == TreeMenuExpandMode.Inline)
            {
                Engine.CollapseAll();
            }

            await Engine.ToggleAsync(item.Key);
        }
        // Handle navigation
        else if (!string.IsNullOrEmpty(item.Item?.Href))
        {
            if (OnNavigate.HasDelegate)
            {
                await OnNavigate.InvokeAsync(item.Item.Href);
            }

            if (ExpandMode == TreeMenuExpandMode.Flyout)
            {
                Engine.CollapseAll();
            }
        }
    }

    private string GetItemClasses(TreeNodeState<TreeMenuItem> item, bool isActive, bool isExpanded)
    {
        var classes = new List<string>();

        if (item.Disabled)
            classes.Add("bui-tree-menu__item--disabled");

        if (isActive)
            classes.Add("bui-tree-menu__item--active");

        if (isExpanded)
            classes.Add("bui-tree-menu__item--expanded");

        return string.Join(" ", classes);
    }

    private string GetExpandIcon()
    {
        if (Orientation == TreeMenuOrientation.Horizontal && ExpandMode == TreeMenuExpandMode.Flyout)
        {
            return BUIIcons.UI.ChevronDown;
        }
        return BUIIcons.UI.ChevronRight;
    }

    private bool IsActive(string? href)
    {
        if (string.IsNullOrEmpty(href)) return false;

        var currentPath = NavigationManager.ToBaseRelativePath(_currentUri);
        var targetPath = NavigationManager.ToBaseRelativePath(NavigationManager.ToAbsoluteUri(href).AbsoluteUri);

        if (string.IsNullOrEmpty(currentPath)) currentPath = "/";
        if (string.IsNullOrEmpty(targetPath)) targetPath = "/";

        var item = Engine.GetNode(Engine.RootNodes.FirstOrDefault(n => n.Item?.Href == href)?.Key ?? string.Empty);
        var match = item?.Item?.Match ?? NavLinkMatch.Prefix;

        if (match == NavLinkMatch.All)
        {
            return string.Equals(currentPath, targetPath, StringComparison.OrdinalIgnoreCase);
        }

        return currentPath.StartsWith(targetPath, StringComparison.OrdinalIgnoreCase);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}