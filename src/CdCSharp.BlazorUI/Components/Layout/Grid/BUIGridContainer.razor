@using CdCSharp.BlazorUI.Components.Layout.Grid
@using CdCSharp.BlazorUI.Core.Abstractions.Behaviors.Design

@namespace CdCSharp.BlazorUI.Components.Layout

@inherits BUIComponentBase
@implements IHasDensity

<bui-component @attributes="ComputedAttributes">
    <div class="bui-grid-container">
        @ChildContent
    </div>
</bui-component>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public GridContainerType Type { get; set; } = GridContainerType.Fixed;
    [Parameter] public bool Fluid { get; set; }
    [Parameter] public string? MaxWidthSm { get; set; }
    [Parameter] public string? MaxWidthMd { get; set; }
    [Parameter] public string? MaxWidthLg { get; set; }
    [Parameter] public string? MaxWidthXl { get; set; }
    [Parameter] public bool DisablePadding { get; set; }
    [Parameter] public DensityEnum Density { get; set; } = DensityEnum.Standard;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        if (Fluid)
            Type = GridContainerType.Fluid;
    }

    public override void BuildComponentDataAttributes(Dictionary<string, object> dataAttributes)
    {
        dataAttributes["data-bui-type"] = ToKebabCase(Type.ToString());

        if (DisablePadding)
            dataAttributes["data-bui-disable-padding"] = "true";
    }

    public override void BuildComponentCssVariables(Dictionary<string, string> cssVariables)
    {
        if (MaxWidthSm != null)
            cssVariables["--bui-container-max-width-sm"] = MaxWidthSm;
        if (MaxWidthMd != null)
            cssVariables["--bui-container-max-width-md"] = MaxWidthMd;
        if (MaxWidthLg != null)
            cssVariables["--bui-container-max-width-lg"] = MaxWidthLg;
        if (MaxWidthXl != null)
            cssVariables["--bui-container-max-width-xl"] = MaxWidthXl;
    }

    private static string ToKebabCase(string value) =>
        string.Concat(value.Select((c, i) => i > 0 && char.IsUpper(c) ? $"-{char.ToLower(c)}" : char.ToLower(c).ToString()));
}