@using CdCSharp.BlazorUI.Core.Abstractions.Behaviors.Design

@namespace CdCSharp.BlazorUI.Components.Layout

@inherits BUIComponentBase
@implements IHasDensity

<bui-component @attributes="ComputedAttributes">
    <div class="bui-grid">
        @ChildContent
    </div>
</bui-component>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public int Columns { get; set; } = 12;

    [Parameter] public string? MaxWidth { get; set; }
    [Parameter] public bool DisablePadding { get; set; }

    [Parameter] public string? Gap { get; set; }
    [Parameter] public string? GapXs { get; set; }
    [Parameter] public string? GapSm { get; set; }
    [Parameter] public string? GapMd { get; set; }
    [Parameter] public string? GapLg { get; set; }
    [Parameter] public string? GapXl { get; set; }
    [Parameter] public string? RowGap { get; set; }
    [Parameter] public string? ColumnGap { get; set; }

    [Parameter] public GridDirection Direction { get; set; } = GridDirection.Row;
    [Parameter] public GridDirection? DirectionXs { get; set; }
    [Parameter] public GridDirection? DirectionSm { get; set; }
    [Parameter] public GridDirection? DirectionMd { get; set; }
    [Parameter] public GridDirection? DirectionLg { get; set; }
    [Parameter] public GridDirection? DirectionXl { get; set; }

    [Parameter] public GridJustifyContent JustifyContent { get; set; } = GridJustifyContent.Start;
    [Parameter] public GridAlignItems AlignItems { get; set; } = GridAlignItems.Stretch;
    [Parameter] public GridWrap Wrap { get; set; } = GridWrap.Wrap;

    [Parameter] public string? P { get; set; }
    [Parameter] public string? Pt { get; set; }
    [Parameter] public string? Pr { get; set; }
    [Parameter] public string? Pb { get; set; }
    [Parameter] public string? Pl { get; set; }
    [Parameter] public string? Px { get; set; }
    [Parameter] public string? Py { get; set; }

    [Parameter] public string? M { get; set; }
    [Parameter] public string? Mt { get; set; }
    [Parameter] public string? Mr { get; set; }
    [Parameter] public string? Mb { get; set; }
    [Parameter] public string? Ml { get; set; }
    [Parameter] public string? Mx { get; set; }
    [Parameter] public string? My { get; set; }

    [Parameter] public DensityEnum Density { get; set; } = DensityEnum.Standard;

    public override void BuildComponentDataAttributes(Dictionary<string, object> dataAttributes)
    {
        dataAttributes["data-bui-direction"] = ToKebabCase(Direction.ToString());
        dataAttributes["data-bui-justify-content"] = ToKebabCase(JustifyContent.ToString());
        dataAttributes["data-bui-align-items"] = ToKebabCase(AlignItems.ToString());
        dataAttributes["data-bui-wrap"] = ToKebabCase(Wrap.ToString());

        if (MaxWidth != null)
            dataAttributes["data-bui-contained"] = "true";

        if (DisablePadding)
            dataAttributes["data-bui-disable-padding"] = "true";

        if (DirectionXs.HasValue)
            dataAttributes["data-bui-direction-xs"] = ToKebabCase(DirectionXs.Value.ToString());
        if (DirectionSm.HasValue)
            dataAttributes["data-bui-direction-sm"] = ToKebabCase(DirectionSm.Value.ToString());
        if (DirectionMd.HasValue)
            dataAttributes["data-bui-direction-md"] = ToKebabCase(DirectionMd.Value.ToString());
        if (DirectionLg.HasValue)
            dataAttributes["data-bui-direction-lg"] = ToKebabCase(DirectionLg.Value.ToString());
        if (DirectionXl.HasValue)
            dataAttributes["data-bui-direction-xl"] = ToKebabCase(DirectionXl.Value.ToString());
    }

    public override void BuildComponentCssVariables(Dictionary<string, string> cssVariables)
    {
        cssVariables["--bui-grid-columns"] = Columns.ToString();

        if (MaxWidth != null)
            cssVariables["--bui-grid-max-width"] = MaxWidth;

        string baseGap = NormalizeGapValue(Gap ?? "1rem");
        cssVariables["--bui-grid-gap"] = $"calc({baseGap} * var(--bui-density-gap, 1))";

        if (RowGap != null)
            cssVariables["--bui-grid-row-gap"] = $"calc({NormalizeGapValue(RowGap)} * var(--bui-density-gap, 1))";
        if (ColumnGap != null)
            cssVariables["--bui-grid-column-gap"] = $"calc({NormalizeGapValue(ColumnGap)} * var(--bui-density-gap, 1))";

        if (GapXs != null) cssVariables["--bui-grid-gap-xs"] = $"calc({NormalizeGapValue(GapXs)} * var(--bui-density-gap, 1))";
        if (GapSm != null) cssVariables["--bui-grid-gap-sm"] = $"calc({NormalizeGapValue(GapSm)} * var(--bui-density-gap, 1))";
        if (GapMd != null) cssVariables["--bui-grid-gap-md"] = $"calc({NormalizeGapValue(GapMd)} * var(--bui-density-gap, 1))";
        if (GapLg != null) cssVariables["--bui-grid-gap-lg"] = $"calc({NormalizeGapValue(GapLg)} * var(--bui-density-gap, 1))";
        if (GapXl != null) cssVariables["--bui-grid-gap-xl"] = $"calc({NormalizeGapValue(GapXl)} * var(--bui-density-gap, 1))";

        AddSpacingVariables(cssVariables, "padding", P, Pt, Pr, Pb, Pl, Px, Py);
        AddSpacingVariables(cssVariables, "margin", M, Mt, Mr, Mb, Ml, Mx, My);
    }

    private void AddSpacingVariables(Dictionary<string, string> cssVariables, string property,
        string? all, string? top, string? right, string? bottom, string? left, string? horizontal, string? vertical)
    {
        if (all != null)
        {
            cssVariables[$"--bui-grid-{property}"] = $"calc({all} * var(--bui-density-gap, 1))";
            return;
        }

        if (vertical != null)
        {
            cssVariables[$"--bui-grid-{property}-top"] = $"calc({vertical} * var(--bui-density-gap, 1))";
            cssVariables[$"--bui-grid-{property}-bottom"] = $"calc({vertical} * var(--bui-density-gap, 1))";
        }
        if (horizontal != null)
        {
            cssVariables[$"--bui-grid-{property}-left"] = $"calc({horizontal} * var(--bui-density-gap, 1))";
            cssVariables[$"--bui-grid-{property}-right"] = $"calc({horizontal} * var(--bui-density-gap, 1))";
        }

        if (top != null) cssVariables[$"--bui-grid-{property}-top"] = $"calc({top} * var(--bui-density-gap, 1))";
        if (right != null) cssVariables[$"--bui-grid-{property}-right"] = $"calc({right} * var(--bui-density-gap, 1))";
        if (bottom != null) cssVariables[$"--bui-grid-{property}-bottom"] = $"calc({bottom} * var(--bui-density-gap, 1))";
        if (left != null) cssVariables[$"--bui-grid-{property}-left"] = $"calc({left} * var(--bui-density-gap, 1))";
    }

    private static string NormalizeGapValue(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "0px";

        string trimmed = value.Trim();

        if (trimmed == "0")
            return "0px";

        return trimmed;
    }

    private static string ToKebabCase(string value) =>
        string.Concat(value.Select((c, i) => i > 0 && char.IsUpper(c) ? $"-{char.ToLower(c)}" : char.ToLower(c).ToString()));
}