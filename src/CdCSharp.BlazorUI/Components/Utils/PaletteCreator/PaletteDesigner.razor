@using CdCSharp.BlazorUI.Components.Layout
@using CdCSharp.BlazorUI.Core.Theming.Abstractions

@namespace CdCSharp.BlazorUI.Components.Utils

<style id="palette-designer-variables">
    :root {
        @foreach (KeyValuePair<string, CssColor>
                kvp in _darkPalette)
        {
            @($"--palette-{kvp.Key}: {kvp.Value.ToString(ColorOutputFormats.Optimized)};")
        }
    }

    html[data-theme="light"] {
        @foreach (KeyValuePair<string, CssColor>
                kvp in _lightPalette)
        {
            @($"--palette-{kvp.Key}: {kvp.Value.ToString(ColorOutputFormats.Optimized)};")
        }
    }
</style>

<BUIGrid Columns="12" Gap="0" style="min-height: 100vh;">
    <BUIGridItem Span="4" Xl="3" Md="12">
        <PaletteCreator DarkPalette="_darkPalette"
                        LightPalette="_lightPalette"
                        OnDarkPaletteChanged="OnDarkPaletteChanged"
                        OnLightPaletteChanged="OnLightPaletteChanged" />
    </BUIGridItem>
    <BUIGridItem Span="8" Xl="9" Md="12">
        <PalettePreview DarkPalette="_darkPalette" LightPalette="_lightPalette" />
    </BUIGridItem>
</BUIGrid>

@code {
    private Dictionary<string, CssColor> _darkPalette = new()
    {
        ["primary"] = new("#8ab4f8"),
        ["primarycontrast"] = new("#121417"),
        ["secondary"] = new("#c792ea"),
        ["secondarycontrast"] = new("#121417"),
        ["error"] = new("#cf6679"),
        ["errorcontrast"] = new("#121417"),
        ["success"] = new("#4dd4a3"),
        ["successcontrast"] = new("#121417"),
        ["warning"] = new("#e6b566"),
        ["warningcontrast"] = new("#121417"),
        ["info"] = new("#7aa2f7"),
        ["infocontrast"] = new("#121417"),
        ["background"] = new("#121417"),
        ["backgroundcontrast"] = new("#eceff1"),
        ["surface"] = new("#1e2126"),
        ["surfacecontrast"] = new("#eceff1"),
        ["border"] = new("#eeeeee"),
        ["shadow"] = new("#777777"),
        ["highlight"] = new("#aa2222"),
        ["black"] = new("#010101"),
        ["white"] = new("#e9e9e9")
    };

    private Dictionary<string, CssColor> _lightPalette = new()
    {
        ["primary"] = new("#2f3e46"),
        ["primarycontrast"] = new("#ffffff"),
        ["secondary"] = new("#6d6875"),
        ["secondarycontrast"] = new("#ffffff"),
        ["error"] = new("#b94a48"),
        ["errorcontrast"] = new("#ffffff"),
        ["success"] = new("#4a7c59"),
        ["successcontrast"] = new("#ffffff"),
        ["warning"] = new("#b5893d"),
        ["warningcontrast"] = new("#1f2328"),
        ["info"] = new("#5a6f8a"),
        ["infocontrast"] = new("#ffffff"),
        ["background"] = new("#f2f2f0"),
        ["backgroundcontrast"] = new("#1f2328"),
        ["surface"] = new("#ffffff"),
        ["surfacecontrast"] = new("#1f2328"),
        ["border"] = new("#111111"),
        ["shadow"] = new("#000000"),
        ["highlight"] = new("#aa2222"),
        ["black"] = new("#010101"),
        ["white"] = new("#e9e9e9")
    };

    private void OnDarkPaletteChanged(Dictionary<string, CssColor> palette)
    {
        _darkPalette = palette;
        StateHasChanged();
    }

    private void OnLightPaletteChanged(Dictionary<string, CssColor> palette)
    {
        _lightPalette = palette;
        StateHasChanged();
    }
}