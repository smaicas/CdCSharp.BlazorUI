@using CdCSharp.BlazorUI.Components.Forms
@using CdCSharp.BlazorUI.Components.Layout
@using CdCSharp.BlazorUI.Core.Theming.Abstractions
@using CdCSharp.BlazorUI.SyntaxHighlight
@using System.Text.Json
@using System.Text

@namespace CdCSharp.BlazorUI.Components.Utils

<BUIGrid Direction="GridDirection.Column" Gap="1rem" P="1rem"
         style="background: var(--palette-surface); border-right: 1px solid var(--palette-border); height: 100vh; overflow-y: auto;">

    <BUIGridItem>
        <h2 style="margin: 0 0 0.25rem 0;">Palette Creator</h2>
        <small style="opacity: 0.7;">Design your theme</small>
    </BUIGridItem>

    <BUIGridItem>
        <BUIGrid Columns="2" Gap="0.5rem">
            <BUIGridItem><BUIButton Text="Complementary" Size="SizeEnum.Small" OnClick="() => ApplyHarmony(ColorHarmony.Complementary)" /></BUIGridItem>
            <BUIGridItem><BUIButton Text="Analogous" Size="SizeEnum.Small" OnClick="() => ApplyHarmony(ColorHarmony.Analogous)" /></BUIGridItem>
            <BUIGridItem><BUIButton Text="Triadic" Size="SizeEnum.Small" OnClick="() => ApplyHarmony(ColorHarmony.Triadic)" /></BUIGridItem>
            <BUIGridItem><BUIButton Text="Random" Size="SizeEnum.Small" OnClick="GenerateRandomPalette" /></BUIGridItem>
        </BUIGrid>
    </BUIGridItem>

    @RenderColorSection("Brand", new[] { "primary", "primarycontrast", "secondary", "secondarycontrast" })
    @RenderColorSection("Semantic", new[] { "error", "errorcontrast", "success", "successcontrast", "warning", "warningcontrast", "info", "infocontrast" })
    @RenderColorSection("Surface", new[] { "background", "backgroundcontrast", "surface", "surfacecontrast" })
    @RenderColorSection("Utility", new[] { "border", "shadow", "highlight", "black", "white" })

    <BUIGridItem>
        <small style="opacity: 0.6; text-transform: uppercase; letter-spacing: 0.05em;">Export</small>
        <BUIGrid Columns="2" Gap="0.5rem" style="margin-top: 0.5rem;">
            <BUIGridItem><BUIButton Text="Dark CSS" Size="SizeEnum.Small" LeadingIcon="@BUIIcons.MaterialIconsRound.i_code" OnClick="() => OpenExportModal(ExportFormat.Css, ThemeMode.Dark)" /></BUIGridItem>
            <BUIGridItem><BUIButton Text="Light CSS" Size="SizeEnum.Small" LeadingIcon="@BUIIcons.MaterialIconsRound.i_code" OnClick="() => OpenExportModal(ExportFormat.Css, ThemeMode.Light)" /></BUIGridItem>
            <BUIGridItem><BUIButton Text="Dark C#" Size="SizeEnum.Small" LeadingIcon="@BUIIcons.MaterialIconsRound.i_terminal" OnClick="() => OpenExportModal(ExportFormat.CSharp, ThemeMode.Dark)" /></BUIGridItem>
            <BUIGridItem><BUIButton Text="Light C#" Size="SizeEnum.Small" LeadingIcon="@BUIIcons.MaterialIconsRound.i_terminal" OnClick="() => OpenExportModal(ExportFormat.CSharp, ThemeMode.Light)" /></BUIGridItem>
            <BUIGridItem><BUIButton Text="Dark JSON" Size="SizeEnum.Small" LeadingIcon="@BUIIcons.MaterialIconsRound.i_data_object" OnClick="() => OpenExportModal(ExportFormat.Json, ThemeMode.Dark)" /></BUIGridItem>
            <BUIGridItem><BUIButton Text="Light JSON" Size="SizeEnum.Small" LeadingIcon="@BUIIcons.MaterialIconsRound.i_data_object" OnClick="() => OpenExportModal(ExportFormat.Json, ThemeMode.Light)" /></BUIGridItem>
            <BUIGridItem Span="2"><BUIButton Text="Import JSON" Size="SizeEnum.Small" LeadingIcon="@BUIIcons.MaterialIconsRound.i_upload" OnClick="OpenImportModal" /></BUIGridItem>
        </BUIGrid>
    </BUIGridItem>
</BUIGrid>

<BUIDialog @bind-Open="_showExportModal" Title="@GetExportTitle()" Closable="true" MaxWidth="800px">
    <Content>
        <BUICodeBlock Code="@_exportContent" Language="@GetExportLanguage()" />
    </Content>
    <Footer>
        <BUIButton Text="Close" OnClick="() => _showExportModal = false" />
    </Footer>
</BUIDialog>

<BUIDialog @bind-Open="_showImportModal" Title="Import Palette (JSON)" Closable="true" MaxWidth="600px">
    <Content>
        <BUIGrid Columns="2" Gap="0.5rem" style="margin-bottom: 1rem;">
            <BUIGridItem><BUIButton Text="Import to Dark" Size="SizeEnum.Small" OnClick="() => ImportPalette(ThemeMode.Dark)" /></BUIGridItem>
            <BUIGridItem><BUIButton Text="Import to Light" Size="SizeEnum.Small" OnClick="() => ImportPalette(ThemeMode.Light)" /></BUIGridItem>
        </BUIGrid>
        <BUIInputTextArea @bind-Value="_importJson" Label="Paste JSON here" Rows="10" Placeholder='{"primary": "#3B82F6", ...}' />
        @if (!string.IsNullOrEmpty(_importError))
        {
            <p style="color: var(--palette-error); margin-top: 0.5rem;">@_importError</p>
        }
    </Content>
    <Footer>
        <BUIButton Text="Close" OnClick="() => _showImportModal = false" />
    </Footer>
</BUIDialog>

@code {
    [Parameter] public Dictionary<string, CssColor> DarkPalette { get; set; } = new();
    [Parameter] public Dictionary<string, CssColor> LightPalette { get; set; } = new();
    [Parameter] public EventCallback<Dictionary<string, CssColor>> OnDarkPaletteChanged { get; set; }
    [Parameter] public EventCallback<Dictionary<string, CssColor>> OnLightPaletteChanged { get; set; }

    private readonly Random _random = new();
    private bool _showExportModal = false;
    private bool _showImportModal = false;
    private ExportFormat _currentExportFormat = ExportFormat.Css;
    private ThemeMode _currentExportTheme = ThemeMode.Dark;
    private string _exportContent = "";
    private string _importJson = "";
    private string _importError = "";

    private static readonly Dictionary<string, string> ColorLabels = new()
    {
        ["primary"] = "Primary",
        ["primarycontrast"] = "Primary Ctr",
        ["secondary"] = "Secondary",
        ["secondarycontrast"] = "Secondary Ctr",
        ["error"] = "Error",
        ["errorcontrast"] = "Error Ctr",
        ["success"] = "Success",
        ["successcontrast"] = "Success Ctr",
        ["warning"] = "Warning",
        ["warningcontrast"] = "Warning Ctr",
        ["info"] = "Info",
        ["infocontrast"] = "Info Ctr",
        ["background"] = "Background",
        ["backgroundcontrast"] = "Bg Contrast",
        ["surface"] = "Surface",
        ["surfacecontrast"] = "Surface Ctr",
        ["border"] = "Border",
        ["shadow"] = "Shadow",
        ["highlight"] = "Highlight",
        ["black"] = "Black",
        ["white"] = "White"
    };

    private RenderFragment RenderColorSection(string title, string[] keys) => __builder =>
    {
        <BUIGridItem>
            <small style="opacity: 0.6; text-transform: uppercase; letter-spacing: 0.05em;">@title</small>
            <BUIGrid Columns="12" Gap="0.25rem" style="margin-top: 0.5rem;">
                <BUIGridItem Span="4"></BUIGridItem>
                <BUIGridItem Span="4" style="text-align: center;"><small style="opacity: 0.5;">Dark</small></BUIGridItem>
                <BUIGridItem Span="4" style="text-align: center;"><small style="opacity: 0.5;">Light</small></BUIGridItem>
                @foreach (string key in keys)
                {
                    <BUIGridItem Span="4" style="display: flex; align-items: center;">
                        <small>@ColorLabels.GetValueOrDefault(key, key)</small>
                    </BUIGridItem>
                    <BUIGridItem Span="4">
                        <BUIInputColor Value="@DarkPalette[key]"
                                       ValueChanged="@(c => OnColorChanged(key, c, ThemeMode.Dark))"
                                       ValueExpression="@(() => DarkPalette[key])"
                                       Size="SizeEnum.Small" />
                    </BUIGridItem>
                    <BUIGridItem Span="4">
                        <BUIInputColor Value="@LightPalette[key]"
                                       ValueChanged="@(c => OnColorChanged(key, c, ThemeMode.Light))"
                                       ValueExpression="@(() => LightPalette[key])"
                                       Size="SizeEnum.Small" />
                    </BUIGridItem>
                }
            </BUIGrid>
        </BUIGridItem>
    };

    private async Task OnColorChanged(string key, CssColor? newColor, ThemeMode mode)
    {
        if (newColor == null) return;

        if (mode == ThemeMode.Dark)
        {
            DarkPalette[key] = newColor;
            await OnDarkPaletteChanged.InvokeAsync(DarkPalette);
        }
        else
        {
            LightPalette[key] = newColor;
            await OnLightPaletteChanged.InvokeAsync(LightPalette);
        }
    }

    private async Task ApplyHarmony(ColorHarmony harmony)
    {
        await ApplyHarmonyToPalette(DarkPalette, harmony);
        await ApplyHarmonyToPalette(LightPalette, harmony);
        await OnDarkPaletteChanged.InvokeAsync(DarkPalette);
        await OnLightPaletteChanged.InvokeAsync(LightPalette);
    }

    private Task ApplyHarmonyToPalette(Dictionary<string, CssColor> palette, ColorHarmony harmony)
    {
        CssColor baseColor = palette["primary"];
        double h = baseColor.H;
        double s = baseColor.S;
        double l = baseColor.L;

        switch (harmony)
        {
            case ColorHarmony.Complementary:
                palette["secondary"] = CreateHsl((h + 180) % 360, s, l);
                break;
            case ColorHarmony.Analogous:
                palette["secondary"] = CreateHsl((h + 30) % 360, s, l);
                break;
            case ColorHarmony.Triadic:
                palette["secondary"] = CreateHsl((h + 120) % 360, s, l);
                break;
        }

        palette["error"] = CreateHsl(0, 0.7, l > 0.5 ? 0.45 : 0.65);
        palette["success"] = CreateHsl(140, 0.6, l > 0.5 ? 0.4 : 0.6);
        palette["warning"] = CreateHsl(40, 0.8, l > 0.5 ? 0.45 : 0.65);
        palette["info"] = CreateHsl(210, 0.6, l > 0.5 ? 0.45 : 0.65);

        UpdateContrastColors(palette);
        return Task.CompletedTask;
    }

    private async Task GenerateRandomPalette()
    {
        double darkHue = _random.Next(0, 360);
        double lightHue = _random.Next(0, 360);

        DarkPalette["primary"] = CreateHsl(darkHue, 0.6 + _random.NextDouble() * 0.3, 0.65 + _random.NextDouble() * 0.15);
        LightPalette["primary"] = CreateHsl(lightHue, 0.4 + _random.NextDouble() * 0.3, 0.3 + _random.NextDouble() * 0.15);

        ColorHarmony[] harmonies = Enum.GetValues<ColorHarmony>();
        ColorHarmony randomHarmony = harmonies[_random.Next(harmonies.Length)];

        await ApplyHarmonyToPalette(DarkPalette, randomHarmony);
        await ApplyHarmonyToPalette(LightPalette, randomHarmony);
        await OnDarkPaletteChanged.InvokeAsync(DarkPalette);
        await OnLightPaletteChanged.InvokeAsync(LightPalette);
    }

    private void UpdateContrastColors(Dictionary<string, CssColor> palette)
    {
        string[] baseColors = { "primary", "secondary", "error", "success", "warning", "info", "background", "surface" };
        foreach (string color in baseColors)
        {
            if (palette.ContainsKey(color))
                palette[$"{color}contrast"] = palette[color].GetBestContrast();
        }
    }

    private CssColor CreateHsl(double h, double s, double l) =>
        new CssColor(h, Math.Clamp(s, 0, 1), Math.Clamp(l, 0, 1), 255);

    private void OpenExportModal(ExportFormat format, ThemeMode theme)
    {
        _currentExportFormat = format;
        _currentExportTheme = theme;
        Dictionary<string, CssColor> palette = theme == ThemeMode.Dark ? DarkPalette : LightPalette;

        _exportContent = format switch
        {
            ExportFormat.Css => GenerateCssExport(palette, theme),
            ExportFormat.CSharp => GenerateCSharpExport(palette, theme),
            ExportFormat.Json => GenerateJsonExport(palette),
            _ => ""
        };
        _showExportModal = true;
    }

    private void OpenImportModal()
    {
        _importJson = "";
        _importError = "";
        _showImportModal = true;
    }

    private string GetExportTitle() => $"Export {_currentExportTheme} - {_currentExportFormat}";

    private SyntaxHighlightLanguage GetExportLanguage() => _currentExportFormat switch
    {
        ExportFormat.Css => SyntaxHighlightLanguage.Css,
        ExportFormat.CSharp => SyntaxHighlightLanguage.CSharp,
        ExportFormat.Json => SyntaxHighlightLanguage.Json,
        _ => SyntaxHighlightLanguage.CSharp
    };

    private string GenerateCssExport(Dictionary<string, CssColor> palette, ThemeMode theme)
    {
        StringBuilder sb = new();
        string selector = theme == ThemeMode.Dark ? ":root" : "html[data-theme=\"light\"]";
        sb.AppendLine($"{selector} {{");
        foreach (KeyValuePair<string, CssColor> kvp in palette.OrderBy(x => x.Key))
        {
            sb.AppendLine($"  --palette-{kvp.Key}: {kvp.Value.ToString(ColorOutputFormats.Hex)};");
        }
        sb.AppendLine("}");
        return sb.ToString();
    }

    private string GenerateCSharpExport(Dictionary<string, CssColor> palette, ThemeMode theme)
    {
        StringBuilder sb = new();
        sb.AppendLine("using CdCSharp.BlazorUI.Components;");
        sb.AppendLine("using CdCSharp.BlazorUI.Core.Theming.Abstractions;");
        sb.AppendLine();
        sb.AppendLine("namespace YourNamespace;");
        sb.AppendLine();
        sb.AppendLine($"public class {theme}Theme : BUIThemePaletteBase");
        sb.AppendLine("{");
        sb.AppendLine($"    public {theme}Theme()");
        sb.AppendLine("    {");
        sb.AppendLine($"        Id = \"{theme.ToString().ToLower()}\";");
        sb.AppendLine($"        Name = \"{theme} Theme\";");

        Dictionary<string, string> propMap = new()
        {
            ["primary"] = "Primary",
            ["primarycontrast"] = "PrimaryContrast",
            ["secondary"] = "Secondary",
            ["secondarycontrast"] = "SecondaryContrast",
            ["error"] = "Error",
            ["errorcontrast"] = "ErrorContrast",
            ["success"] = "Success",
            ["successcontrast"] = "SuccessContrast",
            ["warning"] = "Warning",
            ["warningcontrast"] = "WarningContrast",
            ["info"] = "Info",
            ["infocontrast"] = "InfoContrast",
            ["background"] = "Background",
            ["backgroundcontrast"] = "BackgroundContrast",
            ["surface"] = "Surface",
            ["surfacecontrast"] = "SurfaceContrast",
            ["border"] = "Border",
            ["shadow"] = "Shadow",
            ["highlight"] = "Highlight",
            ["black"] = "Black",
            ["white"] = "White"
        };

        foreach (KeyValuePair<string, CssColor> kvp in palette)
        {
            if (propMap.TryGetValue(kvp.Key, out string? prop))
                sb.AppendLine($"        {prop} = new CssColor(\"{kvp.Value.ToString(ColorOutputFormats.Hex)}\");");
        }

        sb.AppendLine("    }");
        sb.AppendLine("}");
        return sb.ToString();
    }

    private string GenerateJsonExport(Dictionary<string, CssColor> palette)
    {
        Dictionary<string, string> dict = palette.ToDictionary(k => k.Key, v => v.Value.ToString(ColorOutputFormats.Hex));
        return JsonSerializer.Serialize(dict, new JsonSerializerOptions { WriteIndented = true });
    }

    private async Task ImportPalette(ThemeMode mode)
    {
        _importError = "";
        try
        {
            Dictionary<string, string>? imported = JsonSerializer.Deserialize<Dictionary<string, string>>(_importJson);
            if (imported == null)
            {
                _importError = "Invalid JSON format.";
                return;
            }

            Dictionary<string, CssColor> target = mode == ThemeMode.Dark ? DarkPalette : LightPalette;

            foreach (KeyValuePair<string, string> kvp in imported)
            {
                string key = kvp.Key.ToLowerInvariant();
                if (target.ContainsKey(key))
                    target[key] = new CssColor(kvp.Value);
            }

            _showImportModal = false;

            if (mode == ThemeMode.Dark)
                await OnDarkPaletteChanged.InvokeAsync(DarkPalette);
            else
                await OnLightPaletteChanged.InvokeAsync(LightPalette);
        }
        catch (Exception ex)
        {
            _importError = $"Error: {ex.Message}";
        }
    }

    private enum ColorHarmony { Complementary, Analogous, Triadic }
    private enum ExportFormat { Css, CSharp, Json }
    private enum ThemeMode { Dark, Light }
}