@using CdCSharp.BlazorUI.Components.Layout

@namespace CdCSharp.BlazorUI.Components.Utils

<BUIGrid Direction="GridDirection.Column" Gap="1rem" P="1.5rem"
         style="background: var(--palette-surface); border-radius: 12px; border: 1px solid var(--palette-border);">
    <BUIGridItem>
        <h3 style="font-size: 1rem; font-weight: 600; margin: 0; padding-bottom: 0.75rem; border-bottom: 1px solid var(--palette-border);">
            @Title
        </h3>
    </BUIGridItem>
    <BUIGridItem>
        @ChildContent
    </BUIGridItem>
</BUIGrid>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}