@using CdCSharp.BlazorUI.Components.Utils.Patterns.Abstractions
@using System.Globalization
@using CdCSharp.BlazorUI.Components.Utils.Patterns.DateTimePattern

@namespace CdCSharp.BlazorUI.Components.Utils

@inherits BUIBasePattern

<div @ref="_containerBox" class="pattern-container" data-pattern-id="@ComponentId">
    @foreach (var span in _patternState.Spans)
    {
        <span @key="@($"span_{ComponentId}_{span.Index}")"
              class="@GetSpanClass(span)"
              contenteditable="@(span.IsEditable && Editable ? "true" : "false")"
              data-index="@span.Index"
              data-maxlength="@span.MaxLength">@span.DisplayValue</span>
    }
</div>
@(Text != null ? @Text : "null")

@code {
    private ParsedDatePattern? _parsedPattern;

    private string GetSpanClass(SpanState span)
    {
        return span.IsEditable ? "pattern-editable" : "pattern-separator";
    }

    protected override PatternState CreatePatternState()
    {
        PatternState state = new();
        _parsedPattern = DatePatternParser.Parse(Format);
        int spanIndex = 0;

        foreach (DateComponent component in _parsedPattern.Components)
        {
            SpanState span = new()
            {
                Index = spanIndex++,
                IsEditable = component.Type != DateComponentType.Separator,
                AllowedChars = GetAllowedChars(component.Type),
                MaxLength = component.MaxDigits,
                Placeholder = component.DefaultValue,
                Validator = value => ValidateDateComponent(component.Type, value)
            };

            state.Spans.Add(span);
        }

        return state;
    }

    protected override void InitializeFromText(string? text)
    {
        // Reset all spans to empty (showing placeholders)
        foreach (SpanState span in _patternState.Spans.Where(s => s.IsEditable))
        {
            span.Value = string.Empty;
        }

        if (string.IsNullOrEmpty(text) || _parsedPattern == null)
            return;

        // Try to parse with the format
        if (DateTime.TryParseExact(text, Format, CultureInfo.InvariantCulture, DateTimeStyles.None, out DateTime date))
        {
            int spanIndex = 0;
            foreach (DateComponent component in _parsedPattern.Components)
            {
                if (component.Type != DateComponentType.Separator && spanIndex < _patternState.Spans.Count)
                {
                    SpanState span = _patternState.Spans[spanIndex];
                    span.Value = GetComponentValue(component, date);
                }
                spanIndex++;
            }
        }
    }

    protected override bool ValidateComplete(string text)
    {
        return DateTime.TryParseExact(
            text,
            Format,
            CultureInfo.InvariantCulture,
            DateTimeStyles.None,
            out _);
    }

    protected override string NormalizeSeparators(string text)
    {
        // Replace common date separators with the one used in format
        char separator = '/'; // Default

        if (Format.Contains('-')) separator = '-';
        else if (Format.Contains('.')) separator = '.';

        return text
            .Replace('-', separator)
            .Replace('.', separator)
            .Replace(',', separator)
            .Replace('\\', separator)
            .Replace(' ', separator);
    }

    private string GetAllowedChars(DateComponentType type)
    {
        return type switch
        {
            DateComponentType.AmPm => "w",
            DateComponentType.Separator => "",
            _ => "d"
        };
    }

    private bool ValidateDateComponent(DateComponentType type, string value)
    {
        if (string.IsNullOrWhiteSpace(value)) return false;

        return type switch
        {
            DateComponentType.Day => int.TryParse(value, out int d) && d >= 1 && d <= 31,
            DateComponentType.Month => int.TryParse(value, out int m) && m >= 1 && m <= 12,
            DateComponentType.Year => value.Length == 2 || value.Length == 4,
            DateComponentType.Hour12 => int.TryParse(value, out int h) && h >= 1 && h <= 12,
            DateComponentType.Hour24 => int.TryParse(value, out int h) && h >= 0 && h <= 23,
            DateComponentType.Minute => int.TryParse(value, out int m) && m >= 0 && m <= 59,
            DateComponentType.Second => int.TryParse(value, out int s) && s >= 0 && s <= 59,
            DateComponentType.AmPm => value.ToUpperInvariant() is "A" or "P" or "AM" or "PM",
            _ => true
        };
    }

    private string GetComponentValue(DateComponent component, DateTime date)
    {
        return component.Type switch
        {
            DateComponentType.Day => date.Day.ToString("00"),
            DateComponentType.Month => date.Month.ToString("00"),
            DateComponentType.Year => component.MinDigits == 2
                ? date.Year.ToString("00").Substring(2)
                : date.Year.ToString("0000"),
            DateComponentType.Hour12 => (date.Hour % 12 == 0 ? 12 : date.Hour % 12).ToString("00"),
            DateComponentType.Hour24 => date.Hour.ToString("00"),
            DateComponentType.Minute => date.Minute.ToString("00"),
            DateComponentType.Second => date.Second.ToString("00"),
            DateComponentType.AmPm => date.Hour < 12 ? "AM" : "PM",
            _ => ""
        };
    }
}

<style>
    .pattern-container {
        display: inline-flex;
        align-items: center;
        border: 1px solid #ccc;
        border-radius: 4px;
        padding: 6px 8px;
        font-family: monospace;
        font-size: 14px;
    }

    .pattern-editable {
        min-width: 2ch;
        text-align: center;
        outline: none;
        color: #333;
    }

        .pattern-editable:empty:before {
            content: attr(data-placeholder);
            color: #999;
        }

        .pattern-editable:focus {
            background-color: #e3f2fd;
            border-radius: 2px;
        }

    .pattern-separator {
        color: #666;
        padding: 0 2px;
    }
</style>