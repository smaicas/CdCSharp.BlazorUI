@using CdCSharp.BlazorUI.Components.Abstractions
@using CdCSharp.BlazorUI.Components.Features.Common
@using CdCSharp.BlazorUI.Core.Css
@using CdCSharp.BlazorUI.Css

@inherits UIVariantComponentBase<UILoadingIndicator, UILoadingIndicatorVariant>
@implements IHasSize
@implements IHasColor

@{
    base.BuildRenderTree(__builder);
}

@code {
    // IHasColor
    [Parameter] public CssColor? Color { get; set; }

    // IHasSize
    [Parameter] public SizeEnum Size { get; set; } = SizeEnum.Medium;

    /* ========= Variant ========= */

    protected override UILoadingIndicatorVariant DefaultVariant => UILoadingIndicatorVariant.Spinner;

    protected override Dictionary<UILoadingIndicatorVariant, Func<UILoadingIndicator, RenderFragment>> BuiltInTemplates { get; } = new()
    {
        [UILoadingIndicatorVariant.Spinner] = i => i.RenderSpinner(),
        [UILoadingIndicatorVariant.LinearIndeterminate] = i => i.RenderLinear(),
        [UILoadingIndicatorVariant.CircularProgress] = i => i.RenderCircularProgress(),
        [UILoadingIndicatorVariant.Dots] = i => i.RenderDots(),
        [UILoadingIndicatorVariant.Pulse] = i => i.RenderPulse(),
    };

    /* ========= Render Methods ========= */

    private RenderFragment RenderSpinner() => __builder =>
    {
        <ui-component @attributes="ComputedAttributes"
                      data-ui-component="loading-indicator"
                      data-ui-variant="spinner">
            <svg class="ui-loading-spinner" viewBox="0 0 50 50">
                <circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="4"></circle>
            </svg>
        </ui-component>
    };

    private RenderFragment RenderLinear() => __builder =>
    {
        <ui-component @attributes="ComputedAttributes"
                      data-ui-component="loading-indicator"
                      data-ui-variant="linearindeterminate">
            <div class="ui-loading-linear">
                <div class="ui-loading-linear__bar"></div>
            </div>
        </ui-component>
    };

    private RenderFragment RenderCircularProgress() => __builder =>
    {
        <ui-component @attributes="ComputedAttributes"
                      data-ui-component="loading-indicator"
                      data-ui-variant="circularprogress">
            <svg class="ui-loading-circular" viewBox="0 0 50 50">
                <circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="4"></circle>
            </svg>
        </ui-component>
    };

    private RenderFragment RenderDots() => __builder =>
    {
        <ui-component @attributes="ComputedAttributes"
                      data-ui-component="loading-indicator"
                      data-ui-variant="dots">
            <span class="ui-loading-dot"></span>
            <span class="ui-loading-dot"></span>
            <span class="ui-loading-dot"></span>
        </ui-component>
    };

    private RenderFragment RenderPulse() => __builder =>
    {
        <ui-component @attributes="ComputedAttributes"
                      data-ui-component="loading-indicator"
                      data-ui-variant="pulse">
            <span class="ui-loading-pulse"></span>
        </ui-component>
    };
}