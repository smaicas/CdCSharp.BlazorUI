<Project Sdk="Microsoft.NET.Sdk.Razor">
	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<PackageId>CdCSharp.BlazorUI</PackageId>
		<Authors>Samuel Maícas (CdCSharp)</Authors>
		<Description>Librería de componentes Blazor</Description>
		<PackageTags>blazor;components;ui</PackageTags>
		<Version>1.0.0</Version>
	</PropertyGroup>

	<ItemGroup>
		<InternalsVisibleTo Include="CdCSharp.BlazorUI.Tests.Integration" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="10.0.1" />
		<PackageReference Include="Microsoft.Extensions.Localization" Version="10.0.1" />
	</ItemGroup>
	<ItemGroup>
		<ProjectReference Include="..\CdCSharp.BlazorUI.Core\CdCSharp.BlazorUI.Core.csproj" />
	</ItemGroup>
	<!--
	Incluir el archivo de targets en el paquete NuGet -->
	<ItemGroup>
		<None Include="_build\CdCSharp.BlazorUI.targets" Pack="true" PackagePath="build\" />
	</ItemGroup>
	
	<!-- Importar los targets localmente para desarrollo -->
	<Import Project="_build\CdCSharp.BlazorUI.targets" Condition="Exists('_build\CdCSharp.BlazorUI.targets')" />

	<ItemGroup>
		<ProjectReference Include="..\CdCSharp.BlazorUI.Core.CodeGeneration\CdCSharp.BlazorUI.Core.CodeGeneration.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
		<ProjectReference Include="..\CdCSharp.BlazorUI.Localization.Abstractions\CdCSharp.BlazorUI.Localization.Abstractions.csproj" />
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="Types\Behaviors\" />
	</ItemGroup>

	<ItemGroup>
	  <None Update="Types\Storage\LocalStorageInterop.ts">
	    <SubType>Code</SubType>
	  </None>
	</ItemGroup>

</Project>