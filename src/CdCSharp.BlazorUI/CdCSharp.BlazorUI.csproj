<Project Sdk="Microsoft.NET.Sdk.Razor">
	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<PackageId>CdCSharp.BlazorUI</PackageId>
		<Authors>Samuel Maícas (CdCSharp)</Authors>
		<Description>Librería de componentes Blazor</Description>
		<PackageTags>blazor;components;ui</PackageTags>
		<Version>1.0.0</Version>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="10.0.0" />
	</ItemGroup>
	<ItemGroup>
		<ProjectReference Include="..\CdCSharp.BlazorUI.Core\CdCSharp.BlazorUI.Core.csproj" />
	</ItemGroup>
	<!--
	Incluir el archivo de targets en el paquete NuGet -->
	<ItemGroup>
		<None Include="_build\CdCSharp.BlazorUI.targets" Pack="true" PackagePath="build\" />
	</ItemGroup>
	<!--
	Importar los targets localmente para desarrollo -->
	<Import Project="_build\CdCSharp.BlazorUI.targets" Condition="Exists('_build\CdCSharp.BlazorUI.targets')" />

	<!--Code Generators-->

	<ItemGroup>
		<!-- Source Generator -->
		<None Include="..\CdCSharp.BlazorUI.CodeGeneration.VariantDiscovery\bin\$(Configuration)\netstandard2.0\CdCSharp.BlazorUI.CodeGeneration.VariantDiscovery.dll"
			  Pack="true"
			  PackagePath="analyzers/dotnet/cs/"
			  Visible="false" />

		<!-- PDB para debugging -->
		<None Include="..\CdCSharp.BlazorUI.CodeGeneration.VariantDiscovery\bin\$(Configuration)\netstandard2.0\CdCSharp.BlazorUI.CodeGeneration.VariantDiscovery.pdb"
			  Pack="true"
			  PackagePath="analyzers/dotnet/cs/"
			  Visible="false"
			  Condition="Exists('..\CdCSharp.BlazorUI.CodeGeneration.VariantDiscovery\bin\$(Configuration)\netstandard2.0\CdCSharp.BlazorUI.CodeGeneration.VariantDiscovery.pdb')" />
	</ItemGroup>

	<Target Name="EnsureGeneratorsExistBeforePack"
			BeforeTargets="GenerateNuspec;Pack">

		<Error Text="❌ Source generator not found: CdCSharp.BlazorUI.CodeGeneration.VariantDiscovery.dll. Build it first."
			   Condition="!Exists('..\CdCSharp.BlazorUI.CodeGeneration.VariantDiscovery\bin\$(Configuration)\netstandard2.0\CdCSharp.BlazorUI.CodeGeneration.VariantDiscovery.dll')" />

		<Message Text="✅ Source generator found: CdCSharp.BlazorUI.CodeGeneration.VariantDiscovery.dll"
				 Importance="high" />
	</Target>

</Project>