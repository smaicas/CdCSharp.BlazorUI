@using CdCSharp.BlazorUI.Components.Abstractions
@using CdCSharp.BlazorUI.Components.Features.Behaviors
@inherits UIComponentBase
@implements IJsBehavior

<div @ref="_rootElement" @attributes="AdditionalAttributes">Minimal Component</div>

@code {

    private ElementReference _rootElement;

    public ElementReference GetRootElement() => _rootElement;

    public override IEnumerable<string> GetAdditionalCssClasses()
    {
        yield return "minimal-component";
    }
}
