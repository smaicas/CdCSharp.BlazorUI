@using Microsoft.AspNetCore.Components

@code {
    // Basic template that does not add any classes (inherits all from @attributes)
    public RenderFragment BasicCustomTemplate(TestVariantComponent component) => __builder =>
    {
        <button @attributes="component.AdditionalAttributes"
                @onclick="component.OnClick"
                disabled="@component.Disabled">
            @component.Text
        </button>
    };

    // Simple template that adds a single class
    public RenderFragment AddsOneClassTemplate(TestVariantComponent component) => __builder =>
    {
        <button @attributes="component.AdditionalAttributes"
                class="@($"{component.ComputedCssClasses} btn-glass")"
                @onclick="component.OnClick"
                disabled="@component.Disabled">
            @component.Text
        </button>
    };

    // Template that removes class from AdditionalAttributes and adds its own
    public RenderFragment OverrideClassTemplate(TestVariantComponent component) => __builder =>
    {
        <button @attributes="component.AdditionalAttributes"
                class="btn-override-only"
                @onclick="component.OnClick"
                disabled="@component.Disabled">
            Override: @component.Text
        </button>
    };

    // Template for data attributes - user can override
    public RenderFragment DataAttributeTemplate(TestVariantComponent component) => __builder =>
    {
        <button data-variant="custom"
                data-test="template-value"
                @attributes="component.AdditionalAttributes"
                @onclick="component.OnClick"
                disabled="@component.Disabled">
            @component.Text
        </button>
    };

    // Template for data attributes - template has priority
    public RenderFragment DataAttributeTemplatePriority(TestVariantComponent component) => __builder =>
    {
        <button @attributes="component.AdditionalAttributes"
                data-variant="custom"
                data-test="template-value-priority"
                @onclick="component.OnClick"
                disabled="@component.Disabled">
            @component.Text
        </button>
    };

    // Registered variant template
    public RenderFragment RegisteredTemplate(TestVariantComponent component) => __builder =>
    {
        <div @attributes="component.AdditionalAttributes"
             class="@($"{component.ComputedCssClasses} registered-variant")">
            <span>Registered: @component.Text</span>
        </div>
    };
}