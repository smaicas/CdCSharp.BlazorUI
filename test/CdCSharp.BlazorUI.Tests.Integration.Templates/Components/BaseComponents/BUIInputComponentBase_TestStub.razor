@using CdCSharp.BlazorUI.Components
@using CdCSharp.BlazorUI.Core.Abstractions.Behaviors.Design
@using CdCSharp.BlazorUI.Core.Abstractions.Behaviors.Javascript
@using CdCSharp.BlazorUI.Core.Abstractions.Behaviors.State
@using CdCSharp.BlazorUI.Core.Abstractions.Components
@using CdCSharp.BlazorUI.Core.Css
@inherits BUIInputComponentBase<string>
@implements IHasSize
@implements IHasDensity
@implements IHasColor
@implements IHasBackgroundColor
@implements IHasShadow
@implements IHasLoading
@implements IHasError
@implements IHasDisabled
@implements IHasReadOnly
@implements IHasRequired
@implements IHasFullWidth
@implements IHasRipple
@implements IHasBorder
@implements IJsBehavior

<input @ref="_elementRef"
       @attributes="ComputedAttributes"
       value="@CurrentValueAsString"
       disabled="@IsDisabled"
       readonly="@IsReadOnly"
       @onchange="@(e => CurrentValueAsString = e.Value?.ToString())" />

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public SizeEnum Size { get; set; }
    [Parameter] public DensityEnum Density { get; set; }
    [Parameter] public CssColor? Color { get; set; }
    [Parameter] public CssColor? BackgroundColor { get; set; }
    [Parameter] public ShadowStyle? Shadow { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public bool FullWidth { get; set; }
    [Parameter] public bool DisableRipple { get; set; }
    [Parameter] public CssColor? RippleColor { get; set; }
    [Parameter] public int? RippleDurationMs { get; set; }
    [Parameter] public BorderStyle? Border { get; set; }

    private ElementReference _elementRef;
    public ElementReference GetRippleContainer() => _elementRef;

    protected override bool TryParseValueFromString(string? value, out string result, out string? validationErrorMessage)
    {
        result = value ?? string.Empty;
        validationErrorMessage = null;
        return true;
    }
}