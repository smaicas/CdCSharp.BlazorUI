@page "/getting-started/installation"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared

<PageTitle>Installation - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>Installation</h1>
    <p class="doc-intro">
        Get started with CdCSharp.BlazorUI by following these simple installation steps.
    </p>

    <div class="doc-section">
        <h2>Prerequisites</h2>
        <ul>
            <li>.NET 8.0 or later</li>
            <li>Node.js (for building CSS and JavaScript assets)</li>
            <li>A Blazor Server or Blazor WebAssembly project</li>
        </ul>
    </div>

    <div class="doc-section">
        <h2>Installation Steps</h2>
        
        <h3>1. Install the NuGet Package</h3>
        <CodeBlock Code="@nugetInstallCode" Language="bash" Title="Package Manager Console" />

        <h3>2. Add Services</h3>
        <p>In your <code>Program.cs</code>, add the BlazorUI services:</p>
        <CodeBlock Code="@servicesCode" Language="csharp" Title="Program.cs" />

        <h3>3. Add Styles</h3>
        <p>In your <code>App.razor</code> or <code>_Host.cshtml</code>, add the stylesheet reference:</p>
        <CodeBlock Code="@stylesCode" Language="html" Title="App.razor" />

        <h3>4. Add JavaScript</h3>
        <p>The JavaScript files are automatically loaded when needed through lazy loading.</p>
    </div>

    <div class="doc-section">
        <h2>Basic Layout Setup</h2>
        <p>Create a basic layout using UIBlazorLayout:</p>
        <CodeBlock Code="@layoutCode" Language="razor" Title="MainLayout.razor" />
    </div>

    <div class="doc-section">
        <h2>Theme Initialization</h2>
        <p>Initialize the theme system in your layout's <code>OnAfterRenderAsync</code>:</p>
        <CodeBlock Code="@themeInitCode" Language="razor" Title="MainLayout.razor" />
    </div>

    <div class="doc-section">
        <h2>Verify Installation</h2>
        <p>Create a simple page to verify everything is working:</p>
        <CodeBlock Code="@verifyCode" Language="razor" Title="TestPage.razor" />
    </div>

    <div class="doc-note doc-note--info">
        <strong>Note:</strong> The build process automatically generates CSS files during compilation. 
        Make sure Node.js is installed on your system for the build tools to work properly.
    </div>
</div>

@code {
    private string nugetInstallCode = "dotnet add package CdCSharp.BlazorUI";
    
    private string servicesCode = @"using CdCSharp.BlazorUI;

// Add BlazorUI services
builder.Services.AddBlazorUI();";

    private string stylesCode = @"<link href=""/blazor-ui/styles.css"" rel=""stylesheet"" />";

    private string layoutCode = @"@using CdCSharp.BlazorUI.Components.Layout
@using CdCSharp.BlazorUI.Components.Features.Theme.ThemeSwitch
@inherits UIBlazorLayout

<div class=""app-layout"">
    <header>
        <h1>My App</h1>
        <UIThemeSwitch />
    </header>
    
    <main>
        @Body
    </main>
</div>";

    private string themeInitCode = @"@inject IThemeJsInterop ThemeInterop

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeInterop.InitializeAsync(""dark"");
        }
    }
}";

    private string verifyCode = @"@page ""/test""
@using CdCSharp.BlazorUI.Components.Generic.Button

<h1>BlazorUI Test</h1>

<UIButton Text=""Hello BlazorUI!"" 
          OnClick=""@(() => Console.WriteLine(""Button clicked!""))"" 
          Transitions=""@UITransitionPresets.HoverLift"" />";
}