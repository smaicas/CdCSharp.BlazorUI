@page "/theming/colors"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components.Generic.Button
@using CdCSharp.BlazorUI.Core.Css
@using CdCSharp.BlazorUI.Css

<PageTitle>Colors - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>Colors</h1>
    <p class="doc-intro">
        The color system provides a comprehensive set of colors with automatic variants for lighter and darker shades.
        Colors adapt to the current theme and support transparency.
    </p>

    <div class="doc-section">
        <h2>Theme Palette Colors</h2>
        <p>These colors are defined by the current theme and change automatically when switching themes:</p>

        <div class="palette-grid">
            <div class="palette-item">
                <div class="palette-swatch" style="background: var(--palette-primary)"></div>
                <h4>Primary</h4>
                <code>--palette-primary</code>
            </div>
            <div class="palette-item">
                <div class="palette-swatch" style="background: var(--palette-secondary)"></div>
                <h4>Secondary</h4>
                <code>--palette-secondary</code>
            </div>
            <div class="palette-item">
                <div class="palette-swatch" style="background: var(--palette-background); border: 1px solid var(--palette-backgroundcontrast)"></div>
                <h4>Background</h4>
                <code>--palette-background</code>
            </div>
            <div class="palette-item">
                <div class="palette-swatch" style="background: var(--palette-surface)"></div>
                <h4>Surface</h4>
                <code>--palette-surface</code>
            </div>
            <div class="palette-item">
                <div class="palette-swatch" style="background: var(--palette-error)"></div>
                <h4>Error</h4>
                <code>--palette-error</code>
            </div>
            <div class="palette-item">
                <div class="palette-swatch" style="background: var(--palette-warning)"></div>
                <h4>Warning</h4>
                <code>--palette-warning</code>
            </div>
            <div class="palette-item">
                <div class="palette-swatch" style="background: var(--palette-info)"></div>
                <h4>Info</h4>
                <code>--palette-info</code>
            </div>
            <div class="palette-item">
                <div class="palette-swatch" style="background: var(--palette-success)"></div>
                <h4>Success</h4>
                <code>--palette-success</code>
            </div>
        </div>
    </div>

    <div class="doc-section">
        <h2>UIColor System</h2>
        <p>The UIColor system provides predefined colors with automatic light and dark variants:</p>

        <h3>Color Variants</h3>
        <p>Each color has 7 variants:</p>
        <ul>
            <li><code>Lighten3</code> - 30% lighter</li>
            <li><code>Lighten2</code> - 20% lighter</li>
            <li><code>Lighten1</code> - 10% lighter</li>
            <li><code>Default</code> - Base color</li>
            <li><code>Darken1</code> - 10% darker</li>
            <li><code>Darken2</code> - 20% darker</li>
            <li><code>Darken3</code> - 30% darker</li>
        </ul>

        <h3>Example: Blue Variants</h3>
        <div class="color-variants">
            <div class="variant-item">
                <UIButton Text="Lighten3" Color="@UIColor.Blue.Lighten3" />
                <code>UIColor.Blue.Lighten3</code>
            </div>
            <div class="variant-item">
                <UIButton Text="Lighten2" Color="@UIColor.Blue.Lighten2" />
                <code>UIColor.Blue.Lighten2</code>
            </div>
            <div class="variant-item">
                <UIButton Text="Lighten1" Color="@UIColor.Blue.Lighten1" />
                <code>UIColor.Blue.Lighten1</code>
            </div>
            <div class="variant-item">
                <UIButton Text="Default" Color="@UIColor.Blue.Default" />
                <code>UIColor.Blue.Default</code>
            </div>
            <div class="variant-item">
                <UIButton Text="Darken1" Color="@UIColor.Blue.Darken1" />
                <code>UIColor.Blue.Darken1</code>
            </div>
            <div class="variant-item">
                <UIButton Text="Darken2" Color="@UIColor.Blue.Darken2" />
                <code>UIColor.Blue.Darken2</code>
            </div>
            <div class="variant-item">
                <UIButton Text="Darken3" Color="@UIColor.Blue.Darken3" />
                <code>UIColor.Blue.Darken3</code>
            </div>
        </div>
    </div>

    <div class="doc-section">
        <h2>Using Colors</h2>

        <ComponentDemo Code="@usingColorsCode">
            <Demo>
                <div class="demo-row">
                    <UIButton Text="Theme Primary" BackgroundColor="@(new CssColor("var(--palette-primary)", true))" />
                    <UIButton Text="UIColor Blue" BackgroundColor="@UIColor.Blue.Default" />
                    <UIButton Text="Custom Color" BackgroundColor="@(new CssColor("#FF5722"))" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Creating Custom Colors</h2>

        <CodeBlock Code="@customColorsCode" Language="csharp" Title="Custom Colors" />
    </div>
</div>

@code {
    private string usingColorsCode = @"// Using theme palette colors
<UIButton Text=""Theme Primary"" BackgroundColor=""@(new CssColor(""var(--palette-primary)"", true))"" />

// Using UIColor constants
<UIButton Text=""UIColor Blue"" BackgroundColor=""@UIColor.Blue.Default"" />

// Using custom hex color
<UIButton Text=""Custom Color"" BackgroundColor=""@(new CssColor(""#FF5722""))"" />";

    private string customColorsCode = @"// Create from hex
CssColor customColor1 = new CssColor(""#FF5722"");

// Create from RGB
CssColor customColor2 = new CssColor(255, 87, 34);

// Create from RGBA with transparency
CssColor customColor3 = new CssColor(255, 87, 34, 0.5);

// Use CSS variables
CssColor themeColor = new CssColor(""var(--palette-primary)"", true);";
}