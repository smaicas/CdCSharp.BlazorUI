@page "/theming/custom-themes"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared

<PageTitle>Custom Themes - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>Custom Themes</h1>
    <p class="doc-intro">
        Learn how to create custom themes for your application by extending the built-in theme system.
    </p>

    <div class="doc-section">
        <h2>Creating a Custom Theme</h2>
        <p>To create a custom theme, inherit from <code>UIThemePaletteBase</code> and override the color properties:</p>
        
        <CodeBlock Code="@customThemeCode" Language="csharp" Title="CustomTheme.cs" />
    </div>

    <div class="doc-section">
        <h2>Registering Custom Themes</h2>
        <p>Register your custom theme during application startup:</p>
        
        <CodeBlock Code="@registrationCode" Language="csharp" Title="Program.cs" />
    </div>

    <div class="doc-section">
        <h2>Example: Brand Theme</h2>
        <p>Here's a complete example of a custom brand theme:</p>
        
        <CodeBlock Code="@brandThemeCode" Language="csharp" Title="BrandTheme.cs" />
    </div>

    <div class="doc-section">
        <h2>Theme Color Guidelines</h2>
        
        <div class="guidelines-grid">
            <div class="guideline-card">
                <h4>Color Contrast</h4>
                <p>Ensure sufficient contrast between foreground and background colors for accessibility. 
                   Use WCAG guidelines (4.5:1 for normal text, 3:1 for large text).</p>
            </div>
            
            <div class="guideline-card">
                <h4>Color Harmony</h4>
                <p>Choose colors that work well together. Consider using color theory principles 
                   like complementary, analogous, or triadic color schemes.</p>
            </div>
            
            <div class="guideline-card">
                <h4>Consistency</h4>
                <p>Maintain consistency in your color usage. Primary actions should always use 
                   primary colors, errors should always use error colors, etc.</p>
            </div>
            
            <div class="guideline-card">
                <h4>Testing</h4>
                <p>Test your theme with all components to ensure readability and visual appeal 
                   in different contexts and screen conditions.</p>
            </div>
        </div>
    </div>

    <div class="doc-section">
        <h2>Advanced: Dynamic Theme Generation</h2>
        <p>You can also generate themes dynamically based on user preferences or brand colors:</p>
        
        <CodeBlock Code="@dynamicThemeCode" Language="csharp" Title="Dynamic Theme Generation" />
    </div>

    <div class="doc-section">
        <h2>CSS Variable Override</h2>
        <p>For quick customizations without creating a full theme class, you can override CSS variables:</p>
        
        <CodeBlock Code="@cssOverrideCode" Language="css" Title="Custom CSS" />
    </div>

    <div class="doc-section">
        <h2>Theme Color Reference</h2>
        <p>When creating custom themes, consider these color roles:</p>
        
        <div class="color-roles">
            <div class="color-role">
                <h4>Primary & Secondary</h4>
                <p>Brand colors for main actions and accents. Should be vibrant and memorable.</p>
            </div>
            
            <div class="color-role">
                <h4>Background & Surface</h4>
                <p>Base colors for content areas. Surface should be slightly elevated from background.</p>
            </div>
            
            <div class="color-role">
                <h4>Foreground</h4>
                <p>Main text color. Must have good contrast with background and surface.</p>
            </div>
            
            <div class="color-role">
                <h4>Status Colors</h4>
                <p>Semantic colors for different states. Should be universally recognizable.</p>
            </div>
        </div>
    </div>

    <div class="doc-note doc-note--info">
        <strong>Tip:</strong> Use the CssColor class's built-in Lighten and Darken methods to create 
        color variations that maintain harmony with your base colors.
    </div>
</div>

@code {
    private string customThemeCode = @"using CdCSharp.BlazorUI.Core.Theming.Abstractions;
using CdCSharp.BlazorUI.Core.Css;

public class MyCustomTheme : UIThemePaletteBase
{
    public MyCustomTheme()
    {
        // Set theme identifiers
        Id = ""custom"";
        Name = ""My Custom Theme"";
        
        // Define your color palette
        Primary = new CssColor(""#FF6B6B"");
        PrimaryContrast = new CssColor(""#FFFFFF"");
        
        Secondary = new CssColor(""#4ECDC4"");
        SecondaryContrast = new CssColor(""#FFFFFF"");
        
        Background = new CssColor(""#1A1A2E"");
        Surface = new CssColor(""#16213E"");
        Foreground = new CssColor(""#F5F5F5"");
        
        // Status colors
        Error = new CssColor(""#FF4757"");
        Warning = new CssColor(""#FFA502"");
        Info = new CssColor(""#3742FA"");
        Success = new CssColor(""#2ED573"");
    }
}";

    private string registrationCode = @"// In Program.cs
builder.Services.AddBlazorUI(options =>
{
    // Add your custom theme
    options.Themes.Add(new MyCustomTheme());
    
    // Optionally set it as default
    options.DefaultTheme = ""custom"";
});";

    private string brandThemeCode = @"public class BrandTheme : UIThemePaletteBase
{
    public BrandTheme()
    {
        Id = ""brand"";
        Name = ""Brand Theme"";
        
        // Using brand colors
        Primary = new CssColor(""#1B5E20"");  // Brand green
        PrimaryContrast = new CssColor(""#FFFFFF"");
        
        Secondary = new CssColor(""#FF6F00"");  // Brand orange
        SecondaryContrast = new CssColor(""#FFFFFF"");
        
        // Professional dark theme
        Background = new CssColor(""#121212"");
        Surface = new CssColor(""#1E1E1E"");
        Foreground = new CssColor(""#E0E0E0"");
        
        // Semantic colors matching brand
        Error = new CssColor(""#D32F2F"");
        Warning = new CssColor(""#F57C00"");
        Info = new CssColor(""#1976D2"");
        Success = new CssColor(""#388E3C"");
    }
}";

    private string dynamicThemeCode = @"public class DynamicThemeGenerator
{
    public static UIThemePaletteBase GenerateFromColor(CssColor brandColor, bool isDark)
    {
        var theme = new CustomTheme
        {
            Id = $""dynamic-{brandColor.ToHex()}"",
            Name = ""Dynamic Theme"",
            
            // Use the brand color as primary
            Primary = brandColor,
            PrimaryContrast = isDark ? CssColor.White : CssColor.Black,
            
            // Generate complementary color for secondary
            Secondary = GetComplementaryColor(brandColor),
            SecondaryContrast = CssColor.White,
            
            // Set background based on mode
            Background = isDark 
                ? new CssColor(""#0A0A0A"") 
                : new CssColor(""#FFFFFF""),
            
            Surface = isDark 
                ? new CssColor(""#1A1A1A"") 
                : new CssColor(""#F5F5F5""),
            
            Foreground = isDark 
                ? new CssColor(""#E0E0E0"") 
                : new CssColor(""#212121""),
            
            // Standard semantic colors
            Error = new CssColor(""#F44336""),
            Warning = new CssColor(""#FF9800""),
            Info = new CssColor(""#2196F3""),
            Success = new CssColor(""#4CAF50"")
        };
        
        return theme;
    }
    
    private static CssColor GetComplementaryColor(CssColor color)
    {
        // Simple complementary color calculation
        var h = (color.H + 180) % 360;
        return CssColor.FromHsl(h, color.S, color.L);
    }
}";

    private string cssOverrideCode = @"/* Override specific theme variables */
:root {
    /* Custom primary color */
    --palette-primary: #7C3AED;
    --palette-primary-contrast: #FFFFFF;
    
    /* Custom surface with transparency */
    --palette-surface: rgba(255, 255, 255, 0.05);
    
    /* Adjust specific component colors */
    --ui-button-hover: var(--palette-primary-light);
}

/* Dark mode specific overrides */
@media (prefers-color-scheme: dark) {
    :root {
        --palette-background: #0A0A0A;
        --palette-surface: #141414;
    }
}";
}

<style>
    .guidelines-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        margin: 2rem 0;
    }

    .guideline-card {
        padding: 1.5rem;
        background: var(--palette-surface);
        border-radius: 0.5rem;
        border: 1px solid var(--palette-foreground);
    }

    .guideline-card h4 {
        margin: 0 0 0.75rem 0;
        color: var(--palette-primary);
    }

    .guideline-card p {
        margin: 0;
        font-size: 0.875rem;
        line-height: 1.6;
    }

    .color-roles {
        display: grid;
        gap: 1.5rem;
        margin: 2rem 0;
    }

    .color-role {
        padding: 1rem;
        background: var(--palette-surface);
        border-left: 4px solid var(--palette-primary);
        border-radius: 0.25rem;
    }

    .color-role h4 {
        margin: 0 0 0.5rem 0;
        font-size: 1rem;
    }

    .color-role p {
        margin: 0;
        opacity: 0.8;
    }
</style>