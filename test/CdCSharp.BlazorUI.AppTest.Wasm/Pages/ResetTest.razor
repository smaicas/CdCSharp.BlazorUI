<p>Table (realistic)</p>
<table>
    <caption>User list</caption>
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>Alice</td>
            <td>alice@mail.com</td>
            <td>Active</td>
        </tr>
        <tr>
            <td>Bob</td>
            <td>bob@mail.com</td>
            <td>Inactive</td>
        </tr>
    </tbody>
</table>

<hr>
<br>

<p>Form – real usage</p>

<form id="user-form" name="user-form">

    <fieldset>
        <legend>Personal information</legend>

        <label for="name">Name</label>
        <br>
        <input id="name" name="name" type="text" placeholder="John Doe">
        <br>
        <br>

        <label for="email">Email</label>
        <br>
        <input id="email" name="email" type="email">
        <br>
        <br>

        <label for="password">Password</label>
        <br>
        <input id="password" name="password" type="password">
    </fieldset>

    <hr><br>

    <fieldset>
        <legend>Preferences</legend>

        <p>Subscription type (radio)</p>
        <label>
            <input id="sub-basic" name="subscription" type="radio" value="basic">
            Basic
        </label>
        <br>

        <label>
            <input id="sub-pro" name="subscription" type="radio" value="pro">
            Pro
        </label>
        <br>

        <label>
            <input id="sub-enterprise" name="subscription" type="radio" value="enterprise">
            Enterprise
        </label>
    </fieldset>

    <hr><br>

    <fieldset>
        <legend>Notifications (checkbox)</legend>

        <label>
            <input id="notify-email" name="notifications" type="checkbox" value="email">
            Email notifications
        </label>
        <br>

        <label>
            <input id="notify-sms" name="notifications" type="checkbox" value="sms">
            SMS notifications
        </label>
        <br>

        <label>
            <input id="notify-push" name="notifications" type="checkbox" value="push">
            Push notifications
        </label>
    </fieldset>

    <hr><br>

    <fieldset>
        <legend>Other inputs</legend>

        <label for="birthdate">Birth date</label>
        <br>
        <input id="birthdate" name="birthdate" type="date">
        <br>
        <br>

        <label for="volume">Volume</label>
        <br>
        <input id="volume" name="volume" type="range">
        <br>
        <br>

        <label for="color">Favorite color</label>
        <br>
        <input id="color" name="color" type="color">
        <br>
        <br>

        <label for="file">Profile picture</label>
        <br>
        <input id="file" name="file" type="file">
        <br>
        <br>

        <label for="bio">Bio</label>
        <br>
        <textarea id="bio" name="bio">Short bio...</textarea>
        <br>
        <br>

        <label for="country">Country</label>
        <br>
        <select id="country" name="country">
            <option value="">Select one</option>
            <option value="es">Spain</option>
            <option value="fr">France</option>
            <option value="de">Germany</option>
        </select>
    </fieldset>

    <hr><br>

    <fieldset>
        <legend>Actions</legend>
        <button id="btn-submit" name="submit" type="submit">Submit</button>
        <button id="btn-reset" name="reset" type="reset">Reset</button>
        <button id="btn-cancel" name="cancel" type="button">Cancel</button>
    </fieldset>

</form>

