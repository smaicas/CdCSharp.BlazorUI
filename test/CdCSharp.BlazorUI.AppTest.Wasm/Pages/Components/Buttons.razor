@page "/components/buttons"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components.Features.Loading
@using CdCSharp.BlazorUI.Components.Features.Transitions
@using CdCSharp.BlazorUI.Components.Generic.Button
@using CdCSharp.BlazorUI.Components.Generic.Svg
@using CdCSharp.BlazorUI.Css
@using CdCSharp.BlazorUI.Media.Icons
@using CdCSharp.BlazorUI.Components.Features.Common
@using CdCSharp.BlazorUI.Core.Theming

<PageTitle>Buttons - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>Buttons</h1>
    <p class="doc-intro">
        The UIButton component is a versatile button with support for loading states, icons,
        ripple effects, elevation, transitions, borders, and more.
    </p>

    <div class="doc-section">
        <h2>Basic Usage</h2>
        <ComponentDemo Code="@basicUsageCode">
            <Demo>
                <UIButton Text="Click Me" OnClick="@(() => Console.WriteLine("Clicked!"))" />
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Sizes</h2>
        <ComponentDemo Code="@sizesCode">
            <Demo>
                <div class="demo-row">
                    <UIButton Text="Small" Size="SizeEnum.Small" />
                    <UIButton Text="Medium" Size="SizeEnum.Medium" />
                    <UIButton Text="Large" Size="SizeEnum.Large" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Loading States</h2>
        <ComponentDemo Code="@loadingCode">
            <Demo>
                <div class="demo-row">
                    <UIButton Text="Loading Spinner" IsLoading="true" LoadingIndicatorVariant="UILoadingIndicatorVariant.Spinner" />
                    <UIButton Text="Loading Dots" IsLoading="true" LoadingIndicatorVariant="UILoadingIndicatorVariant.Dots" />
                    <UIButton Text="Loading Pulse" IsLoading="true" LoadingIndicatorVariant="UILoadingIndicatorVariant.Pulse" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Icons</h2>
        <ComponentDemo Code="@iconsCode">
            <Demo>
                <div class="demo-row">
                    <UIButton Text="Save" LeadingIcon="@UIIcons.MaterialIconsRound.i_save" />
                    <UIButton Text="Delete" TrailingIcon="@UIIcons.MaterialIconsRound.i_delete" />
                    <UIButton Text="Edit" LeadingIcon="@UIIcons.MaterialIconsRound.i_edit" TrailingIcon="@UIIcons.MaterialIconsRound.i_chevron_right" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Elevation</h2>
        <ComponentDemo Code="@elevationCode">
            <Demo>
                <div class="demo-row">
                    <UIButton Text="No Elevation" Elevation="0" />
                    <UIButton Text="Low" Elevation="2" />
                    <UIButton Text="Medium" Elevation="4" />
                    <UIButton Text="High" Elevation="8" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Borders</h2>
        <ComponentDemo Code="@bordersCode">
            <Demo>
                <div class="demo-row">
                    <UIButton Text="Default Border" Border="@BorderPresets.Default" />
                    <UIButton Text="Primary Border" Border="@BorderPresets.Primary" />
                    <UIButton Text="Rounded" Border="@BorderPresets.Rounded" />
                    <UIButton Text="Pill" Border="@BorderPresets.Pill" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Density</h2>
        <ComponentDemo Code="@densityCode">
            <Demo>
                <div class="demo-row">
                    <UIButton Text="Comfortable" Density="DensityEnum.Comfortable" />
                    <UIButton Text="Standard" Density="DensityEnum.Standard" />
                    <UIButton Text="Compact" Density="DensityEnum.Compact" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Transitions</h2>
        <ComponentDemo Code="@transitionsCode">
            <Demo>
                <div class="demo-row">
                    <UIButton Text="Hover Scale" Transitions="@UITransitionPresets.HoverScale" />
                    <UIButton Text="Hover Lift" Transitions="@UITransitionPresets.HoverLift" />
                    <UIButton Text="Hover Glow" Transitions="@UITransitionPresets.HoverGlow" />
                    <UIButton Text="Focus Ring" Transitions="@UITransitionPresets.FocusRing" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Properties</h2>
        <PropertyTable TItem="ButtonProperty" Items="@ButtonProperties">
            <PropertyTemplate Context="prop">
                <td><code>@prop.Name</code></td>
                <td><code>@prop.Type</code></td>
                <td><code>@prop.Default</code></td>
                <td>@prop.Description</td>
            </PropertyTemplate>
        </PropertyTable>
    </div>
</div>

@code {
    private string basicUsageCode = @"<UIButton Text=""Click Me"" OnClick=""@(() => Console.WriteLine(""Clicked!""))"" />";

    private string sizesCode = @"<UIButton Text=""Small"" Size=""SizeEnum.Small"" />
<UIButton Text=""Medium"" Size=""SizeEnum.Medium"" />
<UIButton Text=""Large"" Size=""SizeEnum.Large"" />";

    private string loadingCode = @"<UIButton Text=""Loading Spinner""
          IsLoading=""true""
          LoadingIndicatorVariant=""UILoadingIndicatorVariant.Spinner"" />";

    private string iconsCode = @"<UIButton Text=""Save"" LeadingIcon=""@UIIcons.MaterialIconsRound.i_save"" />
<UIButton Text=""Delete"" TrailingIcon=""@UIIcons.MaterialIconsRound.i_delete"" />";

    private string elevationCode = @"<UIButton Text=""No Elevation"" Elevation=""0"" />
<UIButton Text=""Low"" Elevation=""2"" />
<UIButton Text=""Medium"" Elevation=""4"" />
<UIButton Text=""High"" Elevation=""8"" />";

    private string bordersCode = @"<UIButton Text=""Default Border"" Border=""@BorderPresets.Default"" />
<UIButton Text=""Primary Border"" Border=""@BorderPresets.Primary"" />
<UIButton Text=""Rounded"" Border=""@BorderPresets.Rounded"" />
<UIButton Text=""Pill"" Border=""@BorderPresets.Pill"" />";

    private string densityCode = @"<UIButton Text=""Comfortable"" Density=""DensityEnum.Comfortable"" />
<UIButton Text=""Standard"" Density=""DensityEnum.Standard"" />
<UIButton Text=""Compact"" Density=""DensityEnum.Compact"" />";

    private string transitionsCode = @"<UIButton Text=""Hover Scale"" Transitions=""@UITransitionPresets.HoverScale"" />
<UIButton Text=""Hover Lift"" Transitions=""@UITransitionPresets.HoverLift"" />";

    private record ButtonProperty(string Name, string Type, string Default, string Description);

    private List<ButtonProperty> ButtonProperties = new()
    {
        new("Text", "string?", "null", "The text content of the button"),
        new("OnClick", "EventCallback<MouseEventArgs>", "-", "Click event handler"),
        new("Disabled", "bool", "false", "Whether the button is disabled"),
        new("Size", "SizeEnum", "Medium", "Size of the button (Small, Medium, Large)"),
        new("Density", "DensityEnum", "Standard", "Density of the button"),
        new("IsLoading", "bool", "false", "Whether the button is in loading state"),
        new("LoadingIndicatorVariant", "UILoadingIndicatorVariant?", "null", "Type of loading indicator"),
        new("LeadingIcon", "string?", "null", "Icon to display before the text"),
        new("TrailingIcon", "string?", "null", "Icon to display after the text"),
        new("Elevation", "int?", "null", "Elevation level (0-24)"),
        new("Border", "BorderStyle?", "null", "Border style for all sides"),
        new("BorderTop", "BorderStyle?", "null", "Top border style"),
        new("BorderRight", "BorderStyle?", "null", "Right border style"),
        new("BorderBottom", "BorderStyle?", "null", "Bottom border style"),
        new("BorderLeft", "BorderStyle?", "null", "Left border style"),
        new("DisableRipple", "bool", "false", "Whether to disable ripple effect"),
        new("RippleColor", "CssColor?", "null", "Custom color for ripple effect"),
        new("RippleDuration", "int?", "null", "Ripple animation duration in milliseconds"),
        new("FullWidth", "bool", "false", "Whether the button should take full width"),
        new("Transitions", "UITransitions?", "null", "Transition animations"),
        new("BackgroundColor", "CssColor?", "null", "Background color"),
        new("Color", "CssColor?", "null", "Text color"),
    };
}