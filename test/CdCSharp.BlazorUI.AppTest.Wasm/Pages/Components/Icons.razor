@page "/components/icons"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared

<PageTitle>Icons - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>Icons</h1>
    <p class="doc-intro">
        The BBUISvgIcon component provides a flexible way to display SVG icons with customizable size and color.
    </p>

    <div class="doc-section">
        <h2>Basic Usage</h2>
        <ComponentDemo Code="@basicIconCode">
            <Demo>
                <BBUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_favorite" />
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Sizes</h2>
        <ComponentDemo Code="@sizesCode">
            <Demo>
                <div class="demo-row">
                    <BBUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_star" Size="SizeEnum.Small" />
                    <BBUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_star" Size="SizeEnum.Medium" />
                    <BBUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_star" Size="SizeEnum.Large" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Colors</h2>
        <ComponentDemo Code="@colorsCode">
            <Demo>
                <div class="demo-row">
                    <BBUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_check" Color="@BUIColor.Green.Default" />
                    <BBUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_warning" Color="@BUIColor.Orange.Default" />
                    <BBUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_error" Color="@BUIColor.Red.Default" />
                    <BBUISvgIcon Icon="@BUIIcons.MaterialIconsRound.i_info" Color="@BUIColor.Blue.Default" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Icon Examples</h2>
        <div class="icon-grid">
            @foreach (var icon in GetSampleIcons())
            {
                <div class="icon-item">
                    <BBUISvgIcon Icon="@icon.Value" Size="SizeEnum.Large" />
                    <code>@icon.Name</code>
                </div>
            }
        </div>
    </div>

    <div class="doc-section">
        <h2>Icon Examples</h2>
        <div class="icon-grid">
            @foreach (var icon in GetSampleIcons())
            {
                <div class="icon-item">
                    <BBUISvgIcon Icon="@icon.Value" Size="SizeEnum.Large" />
                    <code>@icon.Name</code>
                </div>
            }
        </div>
    </div>

    <div class="doc-section">
        <h2>Brand Icons</h2>
        <div class="icon-grid">
            @foreach (var icon in GetBrandIcons())
            {
                <div class="icon-item">
                    <BBUISvgIcon Icon="@icon.Value" Size="SizeEnum.Large" />
                    <code>@icon.Name</code>
                </div>
            }
        </div>
    </div>

    <div class="doc-section">
        <h2>Properties</h2>
        <PropertyTable TItem="IconProperty" Items="@IconProperties">
            <PropertyTemplate Context="prop">
                <td><code>@prop.Name</code></td>
                <td><code>@prop.Type</code></td>
                <td><code>@prop.Default</code></td>
                <td>@prop.Description</td>
            </PropertyTemplate>
        </PropertyTable>
    </div>
</div>

@code {
    private string basicIconCode = @"<BBUISvgIcon Icon=""@BUIIcons.MaterialIconsRound.i_favorite"" />";

    private string sizesCode = @"<BBUISvgIcon Icon=""@BUIIcons.MaterialIconsRound.i_star"" Size=""SizeEnum.Small"" />
<BBUISvgIcon Icon=""@BUIIcons.MaterialIconsRound.i_star"" Size=""SizeEnum.Medium"" />
<BBUISvgIcon Icon=""@BUIIcons.MaterialIconsRound.i_star"" Size=""SizeEnum.Large"" />";

    private string colorsCode = @"<BBUISvgIcon Icon=""@BUIIcons.MaterialIconsRound.i_check"" Color=""@UIColor.Green.Default"" />
<BBUISvgIcon Icon=""@BUIIcons.MaterialIconsRound.i_warning"" Color=""@UIColor.Orange.Default"" />
<BBUISvgIcon Icon=""@BUIIcons.MaterialIconsRound.i_error"" Color=""@UIColor.Red.Default"" />
<BBUISvgIcon Icon=""@BUIIcons.MaterialIconsRound.i_info"" Color=""@UIColor.Blue.Default"" />";

    private record IconProperty(string Name, string Type, string Default, string Description);

    private List<IconProperty> IconProperties = new()
    {
        new("Icon", "string", "required", "SVG content of the icon"),
        new("Size", "SizeEnum", "Medium", "Size of the icon (Small, Medium, Large)"),
        new("Color", "CssColor?", "null", "Color of the icon"),
        new("Title", "string?", "null", "Accessibility title for the icon"),
        new("ViewBox", "string", "0 0 24 24", "SVG viewBox attribute"),
        new("OnClick", "EventCallback<MouseEventArgs>", "-", "Click event handler"),
    };

    private record IconExample(string Name, string Value);

    private List<IconExample> GetSampleIcons()
    {
        return new List<IconExample>
        {
            new("Home", BUIIcons.MaterialIconsRound.i_home),
            new("Settings", BUIIcons.MaterialIconsRound.i_settings),
            new("Search", BUIIcons.MaterialIconsRound.i_search),
            new("Favorite", BUIIcons.MaterialIconsRound.i_favorite),
            new("Star", BUIIcons.MaterialIconsRound.i_star),
            new("Check", BUIIcons.MaterialIconsRound.i_check),
            new("Close", BUIIcons.MaterialIconsRound.i_close),
            new("Edit", BUIIcons.MaterialIconsRound.i_edit),
            new("Delete", BUIIcons.MaterialIconsRound.i_delete),
            new("Save", BUIIcons.MaterialIconsRound.i_save),
            new("Download", BUIIcons.MaterialIconsRound.i_download),
            new("Upload", BUIIcons.MaterialIconsRound.i_upload),
        };
    }

    private List<IconExample> GetBrandIcons()
    {
        return new List<IconExample>
        {
            new("Gmail", BUIIcons.Brands.Gmail),
            new("GitHub", BUIIcons.Brands.GitHub),
            new("Twitter", BUIIcons.Brands.Twitter),
            new("Facebook", BUIIcons.Brands.Facebook),
            new("LinkedIn", BUIIcons.Brands.LinkedIn),
            new("YouTube", BUIIcons.Brands.YouTube),
        };
    }
}
