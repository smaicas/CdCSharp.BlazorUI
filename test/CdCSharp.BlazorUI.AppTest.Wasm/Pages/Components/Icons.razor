@page "/components/icons"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components.Generic.Svg
@using CdCSharp.BlazorUI.Css
@using CdCSharp.BlazorUI.Media.Icons
@using CdCSharp.BlazorUI.Components.Features.Common
@using CdCSharp.BlazorUI.Core.Theming

<PageTitle>Icons - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>Icons</h1>
    <p class="doc-intro">
        The UISvgIcon component provides a flexible way to display SVG icons with customizable size and color.
    </p>

    <div class="doc-section">
        <h2>Basic Usage</h2>
        <ComponentDemo Code="@basicIconCode">
            <Demo>
                <UISvgIcon Icon="@UIIcons.MaterialIconsRound.i_favorite" />
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Sizes</h2>
        <ComponentDemo Code="@sizesCode">
            <Demo>
                <div class="demo-row">
                    <UISvgIcon Icon="@UIIcons.MaterialIconsRound.i_star" Size="SizeEnum.Small" />
                    <UISvgIcon Icon="@UIIcons.MaterialIconsRound.i_star" Size="SizeEnum.Medium" />
                    <UISvgIcon Icon="@UIIcons.MaterialIconsRound.i_star" Size="SizeEnum.Large" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Colors</h2>
        <ComponentDemo Code="@colorsCode">
            <Demo>
                <div class="demo-row">
                    <UISvgIcon Icon="@UIIcons.MaterialIconsRound.i_check" Color="@UIColor.Green.Default" />
                    <UISvgIcon Icon="@UIIcons.MaterialIconsRound.i_warning" Color="@UIColor.Orange.Default" />
                    <UISvgIcon Icon="@UIIcons.MaterialIconsRound.i_error" Color="@UIColor.Red.Default" />
                    <UISvgIcon Icon="@UIIcons.MaterialIconsRound.i_info" Color="@UIColor.Blue.Default" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Icon Examples</h2>
        <div class="icon-grid">
            @foreach (var icon in GetSampleIcons())
            {
                <div class="icon-item">
                    <UISvgIcon Icon="@icon.Value" Size="SizeEnum.Large" />
                    <code>@icon.Name</code>
                </div>
            }
        </div>
    </div>

    <div class="doc-section">
        <h2>Icon Examples</h2>
        <div class="icon-grid">
            @foreach (var icon in GetSampleIcons())
            {
                <div class="icon-item">
                    <UISvgIcon Icon="@icon.Value" Size="SizeEnum.Large" />
                    <code>@icon.Name</code>
                </div>
            }
        </div>
    </div>

    <div class="doc-section">
        <h2>Brand Icons</h2>
        <div class="icon-grid">
            @foreach (var icon in GetBrandIcons())
            {
                <div class="icon-item">
                    <UISvgIcon Icon="@icon.Value" Size="SizeEnum.Large" />
                    <code>@icon.Name</code>
                </div>
            }
        </div>
    </div>

    <div class="doc-section">
        <h2>Properties</h2>
        <PropertyTable TItem="IconProperty" Items="@IconProperties">
            <PropertyTemplate Context="prop">
                <td><code>@prop.Name</code></td>
                <td><code>@prop.Type</code></td>
                <td><code>@prop.Default</code></td>
                <td>@prop.Description</td>
            </PropertyTemplate>
        </PropertyTable>
    </div>
</div>

@code {
    private string basicIconCode = @"<UISvgIcon Icon=""@UIIcons.MaterialIconsRound.i_favorite"" />";

    private string sizesCode = @"<UISvgIcon Icon=""@UIIcons.MaterialIconsRound.i_star"" Size=""SizeEnum.Small"" />
<UISvgIcon Icon=""@UIIcons.MaterialIconsRound.i_star"" Size=""SizeEnum.Medium"" />
<UISvgIcon Icon=""@UIIcons.MaterialIconsRound.i_star"" Size=""SizeEnum.Large"" />";

    private string colorsCode = @"<UISvgIcon Icon=""@UIIcons.MaterialIconsRound.i_check"" Color=""@UIColor.Green.Default"" />
<UISvgIcon Icon=""@UIIcons.MaterialIconsRound.i_warning"" Color=""@UIColor.Orange.Default"" />
<UISvgIcon Icon=""@UIIcons.MaterialIconsRound.i_error"" Color=""@UIColor.Red.Default"" />
<UISvgIcon Icon=""@UIIcons.MaterialIconsRound.i_info"" Color=""@UIColor.Blue.Default"" />";

    private record IconProperty(string Name, string Type, string Default, string Description);

    private List<IconProperty> IconProperties = new()
    {
        new("Icon", "string", "required", "SVG content of the icon"),
        new("Size", "SizeEnum", "Medium", "Size of the icon (Small, Medium, Large)"),
        new("Color", "CssColor?", "null", "Color of the icon"),
        new("Title", "string?", "null", "Accessibility title for the icon"),
        new("ViewBox", "string", "0 0 24 24", "SVG viewBox attribute"),
        new("OnClick", "EventCallback<MouseEventArgs>", "-", "Click event handler"),
    };

    private record IconExample(string Name, string Value);

    private List<IconExample> GetSampleIcons()
    {
        return new List<IconExample>
        {
            new("Home", UIIcons.MaterialIconsRound.i_home),
            new("Settings", UIIcons.MaterialIconsRound.i_settings),
            new("Search", UIIcons.MaterialIconsRound.i_search),
            new("Favorite", UIIcons.MaterialIconsRound.i_favorite),
            new("Star", UIIcons.MaterialIconsRound.i_star),
            new("Check", UIIcons.MaterialIconsRound.i_check),
            new("Close", UIIcons.MaterialIconsRound.i_close),
            new("Edit", UIIcons.MaterialIconsRound.i_edit),
            new("Delete", UIIcons.MaterialIconsRound.i_delete),
            new("Save", UIIcons.MaterialIconsRound.i_save),
            new("Download", UIIcons.MaterialIconsRound.i_download),
            new("Upload", UIIcons.MaterialIconsRound.i_upload),
        };
    }

    private List<IconExample> GetBrandIcons()
    {
        return new List<IconExample>
        {
            new("Gmail", UIIcons.Brands.Gmail),
            new("GitHub", UIIcons.Brands.GitHub),
            new("Twitter", UIIcons.Brands.Twitter),
            new("Facebook", UIIcons.Brands.Facebook),
            new("LinkedIn", UIIcons.Brands.LinkedIn),
            new("YouTube", UIIcons.Brands.YouTube),
        };
    }
}
