@page "/getting-started/first-steps"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Core.Abstractions.Behaviors.Transitions

<PageTitle>First Steps - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>First Steps</h1>
    <p class="doc-intro">
        Now that you've installed CdCSharp.BlazorUI, let's build your first components and explore 
        the library's features through practical examples.
    </p>

    <div class="doc-section">
        <h2>1. Your First Component</h2>
        <p>Let's start with a simple button component:</p>
        
        <ComponentDemo Code="@firstButtonCode">
            <Demo>
                <BUIButton Text="Hello BlazorUI!" 
                         OnClick="@(() => _clickCount++)" />
                <p style="margin-top: 1rem;">Button clicked: @_clickCount times</p>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>2. Adding Icons and States</h2>
        <p>Enhance your button with icons and loading states:</p>
        
        <ComponentDemo Code="@enhancedButtonCode">
            <Demo>
                <div class="demo-buttons">
                    <BUIButton Text="Save" 
                             LeadingIcon="@BUIIcons.MaterialIconsRound.i_save"
                             OnClick="SaveData"
                             IsLoading="@_isSaving"
                             LoadingIndicatorVariant="BUILoadingIndicatorVariant.Spinner" />
                    
                    <BUIButton Text="Delete" 
                              TrailingIcon="@BUIIcons.MaterialIconsRound.i_restore_from_trash"
                             Color="@BUIColor.Red.Default" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>3. Building a Simple Form</h2>
        <p>Combine components to create interactive forms:</p>
        
        <ComponentDemo Code="@formExampleCode">
            <Demo>
                <div class="simple-form">
                    <h4>User Settings</h4>
                    
                    <div class="form-group">
                        <label>Theme Preference</label>
                        <BUIThemeSelector />
                    </div>
                    
                    <div class="form-group">
                        <label>Display Density</label>
                        <div class="button-group">
                            <BUIButton Text="Comfortable" 
                                     Density="DensityEnum.Comfortable"
                                     OnClick="@(() => _selectedDensity = DensityEnum.Comfortable)" />
                            <BUIButton Text="Standard" 
                                     Density="DensityEnum.Standard"
                                     OnClick="@(() => _selectedDensity = DensityEnum.Standard)" />
                            <BUIButton Text="Compact" 
                                     Density="DensityEnum.Compact"
                                     OnClick="@(() => _selectedDensity = DensityEnum.Compact)" />
                        </div>
                    </div>
                    
                    <div class="form-actions">
                        <BUIButton Text="Save Settings" 
                                 LeadingIcon="@BUIIcons.MaterialIconsRound.i_save"
                                 Transitions="@BUITransitionPresets.HoverLift"
                                 OnClick="SaveSettings" />
                    </div>
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>4. Creating a Card Component</h2>
        <p>Use elevation and transitions to create engaging cards:</p>
        
        <ComponentDemo Code="@cardComponentCode">
            <Demo>
                <div class="card-grid">
                    @foreach (var card in _sampleCards)
                    {
                        <div class="custom-card ui-elevation-2 ui-has-transitions ui-transition-hover-lift">
                            <div class="card-icon">
                                <BUISvgIcon Icon="@card.Icon" Size="SizeEnum.Large" class="color-primary" />
                            </div>
                            <h4>@card.Title</h4>
                            <p>@card.Description</p>
                            <BUIButton Text="Learn More" 
                                     Size="SizeEnum.Small"
                                     Transitions="@BUITransitionPresets.HoverScale" />
                        </div>
                    }
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>5. Working with Transitions</h2>
        <p>Add smooth animations to enhance user experience:</p>
        
        <ComponentDemo Code="@transitionsExampleCode">
            <Demo>
                <div class="transition-examples">
                    <BUIButton Text="Hover to Scale" 
                             Transitions="@BUITransitionPresets.HoverScale" />
                    
                    <BUIButton Text="Hover to Lift" 
                             Transitions="@BUITransitionPresets.HoverLift"
                             Elevation="2" />
                    
                    <BUIButton Text="Custom Animation" 
                             Transitions="@_customTransition" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>6. Building a Complete Page</h2>
        <p>Here's an example of a complete page using multiple components:</p>
        
        <CodeBlock Code="@completePageCode" Language="razor" Title="CompletePage.razor" />
    </div>

    <div class="doc-section">
        <h2>Next Steps</h2>
        
        <div class="next-steps-grid">
            <a href="/components/buttons" class="next-step-card">
                <h4>Explore Components</h4>
                <p>Dive deep into each component's features and properties.</p>
            </a>
            
            <a href="/theming/overview" class="next-step-card">
                <h4>Customize Themes</h4>
                <p>Learn how to create custom themes for your brand.</p>
            </a>
            
            <a href="/features/transitions" class="next-step-card">
                <h4>Master Animations</h4>
                <p>Create engaging interactions with the transition system.</p>
            </a>
            
            <a href="/utilities/css-classes" class="next-step-card">
                <h4>Utility Classes</h4>
                <p>Speed up development with ready-to-use CSS classes.</p>
            </a>
        </div>
    </div>

    <div class="doc-note doc-note--success">
        <strong>Congratulations!</strong> You're now ready to build amazing applications with CdCSharp.BlazorUI. 
        Remember to check the component documentation for detailed API references and advanced features.
    </div>
</div>

@code {
    private int _clickCount = 0;
    private bool _isSaving = false;
    private DensityEnum _selectedDensity = DensityEnum.Standard;

    private async Task SaveData()
    {
        _isSaving = true;
        await Task.Delay(2000); // Simulate save operation
        _isSaving = false;
    }

    private async Task SaveSettings()
    {
        // Simulate saving settings
        await Task.Delay(1000);
    }

    private BUITransitions _customTransition = BUITransitionPresets.Create()
        .OnHover()
            .Scale(1.05f, options => {
                options.Duration = TimeSpan.FromMilliseconds(400);
                options.Easing = easing => easing.CubicBezier().MaterialDecelerate();
            })
            .Shadow("0 10px 20px rgba(139, 92, 246, 0.3)")
        .Build();

    private record CardData(string Icon, string Title, string Description);

    private List<CardData> _sampleCards = new()
    {
        new(BUIIcons.MaterialIconsRound.i_flashlight_on, "Fast", "Optimized for performance with minimal overhead."),
        new(BUIIcons.MaterialIconsRound.i_palette, "Beautiful", "Professional design with customizable themes."),
        new(BUIIcons.MaterialIconsRound.i_code, "Simple", "Clean API that's easy to learn and use."),
    };

    private string firstButtonCode = @"<BUIButton Text=""Hello BlazorUI!"" 
         OnClick=""@(() => Console.WriteLine(\""Clicked!\""))"" />";

    private string enhancedButtonCode = @"<BUIButton Text=""Save"" 
         LeadingIcon=""@BUIIcons.Common.Save""
         OnClick=""SaveData""
         IsLoading=""@_isSaving""
         LoadingIndicatorVariant=""UILoadingIndicatorVariant.Spinner"" />

<BUIButton Text=""Delete"" 
         TrailingIcon=""@BUIIcons.Common.Trash""
         Color=""@UIColor.Red"" />";

    private string formExampleCode = @"<div class=""form-group"">
    <label>Theme Preference</label>
    <BUIThemeSelector />
</div>

<div class=""form-group"">
    <label>Display Density</label>
    <div class=""button-group"">
        <BUIButton Text=""Comfortable"" 
                 Density=""DensityEnum.Comfortable""
                 OnClick=""@(() => _selectedDensity = DensityEnum.Comfortable)""
                 Color=""@(_selectedDensity == DensityEnum.Comfortable ? \""var(--palette-primary)\"" : null)"" />
        <!-- Additional buttons... -->
    </div>
</div>";

    private string cardComponentCode = @"<div class=""custom-card ui-elevation-2 ui-has-transitions ui-transition-hover-lift"">
    <div class=""card-icon"">
        <BUISvgIcon Icon=""@BUIIcons.Common.Lightning"" Size=""SizeEnum.Large"" Color=""var(--palette-primary)"" />
    </div>
    <h4>Fast Performance</h4>
    <p>Optimized for speed and efficiency.</p>
    <BUIButton Text=""Learn More"" Size=""SizeEnum.Small"" />
</div>";

    private string transitionsExampleCode = @"// Using preset transitions
<BUIButton Text=""Hover to Scale"" 
         Transitions=""@BUITransitionPresets.HoverScale"" />

// Creating custom transitions
private BUITransitions _customTransition = BUITransitionPresets.Create()
    .OnHover()
        .Scale(1.05f, options => {
            options.Duration = TimeSpan.FromMilliseconds(400);
            options.Easing = easing => easing.CubicBezier().MaterialDecelerate();
        })
        .And()
        .Shadow(\""0 10px 20px rgba(139, 92, 246, 0.3)\"")
    .Build();";

    private string completePageCode = @"@page ""/dashboard""
@using CdCSharp.BlazorUI.Components.Generic.Button
@using CdCSharp.BlazorUI.Components.Features.Theme.ThemeSwitch
@using CdCSharp.BlazorUI.Media.Icons

<div class=""dashboard"">
    <header class=""dashboard-header"">
        <h1>Dashboard</h1>
        <div class=""header-actions"">
            <BUIButton Text=""New Item"" 
                     LeadingIcon=""@BUIIcons.Common.Plus""
                     Transitions=""@BUITransitionPresets.HoverLift"" />
            <BUIThemeSelector Variant=""BUIThemeSelectorVariant.SunMoon"" />
        </div>
    </header>

    <div class=""dashboard-content"">
        <div class=""stats-grid"">
            @foreach (var stat in Statistics)
            {
                <div class=""stat-card ui-elevation-2"">
                    <BUISvgIcon Icon=""@stat.Icon"" Size=""SizeEnum.Large"" />
                    <h3>@stat.Value</h3>
                    <p>@stat.Label</p>
                </div>
            }
        </div>

        <div class=""actions-section"">
            <h2>Quick Actions</h2>
            <div class=""action-buttons"">
                <BUIButton Text=""Generate Report"" 
                         Icon=""@BUIIcons.Common.Document""
                         IsLoading=""@_isGenerating""
                         LoadingIndicatorVariant=""UILoadingIndicatorVariant.Dots"" />
                
                <BUIButton Text=""Export Data"" 
                         Icon=""@BUIIcons.Common.Download""
                         Elevation=""2"" />
            </div>
        </div>
    </div>
</div>

@code {
    private bool _isGenerating = false;
    
    private List<StatData> Statistics = new()
    {
        new(\""1,234\"", \""Active Users\"", BUIIcons.Common.Users),
        new(\""567\"", \""Transactions\"", BUIIcons.Common.TrendingUp),
        new(\""89%\"", \""Success Rate\"", BUIIcons.Common.CheckCircle),
    };
    
    private record StatData(string Value, string Label, string Icon);
}";
}