@code {
    // Custom transitions using the new Easing builder
    private UITransitions linearTransition = UITransitionPresets.Create()
        .OnHover().Scale(1.2f, options =>
        {
            options.Duration = TimeSpan.FromMilliseconds(500);
            options.Easing = easing => easing.Linear();
        })
        .Build();

    private UITransitions customBezierTransition = UITransitionPresets.Create()
        .OnHover().Rotate("180deg", options =>
        {
            options.Duration = TimeSpan.FromMilliseconds(1000);
            options.Easing = easing => easing
                .CubicBezier()
                .WithControlPoints(0.25, 0.46, 0.45, 0.94);
        })
        .Build();

    private UITransitions stepsTransition = UITransitionPresets.Create()
        .OnHover().Scale(1.5f, options =>
        {
            options.Duration = TimeSpan.FromMilliseconds(500);
            options.Easing = easing => easing.Steps(5).End();
        })
        .Build();

    private UITransitions slowMotionTransition = UITransitionPresets.Create()
        .OnHover().Scale(1.1f, options =>
        {
            options.Duration = TimeSpan.FromSeconds(2);
            options.Easing = easing => easing.CubicBezier().MaterialDecelerate();
        })
        .And()
        .OnHover().Shadow("0 20px 40px rgba(0,0,0,0.3)", options =>
        {
            options.Duration = TimeSpan.FromSeconds(2);
            options.Easing = easing => easing.CubicBezier().MaterialDecelerate();
        })
        .Build();
}

