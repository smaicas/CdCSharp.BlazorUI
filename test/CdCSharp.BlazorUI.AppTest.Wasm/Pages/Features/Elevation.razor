@page "/features/elevation"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Components.Features.Transitions
@using CdCSharp.BlazorUI.Components.Generic.Button

<PageTitle>Elevation - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>Elevation System</h1>
    <p class="doc-intro">
        The elevation system provides visual hierarchy through shadows, helping users understand the spatial
        relationships between elements. Elevation values range from 0 to 24.
    </p>

    <div class="doc-section">
        <h2>Elevation Scale</h2>
        <p>Components can be elevated using predefined shadow levels:</p>

        <div class="elevation-grid">
            @for (int i = 0; i <= 24; i += 3)
            {
                <div class="elevation-item ui-elevation-@i">
                    <span class="elevation-value">@i</span>
                    <span class="elevation-label">Elevation @i</span>
                </div>
            }
        </div>
    </div>

    <div class="doc-section">
        <h2>Using Elevation</h2>
        <p>Components that implement <code>IHasElevation</code> support the elevation property:</p>

        <ComponentDemo Code="@elevationCode">
            <Demo>
                <div class="demo-row">
                    <UIButton Text="No Elevation" Elevation="0" />
                    <UIButton Text="Low" Elevation="2" />
                    <UIButton Text="Medium" Elevation="4" />
                    <UIButton Text="High" Elevation="8" />
                    <UIButton Text="Very High" Elevation="16" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Elevation Guidelines</h2>

        <div class="guidelines-list">
            <div class="guideline">
                <h4>0-1: Rest State</h4>
                <p>Default state for most elements. Text fields, search bars.</p>
            </div>

            <div class="guideline">
                <h4>2-4: Raised Elements</h4>
                <p>Cards, raised buttons, quick action buttons.</p>
            </div>

            <div class="guideline">
                <h4>6-8: Floating Elements</h4>
                <p>Floating action buttons, hover states for cards.</p>
            </div>

            <div class="guideline">
                <h4>12-16: Temporary Surfaces</h4>
                <p>Modals, dialogs, dropdown menus.</p>
            </div>

            <div class="guideline">
                <h4>24: Maximum Elevation</h4>
                <p>Toasts, snackbars, highest priority overlays.</p>
            </div>
        </div>
    </div>

    <div class="doc-section">
        <h2>Interactive Elevation</h2>
        <p>Elevation can be combined with transitions for interactive effects:</p>

        <ComponentDemo Code="@interactiveCode">
            <Demo>
                <div class="interactive-cards">
                    <div class="interactive-card ui-elevation-2 ui-has-transitions ui-transition-hover-lift">
                        <h4>Hover to Lift</h4>
                        <p>This card elevates on hover using transitions.</p>
                    </div>

                    <UIButton Text="Elevating Button"
                              Elevation="2"
                              Transitions="@transitions" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>CSS Classes</h2>
        <p>You can also apply elevation directly using CSS classes:</p>

        <CodeBlock Code="@cssClassesCode" Language="html" Title="CSS Classes" />
    </div>

    <div class="doc-section">
        <h2>Custom Elevation</h2>
        <p>Create custom elevation effects with CSS:</p>

        <CodeBlock Code="@customElevationCode" Language="css" Title="Custom Shadows" />
    </div>

    <div class="doc-section">
        <h2>Accessibility Considerations</h2>
        <div class="doc-note doc-note--warning">
            <strong>Important:</strong> Don't rely solely on elevation to convey information.
            Always ensure there are additional visual cues (color, size, position) for users who
            may have difficulty perceiving shadows or depth.
        </div>
    </div>
</div>

@code {

    UITransitions transitions = UITransitionPresets.Create()
                                     .OnHover()
                                     .Shadow("0 8px 16px rgba(0, 0, 0, 0.2)")
                                     .Build();

    private string elevationCode = @"<UIButton Text=""No Elevation"" Elevation=""0"" />
<UIButton Text=""Low"" Elevation=""2"" />
<UIButton Text=""Medium"" Elevation=""4"" />
<UIButton Text=""High"" Elevation=""8"" />
<UIButton Text=""Very High"" Elevation=""16"" />";

    private string interactiveCode = @"<!-- Card with hover elevation -->
<div class=""card ui-elevation-2 ui-has-transitions ui-transition-hover-lift"">
    <h4>Hover to Lift</h4>
    <p>This card elevates on hover.</p>
</div>

<!-- Button with dynamic elevation -->
<UIButton Text=""Elevating Button""
         Elevation=""2""
         Transitions=""@UITransitionPresets.Create()
             .OnHover()
             .Shadow(""0 8px 16px rgba(0,0,0,0.2)"")
             .Build()"" />";

    private string cssClassesCode = @"<!-- Apply elevation with CSS classes -->
<div class=""ui-elevation-0"">No elevation</div>
<div class=""ui-elevation-2"">Slight elevation</div>
<div class=""ui-elevation-4"">Medium elevation</div>
<div class=""ui-elevation-8"">High elevation</div>
<div class=""ui-elevation-16"">Very high elevation</div>
<div class=""ui-elevation-24"">Maximum elevation</div>";

    private string customElevationCode = @"/* Custom elevation with colored shadows */
.custom-elevation {
    box-shadow:
        0 2px 4px -1px rgba(59, 130, 246, 0.2),
        0 4px 6px -1px rgba(59, 130, 246, 0.1),
        0 10px 15px -3px rgba(59, 130, 246, 0.1);
}

/* Elevation with glow effect */
.glow-elevation {
    box-shadow:
        0 0 20px rgba(139, 92, 246, 0.3),
        0 4px 6px -1px rgba(0, 0, 0, 0.1);
}

/* Neumorphic style elevation */
.neumorphic-elevation {
    background: var(--palette-surface);
    box-shadow:
        5px 5px 10px rgba(0, 0, 0, 0.1),
        -5px -5px 10px rgba(255, 255, 255, 0.1);
}";
}

<style>
    .elevation-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 2rem;
        margin: 2rem 0;
    }

    .elevation-item {
        padding: 2rem 1rem;
        background: var(--palette-surface);
        border-radius: 0.5rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        transition: all 0.3s ease;
    }

    .elevation-value {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--palette-primary);
    }

    .elevation-label {
        font-size: 0.875rem;
        opacity: 0.7;
    }

    .guidelines-list {
        display: grid;
        gap: 1.5rem;
        margin: 2rem 0;
    }

    .guideline {
        padding: 1rem;
        background: var(--palette-surface);
        border-radius: 0.5rem;
    }

        .guideline h4 {
            margin: 0 0 0.5rem 0;
            color: var(--palette-primary);
        }

        .guideline p {
            margin: 0;
            opacity: 0.8;
        }

    .demo-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        align-items: center;
    }

    .interactive-cards {
        display: flex;
        gap: 2rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .interactive-card {
        padding: 2rem;
        background: var(--palette-surface);
        border-radius: 0.5rem;
        max-width: 300px;
        cursor: pointer;
    }

        .interactive-card h4 {
            margin: 0 0 0.5rem 0;
        }

        .interactive-card p {
            margin: 0;
            opacity: 0.8;
        }
</style>