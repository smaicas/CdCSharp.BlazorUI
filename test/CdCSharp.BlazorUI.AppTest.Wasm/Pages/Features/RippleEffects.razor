@page "/features/ripple-effects"
@using CdCSharp.BlazorUI.AppTest.Wasm.Shared
@using CdCSharp.BlazorUI.Core.Css

<PageTitle>Ripple Effects - CdCSharp.BlazorUI</PageTitle>

<div class="doc-page">
    <h1>Ripple Effects</h1>
    <p class="doc-intro">
        Ripple effects provide visual feedback when users interact with components, 
        creating a natural and responsive feel inspired by material design.
    </p>

    <div class="doc-section">
        <h2>Basic Ripple</h2>
        <ComponentDemo Code="@basicRippleCode">
            <Demo>
                <div class="ripple-demo">
                    <BUIButton Text="Click for Ripple" DisableRipple="false" />
                    <BUIButton Text="No Ripple" DisableRipple="true" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Ripple Colors</h2>
        <ComponentDemo Code="@rippleColorsCode">
            <Demo>
                <div class="ripple-demo">
                    <BUIButton Text="Default Ripple" DisableRipple="false" />
                    <BUIButton Text="Blue Ripple" DisableRipple="false" RippleColor="@BUIColor.Blue.Default" />
                    <BUIButton Text="Green Ripple" DisableRipple="false" RippleColor="@BUIColor.Green.Default" />
                    <BUIButton Text="Red Ripple" DisableRipple="false" RippleColor="@BUIColor.Red.Default" />
                    <BUIButton Text="Custom Color" DisableRipple="false" RippleColor="@(new CssColor("#FF6B6B"))" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Ripple Duration</h2>
        <ComponentDemo Code="@rippleDurationCode">
            <Demo>
                <div class="ripple-demo">
                    <BUIButton Text="Fast (300ms)" DisableRipple="false" RippleDuration="300" />
                    <BUIButton Text="Normal (600ms)" DisableRipple="false" RippleDuration="600" />
                    <BUIButton Text="Slow (1000ms)" DisableRipple="false" RippleDuration="1000" />
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>How Ripple Works</h2>
        <div class="ripple-explanation">
            <div class="explanation-card">
                <h4>1. Click Detection</h4>
                <p>When a user clicks, the component captures the click position relative to the element.</p>
            </div>
            
            <div class="explanation-card">
                <h4>2. Ripple Creation</h4>
                <p>A circular ripple element is created at the click position and begins expanding.</p>
            </div>
            
            <div class="explanation-card">
                <h4>3. Animation</h4>
                <p>The ripple expands from the click point to cover the entire component with a fade effect.</p>
            </div>
            
            <div class="explanation-card">
                <h4>4. Cleanup</h4>
                <p>After the animation completes, the ripple element is removed from the DOM.</p>
            </div>
        </div>
    </div>

    <div class="doc-section">
        <h2>Custom Ripple Implementation</h2>
        <p>To add ripple effects to custom components:</p>
        
        <CodeBlock Code="@customImplementationCode" Language="csharp" Title="Custom Component with Ripple" />
    </div>

    <div class="doc-section">
        <h2>Ripple on Different Surfaces</h2>
        <ComponentDemo Code="@surfacesCode">
            <Demo>
                <div class="surfaces-demo">
                    <div class="ripple-surface ripple-surface--light ui-has-ripple">
                        <h5>Light Surface</h5>
                        <p>Click anywhere in this box</p>
                    </div>
                    
                    <div class="ripple-surface ripple-surface--dark ui-has-ripple">
                        <h5>Dark Surface</h5>
                        <p>Click anywhere in this box</p>
                    </div>
                    
                    <div class="ripple-surface ripple-surface--primary ui-has-ripple">
                        <h5>Primary Surface</h5>
                        <p>Click anywhere in this box</p>
                    </div>
                </div>
            </Demo>
        </ComponentDemo>
    </div>

    <div class="doc-section">
        <h2>Performance Considerations</h2>
        <ul>
            <li>Ripple effects use CSS animations for optimal performance</li>
            <li>Elements are dynamically created and destroyed to minimize DOM impact</li>
            <li>Hardware acceleration is utilized where available</li>
            <li>Multiple simultaneous ripples are supported without performance degradation</li>
        </ul>
    </div>

    <div class="doc-section">
        <h2>Accessibility</h2>
        <div class="doc-note doc-note--info">
            <strong>Note:</strong> Ripple effects are purely visual and don't affect keyboard navigation 
            or screen reader functionality. They enhance the experience for sighted users while maintaining 
            full accessibility for all users.
        </div>
    </div>

    <div class="doc-section">
        <h2>Properties</h2>
        <PropertyTable TItem="RippleProperty" Items="@RippleProperties">
            <PropertyTemplate Context="prop">
                <td><code>@prop.Name</code></td>
                <td><code>@prop.Type</code></td>
                <td><code>@prop.Default</code></td>
                <td>@prop.Description</td>
            </PropertyTemplate>
        </PropertyTable>
    </div>
</div>

@code {
    private string basicRippleCode = @"<BUIButton Text=""Click for Ripple"" DisableRipple=""false"" />
<BUIButton Text=""No Ripple"" DisableRipple=""true"" />";

    private string rippleColorsCode = @"<BUIButton Text=""Default Ripple"" DisableRipple=""false"" />
<BUIButton Text=""Blue Ripple"" DisableRipple=""false"" RippleColor=""@UIColor.Blue"" />
<BUIButton Text=""Green Ripple"" DisableRipple=""false"" RippleColor=""@UIColor.Green"" />
<BUIButton Text=""Custom Color"" DisableRipple=""false"" RippleColor=""@(new CssColor(""#FF6B6B""))"" />";

    private string rippleDurationCode = @"<BUIButton Text=""Fast (300ms)"" DisableRipple=""false"" RippleDuration=""300"" />
<BUIButton Text=""Normal (600ms)"" DisableRipple=""false"" RippleDuration=""600"" />
<BUIButton Text=""Slow (1000ms)"" DisableRipple=""false"" RippleDuration=""1000"" />";

    private string customImplementationCode = @"@implements IHasRipple
@implements IJsBehavior

<div @ref=""_element"" class=""my-component"">
    <!-- Component content -->
</div>

@code {
    // IHasRipple implementation
    [Parameter] public bool DisableRipple { get; set; }
    [Parameter] public CssColor? RippleColor { get; set; }
    [Parameter] public int RippleDuration { get; set; } = 600;

    // IJsBehavior implementation
    private ElementReference _element;
    public ElementReference GetRootElement() => _element;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !DisableRipple)
        {
            // Ripple behavior is automatically attached by the framework
            // when implementing IHasRipple
        }
    }
}";

    private string surfacesCode = @"<!-- Add ui-has-ripple class to any element -->
<div class=""surface ui-has-ripple"">
    Click anywhere for ripple effect
</div>

<!-- With custom ripple color -->
<div class=""surface ui-has-ripple"" 
     style=""--ui-ripple-color: rgba(255, 107, 107, 0.3);"">
    Custom ripple color
</div>";

    private record RippleProperty(string Name, string Type, string Default, string Description);

    private List<RippleProperty> RippleProperties = new()
    {
        new("DisableRipple", "bool", "false", "Whether to disable the ripple effect"),
        new("RippleColor", "CssColor?", "null", "Custom color for the ripple effect"),
        new("RippleDuration", "int", "600", "Duration of the ripple animation in milliseconds"),
    };
}
