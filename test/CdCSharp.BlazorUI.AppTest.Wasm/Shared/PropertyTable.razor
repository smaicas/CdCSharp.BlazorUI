@typeparam TItem

<div class="property-table-wrapper">
    <table class="property-table">
        <thead>
            <tr>
                <th>Property</th>
                <th>Type</th>
                <th>Default</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Items)
            {
                <tr>
                    @PropertyTemplate(item)
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter] public IEnumerable<TItem> Items { get; set; } = Enumerable.Empty<TItem>();
    [Parameter] public RenderFragment<TItem> PropertyTemplate { get; set; } = default!;
}

<style>
    .property-table-wrapper {
        overflow-x: auto;
        margin: 1rem 0;
    }

    .property-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }

        .property-table th {
            text-align: left;
            padding: 0.75rem;
            border-bottom: 2px solid var(--palette-foreground);
            font-weight: 600;
        }

        .property-table td {
            padding: 0.75rem;
            border-bottom: 1px solid var(--palette-foreground);
        }

        .property-table tbody tr:hover {
            background: var(--palette-surface);
        }

        .property-table code {
            background: var(--palette-surface);
            padding: 0.125rem 0.25rem;
            border-radius: 0.25rem;
            font-size: 0.813rem;
            font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
        }
</style>